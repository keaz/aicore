fn option_match_tag_name(prefix: String) -> String {
    llvm_local(prefix, ".option.tag")
}

fn option_match_payload_name(prefix: String) -> String {
    llvm_local(prefix, ".option.payload")
}

fn option_match_is_some_name(prefix: String) -> String {
    llvm_local(prefix, ".option.is_some")
}

fn option_match_scrutinee_node_type_name(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], node: IrExprNode, locals: BackendLocals) -> String {
    match expr_node_child_at(nodes, node, 0) {
        Some(scrutinee) => if is_vec_get_intrinsic_name(scrutinee.name) {
            ""
        } else if value_node_can_emit(program, function_value, nodes, scrutinee, locals) {
            let type_name = node_type_name(program, function_value, nodes, scrutinee, locals);
            if base_type_name_text(type_name) == "Option" { type_name } else { "" }
        } else {
            ""
        },
        None => "",
    }
}

fn option_match_scrutinee_expr_type_name(program: IrProgram, value: IrExpr, function_value: IrFunctionDef, locals: BackendLocals) -> String {
    match direct_expr_child_at(value.nodes, 0) {
        Some(scrutinee) => if is_vec_get_intrinsic_name(scrutinee.name) {
            ""
        } else if value_node_can_emit(program, function_value, value.nodes, scrutinee, locals) {
            let type_name = node_type_name(program, function_value, value.nodes, scrutinee, locals);
            if base_type_name_text(type_name) == "Option" { type_name } else { "" }
        } else {
            ""
        },
        None => "",
    }
}

fn option_match_node_type_name(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], node: IrExprNode, locals: BackendLocals) -> String {
    if !option_match_arms_are_some_none(node.match_arms) {
        ""
    } else {
        let option_name = option_match_scrutinee_node_type_name(program, function_value, nodes, node, locals);
        if option_name == "" {
            ""
        } else {
            match result_match_node_body_node_for_variant(nodes, node, "Some") {
                Some(some_body) => match result_match_node_body_node_for_variant(nodes, node, "None") {
                    Some(none_body) => if true {
                        let payload_type_name = generic_arg_at(option_name, 0);
                        let payload_locals = push_option_payload_local(program, clone_backend_locals(locals), option_match_payload_name_from_node(node), payload_type_name, option_match_payload_name(llvm_node_prefix(node.node)));
                        let some_type = branch_value_node_type_name_with_locals(program, function_value, nodes, some_body, payload_locals);
                        let none_type = branch_value_node_type_name_with_locals(program, function_value, nodes, none_body, locals);
                        if some_type != "" && some_type == none_type { some_type } else { "" }
                    } else { "" },
                    None => "",
                },
                None => "",
            }
        }
    }
}

fn option_match_expr_type_name(program: IrProgram, value: IrExpr, function_value: IrFunctionDef, locals: BackendLocals) -> String {
    if !option_match_arms_are_some_none(value.match_arms) {
        ""
    } else {
