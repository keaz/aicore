    let mut item_index = 0;
    let mut out = "";
    while out == "" && item_index < vec.vec_len(program.items) {
        match vec.get(program.items, item_index) {
            Some(item) => match item {
                IrStructItemValue(struct_value) => if struct_value.name == name {
                    match vec.get(struct_value.fields, field_index) {
                        Some(field) => if true {
                            out = llvm_type_for_id(program, field.type_id);
                            ()
                        } else { () },
                        None => (),
                    }
                } else {
                    ()
                },
                _ => (),
            },
            None => (),
        };
        item_index = item_index + 1;
    };
    out
}

fn struct_item_field_type_name_by_index(program: IrProgram, name: String, field_index: Int) -> String {
    let mut item_index = 0;
    let mut out = "";
    while out == "" && item_index < vec.vec_len(program.items) {
        match vec.get(program.items, item_index) {
            Some(item) => match item {
                IrStructItemValue(struct_value) => if struct_value.name == name {
                    match vec.get(struct_value.fields, field_index) {
                        Some(field) => if true {
                            out = type_name_for_id(program.types, field.type_id);
                            ()
                        } else { () },
                        None => (),
                    }
                } else {
                    ()
                },
                _ => (),
            },
            None => (),
        };
        item_index = item_index + 1;
    };
    out
}

fn struct_field_llvm_type_by_index(program: IrProgram, name: String, field_index: Int) -> String {
    let known = known_struct_field_llvm_type_by_index(name, field_index);
    if known != "" {
        known
    } else {
        struct_item_field_llvm_type_by_index(program, name, field_index)
    }
}

fn struct_field_type_name_by_index(program: IrProgram, name: String, field_index: Int) -> String {
    let known = known_struct_field_type_name_by_index(name, field_index);
    if known != "" {
        known
    } else {
        struct_item_field_type_name_by_index(program, name, field_index)
    }
}

fn struct_item_llvm_type(program: IrProgram, name: String) -> String {
    let mut item_index = 0;
    let mut out = "";
    while out == "" && item_index < vec.vec_len(program.items) {
        match vec.get(program.items, item_index) {
            Some(item) => match item {
                IrStructItemValue(struct_value) => if struct_value.name == name {
                    let mut parts: Vec[String] = vec.new_vec();
                    parts = vec.push(parts, "{ ");
                    let mut field_index = 0;
                    let mut ok = true;
                    while ok && field_index < vec.vec_len(struct_value.fields) {
                        match vec.get(struct_value.fields, field_index) {
                            Some(field) => if true {
                                let field_ty = llvm_type_for_id(program, field.type_id);
                                if field_ty == "" {
                                    ok = false;
                                } else {
                                    if field_index > 0 {
                                        parts = vec.push(parts, ", ");
                                    } else {
                                        ()
                                    };
                                    parts = vec.push(parts, field_ty);
                                };
                                ()
                            } else { () },
                            None => (),
                        };
                        field_index = field_index + 1;
                    };
                    if ok {
                        parts = vec.push(parts, " }");
                        out = string.join(parts, "");
                    } else {
                        ()
                    }
                } else {
                    ()
                },
                _ => (),
            },
            None => (),
        };
        item_index = item_index + 1;
    };
    out
}

fn enum_item_llvm_type(program: IrProgram, name: String) -> String {
    let mut item_index = 0;
    let mut out = "";
    while out == "" && item_index < vec.vec_len(program.items) {
        match vec.get(program.items, item_index) {
            Some(item) => match item {
                IrEnumItemValue(enum_value) => if enum_value.name == name {
                    let mut parts: Vec[String] = vec.new_vec();
                    parts = vec.push(parts, "{ i32");
                    let mut variant_index = 0;
                    let mut ok = true;
                    while ok && variant_index < vec.vec_len(enum_value.variants) {
                        match vec.get(enum_value.variants, variant_index) {
                            Some(variant) => if true {
                                let slot_ty = match variant.payload_type {
                                    Some(type_id_value) => llvm_payload_slot_type(program, type_name_for_id(program.types, type_id_value)),
                                    None => "i8",
                                };
                                if slot_ty == "" {
                                    ok = false;
                                } else {
                                    parts = vec.push(parts, ", ");
                                    parts = vec.push(parts, slot_ty);
                                };
                                ()
                            } else { () },
                            None => (),
                        };
                        variant_index = variant_index + 1;
                    };
                    if ok {
                        parts = vec.push(parts, " }");
                        out = string.join(parts, "");
                    } else {
                        ()
                    }
                } else {
                    ()
                },
                _ => (),
            },
            None => (),
        };
        item_index = item_index + 1;
    };
    out
}

fn enum_variant_parent_name(program: IrProgram, variant_name: String) -> String {
    let mut item_index = 0;
    let mut out = "";
    if variant_name == "Some" || variant_name == "None" {
        out = "Option";
    } else {
        if variant_name == "Ok" || variant_name == "Err" {
            out = "Result";
        } else {
            ()
        }
    };
    while out == "" && item_index < vec.vec_len(program.items) {
        match vec.get(program.items, item_index) {
            Some(item) => match item {
                IrEnumItemValue(enum_value) => if true {
                    let mut variant_index = 0;
                    while out == "" && variant_index < vec.vec_len(enum_value.variants) {
                        match vec.get(enum_value.variants, variant_index) {
                            Some(variant) => if variant.name == variant_name {
                                out = enum_value.name;
                            } else {
                                ()
                            },
                            None => (),
                        };
                        variant_index = variant_index + 1;
                    };
                    ()
                } else {
                    ()
                },
                _ => (),
            },
            None => (),
        };
        item_index = item_index + 1;
    };
    out
}

fn enum_variant_index(program: IrProgram, parent_name: String, variant_name: String) -> Int {
    let parent_base = base_type_name_text(parent_name);
    let mut item_index = 0;
    let mut out = -1;
    if parent_base == "Option" {
        if variant_name == "Some" {
            out = 0;
        } else {
            if variant_name == "None" {
                out = 1;
            } else {
                ()
            }
        }
    } else {
        if parent_base == "Result" {
            if variant_name == "Ok" {
                out = 0;
            } else {
                if variant_name == "Err" {
                    out = 1;
                } else {
                    ()
                }
            }
        } else {
            ()
        }
    };
    while out < 0 && item_index < vec.vec_len(program.items) {
        match vec.get(program.items, item_index) {
            Some(item) => match item {
                IrEnumItemValue(enum_value) => if base_type_name_text(enum_value.name) == parent_base {
                    let mut variant_index = 0;
                    while out < 0 && variant_index < vec.vec_len(enum_value.variants) {
                        match vec.get(enum_value.variants, variant_index) {
                            Some(variant) => if variant.name == variant_name {
                                out = variant_index;
                            } else {
                                ()
                            },
                            None => (),
                        };
                        variant_index = variant_index + 1;
                    };
                    ()
                } else {
                    ()
                },
                _ => (),
            },
            None => (),
        };
        item_index = item_index + 1;
    };
    out
}

fn enum_variant_count(program: IrProgram, parent_name: String) -> Int {
    let parent_base = base_type_name_text(parent_name);
    let mut item_index = 0;
    let mut out = 0;
    if parent_base == "Option" || parent_base == "Result" {
        out = 2;
    } else {
        ()
    };
    let mut found = out != 0;
    while !found && item_index < vec.vec_len(program.items) {
        match vec.get(program.items, item_index) {
            Some(item) => match item {
                IrEnumItemValue(enum_value) => if base_type_name_text(enum_value.name) == parent_base {
                    out = vec.vec_len(enum_value.variants);
                    found = true;
                } else {
                    ()
                },
                _ => (),
            },
            None => (),
        };
        item_index = item_index + 1;
    };
    out
}

fn enum_variant_payload_type_name_by_index(program: IrProgram, parent_name: String, target_index: Int) -> String {
    if base_type_name_text(parent_name) == "Option" {
        if target_index == enum_variant_index(program, parent_name, "Some") {
            generic_arg_at(parent_name, 0)
        } else {
            "()"
        }
    } else if base_type_name_text(parent_name) == "Result" {
        if target_index == enum_variant_index(program, parent_name, "Ok") {
            generic_arg_at(parent_name, 0)
        } else if target_index == enum_variant_index(program, parent_name, "Err") {
            generic_arg_at(parent_name, 1)
        } else {
            "()"
        }
    } else {
    let parent_base = base_type_name_text(parent_name);
    let mut item_index = 0;
    let mut out = "";
    while out == "" && item_index < vec.vec_len(program.items) {
        match vec.get(program.items, item_index) {
            Some(item) => match item {
                IrEnumItemValue(enum_value) => if base_type_name_text(enum_value.name) == parent_base {
                    match vec.get(enum_value.variants, target_index) {
                        Some(variant) => match variant.payload_type {
                            Some(type_id_value) => if true {
                                out = type_name_for_id(program.types, type_id_value);
                                ()
                            } else {
                                ()
                            },
                            None => if true {
                                out = "()";
                                ()
                            } else {
                                ()
                            },
                        },
                        None => (),
                    };
                    ()
                } else {
                    ()
                },
                _ => (),
            },
            None => (),
        };
        item_index = item_index + 1;
    };
    out
    }
}

fn enum_variant_payload_type_name(program: IrProgram, parent_name: String, variant_name: String) -> String {
    enum_variant_payload_type_name_by_index(program, parent_name, enum_variant_index(program, parent_name, variant_name))
}

fn enum_variant_slot_llvm_type(program: IrProgram, parent_name: String, target_index: Int) -> String {
    let payload_name = enum_variant_payload_type_name_by_index(program, parent_name, target_index);
    if payload_name == "" || payload_name == "()" {
        "i8"
    } else {
        llvm_payload_slot_type(program, payload_name)
    }
}

fn enum_variant_constructor_type_name(program: IrProgram, variant_name: String) -> String {
    enum_variant_parent_name(program, variant_name)
}

fn enum_variant_constructor_llvm_type(program: IrProgram, variant_name: String) -> String {
    let parent_name = enum_variant_parent_name(program, variant_name);
    if parent_name == "" {
        ""
    } else {
        llvm_type_for_repr_in_program(program, parent_name)
    }
}

fn type_alias_target_type_name(program: IrProgram, name: String) -> String {
    let mut item_index = 0;
    let mut out = "";
    while out == "" && item_index < vec.vec_len(program.items) {
        match vec.get(program.items, item_index) {
            Some(item) => match item {
                IrTypeAliasItemValue(alias_value) => if alias_value.name == name {
                    out = type_name_for_id(program.types, alias_value.target_type);
                } else {
                    ()
                },
                _ => (),
            },
            None => (),
        };
        item_index = item_index + 1;
    };
    out
}

fn enum_variant_constructor_child_can_emit(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], child: IrExprNode, locals: BackendLocals, expected: String) -> Bool {
    if expected == "%aic.String" {
        string_call_child_can_emit(program, function_value, nodes, child, locals)
    } else if expected_vec_new_vec_node_can_emit(child, expected) {
        true
    } else {
        value_node_can_emit(program, function_value, nodes, child, locals) && value_node_llvm_type(program, function_value, nodes, child, locals) == expected
    }
}

fn enum_variant_constructor_node_can_emit(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], node: IrExprNode, locals: BackendLocals) -> Bool {
    let parent_name = enum_variant_parent_name(program, node.name);
    if parent_name == "" {
        false
    } else {
        let payload_name = enum_variant_payload_type_name(program, parent_name, node.name);
        if payload_name == "" || payload_name == "()" {
            node.direct_child_count == 0
        } else if node.direct_child_count == 1 {
            match expr_node_child_at(nodes, node, 0) {
                Some(child) => enum_variant_constructor_child_can_emit(program, function_value, nodes, child, locals, llvm_payload_slot_type(program, payload_name)),
                None => false,
            }
        } else {
            false
        }
    }
}

fn enum_variant_constructor_expr_can_emit(program: IrProgram, value: IrExpr, function_value: IrFunctionDef, locals: BackendLocals) -> Bool {
    let parent_name = enum_variant_parent_name(program, value.name);
    if parent_name == "" {
        false
    } else {
        let payload_name = enum_variant_payload_type_name(program, parent_name, value.name);
        if payload_name == "" || payload_name == "()" {
            direct_expr_child_count(value.nodes) == 0
        } else if direct_expr_child_count(value.nodes) == 1 {
            match direct_expr_child_at(value.nodes, 0) {
                Some(child) => enum_variant_constructor_child_can_emit(program, function_value, value.nodes, child, locals, llvm_payload_slot_type(program, payload_name)),
                None => false,
            }
        } else {
            false
        }
    }
}

fn enum_parent_is_known(program: IrProgram, parent_name: String) -> Bool {
    parent_name != "" && enum_variant_count(program, parent_name) > 0 && llvm_type_for_repr_in_program(program, parent_name) != ""
}

fn branch_value_node_type_name_with_locals(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], branch_node: IrExprNode, locals: BackendLocals) -> String {
    if is_block_expr_kind(branch_node.kind) {
        let mut index = 0;
        let mut out = "";
        let mut out_locals = clone_backend_locals(locals);
        while out == "" && index < branch_node.direct_child_count {
            match expr_node_child_at(nodes, branch_node, index) {
                Some(child) => if block_child_is_let(child) {
                    if let_node_can_emit(program, function_value, nodes, child, out_locals) {
                        out_locals = push_node_local(program, function_value, nodes, child, out_locals);
                    } else {
                        ()
                    };
                    ()
                } else if block_child_is_assign(child) {
                    if assign_node_can_emit(program, function_value, nodes, child, out_locals, block_assign_target_from_role(child.role)) {
                        ()
                    } else {
                        ()
                    };
                    ()
                } else if block_child_is_tail(child) {
                    out = branch_value_node_type_name_with_locals(program, function_value, nodes, child, out_locals);
                    ()
                } else {
                    ()
                },
                None => (),
            };
            index = index + 1;
        };
        out
    } else {
        node_type_name(program, function_value, nodes, branch_node, locals)
    }
}

fn branch_value_node_llvm_type_with_locals(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], branch_node: IrExprNode, locals: BackendLocals) -> String {
    if is_block_expr_kind(branch_node.kind) {
        let mut index = 0;
        let mut out = "";
        let mut out_locals = clone_backend_locals(locals);
        while out == "" && index < branch_node.direct_child_count {
            match expr_node_child_at(nodes, branch_node, index) {
                Some(child) => if block_child_is_let(child) {
                    if let_node_can_emit(program, function_value, nodes, child, out_locals) {
                        out_locals = push_node_local(program, function_value, nodes, child, out_locals);
                    } else {
                        ()
                    };
                    ()
                } else if block_child_is_assign(child) {
                    if assign_node_can_emit(program, function_value, nodes, child, out_locals, block_assign_target_from_role(child.role)) {
                        ()
                    } else {
                        ()
                    };
                    ()
                } else if block_child_is_tail(child) {
                    out = branch_value_node_llvm_type_with_locals(program, function_value, nodes, child, out_locals);
                    ()
                } else {
                    ()
                },
                None => (),
            };
            index = index + 1;
        };
        out
    } else {
        value_node_llvm_type(program, function_value, nodes, branch_node, locals)
    }
}

fn if_expr_value_type_name(program: IrProgram, value: IrExpr, function_value: IrFunctionDef, locals: BackendLocals) -> String {
    let explicit = optional_type_name_for_id(program.types, value.type_id);
    if explicit != "" {
        explicit
    } else {
        match direct_expr_child_at(value.nodes, 1) {
            Some(then_block) => match direct_expr_child_at(value.nodes, 2) {
                Some(else_block) => if true {
                    let then_ty = branch_value_node_type_name_with_locals(program, function_value, value.nodes, then_block, locals);
                    let else_ty = branch_value_node_type_name_with_locals(program, function_value, value.nodes, else_block, locals);
                    if then_ty != "" && then_ty == else_ty { then_ty } else { "" }
                } else { "" },
                None => "",
            },
            None => "",
        }
    }
}

fn if_expr_value_llvm_type(program: IrProgram, value: IrExpr, function_value: IrFunctionDef, locals: BackendLocals) -> String {
    let explicit = llvm_type_for_repr_in_program(program, optional_type_name_for_id(program.types, value.type_id));
    if explicit != "" {
        explicit
    } else {
        match direct_expr_child_at(value.nodes, 1) {
            Some(then_block) => match direct_expr_child_at(value.nodes, 2) {
                Some(else_block) => if true {
                    let then_ty = branch_value_node_llvm_type_with_locals(program, function_value, value.nodes, then_block, locals);
                    let else_ty = branch_value_node_llvm_type_with_locals(program, function_value, value.nodes, else_block, locals);
                    if then_ty != "" && then_ty == else_ty { then_ty } else { "" }
                } else { "" },
                None => "",
            },
            None => "",
        }
    }
}

fn if_node_value_type_name(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], node: IrExprNode, locals: BackendLocals) -> String {
    let explicit = optional_type_name_for_id(program.types, node.type_id);
    if explicit != "" {
        explicit
    } else if node.direct_child_count != 3 {
        ""
    } else {
        match expr_node_child_at(nodes, node, 1) {
            Some(then_block) => match expr_node_child_at(nodes, node, 2) {
                Some(else_block) => if true {
                    let then_ty = branch_value_node_type_name_with_locals(program, function_value, nodes, then_block, locals);
                    let else_ty = branch_value_node_type_name_with_locals(program, function_value, nodes, else_block, locals);
                    if then_ty != "" && then_ty == else_ty { then_ty } else { "" }
                } else { "" },
                None => "",
            },
            None => "",
        }
    }
}

fn if_node_value_llvm_type(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], node: IrExprNode, locals: BackendLocals) -> String {
    llvm_type_for_repr_in_program(program, if_node_value_type_name(program, function_value, nodes, node, locals))
}

fn llvm_type_for_repr_in_program(program: IrProgram, repr: String) -> String {
    if repr == "" {
        ""
    } else {
        let primitive = llvm_type_for_repr(repr);
        if primitive != "" {
            primitive
        } else {
            let base = base_type_name_text(repr);
            if base == "Vec" {
                "{ i64, i64, i64 }"
            } else if base == "Result" {
                llvm_result_type(program, repr)
            } else if base == "Option" {
                llvm_option_type(program, repr)
            } else {
                let known_struct = known_struct_llvm_type(program, base);
                if known_struct != "" {
                    known_struct
                } else {
                    let known_enum = known_no_payload_enum_llvm_type(base);
                    if known_enum != "" {
                        known_enum
                    } else {
                        let struct_ty = struct_item_llvm_type(program, base);
                        if struct_ty != "" {
                            struct_ty
                        } else {
                            let enum_ty = enum_item_llvm_type(program, base);
                            if enum_ty != "" {
                                enum_ty
                            } else {
                                let alias_target = type_alias_target_type_name(program, base);
                                if alias_target != "" && alias_target != base {
                                    llvm_type_for_repr_in_program(program, alias_target)
                                } else {
                                    ""
                                }
                            }
                        }
                    }
                }
            }
        }
    }
}

fn llvm_type_for_id(program: IrProgram, id: IrTypeId) -> String {
    llvm_type_for_repr_in_program(program, type_name_for_id(program.types, id))
}

fn is_llvm_primitive_type(repr: String) -> Bool {
    llvm_type_for_repr(repr) != ""
}

fn is_supported_backend_expr_kind(value: IrExprKind) -> Bool {
    match value {
        IrIntExpr => true,
        IrFloatExpr => true,
        IrBoolExpr => true,
        IrStringExpr => true,
        IrCharExpr => true,
        IrTemplateExpr => false,
        IrUnitExpr => true,
        IrNameExpr => true,
        IrCallExpr => true,
        IrClosureExpr => true,
        IrIfExpr => true,
        IrWhileExpr => true,
        IrForExpr => true,
        IrLoopExpr => true,
        IrBreakExpr => true,
        IrContinueExpr => true,
        IrMatchExpr => true,
        IrBinaryExpr => true,
        IrUnaryExpr => true,
        IrBorrowExpr => true,
        IrAwaitExpr => true,
        IrTryExpr => true,
        IrStructLiteralExpr => true,
        IrTupleExpr => true,
        IrFieldAccessExpr => true,
        IrBlockExpr => true,
        IrUnsafeBlockExpr => false,
    }
}

fn is_string_expr_kind(value: IrExprKind) -> Bool {
    match value {
        IrStringExpr => true,
        _ => false,
    }
}

fn is_call_expr_kind(value: IrExprKind) -> Bool {
    match value {
        IrCallExpr => true,
        _ => false,
    }
}

fn is_block_expr_kind(value: IrExprKind) -> Bool {
    match value {
        IrBlockExpr => true,
        _ => false,
    }
}

fn is_io_print_intrinsic_name(name: String) -> Bool {
    name == "print_str" || name == "eprint_str"
}

fn is_fs_string_result_intrinsic_name(name: String) -> Bool {
    name == "read_text" || name == "temp_file"
}

fn is_fs_bool_result_intrinsic_name(name: String) -> Bool {
    name == "write_text" || name == "delete"
}

fn is_fs_intrinsic_name(name: String) -> Bool {
    is_fs_string_result_intrinsic_name(name) || is_fs_bool_result_intrinsic_name(name)
}

fn is_proc_result_intrinsic_name(name: String) -> Bool {
    name == "proc.run"
}

fn is_string_bool_intrinsic_name(name: String) -> Bool {
    name == "string.contains" || name == "string.starts_with" || name == "string.ends_with"
}

fn is_string_len_intrinsic_name(name: String) -> Bool {
    name == "string.len"
}

fn is_string_join_intrinsic_name(name: String) -> Bool {
    name == "string.join"
}

fn is_string_split_intrinsic_name(name: String) -> Bool {
    name == "string.split"
}

fn is_string_trim_intrinsic_name(name: String) -> Bool {
    name == "string.trim"
}

fn is_string_char_at_intrinsic_name(name: String) -> Bool {
    name == "string.char_at"
}

fn is_string_int_to_string_intrinsic_name(name: String) -> Bool {
    name == "string.int_to_string"
}

fn is_vec_len_intrinsic_name(name: String) -> Bool {
    name == "vec.vec_len" || name == "vec_len"
}

fn is_vec_get_intrinsic_name(name: String) -> Bool {
    name == "vec.get"
}

fn is_string_slice_intrinsic_name(name: String) -> Bool {
    name == "string.substring" || name == "bytes.byte_substring"
}

fn string_slice_runtime_name(name: String) -> String {
    if name == "bytes.byte_substring" {
        "@aic_rt_string_byte_substring"
    } else {
        "@aic_rt_string_substring"
    }
}

fn string_bool_runtime_name(name: String) -> String {
    if name == "string.contains" {
        "@aic_rt_string_contains"
    } else if name == "string.starts_with" {
        "@aic_rt_string_starts_with"
    } else {
        "@aic_rt_string_ends_with"
    }
}

fn is_decimal_digit(value: String) -> Bool {
    value == "0" || value == "1" || value == "2" || value == "3" || value == "4" || value == "5" || value == "6" || value == "7" || value == "8" || value == "9"
}

fn is_decimal_integer_text(value: String) -> Bool {
    if value == "" {
        false
    } else {
        let mut index = 0;
        let mut ok = true;
        while ok && index < string.len(value) {
            let part = string.substring(value, index, index + 1);
            if index == 0 && part == "-" {
                ok = string.len(value) > 1;
            } else if !is_decimal_digit(part) {
                ok = false;
            } else {
                ()
            };
            index = index + 1;
        };
        ok
    }
}

fn literal_text_or_name(text: String, name: String) -> String {
    if text == "" { name } else { text }
}

fn bool_literal_llvm_text(text: String, name: String) -> String {
    if literal_text_or_name(text, name) == "true" { "1" } else { "0" }
}

fn function_has_param_named(function_value: IrFunctionDef, name: String) -> Bool {
    let mut index = 0;
    let mut found = false;
    while !found && index < vec.vec_len(function_value.params) {
        match vec.get(function_value.params, index) {
            Some(param) => if param.name == name {
                found = true;
            } else {
                ()
            },
            None => (),
        };
        index = index + 1;
    };
    found
}

fn function_param_llvm_type(program: IrProgram, function_value: IrFunctionDef, name: String) -> String {
    let mut index = 0;
    let mut out = "";
    while out == "" && index < vec.vec_len(function_value.params) {
        match vec.get(function_value.params, index) {
            Some(param) => if param.name == name {
                out = llvm_type_for_id(program, param.type_id);
            } else {
                ()
            },
            None => (),
        };
        index = index + 1;
    };
    out
}

fn function_param_type_name(program: IrProgram, function_value: IrFunctionDef, name: String) -> String {
    let mut index = 0;
    let mut out = "";
    while out == "" && index < vec.vec_len(function_value.params) {
        match vec.get(function_value.params, index) {
            Some(param) => if param.name == name {
                out = type_name_for_id(program.types, param.type_id);
            } else {
                ()
            },
            None => (),
        };
        index = index + 1;
    };
    out
}

fn backend_local_named_index(locals: BackendLocals, name: String) -> Int {
    let mut out = -1;
    let mut index = backend_locals_len(locals);
    while out < 0 && index > 0 {
        index = index - 1;
        match vec.get(locals.names, index) {
            Some(value) => if value == name {
                out = index;
            } else {
                ()
            },
            None => (),
        };
    };
    out
}

fn backend_local_type_name_at(locals: BackendLocals, index: Int) -> String {
    match vec.get(locals.type_names, index) {
        Some(value) => value,
        None => "",
    }
}

fn backend_local_llvm_type_at(locals: BackendLocals, index: Int) -> String {
    match vec.get(locals.llvm_types, index) {
        Some(value) => value,
        None => "",
    }
}

fn backend_local_value_name_at(locals: BackendLocals, index: Int) -> String {
    match vec.get(locals.value_names, index) {
        Some(value) => value,
        None => "",
    }
}

fn clone_string_vec(values: Vec[String]) -> Vec[String] {
    let mut out: Vec[String] = vec.new_vec();
    let mut index = 0;
    while index < vec.vec_len(values) {
        match vec.get(values, index) {
            Some(value) => if true {
                out = vec.push(out, value);
                ()
            } else { () },
            None => (),
        };
        index = index + 1;
    };
    out
}

fn clone_backend_locals(locals: BackendLocals) -> BackendLocals {
    BackendLocals {
        names: clone_string_vec(locals.names),
        type_names: clone_string_vec(locals.type_names),
        llvm_types: clone_string_vec(locals.llvm_types),
        value_names: clone_string_vec(locals.value_names),
    }
}

fn value_name_for_name(function_value: IrFunctionDef, locals: BackendLocals, name: String) -> String {
    if function_has_param_named(function_value, name) {
        value_name_for_param(function_value, name)
    } else {
        let index = backend_local_named_index(locals, name);
        if index >= 0 { backend_local_value_name_at(locals, index) } else { "" }
    }
}

fn storage_name_for_name(locals: BackendLocals, name: String) -> String {
    let index = backend_local_named_index(locals, name);
    if index >= 0 {
        let value_name = backend_local_value_name_at(locals, index);
        if string.contains(value_name, ".slot.") { value_name } else { "" }
    } else {
        ""
    }
}

fn name_uses_storage(locals: BackendLocals, name: String) -> Bool {
    storage_name_for_name(locals, name) != ""
}

fn mutable_storage_name(name: String, node_id: IrNodeId) -> String {
    concat3("%", backend_mangle_symbol(name), concat3(".slot.", string.int_to_string(node_id.value), ""))
}

fn loaded_node_name(node: IrExprNode) -> String {
    llvm_local(llvm_node_prefix(node.node), ".load")
}

fn loaded_expr_name(value: IrExpr) -> String {
    llvm_local(llvm_expr_prefix(value.node), ".load")
}

fn type_name_for_name(program: IrProgram, function_value: IrFunctionDef, locals: BackendLocals, name: String) -> String {
    if function_has_param_named(function_value, name) {
        function_param_type_name(program, function_value, name)
    } else {
        let index = backend_local_named_index(locals, name);
        if index >= 0 { backend_local_type_name_at(locals, index) } else { "" }
    }
}

fn llvm_type_for_name(program: IrProgram, function_value: IrFunctionDef, locals: BackendLocals, name: String) -> String {
    if function_has_param_named(function_value, name) {
        function_param_llvm_type(program, function_value, name)
    } else {
        let index = backend_local_named_index(locals, name);
        if index >= 0 { backend_local_llvm_type_at(locals, index) } else { "" }
    }
}

fn name_is_value_available(function_value: IrFunctionDef, locals: BackendLocals, name: String) -> Bool {
    value_name_for_name(function_value, locals, name) != ""
}

fn value_name_for_param(function_value: IrFunctionDef, name: String) -> String {
    if function_has_param_named(function_value, name) {
        concat2("%", backend_mangle_symbol(name))
    } else {
        ""
    }
}

fn backend_param_locals(program: IrProgram, function_value: IrFunctionDef) -> BackendLocals {
    let mut out: BackendLocals = backend_empty_locals();
    let mut index = 0;
    while index < vec.vec_len(function_value.params) {
        match vec.get(function_value.params, index) {
            Some(param) => if true {
                out = backend_locals_push_parts(out, param.name, type_name_for_id(program.types, param.type_id), llvm_type_for_id(program, param.type_id), value_name_for_param(function_value, param.name));
                ()
            } else { () },
            None => (),
        };
        index = index + 1;
    };
    out
}

