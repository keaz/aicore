        Some(child) => string_call_child_can_emit(program, function_value, nodes, child, locals),
        None => false,
    }
}

fn string_len_expr_can_emit(program: IrProgram, value: IrExpr, function_value: IrFunctionDef, locals: BackendLocals) -> Bool {
