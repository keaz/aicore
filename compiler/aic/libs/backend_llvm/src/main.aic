                parts = vec.push(parts, ", label %");
                parts = vec.push(parts, some_label);
                parts = vec.push(parts, ", label %");
                parts = vec.push(parts, none_label);
                parts = vec.push(parts, "\n");
                parts = vec.push(parts, some_label);
                parts = vec.push(parts, ":\n");
                parts = vec.push(parts, emit_branch_value_store_with_expected_type(program, function_value, nodes, some_body, expected, expected_type_name, out_slot, payload_locals, end_label));
                parts = vec.push(parts, none_label);
                parts = vec.push(parts, ":\n");
