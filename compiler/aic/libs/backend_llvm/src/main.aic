                let end_label = concat2("option.match.end.", string.int_to_string(node.node.value));
                let out_slot = llvm_local(prefix, ".value.slot");
                let option_name = option_match_scrutinee_node_type_name(program, function_value, nodes, node, locals);
                let payload_type_name = generic_arg_at(option_name, 0);
                let payload_locals = push_option_payload_local(program, locals, option_match_payload_name_from_node(node), payload_type_name, option_match_payload_name(prefix));
