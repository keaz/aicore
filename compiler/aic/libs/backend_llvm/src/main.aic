                        let mut parts: Vec[String] = vec.new_vec();
                        parts = vec.push(parts, emit_string_node_value(program, function_value, nodes, path_child, locals));
                        parts = vec.push(parts, emit_string_extracts(path_name, path_prefix));
                        if scrutinee.name == "write_text" {
                            match expr_node_child_at(nodes, scrutinee, 1) {
                                Some(content_child) => if true {
                                    let content_name = string_node_value_name_with_locals(function_value, locals, content_child);
                                    let content_prefix = concat2(prefix, ".content");
                                    parts = vec.push(parts, emit_string_node_value(program, function_value, nodes, content_child, locals));
                                    parts = vec.push(parts, emit_string_extracts(content_name, content_prefix));
                                    parts = vec.push(parts, "  ");
                                    parts = vec.push(parts, llvm_local(prefix, ".rc"));
                                    parts = vec.push(parts, " = call i64 ");
                                    parts = vec.push(parts, fs_bool_runtime_name(scrutinee.name));
                                    parts = vec.push(parts, "(i8* ");
                                    parts = vec.push(parts, llvm_local(path_prefix, ".ptr"));
                                    parts = vec.push(parts, ", i64 ");
                                    parts = vec.push(parts, llvm_local(path_prefix, ".len"));
                                    parts = vec.push(parts, ", i64 ");
                                    parts = vec.push(parts, llvm_local(path_prefix, ".cap"));
                                    parts = vec.push(parts, ", i8* ");
                                    parts = vec.push(parts, llvm_local(content_prefix, ".ptr"));
                                    parts = vec.push(parts, ", i64 ");
                                    parts = vec.push(parts, llvm_local(content_prefix, ".len"));
                                    parts = vec.push(parts, ", i64 ");
                                    parts = vec.push(parts, llvm_local(content_prefix, ".cap"));
                                    parts = vec.push(parts, ")\n");
                                    ()
                                } else { () },
                                None => (),
                            };
                        } else {
                            parts = vec.push(parts, "  ");
                            parts = vec.push(parts, llvm_local(prefix, ".rc"));
                            parts = vec.push(parts, " = call i64 ");
                            parts = vec.push(parts, fs_bool_runtime_name(scrutinee.name));
                            parts = vec.push(parts, "(i8* ");
                            parts = vec.push(parts, llvm_local(path_prefix, ".ptr"));
                            parts = vec.push(parts, ", i64 ");
                            parts = vec.push(parts, llvm_local(path_prefix, ".len"));
                            parts = vec.push(parts, ", i64 ");
                            parts = vec.push(parts, llvm_local(path_prefix, ".cap"));
                            parts = vec.push(parts, ")\n");
                        };
                        parts = vec.push(parts, "  ");
                        parts = vec.push(parts, llvm_local(prefix, ".is_ok"));
                        parts = vec.push(parts, " = icmp eq i64 ");
                        parts = vec.push(parts, llvm_local(prefix, ".rc"));
                        parts = vec.push(parts, ", 0\n  br i1 ");
                        parts = vec.push(parts, llvm_local(prefix, ".is_ok"));
                        parts = vec.push(parts, ", label %");
                        parts = vec.push(parts, ok_label);
                        parts = vec.push(parts, ", label %");
                        parts = vec.push(parts, err_label);
                        parts = vec.push(parts, "\n");
                        parts = vec.push(parts, ok_label);
                        parts = vec.push(parts, ":\n");
                        parts = vec.push(parts, emit_branch_return(program, function_value, nodes, ok_body, ret, locals));
                        parts = vec.push(parts, err_label);
                        parts = vec.push(parts, ":\n");
                        parts = vec.push(parts, emit_branch_return(program, function_value, nodes, err_body, ret, locals));
                        string.join(parts, "")
                    } else { "" },
                    None => "",
                },
                None => "",
            },
            None => "",
        },
        None => "",
    }
}

