fn emit_option_match_node_scrutinee(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], node: IrExprNode, locals: BackendLocals) -> String {
    match expr_node_child_at(nodes, node, 0) {
        Some(scrutinee) => if true {
            let prefix = llvm_node_prefix(node.node);
            let option_ty = value_node_llvm_type(program, function_value, nodes, scrutinee, locals);
            let scrutinee_value = node_value_name(program, function_value, nodes, scrutinee, locals);
            let mut parts: Vec[String] = vec.new_vec();
            parts = vec.push(parts, emit_value_node(program, function_value, nodes, scrutinee, locals));
            parts = vec.push(parts, "  ");
            parts = vec.push(parts, option_match_tag_name(prefix));
            parts = vec.push(parts, " = extractvalue ");
            parts = vec.push(parts, option_ty);
            parts = vec.push(parts, " ");
            parts = vec.push(parts, scrutinee_value);
            parts = vec.push(parts, ", 0\n  ");
            parts = vec.push(parts, option_match_payload_name(prefix));
            parts = vec.push(parts, " = extractvalue ");
            parts = vec.push(parts, option_ty);
            parts = vec.push(parts, " ");
            parts = vec.push(parts, scrutinee_value);
            parts = vec.push(parts, ", 1\n  ");
            parts = vec.push(parts, option_match_is_some_name(prefix));
            parts = vec.push(parts, " = icmp eq i32 ");
            parts = vec.push(parts, option_match_tag_name(prefix));
            parts = vec.push(parts, ", ");
            parts = vec.push(parts, string.int_to_string(enum_variant_index(program, "Option", "Some")));
            parts = vec.push(parts, "\n");
            string.join(parts, "")
        } else { "" },
        None => "",
    }
}

