                            parts = vec.push(parts, " = load ");
                            parts = vec.push(parts, ret);
                            parts = vec.push(parts, ", ");
                            parts = vec.push(parts, ret);
                            parts = vec.push(parts, "* ");
                            parts = vec.push(parts, out_slot);
                            parts = vec.push(parts, "\n  ret ");
