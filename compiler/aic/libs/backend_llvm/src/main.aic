fn emit_direct_result_match_node_return(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], node: IrExprNode, ret: String, locals: BackendLocals) -> String {
    match expr_node_child_at(nodes, node, 0) {
        Some(scrutinee) => match result_match_node_body_node_for_variant(nodes, node, "Ok") {
            Some(ok_body) => match result_match_node_body_node_for_variant(nodes, node, "Err") {
                Some(err_body) => if true {
                    let prefix = llvm_node_prefix(node.node);
                    let result_ty = call_target_return_type(program, scrutinee.name);
                    let result_name = call_target_return_type_name(program, scrutinee.name);
                    let ok_payload_type_name = result_constructor_payload_type_name(result_name, "Ok");
                    let ok_payload_ty = llvm_payload_slot_type(program, ok_payload_type_name);
                    let ok_payload_name = result_match_node_payload_name(node, "Ok");
                    let ok_label = concat2("match.ok.", string.int_to_string(node.node.value));
                    let err_label = concat2("match.err.", string.int_to_string(node.node.value));
                    let mut parts: Vec[String] = vec.new_vec();
                    parts = vec.push(parts, emit_direct_call_node_value(program, function_value, nodes, scrutinee, locals));
                    parts = vec.push(parts, "  ");
                    parts = vec.push(parts, llvm_local(prefix, ".tag"));
                    parts = vec.push(parts, " = extractvalue ");
                    parts = vec.push(parts, result_ty);
                    parts = vec.push(parts, " ");
                    parts = vec.push(parts, llvm_node_value_local(scrutinee));
                    parts = vec.push(parts, ", 0\n  ");
                    parts = vec.push(parts, llvm_local(prefix, ".is_ok"));
                    parts = vec.push(parts, " = icmp eq i32 ");
                    parts = vec.push(parts, llvm_local(prefix, ".tag"));
                    parts = vec.push(parts, ", 0\n  br i1 ");
                    parts = vec.push(parts, llvm_local(prefix, ".is_ok"));
                    parts = vec.push(parts, ", label %");
                    parts = vec.push(parts, ok_label);
                    parts = vec.push(parts, ", label %");
                    parts = vec.push(parts, err_label);
                    parts = vec.push(parts, "\n");
                    parts = vec.push(parts, ok_label);
                    parts = vec.push(parts, ":\n  ");
                    parts = vec.push(parts, llvm_local(prefix, ".ok.value"));
                    parts = vec.push(parts, " = extractvalue ");
                    parts = vec.push(parts, result_ty);
                    parts = vec.push(parts, " ");
                    parts = vec.push(parts, llvm_node_value_local(scrutinee));
                    parts = vec.push(parts, ", 1\n");
                    let ok_locals = backend_locals_push(locals, backend_local(ok_payload_name, ok_payload_type_name, ok_payload_ty, llvm_local(prefix, ".ok.value")));
                    parts = vec.push(parts, emit_return_node_with_locals(program, function_value, nodes, ok_body, ret, ok_locals));
                    parts = vec.push(parts, err_label);
                    parts = vec.push(parts, ":\n");
                    parts = vec.push(parts, emit_return_node_with_locals(program, function_value, nodes, err_body, ret, locals));
                    string.join(parts, "")
                } else { "" },
                None => "",
            },
            None => "",
        },
        None => "",
    }
}

