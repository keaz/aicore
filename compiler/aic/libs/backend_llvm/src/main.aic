fn emit_string_slice_call(prefix: String, name: String, text_value: String, start_value: String, end_value: String) -> String {
    let text_prefix = concat2(prefix, ".arg0");
    let mut parts: Vec[String] = vec.new_vec();
    parts = vec.push(parts, emit_string_extracts(text_value, text_prefix));
    parts = vec.push(parts, "  ");
    parts = vec.push(parts, llvm_local(prefix, ".out.ptr"));
    parts = vec.push(parts, " = alloca i8*\n  ");
    parts = vec.push(parts, llvm_local(prefix, ".out.len"));
    parts = vec.push(parts, " = alloca i64\n  call void ");
    parts = vec.push(parts, string_slice_runtime_name(name));
    parts = vec.push(parts, "(i8* ");
    parts = vec.push(parts, llvm_local(text_prefix, ".ptr"));
    parts = vec.push(parts, ", i64 ");
    parts = vec.push(parts, llvm_local(text_prefix, ".len"));
    parts = vec.push(parts, ", i64 ");
    parts = vec.push(parts, llvm_local(text_prefix, ".cap"));
    parts = vec.push(parts, ", i64 ");
    parts = vec.push(parts, start_value);
    parts = vec.push(parts, ", i64 ");
    parts = vec.push(parts, end_value);
    parts = vec.push(parts, ", i8** ");
    parts = vec.push(parts, llvm_local(prefix, ".out.ptr"));
    parts = vec.push(parts, ", i64* ");
    parts = vec.push(parts, llvm_local(prefix, ".out.len"));
    parts = vec.push(parts, ")\n  ");
    parts = vec.push(parts, llvm_local(prefix, ".ret.ptr"));
    parts = vec.push(parts, " = load i8*, i8** ");
    parts = vec.push(parts, llvm_local(prefix, ".out.ptr"));
    parts = vec.push(parts, "\n  ");
    parts = vec.push(parts, llvm_local(prefix, ".ret.len"));
    parts = vec.push(parts, " = load i64, i64* ");
    parts = vec.push(parts, llvm_local(prefix, ".out.len"));
    parts = vec.push(parts, "\n  ");
    parts = vec.push(parts, llvm_local(prefix, ".0"));
    parts = vec.push(parts, " = insertvalue %aic.String undef, i8* ");
    parts = vec.push(parts, llvm_local(prefix, ".ret.ptr"));
    parts = vec.push(parts, ", 0\n  ");
    parts = vec.push(parts, llvm_local(prefix, ".1"));
    parts = vec.push(parts, " = insertvalue %aic.String ");
    parts = vec.push(parts, llvm_local(prefix, ".0"));
    parts = vec.push(parts, ", i64 ");
    parts = vec.push(parts, llvm_local(prefix, ".ret.len"));
    parts = vec.push(parts, ", 1\n  ");
    parts = vec.push(parts, llvm_local(prefix, ".value"));
    parts = vec.push(parts, " = insertvalue %aic.String ");
    parts = vec.push(parts, llvm_local(prefix, ".1"));
    parts = vec.push(parts, ", i64 ");
    parts = vec.push(parts, llvm_local(prefix, ".ret.len"));
    parts = vec.push(parts, ", 2\n");
    string.join(parts, "")
}

fn emit_string_slice_node_value(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], node: IrExprNode, locals: BackendLocals) -> String {
    match expr_node_child_at(nodes, node, 0) {
        Some(text_child) => match expr_node_child_at(nodes, node, 1) {
            Some(start_child) => match expr_node_child_at(nodes, node, 2) {
                Some(end_child) => if true {
                    let text_value = string_node_value_name_with_locals(function_value, locals, text_child);
                    let start_value = node_value_name(program, function_value, nodes, start_child, locals);
                    let end_value = node_value_name(program, function_value, nodes, end_child, locals);
                    let mut parts: Vec[String] = vec.new_vec();
                    parts = vec.push(parts, emit_string_node_value(program, function_value, nodes, text_child, locals));
                    parts = vec.push(parts, emit_value_node(program, function_value, nodes, start_child, locals));
                    parts = vec.push(parts, emit_value_node(program, function_value, nodes, end_child, locals));
                    parts = vec.push(parts, emit_string_slice_call(llvm_node_prefix(node.node), node.name, text_value, start_value, end_value));
                    string.join(parts, "")
                } else { "" },
                None => "",
            },
            None => "",
        },
        None => "",
    }
}

fn emit_string_slice_expr_value(program: IrProgram, function_value: IrFunctionDef, expr: IrExpr, locals: BackendLocals) -> String {
    match direct_expr_child_at(expr.nodes, 0) {
        Some(text_child) => match direct_expr_child_at(expr.nodes, 1) {
            Some(start_child) => match direct_expr_child_at(expr.nodes, 2) {
                Some(end_child) => if true {
                    let text_value = string_node_value_name_with_locals(function_value, locals, text_child);
                    let start_value = node_value_name(program, function_value, expr.nodes, start_child, locals);
                    let end_value = node_value_name(program, function_value, expr.nodes, end_child, locals);
                    let mut parts: Vec[String] = vec.new_vec();
                    parts = vec.push(parts, emit_string_node_value(program, function_value, expr.nodes, text_child, locals));
                    parts = vec.push(parts, emit_value_node(program, function_value, expr.nodes, start_child, locals));
                    parts = vec.push(parts, emit_value_node(program, function_value, expr.nodes, end_child, locals));
                    parts = vec.push(parts, emit_string_slice_call(llvm_expr_prefix(expr.node), expr.name, text_value, start_value, end_value));
                    string.join(parts, "")
                } else { "" },
                None => "",
            },
            None => "",
        },
        None => "",
    }
}

fn emit_compare_node_value(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], node: IrExprNode, locals: BackendLocals) -> String {
    match expr_node_child_at(nodes, node, 0) {
        Some(left) => match expr_node_child_at(nodes, node, 1) {
            Some(right) => if string_call_child_can_emit(program, function_value, nodes, left, locals) && string_call_child_can_emit(program, function_value, nodes, right, locals) {
                emit_string_compare_node_value(program, function_value, nodes, node, left, right, locals)
            } else {
                emit_primitive_compare_node_value(program, function_value, nodes, node, left, right, locals)
            },
            None => "",
        },
        None => "",
    }
}

fn emit_primitive_compare_node_value(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], node: IrExprNode, left: IrExprNode, right: IrExprNode, locals: BackendLocals) -> String {
    let ty = value_node_llvm_type(program, function_value, nodes, left, locals);
    let mut parts: Vec[String] = vec.new_vec();
    parts = vec.push(parts, emit_value_node(program, function_value, nodes, left, locals));
    parts = vec.push(parts, emit_value_node(program, function_value, nodes, right, locals));
    parts = vec.push(parts, "  ");
    parts = vec.push(parts, llvm_node_value_local(node));
    parts = vec.push(parts, " = icmp ");
    parts = vec.push(parts, compare_predicate(node.op));
    parts = vec.push(parts, " ");
    parts = vec.push(parts, ty);
    parts = vec.push(parts, " ");
    parts = vec.push(parts, node_value_name(program, function_value, nodes, left, locals));
    parts = vec.push(parts, ", ");
    parts = vec.push(parts, node_value_name(program, function_value, nodes, right, locals));
    parts = vec.push(parts, "\n");
    string.join(parts, "")
}

fn emit_string_compare_node_value(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], node: IrExprNode, left: IrExprNode, right: IrExprNode, locals: BackendLocals) -> String {
    let left_name = string_node_value_name_with_locals(function_value, locals, left);
    let right_name = string_node_value_name_with_locals(function_value, locals, right);
    let mut parts: Vec[String] = vec.new_vec();
    parts = vec.push(parts, emit_string_node_value(program, function_value, nodes, left, locals));
    parts = vec.push(parts, emit_string_node_value(program, function_value, nodes, right, locals));
    parts = vec.push(parts, emit_string_extracts(left_name, concat2(llvm_node_prefix(node.node), ".lhs")));
    parts = vec.push(parts, emit_string_extracts(right_name, concat2(llvm_node_prefix(node.node), ".rhs")));
    parts = vec.push(parts, "  ");
    parts = vec.push(parts, llvm_local(llvm_node_prefix(node.node), ".raw"));
    parts = vec.push(parts, " = call i64 @aic_rt_string_compare(i8* ");
    parts = vec.push(parts, llvm_local(concat2(llvm_node_prefix(node.node), ".lhs"), ".ptr"));
    parts = vec.push(parts, ", i64 ");
    parts = vec.push(parts, llvm_local(concat2(llvm_node_prefix(node.node), ".lhs"), ".len"));
    parts = vec.push(parts, ", i64 ");
    parts = vec.push(parts, llvm_local(concat2(llvm_node_prefix(node.node), ".lhs"), ".cap"));
    parts = vec.push(parts, ", i8* ");
    parts = vec.push(parts, llvm_local(concat2(llvm_node_prefix(node.node), ".rhs"), ".ptr"));
    parts = vec.push(parts, ", i64 ");
    parts = vec.push(parts, llvm_local(concat2(llvm_node_prefix(node.node), ".rhs"), ".len"));
    parts = vec.push(parts, ", i64 ");
    parts = vec.push(parts, llvm_local(concat2(llvm_node_prefix(node.node), ".rhs"), ".cap"));
    parts = vec.push(parts, ")\n  ");
    parts = vec.push(parts, llvm_node_value_local(node));
    parts = vec.push(parts, " = icmp ");
    parts = vec.push(parts, string_compare_predicate(node.op));
    parts = vec.push(parts, " i64 ");
    parts = vec.push(parts, llvm_local(llvm_node_prefix(node.node), ".raw"));
    parts = vec.push(parts, ", 0\n");
    string.join(parts, "")
}

fn emit_primitive_compare_expr_value(program: IrProgram, function_value: IrFunctionDef, expr: IrExpr, left: IrExprNode, right: IrExprNode, locals: BackendLocals) -> String {
    let ty = value_node_llvm_type(program, function_value, expr.nodes, left, locals);
    let mut parts: Vec[String] = vec.new_vec();
    parts = vec.push(parts, emit_value_node(program, function_value, expr.nodes, left, locals));
    parts = vec.push(parts, emit_value_node(program, function_value, expr.nodes, right, locals));
    parts = vec.push(parts, "  ");
    parts = vec.push(parts, llvm_expr_value_local(expr));
    parts = vec.push(parts, " = icmp ");
    parts = vec.push(parts, compare_predicate(expr.op));
    parts = vec.push(parts, " ");
    parts = vec.push(parts, ty);
    parts = vec.push(parts, " ");
    parts = vec.push(parts, node_value_name(program, function_value, expr.nodes, left, locals));
    parts = vec.push(parts, ", ");
    parts = vec.push(parts, node_value_name(program, function_value, expr.nodes, right, locals));
    parts = vec.push(parts, "\n");
    string.join(parts, "")
}

fn emit_string_compare_expr_value(program: IrProgram, function_value: IrFunctionDef, expr: IrExpr, left: IrExprNode, right: IrExprNode, locals: BackendLocals) -> String {
    let left_name = string_node_value_name_with_locals(function_value, locals, left);
    let right_name = string_node_value_name_with_locals(function_value, locals, right);
    let prefix = llvm_expr_prefix(expr.node);
    let mut parts: Vec[String] = vec.new_vec();
    parts = vec.push(parts, emit_string_node_value(program, function_value, expr.nodes, left, locals));
    parts = vec.push(parts, emit_string_node_value(program, function_value, expr.nodes, right, locals));
    parts = vec.push(parts, emit_string_extracts(left_name, concat2(prefix, ".lhs")));
    parts = vec.push(parts, emit_string_extracts(right_name, concat2(prefix, ".rhs")));
    parts = vec.push(parts, "  ");
    parts = vec.push(parts, llvm_local(prefix, ".raw"));
    parts = vec.push(parts, " = call i64 @aic_rt_string_compare(i8* ");
    parts = vec.push(parts, llvm_local(concat2(prefix, ".lhs"), ".ptr"));
    parts = vec.push(parts, ", i64 ");
    parts = vec.push(parts, llvm_local(concat2(prefix, ".lhs"), ".len"));
    parts = vec.push(parts, ", i64 ");
    parts = vec.push(parts, llvm_local(concat2(prefix, ".lhs"), ".cap"));
    parts = vec.push(parts, ", i8* ");
    parts = vec.push(parts, llvm_local(concat2(prefix, ".rhs"), ".ptr"));
    parts = vec.push(parts, ", i64 ");
    parts = vec.push(parts, llvm_local(concat2(prefix, ".rhs"), ".len"));
    parts = vec.push(parts, ", i64 ");
    parts = vec.push(parts, llvm_local(concat2(prefix, ".rhs"), ".cap"));
    parts = vec.push(parts, ")\n  ");
    parts = vec.push(parts, llvm_expr_value_local(expr));
    parts = vec.push(parts, " = icmp ");
    parts = vec.push(parts, string_compare_predicate(expr.op));
    parts = vec.push(parts, " i64 ");
    parts = vec.push(parts, llvm_local(prefix, ".raw"));
    parts = vec.push(parts, ", 0\n");
    string.join(parts, "")
}

fn emit_compare_expr_value(program: IrProgram, function_value: IrFunctionDef, expr: IrExpr, locals: BackendLocals) -> String {
    match direct_expr_child_at(expr.nodes, 0) {
        Some(left) => match direct_expr_child_at(expr.nodes, 1) {
            Some(right) => if string_call_child_can_emit(program, function_value, expr.nodes, left, locals) && string_call_child_can_emit(program, function_value, expr.nodes, right, locals) {
                emit_string_compare_expr_value(program, function_value, expr, left, right, locals)
            } else {
                emit_primitive_compare_expr_value(program, function_value, expr, left, right, locals)
            },
            None => "",
        },
        None => "",
    }
}

fn emit_return_name_value(program: IrProgram, function_value: IrFunctionDef, name: String, ret: String, prefix: String) -> String {
    let source_llvm = function_param_llvm_type(program, function_value, name);
    let source_value = concat2("%", backend_mangle_symbol(name));
    let cast_op = function_param_return_cast_op(program, function_value, name, ret);
    let mut parts: Vec[String] = vec.new_vec();
    if cast_op == "" {
        parts = vec.push(parts, "  ret ");
        parts = vec.push(parts, ret);
        parts = vec.push(parts, " ");
        parts = vec.push(parts, source_value);
        parts = vec.push(parts, "\n");
    } else {
        parts = vec.push(parts, "  ");
        parts = vec.push(parts, llvm_local(prefix, ".cast"));
        parts = vec.push(parts, " = ");
        parts = vec.push(parts, cast_op);
        parts = vec.push(parts, " ");
        parts = vec.push(parts, source_llvm);
        parts = vec.push(parts, " ");
        parts = vec.push(parts, source_value);
        parts = vec.push(parts, " to ");
        parts = vec.push(parts, ret);
        parts = vec.push(parts, "\n  ret ");
        parts = vec.push(parts, ret);
        parts = vec.push(parts, " ");
        parts = vec.push(parts, llvm_local(prefix, ".cast"));
        parts = vec.push(parts, "\n");
    };
    string.join(parts, "")
}

fn result_payload_node_value_name(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], payload: IrExprNode, locals: BackendLocals, payload_ty: String) -> String {
    if payload_ty == "%aic.String" {
        string_node_value_name_with_locals(function_value, locals, payload)
    } else if payload.name == "vec.new_vec" && payload_ty == "{ i64, i64, i64 }" {
        llvm_node_value_local(payload)
    } else {
        node_value_name(program, function_value, nodes, payload, locals)
    }
}

fn emit_result_payload_node_value(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], payload: IrExprNode, locals: BackendLocals, payload_ty: String) -> String {
    if payload_ty == "%aic.String" {
        emit_string_node_value(program, function_value, nodes, payload, locals)
    } else if payload.name == "vec.new_vec" && payload_ty == "{ i64, i64, i64 }" {
        emit_empty_vec_value(llvm_node_prefix(payload.node), payload_ty)
    } else {
        emit_value_node(program, function_value, nodes, payload, locals)
    }
}

fn emit_result_constructor_node_return(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], node: IrExprNode, ret: String, locals: BackendLocals) -> String {
    match expr_node_child_at(nodes, node, 0) {
        Some(payload) => if true {
            let result_name = function_result_type_name(program, function_value);
            let payload_name = result_constructor_payload_type_name(result_name, node.name);
            let payload_ty = llvm_payload_slot_type(program, payload_name);
            let prefix = llvm_node_prefix(node.node);
            let mut parts: Vec[String] = vec.new_vec();
            parts = vec.push(parts, emit_result_payload_node_value(program, function_value, nodes, payload, locals, payload_ty));
            parts = vec.push(parts, "  ");
            parts = vec.push(parts, llvm_local(prefix, ".result.0"));
            parts = vec.push(parts, " = insertvalue ");
            parts = vec.push(parts, ret);
            parts = vec.push(parts, " undef, i32 ");
            parts = vec.push(parts, result_constructor_tag(node.name));
            parts = vec.push(parts, ", 0\n  ");
            parts = vec.push(parts, llvm_local(prefix, ".result.1"));
            parts = vec.push(parts, " = insertvalue ");
            parts = vec.push(parts, ret);
            parts = vec.push(parts, " ");
            parts = vec.push(parts, llvm_local(prefix, ".result.0"));
            parts = vec.push(parts, ", ");
            parts = vec.push(parts, payload_ty);
            parts = vec.push(parts, " ");
            parts = vec.push(parts, result_payload_node_value_name(program, function_value, nodes, payload, locals, payload_ty));
            parts = vec.push(parts, ", ");
            parts = vec.push(parts, string.int_to_string(result_constructor_slot_index(node.name)));
            parts = vec.push(parts, "\n  ret ");
            parts = vec.push(parts, ret);
            parts = vec.push(parts, " ");
            parts = vec.push(parts, llvm_local(prefix, ".result.1"));
            parts = vec.push(parts, "\n");
            string.join(parts, "")
        } else { "" },
        None => "",
    }
}

fn emit_return_node_with_locals(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], node: IrExprNode, ret: String, locals: BackendLocals) -> String {
    let mut parts: Vec[String] = vec.new_vec();
    match node.kind {
        IrIntExpr => if true {
            parts = vec.push(parts, "  ret ");
            parts = vec.push(parts, ret);
            parts = vec.push(parts, " ");
            parts = vec.push(parts, literal_text_or_name(node.text, node.name));
            parts = vec.push(parts, "\n");
            ()
        } else { () },
        IrBoolExpr => if true {
            parts = vec.push(parts, "  ret ");
            parts = vec.push(parts, ret);
            parts = vec.push(parts, " ");
            parts = vec.push(parts, bool_literal_llvm_text(node.text, node.name));
            parts = vec.push(parts, "\n");
            ()
        } else { () },
        IrStringExpr => if true {
            parts = vec.push(parts, emit_string_literal_value(llvm_string_node_global_name(function_value.name, node.node), node.text, llvm_node_prefix(node.node)));
            parts = vec.push(parts, "  ret ");
            parts = vec.push(parts, ret);
            parts = vec.push(parts, " ");
            parts = vec.push(parts, llvm_node_value_local(node));
            parts = vec.push(parts, "\n");
            ()
        } else { () },
        IrNameExpr => if true {
            let value_name = value_name_for_name(function_value, locals, node.text);
            if name_uses_storage(locals, node.text) {
                parts = vec.push(parts, emit_load_name_node_value(program, function_value, node, locals));
                parts = vec.push(parts, "  ret ");
                parts = vec.push(parts, ret);
                parts = vec.push(parts, " ");
                parts = vec.push(parts, loaded_node_name(node));
                parts = vec.push(parts, "\n");
            } else if value_name == value_name_for_param(function_value, node.text) {
                parts = vec.push(parts, emit_return_name_value(program, function_value, node.text, ret, llvm_node_prefix(node.node)));
            } else {
                parts = vec.push(parts, "  ret ");
                parts = vec.push(parts, ret);
                parts = vec.push(parts, " ");
                parts = vec.push(parts, value_name);
                parts = vec.push(parts, "\n");
            };
            ()
        } else { () },
        IrFieldAccessExpr => if true {
            parts = vec.push(parts, emit_field_access_node_value(program, function_value, nodes, node, locals));
            parts = vec.push(parts, "  ret ");
            parts = vec.push(parts, ret);
            parts = vec.push(parts, " ");
            parts = vec.push(parts, llvm_node_value_local(node));
            parts = vec.push(parts, "\n");
            ()
        } else { () },
        IrBinaryExpr => if true {
            parts = vec.push(parts, emit_binary_node_value(program, function_value, nodes, node, locals));
            parts = vec.push(parts, "  ret ");
            parts = vec.push(parts, ret);
            parts = vec.push(parts, " ");
            parts = vec.push(parts, llvm_node_value_local(node));
            parts = vec.push(parts, "\n");
            ()
        } else { () },
        IrUnaryExpr => if true {
            if node.op == "-" {
                parts = vec.push(parts, emit_unary_int_node_value(program, function_value, nodes, node, locals));
            } else {
                parts = vec.push(parts, emit_unary_bool_node_value(program, function_value, nodes, node, locals));
            };
            parts = vec.push(parts, "  ret ");
            parts = vec.push(parts, ret);
            parts = vec.push(parts, " ");
            parts = vec.push(parts, llvm_node_value_local(node));
            parts = vec.push(parts, "\n");
            ()
        } else { () },
        IrCallExpr => if true {
            if expected_enum_constructor_node_can_emit(program, function_value, nodes, node, locals, function_result_type_name(program, function_value)) {
                parts = vec.push(parts, emit_expected_enum_constructor_node_value(program, function_value, nodes, node, locals, ret, function_result_type_name(program, function_value)));
                parts = vec.push(parts, "  ret ");
                parts = vec.push(parts, ret);
                parts = vec.push(parts, " ");
                parts = vec.push(parts, expected_enum_constructor_node_value_name(node));
                parts = vec.push(parts, "\n");
            } else if node.name == "Ok" || node.name == "Err" {
                parts = vec.push(parts, emit_result_constructor_node_return(program, function_value, nodes, node, ret, locals));
            } else if is_string_bool_intrinsic_name(node.name) {
                parts = vec.push(parts, emit_string_bool_node_value(program, function_value, nodes, node, locals));
                parts = vec.push(parts, "  ret ");
                parts = vec.push(parts, ret);
                parts = vec.push(parts, " ");
                parts = vec.push(parts, llvm_node_value_local(node));
                parts = vec.push(parts, "\n");
            } else if is_string_join_intrinsic_name(node.name) {
                parts = vec.push(parts, emit_string_join_node_value(program, function_value, nodes, node, locals));
                parts = vec.push(parts, "  ret ");
                parts = vec.push(parts, ret);
                parts = vec.push(parts, " ");
                parts = vec.push(parts, llvm_node_value_local(node));
                parts = vec.push(parts, "\n");
            } else if is_string_len_intrinsic_name(node.name) {
                parts = vec.push(parts, emit_string_len_node_value(program, function_value, nodes, node, locals));
                parts = vec.push(parts, "  ret ");
                parts = vec.push(parts, ret);
                parts = vec.push(parts, " ");
                parts = vec.push(parts, llvm_node_value_local(node));
                parts = vec.push(parts, "\n");
            } else if is_vec_len_intrinsic_name(node.name) {
                parts = vec.push(parts, emit_vec_len_node_value(program, function_value, nodes, node, locals));
                parts = vec.push(parts, "  ret ");
                parts = vec.push(parts, ret);
                parts = vec.push(parts, " ");
                parts = vec.push(parts, llvm_node_value_local(node));
                parts = vec.push(parts, "\n");
            } else if is_vec_get_intrinsic_name(node.name) {
                parts = vec.push(parts, emit_vec_get_node_value(program, function_value, nodes, node, locals));
                parts = vec.push(parts, "  ret ");
                parts = vec.push(parts, ret);
                parts = vec.push(parts, " ");
                parts = vec.push(parts, llvm_node_value_local(node));
                parts = vec.push(parts, "\n");
            } else if is_string_slice_intrinsic_name(node.name) {
                parts = vec.push(parts, emit_string_slice_node_value(program, function_value, nodes, node, locals));
                parts = vec.push(parts, "  ret ");
                parts = vec.push(parts, ret);
                parts = vec.push(parts, " ");
                parts = vec.push(parts, llvm_node_value_local(node));
                parts = vec.push(parts, "\n");
            } else if node.name == "vec.new_vec" {
                parts = vec.push(parts, emit_empty_vec_value(llvm_node_prefix(node.node), ret));
                parts = vec.push(parts, "  ret ");
                parts = vec.push(parts, ret);
                parts = vec.push(parts, " ");
                parts = vec.push(parts, llvm_node_value_local(node));
                parts = vec.push(parts, "\n");
            } else {
                parts = vec.push(parts, emit_value_node(program, function_value, nodes, node, locals));
                parts = vec.push(parts, "  ret ");
                parts = vec.push(parts, ret);
                parts = vec.push(parts, " ");
                parts = vec.push(parts, node_value_name(program, function_value, nodes, node, locals));
                parts = vec.push(parts, "\n");
            };
            ()
        } else { () },
        IrIfExpr => if true {
            parts = vec.push(parts, emit_if_node_return(program, function_value, nodes, node, ret, locals));
            ()
        } else { () },
        IrLoopExpr => if true {
            parts = vec.push(parts, emit_loop_node_value(program, function_value, nodes, node, locals));
            parts = vec.push(parts, "  ret ");
            parts = vec.push(parts, ret);
            parts = vec.push(parts, " ");
            parts = vec.push(parts, llvm_node_value_local(node));
            parts = vec.push(parts, "\n");
            ()
        } else { () },
        IrMatchExpr => if true {
            if direct_result_match_node_can_emit_result_return(program, function_value, nodes, node, ret, locals) {
                parts = vec.push(parts, emit_direct_result_match_node_result_return(program, function_value, nodes, node, ret, locals));
            } else if result_match_node_can_emit_return(program, function_value, nodes, node, ret, locals) {
                parts = vec.push(parts, emit_result_match_node_return(program, function_value, nodes, node, ret, locals));
            } else if option_vec_get_match_node_can_emit_return(program, function_value, nodes, node, ret, locals) {
                parts = vec.push(parts, emit_option_vec_get_match_node_return(program, function_value, nodes, node, ret, locals));
            } else if option_match_node_can_emit_return(program, function_value, nodes, node, ret, locals) {
                parts = vec.push(parts, emit_option_match_node_return(program, function_value, nodes, node, ret, locals));
            } else if result_bool_match_node_can_emit_return(program, function_value, nodes, node, ret, locals) {
                parts = vec.push(parts, emit_result_bool_match_node_return(program, function_value, nodes, node, ret, locals));
            } else if fs_string_match_node_can_emit_int_return(program, function_value, nodes, node, ret, locals) {
                parts = vec.push(parts, emit_fs_string_match_node_int_return(program, function_value, nodes, node, ret, locals));
            } else if proc_run_match_node_can_emit_int_return(program, function_value, nodes, node, ret, locals) {
                parts = vec.push(parts, emit_proc_run_match_node_int_return(program, function_value, nodes, node, ret, locals));
            } else if direct_result_match_node_can_emit_return(program, function_value, nodes, node, ret, locals) {
                parts = vec.push(parts, emit_direct_result_match_node_return(program, function_value, nodes, node, ret, locals));
            } else if enum_bool_match_node_can_emit_return(program, function_value, nodes, node, ret, locals) {
                parts = vec.push(parts, emit_enum_bool_match_node_return(program, function_value, nodes, node, ret, locals));
            } else if ret == "i1" && enum_bool_match_node_can_emit(program, function_value, nodes, node, locals) {
                parts = vec.push(parts, emit_enum_bool_match_node_value(program, function_value, nodes, node, locals));
                parts = vec.push(parts, "  ret ");
                parts = vec.push(parts, ret);
                parts = vec.push(parts, " ");
                parts = vec.push(parts, llvm_node_value_local(node));
                parts = vec.push(parts, "\n");
            } else {
                parts = vec.push(parts, emit_result_string_match_node_value(program, function_value, nodes, node, locals));
                parts = vec.push(parts, "  ret ");
                parts = vec.push(parts, ret);
                parts = vec.push(parts, " ");
                parts = vec.push(parts, llvm_node_value_local(node));
                parts = vec.push(parts, "\n");
            };
            ()
        } else { () },
        IrStructLiteralExpr => if true {
            parts = vec.push(parts, emit_struct_literal_node_value(program, function_value, nodes, node, locals, ret));
            parts = vec.push(parts, "  ret ");
            parts = vec.push(parts, ret);
            parts = vec.push(parts, " ");
            parts = vec.push(parts, struct_literal_value_name(llvm_node_prefix(node.node), node.direct_child_count, ret));
            parts = vec.push(parts, "\n");
            ()
        } else { () },
        _ => (),
    };
    string.join(parts, "")
}

fn emit_return_node(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], node: IrExprNode, ret: String) -> String {
    emit_return_node_with_locals(program, function_value, nodes, node, ret, backend_empty_locals())
}

fn emit_block_tail_return(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], block_node: IrExprNode, ret: String, locals: BackendLocals) -> String {
    emit_block_node_return(program, function_value, nodes, block_node, ret, locals)
}

fn emit_branch_return(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], branch_node: IrExprNode, ret: String, locals: BackendLocals) -> String {
    if is_block_expr_kind(branch_node.kind) {
        emit_block_tail_return(program, function_value, nodes, branch_node, ret, locals)
    } else {
        emit_return_node_with_locals(program, function_value, nodes, branch_node, ret, locals)
    }
}

fn emit_if_node_return(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], node: IrExprNode, ret: String, locals: BackendLocals) -> String {
    match expr_node_child_at(nodes, node, 0) {
        Some(condition) => match expr_node_child_at(nodes, node, 1) {
            Some(then_block) => match expr_node_child_at(nodes, node, 2) {
                Some(else_block) => if true {
                    let then_label = concat2("if.then.", string.int_to_string(node.node.value));
                    let else_label = concat2("if.else.", string.int_to_string(node.node.value));
                    let mut parts: Vec[String] = vec.new_vec();
                    parts = vec.push(parts, emit_bool_node_value(program, function_value, nodes, condition, locals));
                    parts = vec.push(parts, "  br i1 ");
                    parts = vec.push(parts, bool_node_value_name_with_locals(function_value, locals, condition));
                    parts = vec.push(parts, ", label %");
                    parts = vec.push(parts, then_label);
                    parts = vec.push(parts, ", label %");
                    parts = vec.push(parts, else_label);
                    parts = vec.push(parts, "\n");
                    parts = vec.push(parts, then_label);
                    parts = vec.push(parts, ":\n");
                    parts = vec.push(parts, emit_branch_return(program, function_value, nodes, then_block, ret, locals));
                    parts = vec.push(parts, else_label);
                    parts = vec.push(parts, ":\n");
                    parts = vec.push(parts, emit_branch_return(program, function_value, nodes, else_block, ret, locals));
                    string.join(parts, "")
                } else { "" },
                None => "",
            },
            None => "",
        },
        None => "",
    }
}

fn emit_if_expr_return(program: IrProgram, function_value: IrFunctionDef, expr: IrExpr, ret: String, locals: BackendLocals) -> String {
    match direct_expr_child_at(expr.nodes, 0) {
        Some(condition) => match direct_expr_child_at(expr.nodes, 1) {
            Some(then_block) => match direct_expr_child_at(expr.nodes, 2) {
                Some(else_block) => if true {
                    let then_label = concat2("if.then.", string.int_to_string(expr.node.value));
                    let else_label = concat2("if.else.", string.int_to_string(expr.node.value));
                    let mut parts: Vec[String] = vec.new_vec();
                    parts = vec.push(parts, emit_bool_node_value(program, function_value, expr.nodes, condition, locals));
                    parts = vec.push(parts, "  br i1 ");
                    parts = vec.push(parts, bool_node_value_name_with_locals(function_value, locals, condition));
                    parts = vec.push(parts, ", label %");
                    parts = vec.push(parts, then_label);
                    parts = vec.push(parts, ", label %");
                    parts = vec.push(parts, else_label);
                    parts = vec.push(parts, "\n");
                    parts = vec.push(parts, then_label);
                    parts = vec.push(parts, ":\n");
                    parts = vec.push(parts, emit_branch_return(program, function_value, expr.nodes, then_block, ret, locals));
                    parts = vec.push(parts, else_label);
                    parts = vec.push(parts, ":\n");
                    parts = vec.push(parts, emit_branch_return(program, function_value, expr.nodes, else_block, ret, locals));
                    string.join(parts, "")
                } else { "" },
                None => "",
            },
            None => "",
        },
        None => "",
    }
}

fn emit_option_vec_get_match_node_value(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], node: IrExprNode, locals: BackendLocals) -> String {
    match expr_node_child_at(nodes, node, 0) {
        Some(scrutinee) => match expr_node_child_at(nodes, scrutinee, 0) {
            Some(vec_child) => match expr_node_child_at(nodes, scrutinee, 1) {
                Some(index_child) => match result_match_node_body_node_for_variant(nodes, node, "Some") {
                    Some(some_body) => match result_match_node_body_node_for_variant(nodes, node, "None") {
                        Some(none_body) => if true {
                            let probe_prefix = llvm_node_prefix(scrutinee.node);
                            let value_prefix = llvm_node_prefix(node.node);
                            let expected = option_vec_get_match_node_llvm_type(program, function_value, nodes, node, locals);
                            let some_label = concat2("option.match.some.", string.int_to_string(node.node.value));
                            let none_label = concat2("option.match.none.", string.int_to_string(node.node.value));
                            let end_label = concat2("option.match.end.", string.int_to_string(node.node.value));
                            let out_slot = llvm_local(value_prefix, ".value.slot");
                            let payload_type_name = generic_arg_at(vec_get_node_type_name(program, function_value, nodes, scrutinee, locals), 0);
                            let payload_locals = push_option_payload_local(program, clone_backend_locals(locals), option_match_payload_name_from_node(node), payload_type_name, vec_get_loaded_name(probe_prefix));
                            let mut parts: Vec[String] = vec.new_vec();
                            parts = vec.push(parts, "  ");
                            parts = vec.push(parts, out_slot);
                            parts = vec.push(parts, " = alloca ");
                            parts = vec.push(parts, expected);
                            parts = vec.push(parts, "\n");
                            parts = vec.push(parts, emit_value_node(program, function_value, nodes, vec_child, locals));
                            parts = vec.push(parts, emit_value_node(program, function_value, nodes, index_child, locals));
                            parts = vec.push(parts, emit_vec_get_probe(probe_prefix, value_node_llvm_type(program, function_value, nodes, vec_child, locals), llvm_payload_slot_type(program, payload_type_name), node_value_name(program, function_value, nodes, vec_child, locals), node_value_name(program, function_value, nodes, index_child, locals)));
                            parts = vec.push(parts, "  br i1 ");
                            parts = vec.push(parts, vec_get_found_bool_name(probe_prefix));
                            parts = vec.push(parts, ", label %");
                            parts = vec.push(parts, some_label);
                            parts = vec.push(parts, ", label %");
                            parts = vec.push(parts, none_label);
                            parts = vec.push(parts, "\n");
                            parts = vec.push(parts, some_label);
                            parts = vec.push(parts, ":\n");
                            parts = vec.push(parts, emit_branch_value_store(program, function_value, nodes, some_body, expected, out_slot, payload_locals, end_label));
                            parts = vec.push(parts, none_label);
                            parts = vec.push(parts, ":\n");
                            parts = vec.push(parts, emit_branch_value_store(program, function_value, nodes, none_body, expected, out_slot, locals, end_label));
                            parts = vec.push(parts, end_label);
                            parts = vec.push(parts, ":\n  ");
                            parts = vec.push(parts, llvm_node_value_local(node));
                            parts = vec.push(parts, " = load ");
                            parts = vec.push(parts, expected);
                            parts = vec.push(parts, ", ");
                            parts = vec.push(parts, expected);
                            parts = vec.push(parts, "* ");
                            parts = vec.push(parts, out_slot);
                            parts = vec.push(parts, "\n");
                            string.join(parts, "")
                        } else { "" },
                        None => "",
                    },
                    None => "",
                },
                None => "",
            },
            None => "",
        },
        None => "",
    }
}

fn emit_option_vec_get_match_expr_value(program: IrProgram, function_value: IrFunctionDef, expr: IrExpr, locals: BackendLocals) -> String {
    match direct_expr_child_at(expr.nodes, 0) {
        Some(scrutinee) => match expr_node_child_at(expr.nodes, scrutinee, 0) {
            Some(vec_child) => match expr_node_child_at(expr.nodes, scrutinee, 1) {
                Some(index_child) => match result_match_expr_body_node_for_variant(expr, "Some") {
                    Some(some_body) => match result_match_expr_body_node_for_variant(expr, "None") {
                        Some(none_body) => if true {
                            let probe_prefix = llvm_node_prefix(scrutinee.node);
                            let value_prefix = llvm_expr_prefix(expr.node);
                            let expected = option_vec_get_match_expr_llvm_type(program, expr, function_value, locals);
                            let some_label = concat2("option.match.some.", string.int_to_string(expr.node.value));
                            let none_label = concat2("option.match.none.", string.int_to_string(expr.node.value));
                            let end_label = concat2("option.match.end.", string.int_to_string(expr.node.value));
                            let out_slot = llvm_local(value_prefix, ".value.slot");
                            let payload_type_name = generic_arg_at(vec_get_node_type_name(program, function_value, expr.nodes, scrutinee, locals), 0);
                            let payload_locals = push_option_payload_local(program, clone_backend_locals(locals), option_match_payload_name_from_expr(expr), payload_type_name, vec_get_loaded_name(probe_prefix));
                            let mut parts: Vec[String] = vec.new_vec();
                            parts = vec.push(parts, "  ");
                            parts = vec.push(parts, out_slot);
                            parts = vec.push(parts, " = alloca ");
                            parts = vec.push(parts, expected);
                            parts = vec.push(parts, "\n");
                            parts = vec.push(parts, emit_value_node(program, function_value, expr.nodes, vec_child, locals));
                            parts = vec.push(parts, emit_value_node(program, function_value, expr.nodes, index_child, locals));
                            parts = vec.push(parts, emit_vec_get_probe(probe_prefix, value_node_llvm_type(program, function_value, expr.nodes, vec_child, locals), llvm_payload_slot_type(program, payload_type_name), node_value_name(program, function_value, expr.nodes, vec_child, locals), node_value_name(program, function_value, expr.nodes, index_child, locals)));
                            parts = vec.push(parts, "  br i1 ");
                            parts = vec.push(parts, vec_get_found_bool_name(probe_prefix));
                            parts = vec.push(parts, ", label %");
                            parts = vec.push(parts, some_label);
                            parts = vec.push(parts, ", label %");
                            parts = vec.push(parts, none_label);
                            parts = vec.push(parts, "\n");
                            parts = vec.push(parts, some_label);
                            parts = vec.push(parts, ":\n");
                            parts = vec.push(parts, emit_branch_value_store(program, function_value, expr.nodes, some_body, expected, out_slot, payload_locals, end_label));
                            parts = vec.push(parts, none_label);
                            parts = vec.push(parts, ":\n");
                            parts = vec.push(parts, emit_branch_value_store(program, function_value, expr.nodes, none_body, expected, out_slot, locals, end_label));
                            parts = vec.push(parts, end_label);
                            parts = vec.push(parts, ":\n  ");
                            parts = vec.push(parts, llvm_expr_value_local(expr));
                            parts = vec.push(parts, " = load ");
                            parts = vec.push(parts, expected);
                            parts = vec.push(parts, ", ");
                            parts = vec.push(parts, expected);
                            parts = vec.push(parts, "* ");
                            parts = vec.push(parts, out_slot);
                            parts = vec.push(parts, "\n");
                            string.join(parts, "")
                        } else { "" },
                        None => "",
                    },
                    None => "",
                },
                None => "",
            },
            None => "",
        },
        None => "",
    }
}

fn emit_option_vec_get_match_node_return(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], node: IrExprNode, ret: String, locals: BackendLocals) -> String {
    match expr_node_child_at(nodes, node, 0) {
        Some(scrutinee) => match expr_node_child_at(nodes, scrutinee, 0) {
            Some(vec_child) => match expr_node_child_at(nodes, scrutinee, 1) {
                Some(index_child) => match result_match_node_body_node_for_variant(nodes, node, "Some") {
                    Some(some_body) => match result_match_node_body_node_for_variant(nodes, node, "None") {
                        Some(none_body) => if true {
                            let prefix = llvm_node_prefix(scrutinee.node);
                            let some_label = concat2("option.match.some.", string.int_to_string(node.node.value));
                            let none_label = concat2("option.match.none.", string.int_to_string(node.node.value));
                            let end_label = concat2("option.match.end.", string.int_to_string(node.node.value));
                            let out_slot = llvm_local(llvm_node_prefix(node.node), ".return.slot");
                            let payload_type_name = generic_arg_at(vec_get_node_type_name(program, function_value, nodes, scrutinee, locals), 0);
                            let payload_locals = push_option_payload_local(program, locals, option_match_payload_name_from_node(node), payload_type_name, vec_get_loaded_name(prefix));
                            let mut parts: Vec[String] = vec.new_vec();
                            parts = vec.push(parts, emit_value_node(program, function_value, nodes, vec_child, locals));
                            parts = vec.push(parts, emit_value_node(program, function_value, nodes, index_child, locals));
                            parts = vec.push(parts, emit_vec_get_probe(prefix, value_node_llvm_type(program, function_value, nodes, vec_child, locals), llvm_payload_slot_type(program, payload_type_name), node_value_name(program, function_value, nodes, vec_child, locals), node_value_name(program, function_value, nodes, index_child, locals)));
                            parts = vec.push(parts, "  ");
                            parts = vec.push(parts, out_slot);
                            parts = vec.push(parts, " = alloca ");
                            parts = vec.push(parts, ret);
                            parts = vec.push(parts, "\n  br i1 ");
                            parts = vec.push(parts, vec_get_found_bool_name(prefix));
                            parts = vec.push(parts, ", label %");
                            parts = vec.push(parts, some_label);
                            parts = vec.push(parts, ", label %");
                            parts = vec.push(parts, none_label);
                            parts = vec.push(parts, "\n");
                            parts = vec.push(parts, some_label);
                            parts = vec.push(parts, ":\n");
                            parts = vec.push(parts, emit_branch_value_store(program, function_value, nodes, some_body, ret, out_slot, payload_locals, end_label));
