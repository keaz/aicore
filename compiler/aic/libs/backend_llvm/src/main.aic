fn string_join_node_can_emit(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], node: IrExprNode, locals: BackendLocals) -> Bool {
    if !is_string_join_intrinsic_name(node.name) || node.direct_child_count != 2 {
        false
    } else {
        match expr_node_child_at(nodes, node, 0) {
            Some(parts_child) => match expr_node_child_at(nodes, node, 1) {
                Some(separator_child) => if true {
                    let parts_type = node_type_name(program, function_value, nodes, parts_child, locals);
                    base_type_name_text(parts_type) == "Vec"
                        && generic_arg_at(parts_type, 0) == "String"
                        && value_node_can_emit(program, function_value, nodes, parts_child, locals)
                        && value_node_llvm_type(program, function_value, nodes, parts_child, locals) == "{ i64, i64, i64 }"
                        && string_call_child_can_emit(program, function_value, nodes, separator_child, locals)
                } else { false },
                None => false,
            },
            None => false,
        }
    }
}

