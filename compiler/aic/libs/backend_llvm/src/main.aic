    match expr_node_child_at(nodes, node, 0) {
        Some(condition) => match expr_node_child_at(nodes, node, 1) {
            Some(then_block) => match expr_node_child_at(nodes, node, 2) {
                Some(else_block) => if true {
                    let then_label = concat2("if.stmt.then.", string.int_to_string(node.node.value));
                    let else_label = concat2("if.stmt.else.", string.int_to_string(node.node.value));
                    let end_label = concat2("if.stmt.end.", string.int_to_string(node.node.value));
                    let mut parts: Vec[String] = vec.new_vec();
                    parts = vec.push(parts, emit_bool_node_value(program, function_value, nodes, condition, locals));
                    parts = vec.push(parts, "  br i1 ");
                    parts = vec.push(parts, bool_node_value_name_with_locals(function_value, locals, condition));
                    parts = vec.push(parts, ", label %");
                    parts = vec.push(parts, then_label);
                    parts = vec.push(parts, ", label %");
                    parts = vec.push(parts, else_label);
                    parts = vec.push(parts, "\n");
                    parts = vec.push(parts, then_label);
                    parts = vec.push(parts, ":\n");
                    parts = vec.push(parts, emit_unit_loop_statement_branch_node(program, function_value, nodes, then_block, locals, continue_label, break_label, end_label));
                    parts = vec.push(parts, else_label);
                    parts = vec.push(parts, ":\n");
                    parts = vec.push(parts, emit_unit_loop_statement_branch_node(program, function_value, nodes, else_block, locals, continue_label, break_label, end_label));
                    parts = vec.push(parts, end_label);
                    parts = vec.push(parts, ":\n");
                    string.join(parts, "")
                } else { "" },
                None => "",
            },
            None => "",
        },
        None => "",
    }
}

fn emit_if_expr_loop_statement(program: IrProgram, function_value: IrFunctionDef, expr: IrExpr, locals: BackendLocals, continue_label: String, break_label: String) -> String {
    match direct_expr_child_at(expr.nodes, 0) {
        Some(condition) => match direct_expr_child_at(expr.nodes, 1) {
            Some(then_block) => match direct_expr_child_at(expr.nodes, 2) {
                Some(else_block) => if true {
                    let then_label = concat2("if.stmt.then.", string.int_to_string(expr.node.value));
                    let else_label = concat2("if.stmt.else.", string.int_to_string(expr.node.value));
                    let end_label = concat2("if.stmt.end.", string.int_to_string(expr.node.value));
                    let mut parts: Vec[String] = vec.new_vec();
                    parts = vec.push(parts, emit_bool_node_value(program, function_value, expr.nodes, condition, locals));
                    parts = vec.push(parts, "  br i1 ");
                    parts = vec.push(parts, bool_node_value_name_with_locals(function_value, locals, condition));
                    parts = vec.push(parts, ", label %");
                    parts = vec.push(parts, then_label);
                    parts = vec.push(parts, ", label %");
                    parts = vec.push(parts, else_label);
                    parts = vec.push(parts, "\n");
                    parts = vec.push(parts, then_label);
                    parts = vec.push(parts, ":\n");
                    parts = vec.push(parts, emit_unit_loop_statement_branch_node(program, function_value, expr.nodes, then_block, locals, continue_label, break_label, end_label));
                    parts = vec.push(parts, else_label);
                    parts = vec.push(parts, ":\n");
                    parts = vec.push(parts, emit_unit_loop_statement_branch_node(program, function_value, expr.nodes, else_block, locals, continue_label, break_label, end_label));
                    parts = vec.push(parts, end_label);
                    parts = vec.push(parts, ":\n");
                    string.join(parts, "")
                } else { "" },
                None => "",
            },
            None => "",
        },
        None => "",
    }
}

fn emit_expr_node_statement(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], node: IrExprNode, locals: BackendLocals) -> String {
    match node.kind {
        IrCallExpr => if call_target_return_type(program, node.name) == "void" {
            emit_void_call_node_statement(program, function_value, nodes, node, locals)
        } else if fs_bool_node_can_emit(program, function_value, nodes, node, locals) {
            emit_discard_fs_bool_node_statement(program, function_value, nodes, node, locals)
        } else {
            ""
        },
        IrIfExpr => emit_if_node_statement(program, function_value, nodes, node, locals),
        IrWhileExpr => emit_while_node_statement(program, function_value, nodes, node, locals),
        IrLoopExpr => emit_loop_node_statement(program, function_value, nodes, node, locals),
        IrForExpr => emit_for_node_statement(program, function_value, nodes, node, locals),
        IrMatchExpr => if option_vec_get_match_node_can_emit_statement(program, function_value, nodes, node, locals) {
            emit_option_vec_get_match_node_statement(program, function_value, nodes, node, locals)
        } else if option_match_node_can_emit_statement(program, function_value, nodes, node, locals) {
            emit_option_match_node_statement(program, function_value, nodes, node, locals)
        } else if enum_match_node_can_emit_statement(program, function_value, nodes, node, locals) {
            emit_enum_match_node_statement(program, function_value, nodes, node, locals)
        } else {
            ""
        },
        _ => "",
    }
}

fn emit_binary_expr_value(program: IrProgram, function_value: IrFunctionDef, expr: IrExpr, locals: BackendLocals) -> String {
    match direct_expr_child_at(expr.nodes, 0) {
        Some(left) => match direct_expr_child_at(expr.nodes, 1) {
            Some(right) => if true {
                let ty = value_node_llvm_type(program, function_value, expr.nodes, left, locals);
                let mut parts: Vec[String] = vec.new_vec();
                if binary_logical_op_can_emit(expr.op) {
                    parts = vec.push(parts, emit_bool_node_value(program, function_value, expr.nodes, left, locals));
                    parts = vec.push(parts, emit_bool_node_value(program, function_value, expr.nodes, right, locals));
                    parts = vec.push(parts, "  ");
                    parts = vec.push(parts, llvm_expr_value_local(expr));
                    parts = vec.push(parts, " = ");
                    parts = vec.push(parts, bool_llvm_op(expr.op));
                    parts = vec.push(parts, " i1 ");
                    parts = vec.push(parts, bool_node_value_name_with_locals(function_value, locals, left));
                    parts = vec.push(parts, ", ");
                    parts = vec.push(parts, bool_node_value_name_with_locals(function_value, locals, right));
                    parts = vec.push(parts, "\n");
                } else if binary_compare_op_can_emit(expr.op) {
                    parts = vec.push(parts, emit_compare_expr_value(program, function_value, expr, locals));
                } else {
                    parts = vec.push(parts, emit_value_node(program, function_value, expr.nodes, left, locals));
                    parts = vec.push(parts, emit_value_node(program, function_value, expr.nodes, right, locals));
                    parts = vec.push(parts, "  ");
                    parts = vec.push(parts, llvm_expr_value_local(expr));
                    parts = vec.push(parts, " = ");
                    parts = vec.push(parts, binary_llvm_op(expr.op));
                    parts = vec.push(parts, " ");
                    parts = vec.push(parts, ty);
                    parts = vec.push(parts, " ");
                    parts = vec.push(parts, node_value_name(program, function_value, expr.nodes, left, locals));
                    parts = vec.push(parts, ", ");
                    parts = vec.push(parts, node_value_name(program, function_value, expr.nodes, right, locals));
                    parts = vec.push(parts, "\n");
                };
                string.join(parts, "")
            } else { "" },
            None => "",
        },
        None => "",
    }
}

fn emit_expr_value(program: IrProgram, function_value: IrFunctionDef, expr: IrExpr, locals: BackendLocals) -> String {
    match expr.kind {
        IrNameExpr => emit_load_name_expr_value(program, function_value, expr, locals),
        IrStringExpr => emit_string_literal_value(llvm_string_global_name(function_value.name), expr.text, llvm_expr_prefix(expr.node)),
        IrFieldAccessExpr => emit_field_access_expr_value(program, function_value, expr, locals),
        IrBinaryExpr => emit_binary_expr_value(program, function_value, expr, locals),
        IrUnaryExpr => if expr.op == "-" {
            emit_unary_int_expr_value(program, function_value, expr, locals)
        } else {
            emit_unary_bool_expr_value(program, function_value, expr, locals)
        },
        IrIfExpr => emit_if_expr_value(program, function_value, expr, locals),
        IrCallExpr => if is_string_bool_intrinsic_name(expr.name) {
            emit_string_bool_expr_value(program, function_value, expr, locals)
        } else if is_string_len_intrinsic_name(expr.name) {
            emit_string_len_expr_value(program, function_value, expr, locals)
        } else if is_vec_len_intrinsic_name(expr.name) {
            emit_vec_len_expr_value(program, function_value, expr, locals)
        } else if is_string_slice_intrinsic_name(expr.name) {
            emit_string_slice_expr_value(program, function_value, expr, locals)
        } else if expr.name == "string.replace" {
            emit_string_replace_expr_value(program, function_value, expr, locals)
        } else if is_string_join_intrinsic_name(expr.name) {
            emit_string_join_expr_value(program, function_value, expr, locals)
        } else if is_string_split_intrinsic_name(expr.name) {
            emit_string_split_expr_value(program, function_value, expr, locals)
        } else if is_string_trim_intrinsic_name(expr.name) {
            emit_string_trim_expr_value(program, function_value, expr, locals)
        } else if is_string_char_at_intrinsic_name(expr.name) {
            emit_string_char_at_expr_value(program, function_value, expr, locals)
        } else if is_string_int_to_string_intrinsic_name(expr.name) {
            emit_string_int_to_string_expr_value(program, function_value, expr, locals)
        } else if expr.name == "vec.new_vec" {
            emit_empty_vec_value(llvm_expr_prefix(expr.node), vec_new_vec_expr_llvm_type(program, expr))
        } else if expr.name == "vec.push" {
            emit_vec_push_expr_value(program, function_value, expr, locals)
        } else if is_vec_get_intrinsic_name(expr.name) {
            emit_vec_get_expr_value(program, function_value, expr, locals)
        } else if enum_variant_constructor_expr_can_emit(program, expr, function_value, locals) {
            emit_enum_variant_constructor_expr_value(program, function_value, expr, locals)
        } else if call_target_return_type(program, expr.name) == "%aic.String" {
            emit_string_direct_call_expr_value(program, function_value, expr, locals)
        } else {
            let mut parts: Vec[String] = vec.new_vec();
            parts = vec.push(parts, emit_call_arg_values(program, function_value, expr.nodes, expr.name, locals));
            parts = vec.push(parts, "  ");
            parts = vec.push(parts, llvm_expr_value_local(expr));
            parts = vec.push(parts, " = call ");
            parts = vec.push(parts, call_target_return_type(program, expr.name));
            parts = vec.push(parts, " @");
            parts = vec.push(parts, backend_mangle_symbol(expr.name));
            parts = vec.push(parts, "(");
            parts = vec.push(parts, emit_call_args(program, function_value, expr.nodes, expr.name, locals));
            parts = vec.push(parts, ")\n");
            string.join(parts, "")
        },
        IrMatchExpr => if option_vec_get_match_expr_type_name(program, expr, function_value, locals) != "" {
            emit_option_vec_get_match_expr_value(program, function_value, expr, locals)
        } else if option_match_expr_type_name(program, expr, function_value, locals) != "" {
            emit_option_match_expr_value(program, function_value, expr, locals)
        } else if result_string_match_expr_can_emit(program, expr, function_value, locals) {
            emit_result_string_match_expr_value(program, function_value, expr, locals)
        } else if enum_match_expr_type_name(program, expr, function_value, locals) != "" {
            emit_enum_match_expr_value(program, function_value, expr, locals)
        } else if enum_bool_match_expr_can_emit(program, expr, function_value, locals) {
            emit_enum_bool_match_expr_value(program, function_value, expr, locals)
        } else {
            emit_result_string_match_expr_value(program, function_value, expr, locals)
        },
        IrStructLiteralExpr => emit_struct_literal_expr_value(program, function_value, expr, locals, value_expr_llvm_type(program, expr, function_value, locals)),
        IrLoopExpr => emit_loop_expr_value(program, function_value, expr, locals),
        _ => "",
    }
}

fn emit_statement_with_locals(program: IrProgram, function_value: IrFunctionDef, statement: IrStatement, locals: BackendLocals) -> BackendStatementEmission {
    match statement.kind {
        IrLetStatement => match statement.expr {
            Some(expr) => if true {
                let text = emit_let_statement_expr_value(program, function_value, statement, expr, locals);
                if statement.mutable {
                    let llvm_type = let_statement_expr_llvm_type(program, function_value, statement, expr, locals);
                    let storage_name = mutable_storage_name(statement.name, expr.node);
                    let initial_value = if expected_enum_constructor_expr_can_emit(program, function_value, expr, locals, statement_declared_type_name(program, statement)) {
                        expected_enum_constructor_expr_value_name(expr)
                    } else {
                        stored_expr_value_name(program, function_value, expr, locals)
                    };
                    let mut parts: Vec[String] = vec.new_vec();
                    parts = vec.push(parts, text);
                    parts = vec.push(parts, emit_alloca_for_local(llvm_type, storage_name));
                    parts = vec.push(parts, emit_store_to_local(llvm_type, initial_value, storage_name));
                    backend_statement_emission(string.join(parts, ""), backend_locals_push(locals, local_for_statement_expr_with_mutability(program, function_value, statement, expr, locals, statement.name, true)))
                } else {
                    backend_statement_emission(text, backend_locals_push(locals, local_for_statement_expr_with_mutability(program, function_value, statement, expr, locals, statement.name, false)))
                }
            } else { backend_statement_emission("", locals) },
            None => backend_statement_emission("", locals),
        },
        IrAssignStatement => match statement.expr {
            Some(expr) => backend_statement_emission(emit_assign_expr_statement(program, function_value, expr, locals, statement.target), locals),
            None => backend_statement_emission("", locals),
        },
        IrExprStatement => match statement.expr {
            Some(expr) => match expr.kind {
                IrCallExpr => if call_target_return_type(program, expr.name) == "void" {
                    backend_statement_emission(emit_void_call_expr_statement(program, function_value, expr, locals), locals)
                } else if fs_bool_expr_can_emit(program, function_value, expr, locals) {
                    backend_statement_emission(emit_discard_fs_bool_expr_statement(program, function_value, expr, locals), locals)
                } else {
                    backend_statement_emission("", locals)
                },
                IrIfExpr => backend_statement_emission(emit_if_expr_statement(program, function_value, expr, locals), locals),
                IrWhileExpr => backend_statement_emission(emit_while_expr_statement(program, function_value, expr, locals), locals),
                IrLoopExpr => backend_statement_emission(emit_loop_expr_statement(program, function_value, expr, locals), locals),
                IrForExpr => backend_statement_emission(emit_for_expr_statement(program, function_value, expr, locals), locals),
                IrMatchExpr => if option_vec_get_match_expr_can_emit_statement(program, expr, function_value, locals) {
                    backend_statement_emission(emit_option_vec_get_match_expr_statement(program, function_value, expr, locals), locals)
                } else if option_match_expr_can_emit_statement(program, expr, function_value, locals) {
                    backend_statement_emission(emit_option_match_expr_statement(program, function_value, expr, locals), locals)
                } else if enum_match_expr_can_emit_statement(program, expr, function_value, locals) {
                    backend_statement_emission(emit_enum_match_expr_statement(program, function_value, expr, locals), locals)
                } else {
                    backend_statement_emission("", locals)
                },
                _ => backend_statement_emission("", locals),
            },
            None => backend_statement_emission("", locals),
        },
        IrReturnStatement => match statement.expr {
            Some(expr) => backend_statement_emission(emit_return_expr(program, function_value, expr, locals, llvm_type_for_id(program, function_value.return_type)), locals),
            None => if llvm_type_for_id(program, function_value.return_type) == "void" {
                backend_statement_emission("  ret void\n", locals)
            } else {
                backend_statement_emission("", locals)
            },
        },
        _ => backend_statement_emission("", locals),
    }
}

fn emit_statement(program: IrProgram, function_value: IrFunctionDef, statement: IrStatement) -> String {
    match statement.kind {
        IrExprStatement => match statement.expr {
            Some(expr) => match expr.kind {
                IrCallExpr => if call_target_return_type(program, expr.name) == "void" {
                    emit_void_call_expr_statement(program, function_value, expr, backend_empty_locals())
                } else if fs_bool_expr_can_emit(program, function_value, expr, backend_empty_locals()) {
                    emit_discard_fs_bool_expr_statement(program, function_value, expr, backend_empty_locals())
                } else {
                    ""
                },
                IrIfExpr => emit_if_expr_statement(program, function_value, expr, backend_empty_locals()),
                IrWhileExpr => emit_while_expr_statement(program, function_value, expr, backend_empty_locals()),
                IrLoopExpr => emit_loop_expr_statement(program, function_value, expr, backend_empty_locals()),
                IrForExpr => emit_for_expr_statement(program, function_value, expr, backend_empty_locals()),
                IrMatchExpr => if option_vec_get_match_expr_can_emit_statement(program, expr, function_value, backend_empty_locals()) {
                    emit_option_vec_get_match_expr_statement(program, function_value, expr, backend_empty_locals())
                } else if option_match_expr_can_emit_statement(program, expr, function_value, backend_empty_locals()) {
                    emit_option_match_expr_statement(program, function_value, expr, backend_empty_locals())
                } else if enum_match_expr_can_emit_statement(program, expr, function_value, backend_empty_locals()) {
                    emit_enum_match_expr_statement(program, function_value, expr, backend_empty_locals())
                } else {
                    ""
                },
                _ => "",
            },
            None => "",
        },
        _ => "",
    }
}

fn emit_block_statements(program: IrProgram, function_value: IrFunctionDef) -> BackendStatementEmission {
    let mut parts: Vec[String] = vec.new_vec();
    let mut locals: BackendLocals = backend_param_locals(program, function_value);
    let mut index = 0;
    let mut done = false;
    while !done && index < vec.vec_len(function_value.body.statements) {
        match vec.get(function_value.body.statements, index) {
            Some(statement) => if true {
                let checked = statement_check_with_locals(program, function_value, statement, locals);
                if checked.ok {
                    let emitted = emit_statement_with_locals(program, function_value, statement, locals);
                    parts = vec.push(parts, emitted.text);
                    locals = emitted.locals;
                    if statement_is_return(statement) {
                        done = true;
                    } else {
                        ()
                    };
                } else {
                    ()
                };
                ()
            } else {
                ()
            },
            None => (),
        };
        index = index + 1;
    };
    backend_statement_emission(string.join(parts, ""), locals)
}

fn emit_return_expr(program: IrProgram, function_value: IrFunctionDef, expr: IrExpr, locals: BackendLocals, ret: String) -> String {
    let mut parts: Vec[String] = vec.new_vec();
    match expr.kind {
        IrIntExpr => if true {
            parts = vec.push(parts, "  ret ");
            parts = vec.push(parts, ret);
            parts = vec.push(parts, " ");
            parts = vec.push(parts, literal_text_or_name(expr.text, expr.name));
            parts = vec.push(parts, "\n");
            ()
        } else { () },
        IrBoolExpr => if true {
            parts = vec.push(parts, "  ret ");
            parts = vec.push(parts, ret);
            parts = vec.push(parts, " ");
            parts = vec.push(parts, bool_literal_llvm_text(expr.text, expr.name));
            parts = vec.push(parts, "\n");
            ()
        } else { () },
        IrStringExpr => if true {
            let payload = string_literal_payload(expr.text);
            parts = vec.push(parts, "  %str.ptr = getelementptr inbounds [");
            parts = vec.push(parts, string.int_to_string(string.len(payload)));
            parts = vec.push(parts, " x i8], [");
            parts = vec.push(parts, string.int_to_string(string.len(payload)));
            parts = vec.push(parts, " x i8]* ");
            parts = vec.push(parts, llvm_string_global_name(function_value.name));
            parts = vec.push(parts, ", i64 0, i64 0\n");
            parts = vec.push(parts, "  %str.0 = insertvalue %aic.String undef, i8* %str.ptr, 0\n");
            parts = vec.push(parts, "  %str.1 = insertvalue %aic.String %str.0, i64 ");
            parts = vec.push(parts, string.int_to_string(string.len(payload)));
            parts = vec.push(parts, ", 1\n");
            parts = vec.push(parts, "  %str.2 = insertvalue %aic.String %str.1, i64 ");
            parts = vec.push(parts, string.int_to_string(string.len(payload)));
            parts = vec.push(parts, ", 2\n");
            parts = vec.push(parts, "  ret ");
            parts = vec.push(parts, ret);
            parts = vec.push(parts, " %str.2\n");
            ()
        } else { () },
        IrUnitExpr => if true {
            parts = vec.push(parts, "  ret void\n");
            ()
        } else { () },
        IrNameExpr => if true {
            let value_name = value_name_for_name(function_value, locals, expr.text);
            if name_uses_storage(locals, expr.text) {
                parts = vec.push(parts, emit_load_name_expr_value(program, function_value, expr, locals));
                parts = vec.push(parts, "  ret ");
                parts = vec.push(parts, ret);
                parts = vec.push(parts, " ");
                parts = vec.push(parts, loaded_expr_name(expr));
                parts = vec.push(parts, "\n");
            } else if value_name == value_name_for_param(function_value, expr.text) {
                parts = vec.push(parts, emit_return_name_value(program, function_value, expr.text, ret, llvm_expr_prefix(expr.node)));
            } else {
                parts = vec.push(parts, "  ret ");
                parts = vec.push(parts, ret);
                parts = vec.push(parts, " ");
                parts = vec.push(parts, value_name);
                parts = vec.push(parts, "\n");
            };
            ()
        } else { () },
        IrUnaryExpr => if true {
            if expr.op == "-" {
                parts = vec.push(parts, emit_unary_int_expr_value(program, function_value, expr, locals));
            } else {
                parts = vec.push(parts, emit_unary_bool_expr_value(program, function_value, expr, locals));
            };
            parts = vec.push(parts, "  ret ");
            parts = vec.push(parts, ret);
            parts = vec.push(parts, " ");
            parts = vec.push(parts, llvm_expr_value_local(expr));
            parts = vec.push(parts, "\n");
            ()
        } else { () },
        IrFieldAccessExpr => if true {
            parts = vec.push(parts, emit_field_access_expr_value(program, function_value, expr, locals));
            parts = vec.push(parts, "  ret ");
            parts = vec.push(parts, ret);
            parts = vec.push(parts, " ");
            parts = vec.push(parts, llvm_expr_value_local(expr));
            parts = vec.push(parts, "\n");
            ()
        } else { () },
        IrBinaryExpr => if true {
            match direct_expr_child_at(expr.nodes, 0) {
                Some(left) => match direct_expr_child_at(expr.nodes, 1) {
                    Some(right) => if binary_arithmetic_op_can_emit(expr.op) && simple_node_can_emit_with_locals(left, function_value, locals) && simple_node_can_emit_with_locals(right, function_value, locals) {
                        parts = vec.push(parts, "  %ret = ");
                        parts = vec.push(parts, binary_llvm_op(expr.op));
                        parts = vec.push(parts, " ");
                        parts = vec.push(parts, ret);
                        parts = vec.push(parts, " ");
                        parts = vec.push(parts, simple_node_llvm_value_with_locals(left, function_value, locals));
                        parts = vec.push(parts, ", ");
                        parts = vec.push(parts, simple_node_llvm_value_with_locals(right, function_value, locals));
                        parts = vec.push(parts, "\n  ret ");
                        parts = vec.push(parts, ret);
                        parts = vec.push(parts, " %ret\n");
                        ()
                    } else {
                        parts = vec.push(parts, emit_binary_expr_value(program, function_value, expr, locals));
                        parts = vec.push(parts, "  ret ");
                        parts = vec.push(parts, ret);
                        parts = vec.push(parts, " ");
                        parts = vec.push(parts, llvm_expr_value_local(expr));
                        parts = vec.push(parts, "\n");
                        ()
                    },
                    None => (),
                },
                None => (),
            };
            ()
        } else { () },
        IrCallExpr => if true {
            if expected_enum_constructor_expr_can_emit(program, function_value, expr, locals, function_result_type_name(program, function_value)) {
                parts = vec.push(parts, emit_expected_enum_constructor_expr_value(program, function_value, expr, locals, ret, function_result_type_name(program, function_value)));
                parts = vec.push(parts, "  ret ");
                parts = vec.push(parts, ret);
                parts = vec.push(parts, " ");
                parts = vec.push(parts, expected_enum_constructor_expr_value_name(expr));
                parts = vec.push(parts, "\n");
            } else if expr.name == "Ok" || expr.name == "Err" {
                match direct_expr_child_at(expr.nodes, 0) {
                    Some(payload) => if true {
                        let result_name = function_result_type_name(program, function_value);
                        let payload_name = result_constructor_payload_type_name(result_name, expr.name);
                        let payload_ty = llvm_payload_slot_type(program, payload_name);
                        parts = vec.push(parts, emit_result_payload_node_value(program, function_value, expr.nodes, payload, locals, payload_ty));
                        parts = vec.push(parts, "  ");
                        parts = vec.push(parts, llvm_local(llvm_expr_prefix(expr.node), ".result.0"));
                        parts = vec.push(parts, " = insertvalue ");
                        parts = vec.push(parts, ret);
                        parts = vec.push(parts, " undef, i32 ");
                        parts = vec.push(parts, result_constructor_tag(expr.name));
                        parts = vec.push(parts, ", 0\n  ");
                        parts = vec.push(parts, llvm_local(llvm_expr_prefix(expr.node), ".result.1"));
                        parts = vec.push(parts, " = insertvalue ");
                        parts = vec.push(parts, ret);
                        parts = vec.push(parts, " ");
                        parts = vec.push(parts, llvm_local(llvm_expr_prefix(expr.node), ".result.0"));
                        parts = vec.push(parts, ", ");
                        parts = vec.push(parts, payload_ty);
                        parts = vec.push(parts, " ");
                        parts = vec.push(parts, result_payload_node_value_name(program, function_value, expr.nodes, payload, locals, payload_ty));
                        parts = vec.push(parts, ", ");
                        parts = vec.push(parts, string.int_to_string(result_constructor_slot_index(expr.name)));
                        parts = vec.push(parts, "\n  ret ");
                        parts = vec.push(parts, ret);
                        parts = vec.push(parts, " ");
                        parts = vec.push(parts, llvm_local(llvm_expr_prefix(expr.node), ".result.1"));
                        parts = vec.push(parts, "\n");
                        ()
                    } else { () },
                    None => (),
                };
            } else if is_string_bool_intrinsic_name(expr.name) {
                parts = vec.push(parts, emit_string_bool_expr_value(program, function_value, expr, locals));
                parts = vec.push(parts, "  ret ");
                parts = vec.push(parts, ret);
                parts = vec.push(parts, " ");
                parts = vec.push(parts, llvm_expr_value_local(expr));
                parts = vec.push(parts, "\n");
            } else if is_io_print_intrinsic_name(expr.name) {
                parts = vec.push(parts, emit_io_print_expr_return(program, function_value, expr, locals));
            } else if is_fs_string_result_intrinsic_name(expr.name) {
                parts = vec.push(parts, emit_fs_string_result_expr_return(program, function_value, expr, locals, ret));
            } else if is_fs_bool_result_intrinsic_name(expr.name) {
                parts = vec.push(parts, emit_fs_bool_result_expr_return(program, function_value, expr, locals, ret));
            } else if expr.name == "string.replace" {
                parts = vec.push(parts, emit_string_replace_expr_value(program, function_value, expr, locals));
                parts = vec.push(parts, "  ret ");
                parts = vec.push(parts, ret);
                parts = vec.push(parts, " ");
                parts = vec.push(parts, llvm_expr_value_local(expr));
                parts = vec.push(parts, "\n");
            } else if is_string_join_intrinsic_name(expr.name) {
                parts = vec.push(parts, emit_string_join_expr_value(program, function_value, expr, locals));
                parts = vec.push(parts, "  ret ");
                parts = vec.push(parts, ret);
                parts = vec.push(parts, " ");
                parts = vec.push(parts, llvm_expr_value_local(expr));
                parts = vec.push(parts, "\n");
            } else if is_string_split_intrinsic_name(expr.name) {
                parts = vec.push(parts, emit_string_split_expr_value(program, function_value, expr, locals));
                parts = vec.push(parts, "  ret ");
                parts = vec.push(parts, ret);
                parts = vec.push(parts, " ");
                parts = vec.push(parts, llvm_expr_value_local(expr));
                parts = vec.push(parts, "\n");
            } else if is_string_trim_intrinsic_name(expr.name) {
                parts = vec.push(parts, emit_string_trim_expr_value(program, function_value, expr, locals));
                parts = vec.push(parts, "  ret ");
                parts = vec.push(parts, ret);
                parts = vec.push(parts, " ");
                parts = vec.push(parts, llvm_expr_value_local(expr));
                parts = vec.push(parts, "\n");
            } else if is_string_char_at_intrinsic_name(expr.name) {
                parts = vec.push(parts, emit_string_char_at_expr_value(program, function_value, expr, locals));
                parts = vec.push(parts, "  ret ");
                parts = vec.push(parts, ret);
                parts = vec.push(parts, " ");
                parts = vec.push(parts, llvm_expr_value_local(expr));
                parts = vec.push(parts, "\n");
            } else if is_string_int_to_string_intrinsic_name(expr.name) {
                parts = vec.push(parts, emit_string_int_to_string_expr_value(program, function_value, expr, locals));
                parts = vec.push(parts, "  ret ");
                parts = vec.push(parts, ret);
                parts = vec.push(parts, " ");
                parts = vec.push(parts, llvm_expr_value_local(expr));
                parts = vec.push(parts, "\n");
            } else if is_string_len_intrinsic_name(expr.name) {
                parts = vec.push(parts, emit_string_len_expr_value(program, function_value, expr, locals));
                parts = vec.push(parts, "  ret ");
                parts = vec.push(parts, ret);
                parts = vec.push(parts, " ");
                parts = vec.push(parts, llvm_expr_value_local(expr));
                parts = vec.push(parts, "\n");
            } else if is_vec_len_intrinsic_name(expr.name) {
                parts = vec.push(parts, emit_vec_len_expr_value(program, function_value, expr, locals));
                parts = vec.push(parts, "  ret ");
                parts = vec.push(parts, ret);
                parts = vec.push(parts, " ");
                parts = vec.push(parts, llvm_expr_value_local(expr));
                parts = vec.push(parts, "\n");
            } else if is_string_slice_intrinsic_name(expr.name) {
                parts = vec.push(parts, emit_string_slice_expr_value(program, function_value, expr, locals));
                parts = vec.push(parts, "  ret ");
                parts = vec.push(parts, ret);
                parts = vec.push(parts, " ");
                parts = vec.push(parts, llvm_expr_value_local(expr));
                parts = vec.push(parts, "\n");
            } else if expr.name == "vec.new_vec" {
                parts = vec.push(parts, emit_empty_vec_value(llvm_expr_prefix(expr.node), ret));
                parts = vec.push(parts, "  ret ");
                parts = vec.push(parts, ret);
                parts = vec.push(parts, " ");
                parts = vec.push(parts, llvm_expr_value_local(expr));
                parts = vec.push(parts, "\n");
            } else if expr.name == "vec.push" {
                parts = vec.push(parts, emit_vec_push_expr_value(program, function_value, expr, locals));
                parts = vec.push(parts, "  ret ");
                parts = vec.push(parts, ret);
                parts = vec.push(parts, " ");
                parts = vec.push(parts, llvm_expr_value_local(expr));
                parts = vec.push(parts, "\n");
            } else if is_vec_get_intrinsic_name(expr.name) {
                parts = vec.push(parts, emit_vec_get_expr_value(program, function_value, expr, locals));
                parts = vec.push(parts, "  ret ");
                parts = vec.push(parts, ret);
                parts = vec.push(parts, " ");
                parts = vec.push(parts, llvm_expr_value_local(expr));
                parts = vec.push(parts, "\n");
            } else if enum_variant_constructor_expr_can_emit(program, expr, function_value, locals) {
                parts = vec.push(parts, emit_enum_variant_constructor_expr_value(program, function_value, expr, locals));
                parts = vec.push(parts, "  ret ");
                parts = vec.push(parts, ret);
                parts = vec.push(parts, " ");
                parts = vec.push(parts, llvm_expr_value_local(expr));
                parts = vec.push(parts, "\n");
            } else {
                let call_ret = call_target_return_type(program, expr.name);
                if call_ret == "%aic.String" {
                    parts = vec.push(parts, emit_string_direct_call_expr_value(program, function_value, expr, locals));
                    parts = vec.push(parts, "  ret ");
                    parts = vec.push(parts, ret);
                    parts = vec.push(parts, " ");
                    parts = vec.push(parts, llvm_expr_value_local(expr));
                    parts = vec.push(parts, "\n");
                } else {
                    parts = vec.push(parts, emit_call_arg_values(program, function_value, expr.nodes, expr.name, locals));
                    parts = vec.push(parts, "  %ret = call ");
                    parts = vec.push(parts, call_ret);
                    parts = vec.push(parts, " @");
                    parts = vec.push(parts, backend_mangle_symbol(expr.name));
                    parts = vec.push(parts, "(");
                    parts = vec.push(parts, emit_call_args(program, function_value, expr.nodes, expr.name, locals));
                    parts = vec.push(parts, ")\n  ret ");
                    parts = vec.push(parts, ret);
                    parts = vec.push(parts, " %ret\n");
                };
            };
            ()
        } else { () },
        IrIfExpr => if true {
            parts = vec.push(parts, emit_if_expr_return(program, function_value, expr, ret, locals));
            ()
        } else { () },
        IrLoopExpr => if true {
            parts = vec.push(parts, emit_loop_expr_value(program, function_value, expr, locals));
            parts = vec.push(parts, "  ret ");
            parts = vec.push(parts, ret);
            parts = vec.push(parts, " ");
            parts = vec.push(parts, llvm_expr_value_local(expr));
            parts = vec.push(parts, "\n");
            ()
        } else { () },
        IrMatchExpr => if true {
            if direct_result_match_expr_can_emit_result_return(program, expr, function_value, ret, locals) {
                parts = vec.push(parts, emit_direct_result_match_expr_result_return(program, function_value, expr, ret, locals));
            } else if result_match_expr_can_emit_return(program, expr, function_value, ret, locals) {
                parts = vec.push(parts, emit_result_match_expr_return(program, function_value, expr, ret, locals));
            } else if option_vec_get_match_expr_can_emit_return(program, expr, function_value, ret, locals) {
                parts = vec.push(parts, emit_option_vec_get_match_expr_return(program, function_value, expr, ret, locals));
            } else if option_match_expr_can_emit_return(program, expr, function_value, ret, locals) {
                parts = vec.push(parts, emit_option_match_expr_return(program, function_value, expr, ret, locals));
            } else if result_bool_match_expr_can_emit_return(program, expr, function_value, ret, locals) {
                parts = vec.push(parts, emit_result_bool_match_expr_return(program, function_value, expr, ret, locals));
            } else if fs_string_match_expr_can_emit_int_return(program, expr, function_value, ret, locals) {
                parts = vec.push(parts, emit_fs_string_match_expr_int_return(program, function_value, expr, ret, locals));
            } else if proc_run_match_expr_can_emit_int_return(program, expr, function_value, ret, locals) {
                parts = vec.push(parts, emit_proc_run_match_expr_int_return(program, function_value, expr, ret, locals));
            } else if direct_result_match_expr_can_emit_return(program, expr, function_value, ret, locals) {
                parts = vec.push(parts, emit_direct_result_match_expr_return(program, function_value, expr, ret, locals));
            } else if result_string_match_expr_can_emit(program, expr, function_value, locals) {
                parts = vec.push(parts, emit_result_string_match_expr_value(program, function_value, expr, locals));
                parts = vec.push(parts, "  ret ");
                parts = vec.push(parts, ret);
                parts = vec.push(parts, " ");
                parts = vec.push(parts, llvm_expr_value_local(expr));
                parts = vec.push(parts, "\n");
            } else if enum_bool_match_expr_can_emit_return(program, expr, function_value, ret, locals) {
                parts = vec.push(parts, emit_enum_bool_match_expr_return(program, function_value, expr, ret, locals));
            } else if ret == "i1" && enum_bool_match_expr_can_emit(program, expr, function_value, locals) {
                parts = vec.push(parts, emit_enum_bool_match_expr_value(program, function_value, expr, locals));
                parts = vec.push(parts, "  ret ");
                parts = vec.push(parts, ret);
                parts = vec.push(parts, " ");
                parts = vec.push(parts, llvm_expr_value_local(expr));
                parts = vec.push(parts, "\n");
            } else if env_arg_or_empty_expr_can_emit(program, expr, function_value) {
                parts = vec.push(parts, emit_env_arg_or_empty_return(program, function_value, expr));
            } else {
                let selected = static_match_body(expr);
                parts = vec.push(parts, "  ret ");
                parts = vec.push(parts, ret);
                parts = vec.push(parts, " ");
                if selected == "true" {
                    parts = vec.push(parts, "1");
                } else if selected == "false" {
                    parts = vec.push(parts, "0");
                } else {
                    parts = vec.push(parts, selected);
                };
                parts = vec.push(parts, "\n");
            };
            ()
        } else { () },
        IrStructLiteralExpr => if true {
            parts = vec.push(parts, emit_struct_literal_expr_value(program, function_value, expr, locals, ret));
            parts = vec.push(parts, "  ret ");
            parts = vec.push(parts, ret);
            parts = vec.push(parts, " ");
            parts = vec.push(parts, struct_literal_value_name(llvm_expr_prefix(expr.node), direct_expr_child_count(expr.nodes), ret));
            parts = vec.push(parts, "\n");
            ()
        } else { () },
        _ => (),
    };
    string.join(parts, "")
}

fn emit_function_llvm(program: IrProgram, function_value: IrFunctionDef) -> String {
    let ret = llvm_type_for_id(program, function_value.return_type);
    let name = backend_mangle_symbol(function_value.name);
    let params = llvm_param_list(program, function_value.params);
    let mut parts: Vec[String] = vec.new_vec();
    parts = vec.push(parts, "define ");
    parts = vec.push(parts, ret);
    parts = vec.push(parts, " @");
    parts = vec.push(parts, name);
    parts = vec.push(parts, "(");
    parts = vec.push(parts, params);
    parts = vec.push(parts, ") {\nentry:\n");
    let emitted_statements = emit_block_statements(program, function_value);
    parts = vec.push(parts, emitted_statements.text);
    if block_has_explicit_return(function_value.body) {
        ()
    } else {
        match function_value.body.tail_expr {
            Some(expr) => if true {
                parts = vec.push(parts, emit_return_expr(program, function_value, expr, emitted_statements.locals, ret));
                ()
            } else { () },
            None => if ret == "void" {
                parts = vec.push(parts, "  ret void\n");
            } else {
                ()
            },
        };
    };
    parts = vec.push(parts, "}\n");
    string.join(parts, "")
}

fn emit_entry_wrapper_call(program: IrProgram, function_value: IrFunctionDef) -> String {
    let ret = llvm_type_for_id(program, function_value.return_type);
    let type_name = type_name_for_id(program.types, function_value.return_type);
    let mut parts: Vec[String] = vec.new_vec();
    if ret == "void" {
        parts = vec.push(parts, "  call void @aic_main()\n");
        parts = vec.push(parts, "  ret i32 0\n");
    } else if ret == "i1" {
        parts = vec.push(parts, "  %aic.entry.result = call i1 @aic_main()\n");
        parts = vec.push(parts, "  %aic.entry.exit = zext i1 %aic.entry.result to i32\n");
        parts = vec.push(parts, "  ret i32 %aic.entry.exit\n");
    } else if ret == "i32" {
        parts = vec.push(parts, "  %aic.entry.result = call i32 @aic_main()\n");
        parts = vec.push(parts, "  ret i32 %aic.entry.result\n");
    } else if ret == "i64" {
        parts = vec.push(parts, "  %aic.entry.result = call i64 @aic_main()\n");
        parts = vec.push(parts, "  %aic.entry.exit = trunc i64 %aic.entry.result to i32\n");
        parts = vec.push(parts, "  ret i32 %aic.entry.exit\n");
    } else if ret == "i8" || ret == "i16" {
        let cast = if type_name_is_signed_integer(type_name) { "sext" } else { "zext" };
        parts = vec.push(parts, "  %aic.entry.result = call ");
        parts = vec.push(parts, ret);
        parts = vec.push(parts, " @aic_main()\n  %aic.entry.exit = ");
        parts = vec.push(parts, cast);
        parts = vec.push(parts, " ");
        parts = vec.push(parts, ret);
        parts = vec.push(parts, " %aic.entry.result to i32\n  ret i32 %aic.entry.exit\n");
    } else {
        ()
    };
    string.join(parts, "")
}

fn emit_entry_wrapper(program: IrProgram) -> String {
    match program_entry_function(program) {
        Some(function_value) => if entry_return_type_can_emit(program, function_value) {
            let mut parts: Vec[String] = vec.new_vec();
            parts = vec.push(parts, "define i32 @main(i32 %argc, i8** %argv) {\nentry:\n");
            parts = vec.push(parts, "  call void @aic_rt_stack_ensure_min(i64 67108864)\n");
            parts = vec.push(parts, "  call void @aic_rt_env_set_args(i32 %argc, i8** %argv)\n");
            parts = vec.push(parts, emit_entry_wrapper_call(program, function_value));
            parts = vec.push(parts, "}\n");
            string.join(parts, "")
        } else {
            ""
        },
        None => "",
    }
}

fn collect_backend_symbols(program: IrProgram) -> Vec[BackendSymbol] {
    let mut symbols: Vec[BackendSymbol] = vec.new_vec();
    let mut index = 0;
    while index < vec.vec_len(program.items) {
        match vec.get(program.items, index) {
            Some(item) => match item {
                IrFunctionItemValue(function_value) => if function_value.runtime_visible {
                    symbols = vec.push(symbols, backend_symbol(function_value.name, backend_mangle_symbol(function_value.name), "function", function_value.span));
                } else {
                    ()
                },
                IrStructItemValue(struct_value) => if true {
                    symbols = vec.push(symbols, backend_symbol(struct_value.name, backend_mangle_symbol(struct_value.name), "struct", struct_value.span));
                    ()
                } else { () },
                IrEnumItemValue(enum_value) => if true {
                    symbols = vec.push(symbols, backend_symbol(enum_value.name, backend_mangle_symbol(enum_value.name), "enum", enum_value.span));
                    ()
                } else { () },
                IrTraitItemValue(trait_value) => if true {
                    symbols = vec.push(symbols, backend_symbol(trait_value.name, backend_mangle_symbol(trait_value.name), "trait", trait_value.span));
                    ()
                } else { () },
                IrImplItemValue(impl_value) => if true {
                    symbols = vec.push(symbols, backend_symbol(impl_value.head_text, backend_mangle_symbol(impl_value.head_text), "impl", impl_value.span));
                    ()
                } else { () },
                IrTypeAliasItemValue(alias_value) => if true {
                    symbols = vec.push(symbols, backend_symbol(alias_value.name, backend_mangle_symbol(alias_value.name), "type_alias", alias_value.span));
                    ()
                } else { () },
                IrConstItemValue(const_value) => if true {
                    symbols = vec.push(symbols, backend_symbol(const_value.name, backend_mangle_symbol(const_value.name), "const", const_value.span));
                    ()
                } else { () },
            },
            None => (),
        };
        index = index + 1;
    };
    symbols
}

fn emit_item_metadata(program: IrProgram) -> String {
    let mut parts: Vec[String] = vec.new_vec();
    let mut index = 0;
    while index < vec.vec_len(program.items) {
        match vec.get(program.items, index) {
            Some(item) => match item {
                IrStructItemValue(value) => if true {
                    parts = vec.push(parts, "; struct ");
                    parts = vec.push(parts, value.name);
                    parts = vec.push(parts, " fields=");
                    parts = vec.push(parts, string.int_to_string(vec.vec_len(value.fields)));
                    parts = vec.push(parts, "\n");
                    ()
                } else { () },
                IrEnumItemValue(value) => if true {
                    parts = vec.push(parts, "; enum ");
                    parts = vec.push(parts, value.name);
                    parts = vec.push(parts, " variants=");
                    parts = vec.push(parts, string.int_to_string(vec.vec_len(value.variants)));
                    parts = vec.push(parts, "\n");
                    ()
                } else { () },
                IrTraitItemValue(value) => if true {
                    parts = vec.push(parts, "; trait ");
                    parts = vec.push(parts, value.name);
                    parts = vec.push(parts, " methods=");
                    parts = vec.push(parts, string.int_to_string(vec.vec_len(value.methods)));
                    parts = vec.push(parts, "\n");
                    ()
                } else { () },
                IrImplItemValue(value) => if true {
                    parts = vec.push(parts, "; impl ");
                    parts = vec.push(parts, value.head_text);
                    parts = vec.push(parts, " methods=");
                    parts = vec.push(parts, string.int_to_string(vec.vec_len(value.methods)));
                    parts = vec.push(parts, "\n");
                    ()
                } else { () },
                IrTypeAliasItemValue(value) => if true {
                    parts = vec.push(parts, "; type_alias ");
                    parts = vec.push(parts, value.name);
                    parts = vec.push(parts, "\n");
                    ()
                } else { () },
                IrConstItemValue(value) => if true {
                    parts = vec.push(parts, "@");
                    parts = vec.push(parts, backend_mangle_symbol(value.name));
                    parts = vec.push(parts, " = internal constant i64 0\n");
                    ()
                } else { () },
                IrFunctionItemValue(_) => (),
            },
            None => (),
        };
        index = index + 1;
    };
    string.join(parts, "")
}

fn emit_functions_llvm(program: IrProgram) -> String {
    let mut parts: Vec[String] = vec.new_vec();
    let mut index = 0;
    while index < vec.vec_len(program.items) {
        match vec.get(program.items, index) {
            Some(item) => match item {
                IrFunctionItemValue(function_value) => if function_value.runtime_visible {
                    parts = vec.push(parts, emit_function_llvm(program, function_value));
                    parts = vec.push(parts, "\n");
                } else {
                    ()
                },
                _ => (),
            },
            None => (),
        };
        index = index + 1;
    };
    string.join(parts, "")
}

fn native_links_summary(links: Vec[BackendNativeLink]) -> String {
    let mut parts: Vec[String] = vec.new_vec();
    let mut index = 0;
    while index < vec.vec_len(links) {
        match vec.get(links, index) {
            Some(link) => if true {
                parts = vec.push(parts, "; native_link ");
                parts = vec.push(parts, backend_native_link_kind_name(link.kind));
                parts = vec.push(parts, " ");
                parts = vec.push(parts, link.name);
                if link.path != "" {
                    parts = vec.push(parts, " path=");
                    parts = vec.push(parts, link.path);
                } else {
                    ()
                };
                if link.static_link {
                    parts = vec.push(parts, " static=true");
                } else {
                    ()
                };
                parts = vec.push(parts, "\n");
                ()
            } else {
                ()
            },
            None => (),
        };
        index = index + 1;
    };
    string.join(parts, "")
}

pub fn emit_llvm_text(program: IrProgram, options: BackendOptions) -> String {
    let mut parts: Vec[String] = vec.new_vec();
    parts = vec.push(parts, "; AICore self-host LLVM IR (deterministic)\n");
    parts = vec.push(parts, "; format=aicore-selfhost-backend-llvm-v1\n");
    parts = vec.push(parts, "; module=");
    parts = vec.push(parts, program.module_path);
    parts = vec.push(parts, "\n");
    parts = vec.push(parts, "; artifact=");
    parts = vec.push(parts, backend_artifact_file_name(options));
    parts = vec.push(parts, "\n");
    if options.target_triple == "" {
        parts = vec.push(parts, "; target=native\n\n");
    } else {
        parts = vec.push(parts, "target triple = \"");
        parts = vec.push(parts, options.target_triple);
        parts = vec.push(parts, "\"\n\n");
    };
    parts = vec.push(parts, native_links_summary(options.native_links));
    parts = vec.push(parts, emit_type_declarations(program));
    parts = vec.push(parts, emit_runtime_declarations(program));
    parts = vec.push(parts, emit_string_globals(program));
    parts = vec.push(parts, emit_item_metadata(program));
    parts = vec.push(parts, "\n");
    parts = vec.push(parts, emit_functions_llvm(program));
    parts = vec.push(parts, emit_entry_wrapper(program));
    string.join(parts, "")
}

pub fn backend_artifact_digest(program: IrProgram, options: BackendOptions, llvm_text: String) -> String {
    let mut parts: Vec[String] = vec.new_vec();
    parts = vec.push(parts, "backend-v1;module=");
    parts = vec.push(parts, program.module_path);
    parts = vec.push(parts, ";artifact=");
    parts = vec.push(parts, backend_artifact_file_name(options));
    parts = vec.push(parts, ";kind=");
    parts = vec.push(parts, backend_artifact_kind_name(options.artifact_kind));
    parts = vec.push(parts, ";items=");
    parts = vec.push(parts, string.int_to_string(vec.vec_len(program.items)));
    parts = vec.push(parts, ";symbols=");
    parts = vec.push(parts, string.int_to_string(vec.vec_len(program.symbols)));
    parts = vec.push(parts, ";features=");
    parts = vec.push(parts, string.join(backend_program_features(program, options), ","));
    parts = vec.push(parts, ";bytes=");
    parts = vec.push(parts, string.int_to_string(string.len(llvm_text)));
    string.join(parts, "")
}

pub fn emit_backend_artifact(program: IrProgram, options: BackendOptions, max_errors: Int) -> BackendArtifact {
    let diagnostics = validate_backend_program(program, options, max_errors);
    let artifact_valid = vec.vec_len(diagnostics) == 0;
    let llvm_text = if artifact_valid {
        emit_llvm_text(program, options)
    } else {
        ""
    };
    let symbols: Vec[BackendSymbol] = if artifact_valid {
        collect_backend_symbols(program)
    } else {
        vec.new_vec()
    };
    let features: Vec[String] = if artifact_valid {
        backend_program_features(program, options)
    } else {
        vec.new_vec()
    };
    let digest = if artifact_valid {
        backend_artifact_digest(program, options, llvm_text)
    } else {
        ""
    };
    BackendArtifact {
        format: "aicore-selfhost-backend-llvm-v1",
        schema_version: 1,
        artifact_name: options.artifact_name,
        file_name: backend_artifact_file_name(options),
        artifact_kind: options.artifact_kind,
        target_triple: options.target_triple,
        llvm_ir: llvm_text,
        symbols: symbols,
        features: features,
        native_links: options.native_links,
        digest: digest,
        diagnostics: diagnostics,
    }
}

pub fn backend_artifact_ok(value: BackendArtifact) -> Bool {
    vec.vec_len(value.diagnostics) == 0 && value.llvm_ir != ""
}

pub fn backend_diagnostic_count(value: BackendArtifact) -> Int {
    vec.vec_len(value.diagnostics)
}

pub fn backend_has_diagnostic_code(value: BackendArtifact, code: String) -> Bool {
    let mut index = 0;
    let mut found = false;
    while !found && index < vec.vec_len(value.diagnostics) {
        match vec.get(value.diagnostics, index) {
            Some(diagnostic_value) => if diagnostic_value.code.value == code {
                found = true;
            } else {
                ()
            },
            None => (),
        };
        index = index + 1;
    };
    found
}
