                                parts = vec.push(parts, ", label %");
                                parts = vec.push(parts, next_label);
                                parts = vec.push(parts, "\n");
                            };
                            parts = vec.push(parts, arm_label);
                            parts = vec.push(parts, ":\n");
                            parts = vec.push(parts, emit_enum_match_arm_payload_extract(program, parent_name, arm, prefix, index, enum_ty, scrutinee_value));
                            let arm_locals = enum_match_arm_locals(program, parent_name, arm, locals, enum_match_arm_payload_value_name(prefix, index));
                            parts = vec.push(parts, emit_return_node_with_locals(program, function_value, nodes, body, ret, arm_locals));
                            ()
                        } else { () },
                        None => (),
                    },
                    None => (),
                };
                index = index + 1;
            };
            string.join(parts, "")
        } else { "" },
        None => "",
    }
}

fn emit_store_to_local(llvm_type: String, value_name: String, storage_name: String) -> String {
    let mut parts: Vec[String] = vec.new_vec();
    parts = vec.push(parts, "  store ");
    parts = vec.push(parts, llvm_type);
    parts = vec.push(parts, " ");
    parts = vec.push(parts, value_name);
    parts = vec.push(parts, ", ");
    parts = vec.push(parts, llvm_type);
    parts = vec.push(parts, "* ");
    parts = vec.push(parts, storage_name);
    parts = vec.push(parts, "\n");
    string.join(parts, "")
}

fn stored_node_value_name(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], node: IrExprNode, locals: BackendLocals) -> String {
    match node.kind {
        IrIntExpr => literal_text_or_name(node.text, node.name),
        IrBoolExpr => bool_literal_llvm_text(node.text, node.name),
        _ => node_value_name(program, function_value, nodes, node, locals),
    }
}

fn stored_expr_value_name(program: IrProgram, function_value: IrFunctionDef, expr: IrExpr, locals: BackendLocals) -> String {
    match expr.kind {
        IrIntExpr => literal_text_or_name(expr.text, expr.name),
        IrBoolExpr => bool_literal_llvm_text(expr.text, expr.name),
        _ => expr_value_name(program, function_value, expr, locals),
    }
}

fn emit_alloca_for_local(llvm_type: String, storage_name: String) -> String {
    let mut parts: Vec[String] = vec.new_vec();
    parts = vec.push(parts, "  ");
    parts = vec.push(parts, storage_name);
    parts = vec.push(parts, " = alloca ");
    parts = vec.push(parts, llvm_type);
    parts = vec.push(parts, "\n");
    string.join(parts, "")
}

fn emit_let_node_value(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], node: IrExprNode, locals: BackendLocals) -> String {
    let declared_type_name = block_let_type_name_from_role(node.role);
    let expected_declared_enum = declared_type_name != "" && expected_enum_constructor_node_can_emit(program, function_value, nodes, node, locals, declared_type_name);
    let declared_llvm_type = llvm_type_for_repr_in_program(program, declared_type_name);
    let text = if expected_declared_enum {
        emit_expected_enum_constructor_node_value(program, function_value, nodes, node, locals, declared_llvm_type, declared_type_name)
    } else {
        emit_value_node(program, function_value, nodes, node, locals)
    };
    if block_child_is_let(node) && block_let_is_mutable_from_role(node.role) {
        let llvm_type = if declared_llvm_type != "" { declared_llvm_type } else { value_node_llvm_type(program, function_value, nodes, node, locals) };
        let storage_name = mutable_storage_name(block_let_name_from_role(node.role), node.node);
        let initial_value = if expected_declared_enum {
            expected_enum_constructor_node_value_name(node)
        } else {
            stored_node_value_name(program, function_value, nodes, node, locals)
        };
        let mut parts: Vec[String] = vec.new_vec();
        parts = vec.push(parts, text);
        parts = vec.push(parts, emit_alloca_for_local(llvm_type, storage_name));
        parts = vec.push(parts, emit_store_to_local(llvm_type, initial_value, storage_name));
        string.join(parts, "")
    } else {
        text
    }
}

fn emit_assign_node_statement(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], node: IrExprNode, locals: BackendLocals, target: String) -> String {
    let llvm_type = llvm_type_for_name(program, function_value, locals, target);
    let storage_name = storage_name_for_name(locals, target);
    let target_type_name = type_name_for_name(program, function_value, locals, target);
    let assigned_value = if expected_enum_constructor_node_can_emit(program, function_value, nodes, node, locals, target_type_name) {
        expected_enum_constructor_node_value_name(node)
    } else {
        stored_node_value_name(program, function_value, nodes, node, locals)
    };
    let mut parts: Vec[String] = vec.new_vec();
    if expected_enum_constructor_node_can_emit(program, function_value, nodes, node, locals, target_type_name) {
        parts = vec.push(parts, emit_expected_enum_constructor_node_value(program, function_value, nodes, node, locals, llvm_type, target_type_name));
    } else if node_is_if_expr(node) && if_node_value_can_emit_with_expected_type(program, function_value, nodes, node, locals, llvm_type, target_type_name) {
        parts = vec.push(parts, emit_if_node_value_with_expected_type(program, function_value, nodes, node, locals, llvm_type, target_type_name));
    } else if node_is_match_expr(node) && direct_option_match_node_can_emit_expected_path(nodes, node) {
        parts = vec.push(parts, emit_option_match_node_value_expected(program, function_value, nodes, node, locals, llvm_type, target_type_name));
    } else {
        parts = vec.push(parts, emit_value_node(program, function_value, nodes, node, locals));
    };
    parts = vec.push(parts, emit_store_to_local(llvm_type, assigned_value, storage_name));
    string.join(parts, "")
}

fn emit_assign_expr_statement(program: IrProgram, function_value: IrFunctionDef, expr: IrExpr, locals: BackendLocals, target: String) -> String {
    let llvm_type = llvm_type_for_name(program, function_value, locals, target);
    let storage_name = storage_name_for_name(locals, target);
    let target_type_name = type_name_for_name(program, function_value, locals, target);
    let assigned_value = if expected_enum_constructor_expr_can_emit(program, function_value, expr, locals, target_type_name) {
        expected_enum_constructor_expr_value_name(expr)
    } else {
        stored_expr_value_name(program, function_value, expr, locals)
    };
    let mut parts: Vec[String] = vec.new_vec();
    if expected_enum_constructor_expr_can_emit(program, function_value, expr, locals, target_type_name) {
        parts = vec.push(parts, emit_expected_enum_constructor_expr_value(program, function_value, expr, locals, llvm_type, target_type_name));
    } else if expr_is_if_expr(expr) && if_expr_value_can_emit_with_expected_type(program, expr, function_value, locals, llvm_type, target_type_name) {
        parts = vec.push(parts, emit_if_expr_value_with_expected_type(program, function_value, expr, locals, llvm_type, target_type_name));
    } else if expr_is_match_expr(expr) && direct_option_match_expr_can_emit_expected_path(expr) {
        parts = vec.push(parts, emit_option_match_expr_value_expected(program, function_value, expr, locals, llvm_type, target_type_name));
    } else {
        parts = vec.push(parts, emit_expr_value(program, function_value, expr, locals));
    };
    parts = vec.push(parts, emit_store_to_local(llvm_type, assigned_value, storage_name));
    string.join(parts, "")
}

fn emit_block_node_return(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], block_node: IrExprNode, ret: String, locals: BackendLocals) -> String {
    let mut out_locals = locals;
    let mut parts: Vec[String] = vec.new_vec();
    let mut index = 0;
    let mut done = false;
    while !done && index < block_node.direct_child_count {
        match expr_node_child_at(nodes, block_node, index) {
            Some(child) => if block_child_is_let(child) {
                parts = vec.push(parts, emit_let_node_value(program, function_value, nodes, child, out_locals));
                out_locals = push_node_local(program, function_value, nodes, child, out_locals);
                ()
            } else if block_child_is_assign(child) {
                parts = vec.push(parts, emit_assign_node_statement(program, function_value, nodes, child, out_locals, block_assign_target_from_role(child.role)));
                ()
            } else if block_child_is_expr(child) {
                parts = vec.push(parts, emit_expr_node_statement(program, function_value, nodes, child, out_locals));
                ()
            } else if block_child_is_tail(child) {
                parts = vec.push(parts, emit_return_node_with_locals(program, function_value, nodes, child, ret, out_locals));
                done = true;
                ()
            } else if block_child_is_return(child) {
                parts = vec.push(parts, emit_return_node_with_locals(program, function_value, nodes, child, ret, out_locals));
                done = true;
                ()
            } else {
                ()
            },
            None => (),
        };
        index = index + 1;
    };
    string.join(parts, "")
}

fn io_print_runtime_name(name: String) -> String {
    if name == "eprint_str" {
        "@aic_rt_eprint_str"
    } else {
        "@aic_rt_print_str"
    }
}

fn emit_io_print_expr_return(program: IrProgram, function_value: IrFunctionDef, expr: IrExpr, locals: BackendLocals) -> String {
    match direct_expr_child_at(expr.nodes, 0) {
        Some(child) => if true {
            let arg_name = string_node_value_name_with_locals(function_value, locals, child);
            let prefix = llvm_expr_prefix(expr.node);
            let mut parts: Vec[String] = vec.new_vec();
            parts = vec.push(parts, emit_string_node_value(program, function_value, expr.nodes, child, locals));
            parts = vec.push(parts, emit_string_extracts(arg_name, prefix));
            parts = vec.push(parts, "  call void ");
            parts = vec.push(parts, io_print_runtime_name(expr.name));
            parts = vec.push(parts, "(i8* ");
            parts = vec.push(parts, llvm_local(prefix, ".ptr"));
            parts = vec.push(parts, ", i64 ");
            parts = vec.push(parts, llvm_local(prefix, ".len"));
            parts = vec.push(parts, ", i64 ");
            parts = vec.push(parts, llvm_local(prefix, ".cap"));
            parts = vec.push(parts, ")\n  ret void\n");
            string.join(parts, "")
        } else { "" },
        None => "",
    }
}

fn fs_string_runtime_name(name: String) -> String {
    if name == "temp_file" {
        "@aic_rt_fs_temp_file"
    } else {
        "@aic_rt_fs_read_text"
    }
}

fn fs_bool_runtime_name(name: String) -> String {
    if name == "delete" {
        "@aic_rt_fs_delete"
    } else {
        "@aic_rt_fs_write_text"
    }
}

fn fs_error_value_name(prefix: String) -> String {
    llvm_local(prefix, ".err.value")
}

fn emit_fs_error_value(prefix: String, raw_code_name: String) -> String {
    let err_ty = known_no_payload_enum_llvm_type("FsError");
    let mut parts: Vec[String] = vec.new_vec();
    parts = vec.push(parts, "  ");
    parts = vec.push(parts, llvm_local(prefix, ".err.is_io"));
    parts = vec.push(parts, " = icmp eq i64 ");
    parts = vec.push(parts, raw_code_name);
    parts = vec.push(parts, ", 5\n  ");
    parts = vec.push(parts, llvm_local(prefix, ".err.minus64"));
    parts = vec.push(parts, " = sub i64 ");
    parts = vec.push(parts, raw_code_name);
    parts = vec.push(parts, ", 1\n  ");
    parts = vec.push(parts, llvm_local(prefix, ".err.minus"));
    parts = vec.push(parts, " = trunc i64 ");
    parts = vec.push(parts, llvm_local(prefix, ".err.minus64"));
    parts = vec.push(parts, " to i32\n  ");
    parts = vec.push(parts, llvm_local(prefix, ".err.tag"));
    parts = vec.push(parts, " = select i1 ");
    parts = vec.push(parts, llvm_local(prefix, ".err.is_io"));
    parts = vec.push(parts, ", i32 6, i32 ");
    parts = vec.push(parts, llvm_local(prefix, ".err.minus"));
    parts = vec.push(parts, "\n  ");
    parts = vec.push(parts, fs_error_value_name(prefix));
    parts = vec.push(parts, " = insertvalue ");
    parts = vec.push(parts, err_ty);
    parts = vec.push(parts, " undef, i32 ");
    parts = vec.push(parts, llvm_local(prefix, ".err.tag"));
    parts = vec.push(parts, ", 0\n");
    string.join(parts, "")
}

fn emit_string_from_ptr_len(prefix: String, ptr_name: String, len_name: String) -> String {
    let mut parts: Vec[String] = vec.new_vec();
    parts = vec.push(parts, "  ");
    parts = vec.push(parts, llvm_local(prefix, ".0"));
    parts = vec.push(parts, " = insertvalue %aic.String undef, i8* ");
    parts = vec.push(parts, ptr_name);
    parts = vec.push(parts, ", 0\n  ");
    parts = vec.push(parts, llvm_local(prefix, ".1"));
    parts = vec.push(parts, " = insertvalue %aic.String ");
    parts = vec.push(parts, llvm_local(prefix, ".0"));
    parts = vec.push(parts, ", i64 ");
    parts = vec.push(parts, len_name);
    parts = vec.push(parts, ", 1\n  ");
    parts = vec.push(parts, llvm_local(prefix, ".2"));
    parts = vec.push(parts, " = insertvalue %aic.String ");
    parts = vec.push(parts, llvm_local(prefix, ".1"));
    parts = vec.push(parts, ", i64 ");
    parts = vec.push(parts, len_name);
    parts = vec.push(parts, ", 2\n");
    string.join(parts, "")
}

fn emit_store_string_node_value(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], node: IrExprNode, locals: BackendLocals, out_ptr: String) -> String {
    let mut parts: Vec[String] = vec.new_vec();
    parts = vec.push(parts, emit_string_node_value(program, function_value, nodes, node, locals));
    parts = vec.push(parts, "  store %aic.String ");
    parts = vec.push(parts, string_node_value_name_with_locals(function_value, locals, node));
    parts = vec.push(parts, ", %aic.String* ");
    parts = vec.push(parts, out_ptr);
    parts = vec.push(parts, "\n");
    string.join(parts, "")
}

fn emit_result_string_match_node_value(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], node: IrExprNode, locals: BackendLocals) -> String {
    match expr_node_child_at(nodes, node, 0) {
        Some(scrutinee) => match expr_node_child_at(nodes, scrutinee, 0) {
            Some(path_child) => match result_match_node_body_node_for_variant(nodes, node, "Ok") {
                Some(ok_body) => match result_match_node_body_node_for_variant(nodes, node, "Err") {
                    Some(err_body) => if true {
                        let prefix = llvm_node_prefix(node.node);
                        let path_name = string_node_value_name_with_locals(function_value, locals, path_child);
                        let path_prefix = concat2(prefix, ".path");
                        let ok_label = concat2("match.ok.", string.int_to_string(node.node.value));
                        let err_label = concat2("match.err.", string.int_to_string(node.node.value));
                        let end_label = concat2("match.end.", string.int_to_string(node.node.value));
                        let out_ptr = llvm_local(prefix, ".out");
                        let ok_string_prefix = concat2(prefix, ".ok.str");
                        let ok_payload = result_match_node_payload_name_or_default(node, "Ok", "text");
                        let ok_locals = push_result_string_payload_local(locals, ok_payload, llvm_local(ok_string_prefix, ".2"));
                        let mut parts: Vec[String] = vec.new_vec();
                        parts = vec.push(parts, "  ");
                        parts = vec.push(parts, out_ptr);
                        parts = vec.push(parts, " = alloca %aic.String\n");
                        parts = vec.push(parts, emit_string_node_value(program, function_value, nodes, path_child, locals));
                        parts = vec.push(parts, emit_string_extracts(path_name, path_prefix));
                        parts = vec.push(parts, "  ");
                        parts = vec.push(parts, llvm_local(prefix, ".out.ptr"));
                        parts = vec.push(parts, " = alloca i8*\n  ");
                        parts = vec.push(parts, llvm_local(prefix, ".out.len"));
                        parts = vec.push(parts, " = alloca i64\n  ");
                        parts = vec.push(parts, llvm_local(prefix, ".rc"));
                        parts = vec.push(parts, " = call i64 ");
                        parts = vec.push(parts, fs_string_runtime_name(scrutinee.name));
                        parts = vec.push(parts, "(i8* ");
                        parts = vec.push(parts, llvm_local(path_prefix, ".ptr"));
                        parts = vec.push(parts, ", i64 ");
                        parts = vec.push(parts, llvm_local(path_prefix, ".len"));
                        parts = vec.push(parts, ", i64 ");
                        parts = vec.push(parts, llvm_local(path_prefix, ".cap"));
                        parts = vec.push(parts, ", i8** ");
                        parts = vec.push(parts, llvm_local(prefix, ".out.ptr"));
                        parts = vec.push(parts, ", i64* ");
                        parts = vec.push(parts, llvm_local(prefix, ".out.len"));
                        parts = vec.push(parts, ")\n  ");
                        parts = vec.push(parts, llvm_local(prefix, ".is_ok"));
                        parts = vec.push(parts, " = icmp eq i64 ");
                        parts = vec.push(parts, llvm_local(prefix, ".rc"));
                        parts = vec.push(parts, ", 0\n  br i1 ");
                        parts = vec.push(parts, llvm_local(prefix, ".is_ok"));
                        parts = vec.push(parts, ", label %");
                        parts = vec.push(parts, ok_label);
                        parts = vec.push(parts, ", label %");
                        parts = vec.push(parts, err_label);
                        parts = vec.push(parts, "\n");
                        parts = vec.push(parts, ok_label);
                        parts = vec.push(parts, ":\n  ");
                        parts = vec.push(parts, llvm_local(prefix, ".ok.ptr"));
                        parts = vec.push(parts, " = load i8*, i8** ");
                        parts = vec.push(parts, llvm_local(prefix, ".out.ptr"));
                        parts = vec.push(parts, "\n  ");
                        parts = vec.push(parts, llvm_local(prefix, ".ok.len"));
                        parts = vec.push(parts, " = load i64, i64* ");
                        parts = vec.push(parts, llvm_local(prefix, ".out.len"));
                        parts = vec.push(parts, "\n");
                        parts = vec.push(parts, emit_string_from_ptr_len(ok_string_prefix, llvm_local(prefix, ".ok.ptr"), llvm_local(prefix, ".ok.len")));
                        parts = vec.push(parts, emit_store_string_node_value(program, function_value, nodes, ok_body, ok_locals, out_ptr));
                        parts = vec.push(parts, "  br label %");
                        parts = vec.push(parts, end_label);
                        parts = vec.push(parts, "\n");
                        parts = vec.push(parts, err_label);
                        parts = vec.push(parts, ":\n");
                        parts = vec.push(parts, emit_store_string_node_value(program, function_value, nodes, err_body, locals, out_ptr));
                        parts = vec.push(parts, "  br label %");
                        parts = vec.push(parts, end_label);
                        parts = vec.push(parts, "\n");
                        parts = vec.push(parts, end_label);
                        parts = vec.push(parts, ":\n  ");
                        parts = vec.push(parts, llvm_node_value_local(node));
                        parts = vec.push(parts, " = load %aic.String, %aic.String* ");
                        parts = vec.push(parts, out_ptr);
                        parts = vec.push(parts, "\n");
                        string.join(parts, "")
                    } else { "" },
                    None => "",
                },
                None => "",
            },
            None => "",
        },
        None => "",
    }
}

fn emit_result_match_node_return(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], node: IrExprNode, ret: String, locals: BackendLocals) -> String {
    match expr_node_child_at(nodes, node, 0) {
        Some(scrutinee) => match expr_node_child_at(nodes, scrutinee, 0) {
            Some(path_child) => match result_match_node_body_node_for_variant(nodes, node, "Ok") {
                Some(ok_body) => match result_match_node_body_node_for_variant(nodes, node, "Err") {
                    Some(err_body) => if true {
                        let prefix = llvm_node_prefix(node.node);
                        let path_name = string_node_value_name_with_locals(function_value, locals, path_child);
                        let path_prefix = concat2(prefix, ".path");
                        let ok_label = concat2("match.ok.", string.int_to_string(node.node.value));
                        let err_label = concat2("match.err.", string.int_to_string(node.node.value));
                        let ok_string_prefix = concat2(prefix, ".ok.str");
                        let ok_value_name = llvm_local(ok_string_prefix, ".2");
                        let ok_payload_name = result_match_node_payload_name(node, "Ok");
                        let ok_base_locals = clone_backend_locals(locals);
                        let ok_locals = if ok_payload_name == "" {
                            ok_base_locals
                        } else {
                            backend_locals_push(ok_base_locals, backend_local(ok_payload_name, "String", "%aic.String", ok_value_name))
                        };
                        let mut parts: Vec[String] = vec.new_vec();
                        parts = vec.push(parts, emit_string_node_value(program, function_value, nodes, path_child, locals));
                        parts = vec.push(parts, emit_string_extracts(path_name, path_prefix));
                        parts = vec.push(parts, "  ");
                        parts = vec.push(parts, llvm_local(prefix, ".out.ptr"));
                        parts = vec.push(parts, " = alloca i8*\n  ");
                        parts = vec.push(parts, llvm_local(prefix, ".out.len"));
                        parts = vec.push(parts, " = alloca i64\n  ");
                        parts = vec.push(parts, llvm_local(prefix, ".rc"));
                        parts = vec.push(parts, " = call i64 ");
                        parts = vec.push(parts, fs_string_runtime_name(scrutinee.name));
                        parts = vec.push(parts, "(i8* ");
                        parts = vec.push(parts, llvm_local(path_prefix, ".ptr"));
                        parts = vec.push(parts, ", i64 ");
                        parts = vec.push(parts, llvm_local(path_prefix, ".len"));
                        parts = vec.push(parts, ", i64 ");
                        parts = vec.push(parts, llvm_local(path_prefix, ".cap"));
                        parts = vec.push(parts, ", i8** ");
                        parts = vec.push(parts, llvm_local(prefix, ".out.ptr"));
                        parts = vec.push(parts, ", i64* ");
                        parts = vec.push(parts, llvm_local(prefix, ".out.len"));
                        parts = vec.push(parts, ")\n  ");
                        parts = vec.push(parts, llvm_local(prefix, ".is_ok"));
                        parts = vec.push(parts, " = icmp eq i64 ");
                        parts = vec.push(parts, llvm_local(prefix, ".rc"));
                        parts = vec.push(parts, ", 0\n  br i1 ");
                        parts = vec.push(parts, llvm_local(prefix, ".is_ok"));
                        parts = vec.push(parts, ", label %");
                        parts = vec.push(parts, ok_label);
                        parts = vec.push(parts, ", label %");
                        parts = vec.push(parts, err_label);
                        parts = vec.push(parts, "\n");
                        parts = vec.push(parts, ok_label);
                        parts = vec.push(parts, ":\n  ");
                        parts = vec.push(parts, llvm_local(prefix, ".ok.ptr"));
                        parts = vec.push(parts, " = load i8*, i8** ");
                        parts = vec.push(parts, llvm_local(prefix, ".out.ptr"));
                        parts = vec.push(parts, "\n  ");
                        parts = vec.push(parts, llvm_local(prefix, ".ok.len"));
                        parts = vec.push(parts, " = load i64, i64* ");
                        parts = vec.push(parts, llvm_local(prefix, ".out.len"));
                        parts = vec.push(parts, "\n");
                        parts = vec.push(parts, emit_string_from_ptr_len(ok_string_prefix, llvm_local(prefix, ".ok.ptr"), llvm_local(prefix, ".ok.len")));
                        parts = vec.push(parts, emit_return_node_with_locals(program, function_value, nodes, ok_body, ret, ok_locals));
                        parts = vec.push(parts, err_label);
                        parts = vec.push(parts, ":\n");
                        parts = vec.push(parts, emit_fs_error_value(prefix, llvm_local(prefix, ".rc")));
                        let err_value_name = fs_error_value_name(prefix);
                        let err_payload_name = result_match_node_payload_name(node, "Err");
                        let err_base_locals = clone_backend_locals(locals);
                        let err_locals = if err_payload_name == "" {
                            err_base_locals
                        } else {
                            backend_locals_push(err_base_locals, backend_local(err_payload_name, "FsError", known_no_payload_enum_llvm_type("FsError"), err_value_name))
                        };
                        parts = vec.push(parts, emit_return_node_with_locals(program, function_value, nodes, err_body, ret, err_locals));
                        string.join(parts, "")
                    } else { "" },
                    None => "",
                },
                None => "",
            },
            None => "",
        },
        None => "",
    }
}

fn emit_result_match_expr_return(program: IrProgram, function_value: IrFunctionDef, expr: IrExpr, ret: String, locals: BackendLocals) -> String {
    match direct_expr_child_at(expr.nodes, 0) {
        Some(scrutinee) => match expr_node_child_at(expr.nodes, scrutinee, 0) {
            Some(path_child) => match result_match_expr_body_node_for_variant(expr, "Ok") {
                Some(ok_body) => match result_match_expr_body_node_for_variant(expr, "Err") {
                    Some(err_body) => if true {
                        let prefix = llvm_expr_prefix(expr.node);
                        let path_name = string_node_value_name_with_locals(function_value, locals, path_child);
                        let path_prefix = concat2(prefix, ".path");
                        let ok_label = concat2("match.ok.", string.int_to_string(expr.node.value));
                        let err_label = concat2("match.err.", string.int_to_string(expr.node.value));
                        let ok_string_prefix = concat2(prefix, ".ok.str");
                        let ok_value_name = llvm_local(ok_string_prefix, ".2");
                        let ok_payload_name = result_match_expr_payload_name(expr, "Ok");
                        let ok_base_locals = clone_backend_locals(locals);
                        let ok_locals = if ok_payload_name == "" {
                            ok_base_locals
                        } else {
                            backend_locals_push(ok_base_locals, backend_local(ok_payload_name, "String", "%aic.String", ok_value_name))
                        };
                        let mut parts: Vec[String] = vec.new_vec();
                        parts = vec.push(parts, emit_string_node_value(program, function_value, expr.nodes, path_child, locals));
                        parts = vec.push(parts, emit_string_extracts(path_name, path_prefix));
                        parts = vec.push(parts, "  ");
                        parts = vec.push(parts, llvm_local(prefix, ".out.ptr"));
                        parts = vec.push(parts, " = alloca i8*\n  ");
                        parts = vec.push(parts, llvm_local(prefix, ".out.len"));
                        parts = vec.push(parts, " = alloca i64\n  ");
                        parts = vec.push(parts, llvm_local(prefix, ".rc"));
                        parts = vec.push(parts, " = call i64 ");
                        parts = vec.push(parts, fs_string_runtime_name(scrutinee.name));
                        parts = vec.push(parts, "(i8* ");
                        parts = vec.push(parts, llvm_local(path_prefix, ".ptr"));
                        parts = vec.push(parts, ", i64 ");
                        parts = vec.push(parts, llvm_local(path_prefix, ".len"));
                        parts = vec.push(parts, ", i64 ");
                        parts = vec.push(parts, llvm_local(path_prefix, ".cap"));
                        parts = vec.push(parts, ", i8** ");
                        parts = vec.push(parts, llvm_local(prefix, ".out.ptr"));
                        parts = vec.push(parts, ", i64* ");
                        parts = vec.push(parts, llvm_local(prefix, ".out.len"));
                        parts = vec.push(parts, ")\n  ");
                        parts = vec.push(parts, llvm_local(prefix, ".is_ok"));
                        parts = vec.push(parts, " = icmp eq i64 ");
                        parts = vec.push(parts, llvm_local(prefix, ".rc"));
                        parts = vec.push(parts, ", 0\n  br i1 ");
                        parts = vec.push(parts, llvm_local(prefix, ".is_ok"));
                        parts = vec.push(parts, ", label %");
                        parts = vec.push(parts, ok_label);
                        parts = vec.push(parts, ", label %");
                        parts = vec.push(parts, err_label);
                        parts = vec.push(parts, "\n");
                        parts = vec.push(parts, ok_label);
                        parts = vec.push(parts, ":\n  ");
                        parts = vec.push(parts, llvm_local(prefix, ".ok.ptr"));
                        parts = vec.push(parts, " = load i8*, i8** ");
                        parts = vec.push(parts, llvm_local(prefix, ".out.ptr"));
                        parts = vec.push(parts, "\n  ");
                        parts = vec.push(parts, llvm_local(prefix, ".ok.len"));
                        parts = vec.push(parts, " = load i64, i64* ");
                        parts = vec.push(parts, llvm_local(prefix, ".out.len"));
                        parts = vec.push(parts, "\n");
                        parts = vec.push(parts, emit_string_from_ptr_len(ok_string_prefix, llvm_local(prefix, ".ok.ptr"), llvm_local(prefix, ".ok.len")));
                        parts = vec.push(parts, emit_return_node_with_locals(program, function_value, expr.nodes, ok_body, ret, ok_locals));
                        parts = vec.push(parts, err_label);
                        parts = vec.push(parts, ":\n");
                        parts = vec.push(parts, emit_fs_error_value(prefix, llvm_local(prefix, ".rc")));
                        let err_value_name = fs_error_value_name(prefix);
                        let err_payload_name = result_match_expr_payload_name(expr, "Err");
                        let err_base_locals = clone_backend_locals(locals);
                        let err_locals = if err_payload_name == "" {
                            err_base_locals
                        } else {
                            backend_locals_push(err_base_locals, backend_local(err_payload_name, "FsError", known_no_payload_enum_llvm_type("FsError"), err_value_name))
                        };
                        parts = vec.push(parts, emit_return_node_with_locals(program, function_value, expr.nodes, err_body, ret, err_locals));
                        string.join(parts, "")
                    } else { "" },
                    None => "",
                },
                None => "",
            },
            None => "",
        },
        None => "",
    }
}

fn emit_result_bool_match_node_return(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], node: IrExprNode, ret: String, locals: BackendLocals) -> String {
    match expr_node_child_at(nodes, node, 0) {
        Some(scrutinee) => match expr_node_child_at(nodes, scrutinee, 0) {
            Some(path_child) => match result_match_node_body_node_for_variant(nodes, node, "Ok") {
                Some(ok_body) => match result_match_node_body_node_for_variant(nodes, node, "Err") {
                    Some(err_body) => if true {
                        let prefix = llvm_node_prefix(node.node);
