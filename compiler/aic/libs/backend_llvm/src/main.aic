                    let parts_type = node_type_name(program, function_value, value.nodes, parts_child, locals);
                    base_type_name_text(parts_type) == "Vec"
                        && generic_arg_at(parts_type, 0) == "String"
                        && value_node_can_emit(program, function_value, value.nodes, parts_child, locals)
                        && value_node_llvm_type(program, function_value, value.nodes, parts_child, locals) == "{ i64, i64, i64 }"
                        && string_call_child_can_emit(program, function_value, value.nodes, separator_child, locals)
                } else { false },
                None => false,
            },
            None => false,
        }
    }
}

