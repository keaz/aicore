fn option_match_node_llvm_type(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], node: IrExprNode, locals: BackendLocals) -> String {
    llvm_type_for_repr_in_program(program, option_match_node_type_name(program, function_value, nodes, node, locals))
}

fn option_match_expr_llvm_type(program: IrProgram, value: IrExpr, function_value: IrFunctionDef, locals: BackendLocals) -> String {
    llvm_type_for_repr_in_program(program, option_match_expr_type_name(program, value, function_value, locals))
}

fn option_match_node_can_emit_value(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], node: IrExprNode, locals: BackendLocals) -> Bool {
    if !option_match_arms_are_some_none(node.match_arms) {
        false
    } else {
        let option_name = option_match_scrutinee_node_type_name(program, function_value, nodes, node, locals);
        let expected = option_match_node_llvm_type(program, function_value, nodes, node, locals);
        if option_name == "" || expected == "" || expected == "void" {
            false
        } else {
            match result_match_node_body_node_for_variant(nodes, node, "Some") {
                Some(some_body) => match result_match_node_body_node_for_variant(nodes, node, "None") {
