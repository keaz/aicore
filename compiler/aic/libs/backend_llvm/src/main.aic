                    match result_match_expr_body_node_for_variant(value, "Ok") {
                        Some(ok_body) => match result_match_expr_body_node_for_variant(value, "Err") {
                            Some(err_body) => return_node_can_emit_with_locals(program, function_value, value.nodes, ok_body, ret, ok_locals) && return_node_can_emit_with_locals(program, function_value, value.nodes, err_body, ret, locals),
                            None => false,
                        },
                        None => false,
                    }
                } else {
                    false
                }
            } else {
                false
            },
            None => false,
        }
    }
}

fn direct_result_match_node_can_emit_result_return(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], node: IrExprNode, ret: String, locals: BackendLocals) -> Bool {
    if base_type_name_text(function_result_type_name(program, function_value)) != "Result" || llvm_type_for_id(program, function_value.return_type) != ret || !result_match_arms_are_ok_err(node.match_arms) {
        false
    } else {
        match expr_node_child_at(nodes, node, 0) {
            Some(scrutinee) => if is_call_expr_kind(scrutinee.kind) && !is_fs_intrinsic_name(scrutinee.name) && !is_proc_result_intrinsic_name(scrutinee.name) && direct_call_node_can_emit(program, function_value, nodes, scrutinee, locals) {
                let result_name = call_target_return_type_name(program, scrutinee.name);
                let result_ty = call_target_return_type(program, scrutinee.name);
                let ok_payload_type_name = result_constructor_payload_type_name(result_name, "Ok");
                let ok_payload_ty = llvm_payload_slot_type(program, ok_payload_type_name);
                let ok_payload_name = result_match_node_payload_name(node, "Ok");
                let err_payload_type_name = result_constructor_payload_type_name(result_name, "Err");
                let err_payload_ty = llvm_payload_slot_type(program, err_payload_type_name);
                let err_payload_name = result_match_node_payload_name(node, "Err");
                if base_type_name_text(result_name) == "Result" && result_ty != "" && ok_payload_ty != "" && err_payload_ty != "" {
                    let ok_base_locals = clone_backend_locals(locals);
                    let ok_locals = if ok_payload_name == "" {
                        ok_base_locals
                    } else {
                        backend_locals_push(ok_base_locals, backend_local(ok_payload_name, ok_payload_type_name, ok_payload_ty, llvm_local(llvm_node_prefix(node.node), ".ok.value")))
                    };
                    match result_match_node_body_node_for_variant(nodes, node, "Ok") {
                        Some(ok_body) => match result_match_node_body_node_for_variant(nodes, node, "Err") {
                            Some(err_body) => if true {
                                let err_base_locals = clone_backend_locals(locals);
                                let err_locals = if err_payload_name == "" {
                                    err_base_locals
                                } else {
                                    backend_locals_push(err_base_locals, backend_local(err_payload_name, err_payload_type_name, err_payload_ty, llvm_local(llvm_node_prefix(node.node), ".err.value")))
                                };
                                return_node_can_emit_with_locals(program, function_value, nodes, ok_body, ret, ok_locals) && return_node_can_emit_with_locals(program, function_value, nodes, err_body, ret, err_locals)
                            } else { false },
                            None => false,
                        },
                        None => false,
                    }
                } else {
                    false
                }
            } else {
                false
            },
            None => false,
        }
    }
}

