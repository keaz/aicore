                let none_label = concat2("option.match.none.", string.int_to_string(expr.node.value));
                let end_label = concat2("option.match.end.", string.int_to_string(expr.node.value));
                let option_name = option_match_scrutinee_expr_type_name(program, expr, function_value, locals);
                let payload_type_name = generic_arg_at(option_name, 0);
                let payload_locals = push_option_payload_local(program, locals, option_match_payload_name_from_expr(expr), payload_type_name, option_match_payload_name(prefix));
                let mut parts: Vec[String] = vec.new_vec();
                parts = vec.push(parts, emit_option_match_expr_scrutinee(program, function_value, expr, locals));
                parts = vec.push(parts, "  br i1 ");
                parts = vec.push(parts, option_match_is_some_name(prefix));
                parts = vec.push(parts, ", label %");
                parts = vec.push(parts, some_label);
                parts = vec.push(parts, ", label %");
                parts = vec.push(parts, none_label);
                parts = vec.push(parts, "\n");
                parts = vec.push(parts, some_label);
                parts = vec.push(parts, ":\n");
                parts = vec.push(parts, emit_unit_statement_branch_node(program, function_value, expr.nodes, some_body, payload_locals, end_label));
                parts = vec.push(parts, none_label);
                parts = vec.push(parts, ":\n");
                parts = vec.push(parts, emit_unit_statement_branch_node(program, function_value, expr.nodes, none_body, locals, end_label));
                parts = vec.push(parts, end_label);
                parts = vec.push(parts, ":\n");
                string.join(parts, "")
            } else { "" },
            None => "",
        },
        None => "",
    }
}

fn branch_expected_type_name(program: IrProgram, function_value: IrFunctionDef, expected: String) -> String {
    let result_name = function_result_type_name(program, function_value);
    if result_name != "" && llvm_type_for_repr_in_program(program, result_name) == expected {
        result_name
    } else {
        ""
    }
}

fn emit_branch_value_store(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], branch_node: IrExprNode, expected: String, out_slot: String, locals: BackendLocals, end_label: String) -> String {
    emit_branch_value_store_with_expected_type(program, function_value, nodes, branch_node, expected, branch_expected_type_name(program, function_value, expected), out_slot, locals, end_label)
}

fn emit_branch_value_store_with_expected_type(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], branch_node: IrExprNode, expected: String, expected_type_name: String, out_slot: String, locals: BackendLocals, end_label: String) -> String {
    if is_block_expr_kind(branch_node.kind) {
        emit_block_value_store_with_expected_type(program, function_value, nodes, branch_node, expected, expected_type_name, out_slot, locals, end_label)
    } else if expected_vec_new_vec_node_can_emit(branch_node, expected) {
        let mut parts: Vec[String] = vec.new_vec();
        parts = vec.push(parts, emit_empty_vec_value(llvm_node_prefix(branch_node.node), expected));
        parts = vec.push(parts, "  store ");
        parts = vec.push(parts, expected);
        parts = vec.push(parts, " ");
        parts = vec.push(parts, llvm_node_value_local(branch_node));
        parts = vec.push(parts, ", ");
        parts = vec.push(parts, expected);
        parts = vec.push(parts, "* ");
        parts = vec.push(parts, out_slot);
        parts = vec.push(parts, "\n  br label %");
        parts = vec.push(parts, end_label);
        parts = vec.push(parts, "\n");
        string.join(parts, "")
    } else if expected_enum_constructor_node_can_emit(program, function_value, nodes, branch_node, locals, expected_type_name) {
        let mut parts: Vec[String] = vec.new_vec();
        parts = vec.push(parts, emit_expected_enum_constructor_node_value(program, function_value, nodes, branch_node, locals, expected, expected_type_name));
        parts = vec.push(parts, "  store ");
        parts = vec.push(parts, expected);
        parts = vec.push(parts, " ");
        parts = vec.push(parts, expected_enum_constructor_node_value_name(branch_node));
        parts = vec.push(parts, ", ");
        parts = vec.push(parts, expected);
        parts = vec.push(parts, "* ");
        parts = vec.push(parts, out_slot);
        parts = vec.push(parts, "\n  br label %");
        parts = vec.push(parts, end_label);
        parts = vec.push(parts, "\n");
        string.join(parts, "")
    } else if node_is_if_expr(branch_node) {
        let mut parts: Vec[String] = vec.new_vec();
        parts = vec.push(parts, emit_if_node_value_with_expected_type(program, function_value, nodes, branch_node, locals, expected, expected_type_name));
        parts = vec.push(parts, "  store ");
        parts = vec.push(parts, expected);
        parts = vec.push(parts, " ");
        parts = vec.push(parts, llvm_node_value_local(branch_node));
        parts = vec.push(parts, ", ");
        parts = vec.push(parts, expected);
        parts = vec.push(parts, "* ");
        parts = vec.push(parts, out_slot);
        parts = vec.push(parts, "\n  br label %");
        parts = vec.push(parts, end_label);
        parts = vec.push(parts, "\n");
        string.join(parts, "")
    } else if node_is_match_expr(branch_node) && direct_option_match_node_can_emit_expected_path(nodes, branch_node) {
        let mut parts: Vec[String] = vec.new_vec();
        parts = vec.push(parts, emit_option_match_node_value_expected(program, function_value, nodes, branch_node, locals, expected, expected_type_name));
        parts = vec.push(parts, "  store ");
        parts = vec.push(parts, expected);
        parts = vec.push(parts, " ");
        parts = vec.push(parts, llvm_node_value_local(branch_node));
        parts = vec.push(parts, ", ");
        parts = vec.push(parts, expected);
        parts = vec.push(parts, "* ");
        parts = vec.push(parts, out_slot);
        parts = vec.push(parts, "\n  br label %");
        parts = vec.push(parts, end_label);
        parts = vec.push(parts, "\n");
        string.join(parts, "")
    } else {
        let mut parts: Vec[String] = vec.new_vec();
        parts = vec.push(parts, emit_value_node(program, function_value, nodes, branch_node, locals));
        parts = vec.push(parts, "  store ");
        parts = vec.push(parts, expected);
        parts = vec.push(parts, " ");
        parts = vec.push(parts, node_value_name(program, function_value, nodes, branch_node, locals));
        parts = vec.push(parts, ", ");
        parts = vec.push(parts, expected);
        parts = vec.push(parts, "* ");
        parts = vec.push(parts, out_slot);
        parts = vec.push(parts, "\n  br label %");
        parts = vec.push(parts, end_label);
        parts = vec.push(parts, "\n");
        string.join(parts, "")
    }
}

fn emit_block_value_store(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], block_node: IrExprNode, expected: String, out_slot: String, locals: BackendLocals, end_label: String) -> String {
    emit_block_value_store_with_expected_type(program, function_value, nodes, block_node, expected, branch_expected_type_name(program, function_value, expected), out_slot, locals, end_label)
}

fn emit_block_value_store_with_expected_type(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], block_node: IrExprNode, expected: String, expected_type_name: String, out_slot: String, locals: BackendLocals, end_label: String) -> String {
    let mut out_locals = locals;
    let mut parts: Vec[String] = vec.new_vec();
    let mut index = 0;
    let mut done = false;
    while !done && index < block_node.direct_child_count {
        match expr_node_child_at(nodes, block_node, index) {
            Some(child) => if block_child_is_let(child) {
                parts = vec.push(parts, emit_let_node_value(program, function_value, nodes, child, out_locals));
                out_locals = push_node_local(program, function_value, nodes, child, out_locals);
                ()
            } else if block_child_is_assign(child) {
                parts = vec.push(parts, emit_assign_node_statement(program, function_value, nodes, child, out_locals, block_assign_target_from_role(child.role)));
                ()
            } else if block_child_is_expr(child) {
                parts = vec.push(parts, emit_expr_node_statement(program, function_value, nodes, child, out_locals));
                ()
            } else if block_child_is_tail(child) {
                parts = vec.push(parts, emit_branch_value_store_with_expected_type(program, function_value, nodes, child, expected, expected_type_name, out_slot, out_locals, end_label));
                done = true;
                ()
            } else {
                ()
            },
            None => (),
        };
        index = index + 1;
    };
    string.join(parts, "")
}

fn emit_if_node_value(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], node: IrExprNode, locals: BackendLocals) -> String {
    emit_if_node_value_with_expected(program, function_value, nodes, node, locals, if_node_value_llvm_type(program, function_value, nodes, node, locals))
}

fn emit_if_node_value_with_expected(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], node: IrExprNode, locals: BackendLocals, expected: String) -> String {
    emit_if_node_value_with_expected_type(program, function_value, nodes, node, locals, expected, branch_expected_type_name(program, function_value, expected))
}

fn emit_if_node_value_with_expected_type(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], node: IrExprNode, locals: BackendLocals, expected: String, expected_type_name: String) -> String {
    match expr_node_child_at(nodes, node, 0) {
        Some(condition) => match expr_node_child_at(nodes, node, 1) {
            Some(then_block) => match expr_node_child_at(nodes, node, 2) {
                Some(else_block) => if true {
                    let prefix = llvm_node_prefix(node.node);
                    let then_label = concat2("if.then.", string.int_to_string(node.node.value));
                    let else_label = concat2("if.else.", string.int_to_string(node.node.value));
                    let end_label = concat2("if.end.", string.int_to_string(node.node.value));
                    let out_slot = llvm_local(prefix, ".value.slot");
                    let mut parts: Vec[String] = vec.new_vec();
                    parts = vec.push(parts, "  ");
                    parts = vec.push(parts, out_slot);
                    parts = vec.push(parts, " = alloca ");
                    parts = vec.push(parts, expected);
                    parts = vec.push(parts, "\n");
                    parts = vec.push(parts, emit_bool_node_value(program, function_value, nodes, condition, locals));
                    parts = vec.push(parts, "  br i1 ");
                    parts = vec.push(parts, bool_node_value_name_with_locals(function_value, locals, condition));
                    parts = vec.push(parts, ", label %");
                    parts = vec.push(parts, then_label);
                    parts = vec.push(parts, ", label %");
                    parts = vec.push(parts, else_label);
                    parts = vec.push(parts, "\n");
                    parts = vec.push(parts, then_label);
                    parts = vec.push(parts, ":\n");
                    parts = vec.push(parts, emit_branch_value_store_with_expected_type(program, function_value, nodes, then_block, expected, expected_type_name, out_slot, locals, end_label));
                    parts = vec.push(parts, else_label);
                    parts = vec.push(parts, ":\n");
                    parts = vec.push(parts, emit_branch_value_store_with_expected_type(program, function_value, nodes, else_block, expected, expected_type_name, out_slot, locals, end_label));
                    parts = vec.push(parts, end_label);
                    parts = vec.push(parts, ":\n  ");
                    parts = vec.push(parts, llvm_node_value_local(node));
                    parts = vec.push(parts, " = load ");
                    parts = vec.push(parts, expected);
                    parts = vec.push(parts, ", ");
                    parts = vec.push(parts, expected);
                    parts = vec.push(parts, "* ");
                    parts = vec.push(parts, out_slot);
                    parts = vec.push(parts, "\n");
                    string.join(parts, "")
                } else { "" },
                None => "",
            },
            None => "",
        },
        None => "",
    }
}

fn emit_if_expr_value(program: IrProgram, function_value: IrFunctionDef, expr: IrExpr, locals: BackendLocals) -> String {
    emit_if_expr_value_with_expected(program, function_value, expr, locals, value_expr_llvm_type(program, expr, function_value, locals))
}

fn emit_if_expr_value_with_expected(program: IrProgram, function_value: IrFunctionDef, expr: IrExpr, locals: BackendLocals, expected: String) -> String {
    emit_if_expr_value_with_expected_type(program, function_value, expr, locals, expected, branch_expected_type_name(program, function_value, expected))
}

fn emit_if_expr_value_with_expected_type(program: IrProgram, function_value: IrFunctionDef, expr: IrExpr, locals: BackendLocals, expected: String, expected_type_name: String) -> String {
    match direct_expr_child_at(expr.nodes, 0) {
        Some(condition) => match direct_expr_child_at(expr.nodes, 1) {
            Some(then_block) => match direct_expr_child_at(expr.nodes, 2) {
                Some(else_block) => if true {
                    let prefix = llvm_expr_prefix(expr.node);
                    let then_label = concat2("if.then.", string.int_to_string(expr.node.value));
                    let else_label = concat2("if.else.", string.int_to_string(expr.node.value));
                    let end_label = concat2("if.end.", string.int_to_string(expr.node.value));
                    let out_slot = llvm_local(prefix, ".value.slot");
                    let mut parts: Vec[String] = vec.new_vec();
                    parts = vec.push(parts, "  ");
                    parts = vec.push(parts, out_slot);
                    parts = vec.push(parts, " = alloca ");
                    parts = vec.push(parts, expected);
                    parts = vec.push(parts, "\n");
                    parts = vec.push(parts, emit_bool_node_value(program, function_value, expr.nodes, condition, locals));
                    parts = vec.push(parts, "  br i1 ");
                    parts = vec.push(parts, bool_node_value_name_with_locals(function_value, locals, condition));
                    parts = vec.push(parts, ", label %");
                    parts = vec.push(parts, then_label);
                    parts = vec.push(parts, ", label %");
                    parts = vec.push(parts, else_label);
                    parts = vec.push(parts, "\n");
                    parts = vec.push(parts, then_label);
                    parts = vec.push(parts, ":\n");
                    parts = vec.push(parts, emit_branch_value_store_with_expected_type(program, function_value, expr.nodes, then_block, expected, expected_type_name, out_slot, locals, end_label));
                    parts = vec.push(parts, else_label);
                    parts = vec.push(parts, ":\n");
                    parts = vec.push(parts, emit_branch_value_store_with_expected_type(program, function_value, expr.nodes, else_block, expected, expected_type_name, out_slot, locals, end_label));
                    parts = vec.push(parts, end_label);
                    parts = vec.push(parts, ":\n  ");
                    parts = vec.push(parts, llvm_expr_value_local(expr));
                    parts = vec.push(parts, " = load ");
                    parts = vec.push(parts, expected);
                    parts = vec.push(parts, ", ");
                    parts = vec.push(parts, expected);
                    parts = vec.push(parts, "* ");
                    parts = vec.push(parts, out_slot);
                    parts = vec.push(parts, "\n");
                    string.join(parts, "")
                } else { "" },
                None => "",
            },
            None => "",
        },
        None => "",
    }
}

fn emit_enum_bool_match_selects(program: IrProgram, parent_name: String, arms: Vec[IrMatchArm], prefix: String, tag_name: String, result_name: String) -> String {
    let mut parts: Vec[String] = vec.new_vec();
    let mut previous = "0";
    let mut default_index = 0;
    while default_index < vec.vec_len(arms) {
        match vec.get(arms, default_index) {
            Some(arm) => if arm.pattern_text == "_" && bool_literal_text_can_emit(arm.body_text) {
                previous = bool_literal_llvm_value(arm.body_text);
            } else {
                ()
            },
            None => (),
        };
        default_index = default_index + 1;
    };
    let mut index = 0;
    while index < vec.vec_len(arms) {
        match vec.get(arms, index) {
            Some(arm) => if arm.pattern_text == "_" {
                ()
            } else {
                let cmp_name = llvm_local(prefix, concat2(".is.", string.int_to_string(index)));
                let select_name = if index + 1 == vec.vec_len(arms) {
                    result_name
                } else {
                    llvm_local(prefix, concat2(".select.", string.int_to_string(index)))
                };
                parts = vec.push(parts, "  ");
                parts = vec.push(parts, cmp_name);
                parts = vec.push(parts, " = icmp eq i32 ");
                parts = vec.push(parts, tag_name);
                parts = vec.push(parts, ", ");
                parts = vec.push(parts, string.int_to_string(enum_variant_index(program, parent_name, match_arm_variant_text(arm.pattern_text))));
                parts = vec.push(parts, "\n  ");
                parts = vec.push(parts, select_name);
                parts = vec.push(parts, " = select i1 ");
                parts = vec.push(parts, cmp_name);
                parts = vec.push(parts, ", i1 ");
                parts = vec.push(parts, bool_literal_llvm_value(arm.body_text));
                parts = vec.push(parts, ", i1 ");
                parts = vec.push(parts, previous);
                parts = vec.push(parts, "\n");
                previous = select_name;
            },
            None => (),
        };
        index = index + 1;
    };
    if previous != result_name {
        parts = vec.push(parts, "  ");
        parts = vec.push(parts, result_name);
        parts = vec.push(parts, " = add i1 ");
        parts = vec.push(parts, previous);
        parts = vec.push(parts, ", 0\n");
    } else {
        ()
    };
    string.join(parts, "")
}

fn emit_enum_bool_match_expr_value(program: IrProgram, function_value: IrFunctionDef, expr: IrExpr, locals: BackendLocals) -> String {
    match direct_expr_child_at(expr.nodes, 0) {
        Some(scrutinee) => if true {
            let parent_name = node_type_name(program, function_value, expr.nodes, scrutinee, locals);
            let enum_ty = llvm_type_for_repr_in_program(program, parent_name);
            let scrutinee_value = node_value_name(program, function_value, expr.nodes, scrutinee, locals);
            let prefix = llvm_expr_prefix(expr.node);
            let tag_name = llvm_local(prefix, ".tag");
            let mut parts: Vec[String] = vec.new_vec();
            parts = vec.push(parts, emit_value_node(program, function_value, expr.nodes, scrutinee, locals));
            parts = vec.push(parts, "  ");
            parts = vec.push(parts, tag_name);
            parts = vec.push(parts, " = extractvalue ");
            parts = vec.push(parts, enum_ty);
            parts = vec.push(parts, " ");
            parts = vec.push(parts, scrutinee_value);
            parts = vec.push(parts, ", 0\n");
            parts = vec.push(parts, emit_enum_bool_match_selects(program, parent_name, expr.match_arms, prefix, tag_name, llvm_expr_value_local(expr)));
            string.join(parts, "")
        } else { "" },
        None => "",
    }
}

fn emit_enum_bool_match_node_value(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], node: IrExprNode, locals: BackendLocals) -> String {
    match expr_node_child_at(nodes, node, 0) {
        Some(scrutinee) => if true {
            let parent_name = node_type_name(program, function_value, nodes, scrutinee, locals);
            let enum_ty = llvm_type_for_repr_in_program(program, parent_name);
            let scrutinee_value = node_value_name(program, function_value, nodes, scrutinee, locals);
            let prefix = llvm_node_prefix(node.node);
            let tag_name = llvm_local(prefix, ".tag");
            let mut parts: Vec[String] = vec.new_vec();
            parts = vec.push(parts, emit_value_node(program, function_value, nodes, scrutinee, locals));
            parts = vec.push(parts, "  ");
            parts = vec.push(parts, tag_name);
            parts = vec.push(parts, " = extractvalue ");
            parts = vec.push(parts, enum_ty);
            parts = vec.push(parts, " ");
            parts = vec.push(parts, scrutinee_value);
            parts = vec.push(parts, ", 0\n");
            parts = vec.push(parts, emit_enum_bool_match_selects(program, parent_name, node.match_arms, prefix, tag_name, llvm_node_value_local(node)));
            string.join(parts, "")
        } else { "" },
        None => "",
    }
}

fn emit_enum_match_expr_value(program: IrProgram, function_value: IrFunctionDef, expr: IrExpr, locals: BackendLocals) -> String {
    match direct_expr_child_at(expr.nodes, 0) {
        Some(scrutinee) => if true {
            let expected = enum_match_expr_llvm_type(program, expr, function_value, locals);
            let parent_name = node_type_name(program, function_value, expr.nodes, scrutinee, locals);
            let enum_ty = llvm_type_for_repr_in_program(program, parent_name);
            let scrutinee_value = node_value_name(program, function_value, expr.nodes, scrutinee, locals);
            let prefix = llvm_expr_prefix(expr.node);
            let tag_name = llvm_local(prefix, ".tag");
            let out_slot = llvm_local(prefix, ".value.slot");
            let end_label = concat2("match.end.", string.int_to_string(expr.node.value));
            let mut parts: Vec[String] = vec.new_vec();
            parts = vec.push(parts, "  ");
            parts = vec.push(parts, out_slot);
            parts = vec.push(parts, " = alloca ");
            parts = vec.push(parts, expected);
            parts = vec.push(parts, "\n");
            parts = vec.push(parts, emit_value_node(program, function_value, expr.nodes, scrutinee, locals));
            parts = vec.push(parts, "  ");
            parts = vec.push(parts, tag_name);
            parts = vec.push(parts, " = extractvalue ");
            parts = vec.push(parts, enum_ty);
            parts = vec.push(parts, " ");
            parts = vec.push(parts, scrutinee_value);
            parts = vec.push(parts, ", 0\n  br label %");
            parts = vec.push(parts, emit_enum_match_check_prefix(prefix, 0));
            parts = vec.push(parts, "\n");
            let mut index = 0;
            while index < vec.vec_len(expr.match_arms) {
                match vec.get(expr.match_arms, index) {
                    Some(arm) => match direct_expr_child_at(expr.nodes, index + 1) {
                        Some(body) => if true {
                            let check_label = emit_enum_match_check_prefix(prefix, index);
                            let arm_label = emit_enum_match_arm_prefix(prefix, index);
                            let next_label = if index + 1 == vec.vec_len(expr.match_arms) {
                                arm_label
                            } else {
                                emit_enum_match_check_prefix(prefix, index + 1)
                            };
                            parts = vec.push(parts, check_label);
                            parts = vec.push(parts, ":\n");
                            if arm.pattern_text == "_" {
                                parts = vec.push(parts, "  br label %");
                                parts = vec.push(parts, arm_label);
                                parts = vec.push(parts, "\n");
                            } else {
                                let cmp_name = llvm_local(prefix, concat2(".is.", string.int_to_string(index)));
                                parts = vec.push(parts, "  ");
                                parts = vec.push(parts, cmp_name);
                                parts = vec.push(parts, " = icmp eq i32 ");
                                parts = vec.push(parts, tag_name);
                                parts = vec.push(parts, ", ");
                                parts = vec.push(parts, string.int_to_string(enum_variant_index(program, parent_name, match_arm_variant_text(arm.pattern_text))));
                                parts = vec.push(parts, "\n  br i1 ");
                                parts = vec.push(parts, cmp_name);
                                parts = vec.push(parts, ", label %");
                                parts = vec.push(parts, arm_label);
                                parts = vec.push(parts, ", label %");
                                parts = vec.push(parts, next_label);
                                parts = vec.push(parts, "\n");
                            };
                            parts = vec.push(parts, arm_label);
                            parts = vec.push(parts, ":\n");
                            parts = vec.push(parts, emit_enum_match_arm_payload_extract(program, parent_name, arm, prefix, index, enum_ty, scrutinee_value));
                            let arm_locals = enum_match_arm_locals(program, parent_name, arm, locals, enum_match_arm_payload_value_name(prefix, index));
                            parts = vec.push(parts, emit_branch_value_store(program, function_value, expr.nodes, body, expected, out_slot, arm_locals, end_label));
                            ()
                        } else { () },
                        None => (),
                    },
                    None => (),
                };
                index = index + 1;
            };
            parts = vec.push(parts, end_label);
            parts = vec.push(parts, ":\n  ");
            parts = vec.push(parts, llvm_expr_value_local(expr));
            parts = vec.push(parts, " = load ");
            parts = vec.push(parts, expected);
            parts = vec.push(parts, ", ");
            parts = vec.push(parts, expected);
            parts = vec.push(parts, "* ");
            parts = vec.push(parts, out_slot);
            parts = vec.push(parts, "\n");
            string.join(parts, "")
        } else { "" },
        None => "",
    }
}

