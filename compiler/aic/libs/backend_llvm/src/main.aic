                let some_label = concat2("option.match.some.", string.int_to_string(expr.node.value));
                let none_label = concat2("option.match.none.", string.int_to_string(expr.node.value));
                let end_label = concat2("option.match.end.", string.int_to_string(expr.node.value));
                let out_slot = llvm_local(prefix, ".return.slot");
                let option_name = option_match_scrutinee_expr_type_name(program, expr, function_value, locals);
                let payload_type_name = generic_arg_at(option_name, 0);
                let payload_locals = push_option_payload_local(program, locals, option_match_payload_name_from_expr(expr), payload_type_name, option_match_payload_name(prefix));
                let mut parts: Vec[String] = vec.new_vec();
                parts = vec.push(parts, emit_option_match_expr_scrutinee(program, function_value, expr, locals));
                parts = vec.push(parts, "  ");
                parts = vec.push(parts, out_slot);
                parts = vec.push(parts, " = alloca ");
                parts = vec.push(parts, ret);
                parts = vec.push(parts, "\n  br i1 ");
                parts = vec.push(parts, option_match_is_some_name(prefix));
                parts = vec.push(parts, ", label %");
                parts = vec.push(parts, some_label);
                parts = vec.push(parts, ", label %");
                parts = vec.push(parts, none_label);
                parts = vec.push(parts, "\n");
                parts = vec.push(parts, some_label);
                parts = vec.push(parts, ":\n");
                parts = vec.push(parts, emit_branch_value_store(program, function_value, expr.nodes, some_body, ret, out_slot, payload_locals, end_label));
                parts = vec.push(parts, none_label);
                parts = vec.push(parts, ":\n");
                parts = vec.push(parts, emit_branch_value_store(program, function_value, expr.nodes, none_body, ret, out_slot, locals, end_label));
                parts = vec.push(parts, end_label);
                parts = vec.push(parts, ":\n  ");
                parts = vec.push(parts, llvm_expr_value_local(expr));
                parts = vec.push(parts, " = load ");
                parts = vec.push(parts, ret);
                parts = vec.push(parts, ", ");
                parts = vec.push(parts, ret);
                parts = vec.push(parts, "* ");
                parts = vec.push(parts, out_slot);
                parts = vec.push(parts, "\n  ret ");
                parts = vec.push(parts, ret);
                parts = vec.push(parts, " ");
                parts = vec.push(parts, llvm_expr_value_local(expr));
                parts = vec.push(parts, "\n");
                string.join(parts, "")
            } else { "" },
            None => "",
        },
        None => "",
    }
}

fn emit_option_match_node_statement(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], node: IrExprNode, locals: BackendLocals) -> String {
    match result_match_node_body_node_for_variant(nodes, node, "Some") {
        Some(some_body) => match result_match_node_body_node_for_variant(nodes, node, "None") {
            Some(none_body) => if true {
                let prefix = llvm_node_prefix(node.node);
                let some_label = concat2("option.match.some.", string.int_to_string(node.node.value));
                let none_label = concat2("option.match.none.", string.int_to_string(node.node.value));
                let end_label = concat2("option.match.end.", string.int_to_string(node.node.value));
                let option_name = option_match_scrutinee_node_type_name(program, function_value, nodes, node, locals);
                let payload_type_name = generic_arg_at(option_name, 0);
                let payload_locals = push_option_payload_local(program, locals, option_match_payload_name_from_node(node), payload_type_name, option_match_payload_name(prefix));
                let mut parts: Vec[String] = vec.new_vec();
                parts = vec.push(parts, emit_option_match_node_scrutinee(program, function_value, nodes, node, locals));
                parts = vec.push(parts, "  br i1 ");
                parts = vec.push(parts, option_match_is_some_name(prefix));
                parts = vec.push(parts, ", label %");
                parts = vec.push(parts, some_label);
                parts = vec.push(parts, ", label %");
                parts = vec.push(parts, none_label);
                parts = vec.push(parts, "\n");
                parts = vec.push(parts, some_label);
                parts = vec.push(parts, ":\n");
                parts = vec.push(parts, emit_unit_statement_branch_node(program, function_value, nodes, some_body, payload_locals, end_label));
                parts = vec.push(parts, none_label);
                parts = vec.push(parts, ":\n");
                parts = vec.push(parts, emit_unit_statement_branch_node(program, function_value, nodes, none_body, locals, end_label));
                parts = vec.push(parts, end_label);
                parts = vec.push(parts, ":\n");
                string.join(parts, "")
            } else { "" },
            None => "",
        },
        None => "",
    }
}

fn emit_option_match_expr_statement(program: IrProgram, function_value: IrFunctionDef, expr: IrExpr, locals: BackendLocals) -> String {
    match result_match_expr_body_node_for_variant(expr, "Some") {
        Some(some_body) => match result_match_expr_body_node_for_variant(expr, "None") {
            Some(none_body) => if true {
                let prefix = llvm_expr_prefix(expr.node);
