                            Some(content_child) => string_call_child_can_emit(program, function_value, value.nodes, path_child, locals) && string_call_child_can_emit(program, function_value, value.nodes, content_child, locals),
                            None => false,
                        },
                        None => false,
                    }
                } else {
                    scrutinee.direct_child_count == 1 && match expr_node_child_at(value.nodes, scrutinee, 0) {
                        Some(path_child) => string_call_child_can_emit(program, function_value, value.nodes, path_child, locals),
                        None => false,
                    }
                };
                if args_ok {
                    match result_match_expr_body_node_for_variant(value, "Ok") {
                        Some(ok_body) => match result_match_expr_body_node_for_variant(value, "Err") {
                            Some(err_body) => branch_node_can_emit_with_locals(program, function_value, value.nodes, ok_body, ret, locals) && branch_node_can_emit_with_locals(program, function_value, value.nodes, err_body, ret, locals),
                            None => false,
                        },
                        None => false,
                    }
                } else {
                    false
                }
            } else {
                false
            },
            None => false,
        }
    }
}

fn fs_bool_node_can_emit(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], node: IrExprNode, locals: BackendLocals) -> Bool {
    if !is_fs_bool_result_intrinsic_name(node.name) {
        false
    } else if node.name == "write_text" {
        node.direct_child_count == 2 && match expr_node_child_at(nodes, node, 0) {
            Some(path_child) => match expr_node_child_at(nodes, node, 1) {
                Some(content_child) => string_call_child_can_emit(program, function_value, nodes, path_child, locals) && string_call_child_can_emit(program, function_value, nodes, content_child, locals),
                None => false,
            },
            None => false,
        }
    } else {
        node.direct_child_count == 1 && match expr_node_child_at(nodes, node, 0) {
            Some(path_child) => string_call_child_can_emit(program, function_value, nodes, path_child, locals),
            None => false,
        }
    }
}

fn fs_bool_expr_can_emit(program: IrProgram, function_value: IrFunctionDef, expr: IrExpr, locals: BackendLocals) -> Bool {
    if !is_fs_bool_result_intrinsic_name(expr.name) {
        false
    } else if expr.name == "write_text" {
        direct_expr_child_count(expr.nodes) == 2 && match direct_expr_child_at(expr.nodes, 0) {
            Some(path_child) => match direct_expr_child_at(expr.nodes, 1) {
                Some(content_child) => string_call_child_can_emit(program, function_value, expr.nodes, path_child, locals) && string_call_child_can_emit(program, function_value, expr.nodes, content_child, locals),
                None => false,
            },
            None => false,
        }
    } else {
        direct_expr_child_count(expr.nodes) == 1 && match direct_expr_child_at(expr.nodes, 0) {
            Some(path_child) => string_call_child_can_emit(program, function_value, expr.nodes, path_child, locals),
            None => false,
        }
    }
}

fn direct_result_match_node_can_emit_return(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], node: IrExprNode, ret: String, locals: BackendLocals) -> Bool {
    if ret != "i64" || !result_match_arms_are_ok_err(node.match_arms) {
        false
    } else {
        match expr_node_child_at(nodes, node, 0) {
            Some(scrutinee) => if is_call_expr_kind(scrutinee.kind) && !is_fs_intrinsic_name(scrutinee.name) && !is_proc_result_intrinsic_name(scrutinee.name) && direct_call_node_can_emit(program, function_value, nodes, scrutinee, locals) {
                let result_name = call_target_return_type_name(program, scrutinee.name);
                let ok_payload_type_name = result_constructor_payload_type_name(result_name, "Ok");
                let ok_payload_ty = llvm_payload_slot_type(program, ok_payload_type_name);
                let ok_payload_name = result_match_node_payload_name(node, "Ok");
                if base_type_name_text(result_name) == "Result" && ok_payload_name != "" && ok_payload_ty != "" {
                    let ok_locals = backend_locals_push(locals, backend_local(ok_payload_name, ok_payload_type_name, ok_payload_ty, llvm_local(llvm_node_prefix(node.node), ".ok.value")));
                    match result_match_node_body_node_for_variant(nodes, node, "Ok") {
                        Some(ok_body) => match result_match_node_body_node_for_variant(nodes, node, "Err") {
                            Some(err_body) => return_node_can_emit_with_locals(program, function_value, nodes, ok_body, ret, ok_locals) && return_node_can_emit_with_locals(program, function_value, nodes, err_body, ret, locals),
                            None => false,
                        },
                        None => false,
                    }
                } else {
                    false
                }
            } else {
                false
            },
            None => false,
        }
    }
}

fn direct_result_match_expr_can_emit_return(program: IrProgram, value: IrExpr, function_value: IrFunctionDef, ret: String, locals: BackendLocals) -> Bool {
    if ret != "i64" || !result_match_arms_are_ok_err(value.match_arms) {
        false
    } else {
        match direct_expr_child_at(value.nodes, 0) {
