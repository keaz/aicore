fn emit_unit_statement_tail_node(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], node: IrExprNode, locals: BackendLocals) -> String {
    match node.kind {
        IrUnitExpr => "",
        IrCallExpr => emit_void_call_node_statement(program, function_value, nodes, node, locals),
        IrIfExpr => emit_if_node_statement(program, function_value, nodes, node, locals),
        IrWhileExpr => emit_while_node_statement(program, function_value, nodes, node, locals),
        IrLoopExpr => emit_loop_node_statement(program, function_value, nodes, node, locals),
        IrForExpr => emit_for_node_statement(program, function_value, nodes, node, locals),
        IrMatchExpr => if option_vec_get_match_node_can_emit_statement(program, function_value, nodes, node, locals) {
            emit_option_vec_get_match_node_statement(program, function_value, nodes, node, locals)
        } else if option_match_node_can_emit_statement(program, function_value, nodes, node, locals) {
            emit_option_match_node_statement(program, function_value, nodes, node, locals)
        } else if enum_match_node_can_emit_statement(program, function_value, nodes, node, locals) {
            emit_enum_match_node_statement(program, function_value, nodes, node, locals)
        } else {
            ""
        },
        _ => "",
    }
}

fn emit_unit_statement_branch_node(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], branch_node: IrExprNode, locals: BackendLocals, end_label: String) -> String {
    let mut parts: Vec[String] = vec.new_vec();
    let mut returned = false;
    if is_block_expr_kind(branch_node.kind) {
        let mut out_locals = locals;
        let mut index = 0;
        while !returned && index < branch_node.direct_child_count {
            match expr_node_child_at(nodes, branch_node, index) {
                Some(child) => if block_child_is_expr(child) {
                    parts = vec.push(parts, emit_expr_node_statement(program, function_value, nodes, child, out_locals));
                    ()
                } else if block_child_is_let(child) {
                    parts = vec.push(parts, emit_let_node_value(program, function_value, nodes, child, out_locals));
                    out_locals = push_node_local(program, function_value, nodes, child, out_locals);
                    ()
                } else if block_child_is_assign(child) {
                    parts = vec.push(parts, emit_assign_node_statement(program, function_value, nodes, child, out_locals, block_assign_target_from_role(child.role)));
                    ()
                } else if block_child_is_tail(child) {
                    parts = vec.push(parts, emit_unit_statement_tail_node(program, function_value, nodes, child, out_locals));
                    ()
                } else if block_child_is_return(child) {
                    parts = vec.push(parts, emit_return_node_with_locals(program, function_value, nodes, child, llvm_type_for_id(program, function_value.return_type), out_locals));
                    returned = true;
                    ()
                } else {
                    ()
                },
                None => (),
            };
            index = index + 1;
        }
    } else {
        parts = vec.push(parts, emit_unit_statement_tail_node(program, function_value, nodes, branch_node, locals));
    };
    if returned {
        ()
    } else {
        parts = vec.push(parts, "  br label %");
        parts = vec.push(parts, end_label);
        parts = vec.push(parts, "\n");
    };
    string.join(parts, "")
}

fn loop_control_target_label(node: IrExprNode, continue_label: String, break_label: String) -> String {
    match node.kind {
        IrBreakExpr => break_label,
        IrContinueExpr => continue_label,
        _ => "",
    }
}

fn emit_loop_control_node_statement(node: IrExprNode, continue_label: String, break_label: String) -> String {
    let target = loop_control_target_label(node, continue_label, break_label);
    if target == "" {
        ""
    } else {
        concat2(concat2("  br label %", target), "\n")
    }
}

fn emit_unit_loop_statement_tail_node(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], node: IrExprNode, locals: BackendLocals, continue_label: String, break_label: String) -> String {
    if node_is_unit_loop_control(node) {
        emit_loop_control_node_statement(node, continue_label, break_label)
    } else {
        match node.kind {
            IrUnitExpr => "",
            IrCallExpr => emit_void_call_node_statement(program, function_value, nodes, node, locals),
            IrIfExpr => emit_if_node_loop_statement(program, function_value, nodes, node, locals, continue_label, break_label),
            IrWhileExpr => emit_while_node_statement(program, function_value, nodes, node, locals),
            IrLoopExpr => emit_loop_node_statement(program, function_value, nodes, node, locals),
            IrForExpr => emit_for_node_statement(program, function_value, nodes, node, locals),
            IrMatchExpr => if option_vec_get_match_node_can_emit_statement(program, function_value, nodes, node, locals) {
                emit_option_vec_get_match_node_statement(program, function_value, nodes, node, locals)
            } else if option_match_node_can_emit_statement(program, function_value, nodes, node, locals) {
                emit_option_match_node_statement(program, function_value, nodes, node, locals)
            } else if enum_match_node_can_emit_statement(program, function_value, nodes, node, locals) {
                emit_enum_match_node_statement(program, function_value, nodes, node, locals)
            } else {
                ""
            },
            _ => "",
        }
    }
}

fn emit_expr_node_loop_statement(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], node: IrExprNode, locals: BackendLocals, continue_label: String, break_label: String) -> String {
    if node_is_unit_loop_control(node) {
        emit_loop_control_node_statement(node, continue_label, break_label)
    } else {
        match node.kind {
            IrCallExpr => if call_target_return_type(program, node.name) == "void" {
                emit_void_call_node_statement(program, function_value, nodes, node, locals)
            } else if fs_bool_node_can_emit(program, function_value, nodes, node, locals) {
                emit_discard_fs_bool_node_statement(program, function_value, nodes, node, locals)
            } else {
                ""
            },
            IrIfExpr => emit_if_node_loop_statement(program, function_value, nodes, node, locals, continue_label, break_label),
            IrWhileExpr => emit_while_node_statement(program, function_value, nodes, node, locals),
            IrLoopExpr => emit_loop_node_statement(program, function_value, nodes, node, locals),
            IrForExpr => emit_for_node_statement(program, function_value, nodes, node, locals),
            IrMatchExpr => if option_vec_get_match_node_can_emit_statement(program, function_value, nodes, node, locals) {
                emit_option_vec_get_match_node_statement(program, function_value, nodes, node, locals)
            } else if option_match_node_can_emit_statement(program, function_value, nodes, node, locals) {
                emit_option_match_node_statement(program, function_value, nodes, node, locals)
            } else if enum_match_node_can_emit_statement(program, function_value, nodes, node, locals) {
                emit_enum_match_node_statement(program, function_value, nodes, node, locals)
            } else {
                ""
            },
            IrUnitExpr => "",
            _ => "",
        }
    }
}

fn emit_unit_loop_statement_branch_node(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], branch_node: IrExprNode, locals: BackendLocals, continue_label: String, break_label: String, fallthrough_label: String) -> String {
    let mut parts: Vec[String] = vec.new_vec();
    let mut terminated = false;
    if is_block_expr_kind(branch_node.kind) {
        let mut out_locals = locals;
        let mut index = 0;
        while !terminated && index < branch_node.direct_child_count {
            match expr_node_child_at(nodes, branch_node, index) {
                Some(child) => if block_child_is_expr(child) {
                    parts = vec.push(parts, emit_expr_node_loop_statement(program, function_value, nodes, child, out_locals, continue_label, break_label));
                    if node_is_unit_loop_control(child) {
                        terminated = true;
                    } else {
                        ()
                    };
                    ()
                } else if block_child_is_let(child) {
                    parts = vec.push(parts, emit_let_node_value(program, function_value, nodes, child, out_locals));
                    out_locals = push_node_local(program, function_value, nodes, child, out_locals);
                    ()
                } else if block_child_is_assign(child) {
                    parts = vec.push(parts, emit_assign_node_statement(program, function_value, nodes, child, out_locals, block_assign_target_from_role(child.role)));
                    ()
                } else if block_child_is_tail(child) {
                    parts = vec.push(parts, emit_unit_loop_statement_tail_node(program, function_value, nodes, child, out_locals, continue_label, break_label));
                    if node_is_unit_loop_control(child) {
                        terminated = true;
                    } else {
                        ()
                    };
                    ()
                } else if block_child_is_return(child) {
                    parts = vec.push(parts, emit_return_node_with_locals(program, function_value, nodes, child, llvm_type_for_id(program, function_value.return_type), out_locals));
                    terminated = true;
                    ()
                } else {
                    ()
                },
                None => (),
            };
            index = index + 1;
        }
    } else {
        parts = vec.push(parts, emit_unit_loop_statement_tail_node(program, function_value, nodes, branch_node, locals, continue_label, break_label));
        if node_is_unit_loop_control(branch_node) {
            terminated = true;
        } else {
            ()
        }
    };
    if terminated {
        ()
    } else {
        parts = vec.push(parts, "  br label %");
        parts = vec.push(parts, fallthrough_label);
        parts = vec.push(parts, "\n");
    };
    string.join(parts, "")
}

fn emit_loop_value_break_node(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], node: IrExprNode, locals: BackendLocals, expected: String, expected_type_name: String, result_slot: String, end_label: String) -> String {
    match break_value_node_child(nodes, node) {
        Some(child) => if true {
            let mut parts: Vec[String] = vec.new_vec();
            let value_name = if expected_enum_constructor_node_can_emit(program, function_value, nodes, child, locals, expected_type_name) {
                parts = vec.push(parts, emit_expected_enum_constructor_node_value(program, function_value, nodes, child, locals, expected, expected_type_name));
                expected_enum_constructor_node_value_name(child)
            } else {
                parts = vec.push(parts, emit_value_node(program, function_value, nodes, child, locals));
                node_value_name(program, function_value, nodes, child, locals)
            };
            parts = vec.push(parts, emit_store_to_local(expected, value_name, result_slot));
            parts = vec.push(parts, "  br label %");
            parts = vec.push(parts, end_label);
            parts = vec.push(parts, "\n");
            string.join(parts, "")
        } else { "" },
        None => "",
    }
}

fn emit_loop_value_statement_node(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], node: IrExprNode, locals: BackendLocals, expected: String, expected_type_name: String, result_slot: String, continue_label: String, end_label: String, fallthrough_label: String) -> String {
    if node_is_value_break(node) {
        emit_loop_value_break_node(program, function_value, nodes, node, locals, expected, expected_type_name, result_slot, end_label)
    } else if node_is_continue_control(node) {
        emit_loop_control_node_statement(node, continue_label, end_label)
    } else {
        match node.kind {
            IrUnitExpr => "",
            IrCallExpr => if call_target_return_type(program, node.name) == "void" {
                emit_void_call_node_statement(program, function_value, nodes, node, locals)
            } else if fs_bool_node_can_emit(program, function_value, nodes, node, locals) {
                emit_discard_fs_bool_node_statement(program, function_value, nodes, node, locals)
            } else {
                ""
            },
            IrIfExpr => emit_loop_value_if_node_statement(program, function_value, nodes, node, locals, expected, expected_type_name, result_slot, continue_label, end_label),
            IrWhileExpr => emit_while_node_statement(program, function_value, nodes, node, locals),
            IrLoopExpr => emit_loop_node_statement(program, function_value, nodes, node, locals),
            IrForExpr => emit_for_node_statement(program, function_value, nodes, node, locals),
            IrMatchExpr => if option_vec_get_match_node_can_emit_statement(program, function_value, nodes, node, locals) {
                emit_option_vec_get_match_node_statement(program, function_value, nodes, node, locals)
            } else if option_match_node_can_emit_statement(program, function_value, nodes, node, locals) {
                emit_option_match_node_statement(program, function_value, nodes, node, locals)
            } else if enum_match_node_can_emit_statement(program, function_value, nodes, node, locals) {
                emit_enum_match_node_statement(program, function_value, nodes, node, locals)
            } else {
                ""
            },
            _ => "",
        }
    }
}

fn emit_loop_value_branch_node(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], branch_node: IrExprNode, locals: BackendLocals, expected: String, expected_type_name: String, result_slot: String, continue_label: String, end_label: String, fallthrough_label: String) -> String {
    let mut parts: Vec[String] = vec.new_vec();
    let mut terminated = false;
    if is_block_expr_kind(branch_node.kind) {
        let mut out_locals = locals;
        let mut index = 0;
        while !terminated && index < branch_node.direct_child_count {
            match expr_node_child_at(nodes, branch_node, index) {
                Some(child) => if block_child_is_let(child) {
                    parts = vec.push(parts, emit_let_node_value(program, function_value, nodes, child, out_locals));
                    out_locals = push_node_local(program, function_value, nodes, child, out_locals);
                    ()
                } else if block_child_is_assign(child) {
                    parts = vec.push(parts, emit_assign_node_statement(program, function_value, nodes, child, out_locals, block_assign_target_from_role(child.role)));
                    ()
                } else if block_child_is_return(child) {
                    parts = vec.push(parts, emit_return_node_with_locals(program, function_value, nodes, child, llvm_type_for_id(program, function_value.return_type), out_locals));
                    terminated = true;
                    ()
                } else if block_child_is_expr(child) || block_child_is_tail(child) {
                    parts = vec.push(parts, emit_loop_value_statement_node(program, function_value, nodes, child, out_locals, expected, expected_type_name, result_slot, continue_label, end_label, fallthrough_label));
                    if node_is_value_break(child) || node_is_continue_control(child) {
                        terminated = true;
                    } else {
                        ()
                    };
                    ()
                } else {
                    ()
                },
                None => (),
            };
            index = index + 1;
        }
    } else {
        parts = vec.push(parts, emit_loop_value_statement_node(program, function_value, nodes, branch_node, locals, expected, expected_type_name, result_slot, continue_label, end_label, fallthrough_label));
        if node_is_value_break(branch_node) || node_is_continue_control(branch_node) {
            terminated = true;
        } else {
            ()
        };
    };
    if terminated {
        ()
    } else {
        parts = vec.push(parts, "  br label %");
        parts = vec.push(parts, fallthrough_label);
        parts = vec.push(parts, "\n");
    };
    string.join(parts, "")
}

fn emit_loop_value_if_node_statement(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], node: IrExprNode, locals: BackendLocals, expected: String, expected_type_name: String, result_slot: String, continue_label: String, end_label: String) -> String {
    match expr_node_child_at(nodes, node, 0) {
        Some(condition) => match expr_node_child_at(nodes, node, 1) {
            Some(then_block) => match expr_node_child_at(nodes, node, 2) {
                Some(else_block) => if true {
                    let then_label = concat2("if.loop.value.then.", string.int_to_string(node.node.value));
                    let else_label = concat2("if.loop.value.else.", string.int_to_string(node.node.value));
                    let join_label = concat2("if.loop.value.end.", string.int_to_string(node.node.value));
                    let mut parts: Vec[String] = vec.new_vec();
                    parts = vec.push(parts, emit_bool_node_value(program, function_value, nodes, condition, locals));
                    parts = vec.push(parts, "  br i1 ");
                    parts = vec.push(parts, bool_node_value_name_with_locals(function_value, locals, condition));
                    parts = vec.push(parts, ", label %");
                    parts = vec.push(parts, then_label);
                    parts = vec.push(parts, ", label %");
                    parts = vec.push(parts, else_label);
                    parts = vec.push(parts, "\n");
                    parts = vec.push(parts, then_label);
                    parts = vec.push(parts, ":\n");
                    parts = vec.push(parts, emit_loop_value_branch_node(program, function_value, nodes, then_block, locals, expected, expected_type_name, result_slot, continue_label, end_label, join_label));
                    parts = vec.push(parts, else_label);
                    parts = vec.push(parts, ":\n");
                    parts = vec.push(parts, emit_loop_value_branch_node(program, function_value, nodes, else_block, locals, expected, expected_type_name, result_slot, continue_label, end_label, join_label));
                    parts = vec.push(parts, join_label);
                    parts = vec.push(parts, ":\n");
                    string.join(parts, "")
                } else { "" },
                None => "",
            },
            None => "",
        },
        None => "",
    }
}

fn emit_loop_value_with_type(prefix: String, id_value: Int, program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], body_node: IrExprNode, locals: BackendLocals, expected: String, expected_type_name: String) -> String {
    let body_label = concat2("loop.body.", string.int_to_string(id_value));
    let end_label = concat2("loop.end.", string.int_to_string(id_value));
    let result_slot = llvm_local(prefix, ".break.slot");
    let result_value = llvm_local(prefix, ".value");
    let mut parts: Vec[String] = vec.new_vec();
    parts = vec.push(parts, emit_alloca_for_local(expected, result_slot));
    parts = vec.push(parts, "  br label %");
    parts = vec.push(parts, body_label);
    parts = vec.push(parts, "\n");
    parts = vec.push(parts, body_label);
    parts = vec.push(parts, ":\n");
    parts = vec.push(parts, emit_loop_value_branch_node(program, function_value, nodes, body_node, locals, expected, expected_type_name, result_slot, body_label, end_label, body_label));
    parts = vec.push(parts, end_label);
    parts = vec.push(parts, ":\n  ");
    parts = vec.push(parts, result_value);
    parts = vec.push(parts, " = load ");
    parts = vec.push(parts, expected);
    parts = vec.push(parts, ", ");
    parts = vec.push(parts, expected);
    parts = vec.push(parts, "* ");
    parts = vec.push(parts, result_slot);
    parts = vec.push(parts, "\n");
    string.join(parts, "")
}

fn emit_loop_expr_value(program: IrProgram, function_value: IrFunctionDef, expr: IrExpr, locals: BackendLocals) -> String {
    match direct_expr_child_at(expr.nodes, 0) {
        Some(body) => emit_loop_value_with_type(llvm_expr_prefix(expr.node), expr.node.value, program, function_value, expr.nodes, body, locals, value_expr_llvm_type(program, expr, function_value, locals), loop_expr_value_type_name(program, expr, function_value, locals)),
        None => "",
    }
}

fn emit_loop_node_value(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], node: IrExprNode, locals: BackendLocals) -> String {
    match expr_node_child_at(nodes, node, 0) {
        Some(body) => emit_loop_value_with_type(llvm_node_prefix(node.node), node.node.value, program, function_value, nodes, body, locals, value_node_llvm_type(program, function_value, nodes, node, locals), loop_node_value_type_name(program, function_value, nodes, node, locals)),
        None => "",
    }
}

fn emit_loop_unit_statement(prefix: String, id_value: Int, program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], body_node: IrExprNode, locals: BackendLocals) -> String {
    let body_label = concat2("loop.body.", string.int_to_string(id_value));
    let end_label = concat2("loop.end.", string.int_to_string(id_value));
    let mut parts: Vec[String] = vec.new_vec();
    parts = vec.push(parts, "  br label %");
    parts = vec.push(parts, body_label);
    parts = vec.push(parts, "\n");
    parts = vec.push(parts, body_label);
    parts = vec.push(parts, ":\n");
    parts = vec.push(parts, emit_unit_loop_statement_branch_node(program, function_value, nodes, body_node, locals, body_label, end_label, body_label));
    parts = vec.push(parts, end_label);
    parts = vec.push(parts, ":\n");
    string.join(parts, "")
}

fn emit_loop_node_statement(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], node: IrExprNode, locals: BackendLocals) -> String {
    match expr_node_child_at(nodes, node, 0) {
        Some(body) => emit_loop_unit_statement(llvm_node_prefix(node.node), node.node.value, program, function_value, nodes, body, locals),
        None => "",
    }
}

fn emit_loop_expr_statement(program: IrProgram, function_value: IrFunctionDef, expr: IrExpr, locals: BackendLocals) -> String {
    match direct_expr_child_at(expr.nodes, 0) {
        Some(body) => emit_loop_unit_statement(llvm_expr_prefix(expr.node), expr.node.value, program, function_value, expr.nodes, body, locals),
        None => "",
    }
}

fn emit_while_node_statement(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], node: IrExprNode, locals: BackendLocals) -> String {
    match expr_node_child_at(nodes, node, 0) {
        Some(condition) => match expr_node_child_at(nodes, node, 1) {
            Some(body) => if true {
                let cond_label = concat2("while.cond.", string.int_to_string(node.node.value));
                let body_label = concat2("while.body.", string.int_to_string(node.node.value));
                let end_label = concat2("while.end.", string.int_to_string(node.node.value));
                let mut parts: Vec[String] = vec.new_vec();
                parts = vec.push(parts, "  br label %");
                parts = vec.push(parts, cond_label);
                parts = vec.push(parts, "\n");
                parts = vec.push(parts, cond_label);
                parts = vec.push(parts, ":\n");
                parts = vec.push(parts, emit_bool_node_value(program, function_value, nodes, condition, locals));
                parts = vec.push(parts, "  br i1 ");
                parts = vec.push(parts, bool_node_value_name_with_locals(function_value, locals, condition));
                parts = vec.push(parts, ", label %");
                parts = vec.push(parts, body_label);
                parts = vec.push(parts, ", label %");
                parts = vec.push(parts, end_label);
                parts = vec.push(parts, "\n");
                parts = vec.push(parts, body_label);
                parts = vec.push(parts, ":\n");
                parts = vec.push(parts, emit_unit_loop_statement_branch_node(program, function_value, nodes, body, locals, cond_label, end_label, cond_label));
                parts = vec.push(parts, end_label);
                parts = vec.push(parts, ":\n");
                string.join(parts, "")
            } else { "" },
            None => "",
        },
        None => "",
    }
}

fn emit_while_expr_statement(program: IrProgram, function_value: IrFunctionDef, expr: IrExpr, locals: BackendLocals) -> String {
    match direct_expr_child_at(expr.nodes, 0) {
        Some(condition) => match direct_expr_child_at(expr.nodes, 1) {
            Some(body) => if true {
                let cond_label = concat2("while.cond.", string.int_to_string(expr.node.value));
                let body_label = concat2("while.body.", string.int_to_string(expr.node.value));
                let end_label = concat2("while.end.", string.int_to_string(expr.node.value));
                let mut parts: Vec[String] = vec.new_vec();
                parts = vec.push(parts, "  br label %");
                parts = vec.push(parts, cond_label);
                parts = vec.push(parts, "\n");
                parts = vec.push(parts, cond_label);
                parts = vec.push(parts, ":\n");
                parts = vec.push(parts, emit_bool_node_value(program, function_value, expr.nodes, condition, locals));
                parts = vec.push(parts, "  br i1 ");
                parts = vec.push(parts, bool_node_value_name_with_locals(function_value, locals, condition));
                parts = vec.push(parts, ", label %");
                parts = vec.push(parts, body_label);
                parts = vec.push(parts, ", label %");
                parts = vec.push(parts, end_label);
                parts = vec.push(parts, "\n");
                parts = vec.push(parts, body_label);
                parts = vec.push(parts, ":\n");
                parts = vec.push(parts, emit_unit_loop_statement_branch_node(program, function_value, expr.nodes, body, locals, cond_label, end_label, cond_label));
                parts = vec.push(parts, end_label);
                parts = vec.push(parts, ":\n");
                string.join(parts, "")
            } else { "" },
            None => "",
        },
        None => "",
    }
}

fn emit_for_range_statement(prefix: String, id_value: Int, program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], range_node: IrExprNode, body_node: IrExprNode, body_locals: BackendLocals, locals: BackendLocals) -> String {
    match expr_node_child_at(nodes, range_node, 0) {
        Some(start_node) => match expr_node_child_at(nodes, range_node, 1) {
            Some(end_node) => if true {
                let cond_label = concat2("for.cond.", string.int_to_string(id_value));
                let body_label = concat2("for.body.", string.int_to_string(id_value));
                let inc_label = concat2("for.inc.", string.int_to_string(id_value));
                let end_label = concat2("for.end.", string.int_to_string(id_value));
                let cur_slot = llvm_local(prefix, ".range.cur.slot");
                let end_slot = llvm_local(prefix, ".range.end.slot");
                let cur_value = llvm_local(prefix, ".range.cur");
                let end_value = llvm_local(prefix, ".range.end");
                let cmp_value = llvm_local(prefix, ".range.cmp");
                let next_value = llvm_local(prefix, ".range.next");
                let mut parts: Vec[String] = vec.new_vec();
                parts = vec.push(parts, emit_value_node(program, function_value, nodes, start_node, locals));
                parts = vec.push(parts, emit_value_node(program, function_value, nodes, end_node, locals));
                parts = vec.push(parts, emit_alloca_for_local("i64", cur_slot));
                parts = vec.push(parts, emit_store_to_local("i64", node_value_name(program, function_value, nodes, start_node, locals), cur_slot));
                parts = vec.push(parts, emit_alloca_for_local("i64", end_slot));
                parts = vec.push(parts, emit_store_to_local("i64", node_value_name(program, function_value, nodes, end_node, locals), end_slot));
                parts = vec.push(parts, "  br label %");
                parts = vec.push(parts, cond_label);
                parts = vec.push(parts, "\n");
                parts = vec.push(parts, cond_label);
                parts = vec.push(parts, ":\n  ");
                parts = vec.push(parts, cur_value);
                parts = vec.push(parts, " = load i64, i64* ");
                parts = vec.push(parts, cur_slot);
                parts = vec.push(parts, "\n  ");
                parts = vec.push(parts, end_value);
                parts = vec.push(parts, " = load i64, i64* ");
                parts = vec.push(parts, end_slot);
                parts = vec.push(parts, "\n  ");
                parts = vec.push(parts, cmp_value);
                parts = vec.push(parts, " = icmp slt i64 ");
                parts = vec.push(parts, cur_value);
                parts = vec.push(parts, ", ");
                parts = vec.push(parts, end_value);
                parts = vec.push(parts, "\n  br i1 ");
                parts = vec.push(parts, cmp_value);
                parts = vec.push(parts, ", label %");
                parts = vec.push(parts, body_label);
                parts = vec.push(parts, ", label %");
                parts = vec.push(parts, end_label);
                parts = vec.push(parts, "\n");
                parts = vec.push(parts, body_label);
                parts = vec.push(parts, ":\n");
                parts = vec.push(parts, emit_unit_loop_statement_branch_node(program, function_value, nodes, body_node, body_locals, inc_label, end_label, inc_label));
                parts = vec.push(parts, inc_label);
                parts = vec.push(parts, ":\n  ");
                parts = vec.push(parts, next_value);
                parts = vec.push(parts, " = add i64 ");
                parts = vec.push(parts, cur_value);
                parts = vec.push(parts, ", 1\n");
                parts = vec.push(parts, emit_store_to_local("i64", next_value, cur_slot));
                parts = vec.push(parts, "  br label %");
                parts = vec.push(parts, cond_label);
                parts = vec.push(parts, "\n");
                parts = vec.push(parts, end_label);
                parts = vec.push(parts, ":\n");
                string.join(parts, "")
            } else { "" },
            None => "",
        },
        None => "",
    }
}

fn emit_for_iter_statement(prefix: String, id_value: Int, program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], iterable_node: IrExprNode, body_node: IrExprNode, body_locals: BackendLocals, locals: BackendLocals) -> String {
    let vec_ty = value_node_llvm_type(program, function_value, nodes, iterable_node, locals);
    let vec_value = node_value_name(program, function_value, nodes, iterable_node, locals);
    let elem_name = for_iter_vec_elem_type_name(node_type_name(program, function_value, nodes, iterable_node, locals));
    let elem_ty = llvm_type_for_repr_in_program(program, elem_name);
    let cond_label = concat2("for.iter.cond.", string.int_to_string(id_value));
    let body_label = concat2("for.iter.body.", string.int_to_string(id_value));
    let ready_label = concat2("for.iter.ready.", string.int_to_string(id_value));
    let inc_label = concat2("for.iter.inc.", string.int_to_string(id_value));
    let end_label = concat2("for.iter.end.", string.int_to_string(id_value));
    let idx_slot = llvm_local(prefix, ".iter.index.slot");
    let idx_value = llvm_local(prefix, ".iter.index");
    let len_value = llvm_local(prefix, ".iter.len");
    let cmp_value = llvm_local(prefix, ".iter.cmp");
    let next_value = llvm_local(prefix, ".iter.next");
    let probe_prefix = concat2(prefix, ".iter.get");
    let mut parts: Vec[String] = vec.new_vec();
    parts = vec.push(parts, emit_value_node(program, function_value, nodes, iterable_node, locals));
    parts = vec.push(parts, "  ");
    parts = vec.push(parts, len_value);
    parts = vec.push(parts, " = extractvalue ");
    parts = vec.push(parts, vec_ty);
    parts = vec.push(parts, " ");
    parts = vec.push(parts, vec_value);
    parts = vec.push(parts, ", 1\n");
    parts = vec.push(parts, emit_alloca_for_local("i64", idx_slot));
    parts = vec.push(parts, emit_store_to_local("i64", "0", idx_slot));
    parts = vec.push(parts, "  br label %");
    parts = vec.push(parts, cond_label);
    parts = vec.push(parts, "\n");
    parts = vec.push(parts, cond_label);
    parts = vec.push(parts, ":\n  ");
    parts = vec.push(parts, idx_value);
    parts = vec.push(parts, " = load i64, i64* ");
    parts = vec.push(parts, idx_slot);
    parts = vec.push(parts, "\n  ");
    parts = vec.push(parts, cmp_value);
    parts = vec.push(parts, " = icmp slt i64 ");
    parts = vec.push(parts, idx_value);
    parts = vec.push(parts, ", ");
    parts = vec.push(parts, len_value);
    parts = vec.push(parts, "\n  br i1 ");
    parts = vec.push(parts, cmp_value);
    parts = vec.push(parts, ", label %");
    parts = vec.push(parts, body_label);
    parts = vec.push(parts, ", label %");
    parts = vec.push(parts, end_label);
    parts = vec.push(parts, "\n");
    parts = vec.push(parts, body_label);
    parts = vec.push(parts, ":\n");
    parts = vec.push(parts, emit_vec_get_probe(probe_prefix, vec_ty, elem_ty, vec_value, idx_value));
    parts = vec.push(parts, "  br i1 ");
    parts = vec.push(parts, vec_get_found_bool_name(probe_prefix));
    parts = vec.push(parts, ", label %");
    parts = vec.push(parts, ready_label);
    parts = vec.push(parts, ", label %");
    parts = vec.push(parts, end_label);
    parts = vec.push(parts, "\n");
    parts = vec.push(parts, ready_label);
    parts = vec.push(parts, ":\n");
    parts = vec.push(parts, emit_unit_loop_statement_branch_node(program, function_value, nodes, body_node, body_locals, inc_label, end_label, inc_label));
    parts = vec.push(parts, inc_label);
    parts = vec.push(parts, ":\n  ");
    parts = vec.push(parts, next_value);
    parts = vec.push(parts, " = add i64 ");
    parts = vec.push(parts, idx_value);
    parts = vec.push(parts, ", 1\n");
    parts = vec.push(parts, emit_store_to_local("i64", next_value, idx_slot));
    parts = vec.push(parts, "  br label %");
    parts = vec.push(parts, cond_label);
    parts = vec.push(parts, "\n");
    parts = vec.push(parts, end_label);
    parts = vec.push(parts, ":\n");
    string.join(parts, "")
}

fn emit_for_node_statement(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], node: IrExprNode, locals: BackendLocals) -> String {
    match expr_node_child_at(nodes, node, 0) {
        Some(iterable_node) => match expr_node_child_at(nodes, node, 1) {
            Some(body_node) => if node_is_range_expr(iterable_node) {
                emit_for_range_statement(llvm_node_prefix(node.node), node.node.value, program, function_value, nodes, iterable_node, body_node, for_node_body_locals(node, locals), locals)
            } else {
                emit_for_iter_statement(llvm_node_prefix(node.node), node.node.value, program, function_value, nodes, iterable_node, body_node, for_node_iter_body_locals(program, function_value, nodes, node, locals), locals)
            },
            None => "",
        },
        None => "",
    }
}

fn emit_for_expr_statement(program: IrProgram, function_value: IrFunctionDef, expr: IrExpr, locals: BackendLocals) -> String {
    match direct_expr_child_at(expr.nodes, 0) {
        Some(iterable_node) => match direct_expr_child_at(expr.nodes, 1) {
            Some(body_node) => if node_is_range_expr(iterable_node) {
                emit_for_range_statement(llvm_expr_prefix(expr.node), expr.node.value, program, function_value, expr.nodes, iterable_node, body_node, for_expr_body_locals(expr, locals), locals)
            } else {
                emit_for_iter_statement(llvm_expr_prefix(expr.node), expr.node.value, program, function_value, expr.nodes, iterable_node, body_node, for_expr_iter_body_locals(program, function_value, expr, locals), locals)
            },
            None => "",
        },
        None => "",
    }
}

fn emit_if_node_statement(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], node: IrExprNode, locals: BackendLocals) -> String {
    match expr_node_child_at(nodes, node, 0) {
        Some(condition) => match expr_node_child_at(nodes, node, 1) {
            Some(then_block) => match expr_node_child_at(nodes, node, 2) {
                Some(else_block) => if true {
                    let then_label = concat2("if.stmt.then.", string.int_to_string(node.node.value));
                    let else_label = concat2("if.stmt.else.", string.int_to_string(node.node.value));
                    let end_label = concat2("if.stmt.end.", string.int_to_string(node.node.value));
                    let mut parts: Vec[String] = vec.new_vec();
                    parts = vec.push(parts, emit_bool_node_value(program, function_value, nodes, condition, locals));
                    parts = vec.push(parts, "  br i1 ");
                    parts = vec.push(parts, bool_node_value_name_with_locals(function_value, locals, condition));
                    parts = vec.push(parts, ", label %");
                    parts = vec.push(parts, then_label);
                    parts = vec.push(parts, ", label %");
                    parts = vec.push(parts, else_label);
                    parts = vec.push(parts, "\n");
                    parts = vec.push(parts, then_label);
                    parts = vec.push(parts, ":\n");
                    parts = vec.push(parts, emit_unit_statement_branch_node(program, function_value, nodes, then_block, locals, end_label));
                    parts = vec.push(parts, else_label);
                    parts = vec.push(parts, ":\n");
                    parts = vec.push(parts, emit_unit_statement_branch_node(program, function_value, nodes, else_block, locals, end_label));
                    parts = vec.push(parts, end_label);
                    parts = vec.push(parts, ":\n");
                    string.join(parts, "")
                } else { "" },
                None => "",
            },
            None => "",
        },
        None => "",
    }
}

