        } else if field_name == "schema_version" {
            1
        } else if field_name == "artifact_name" {
            2
        } else if field_name == "file_name" {
            3
        } else if field_name == "artifact_kind" {
            4
        } else if field_name == "target_triple" {
            5
        } else if field_name == "llvm_ir" {
            6
        } else if field_name == "symbols" {
            7
        } else if field_name == "features" {
            8
        } else if field_name == "native_links" {
            9
        } else if field_name == "digest" {
            10
        } else if field_name == "diagnostics" {
            11
        } else {
            -1
        }
    } else if name == "DriverSource" {
        if field_name == "path" {
            0
        } else if field_name == "text" {
            1
        } else if field_name == "source" {
            2
        } else {
            -1
        }
    } else if name == "DriverCommandResult" {
        if field_name == "exit_code" {
            0
        } else if field_name == "stdout" {
            1
        } else if field_name == "stderr" {
            2
        } else if field_name == "artifact_path" {
            3
        } else if field_name == "artifact_text" {
            4
        } else if field_name == "diagnostics" {
            5
        } else {
            -1
        }
    } else if name == "ProcOutput" {
        if field_name == "status" {
            0
        } else if field_name == "stdout" {
            1
        } else if field_name == "stderr" {
            2
        } else {
            -1
        }
    } else {
        -1
    }
}

fn struct_item_field_index_by_name(program: IrProgram, name: String, field_name: String) -> Int {
    let mut item_index = 0;
    let mut out = -1;
    while out < 0 && item_index < vec.vec_len(program.items) {
        match vec.get(program.items, item_index) {
            Some(item) => match item {
                IrStructItemValue(struct_value) => if struct_value.name == name {
                    let mut field_index = 0;
                    while out < 0 && field_index < vec.vec_len(struct_value.fields) {
                        match vec.get(struct_value.fields, field_index) {
                            Some(field) => if field.name == field_name {
                                out = field_index;
                            } else {
                                ()
                            },
                            None => (),
                        };
                        field_index = field_index + 1;
                    };
                    ()
                } else {
                    ()
                },
                _ => (),
            },
            None => (),
        };
        item_index = item_index + 1;
    };
    out
}

fn struct_field_index_by_name(program: IrProgram, name: String, field_name: String) -> Int {
    let known = known_struct_field_index_by_name(name, field_name);
    if known >= 0 {
        known
    } else {
        struct_item_field_index_by_name(program, name, field_name)
    }
}

fn field_access_name_from_text(value: String) -> String {
    let mut index = 0;
    let mut start = 0;
    while index < string.len(value) {
        if string.substring(value, index, index + 1) == "." {
            start = index + 1;
        } else {
            ()
        };
        index = index + 1;
    };
    string.substring(value, start, string.len(value))
}

fn field_access_field_name(node: IrExprNode) -> String {
    if node.name != "" {
        node.name
    } else {
        field_access_name_from_text(node.text)
    }
}

fn field_access_base_node(nodes: Vec[IrExprNode], node: IrExprNode) -> Option[IrExprNode] {
    expr_node_child_at(nodes, node, 0)
}

fn field_access_base_type_name(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], node: IrExprNode, locals: BackendLocals) -> String {
    match field_access_base_node(nodes, node) {
        Some(base) => node_type_name(program, function_value, nodes, base, locals),
        None => "",
    }
}

fn field_access_node_llvm_type(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], node: IrExprNode, locals: BackendLocals) -> String {
    let base_type = field_access_base_type_name(program, function_value, nodes, node, locals);
    let field_index = struct_field_index_by_name(program, base_type, field_access_field_name(node));
    if base_type == "" || field_index < 0 {
        ""
    } else {
        struct_field_llvm_type_by_index(program, base_type, field_index)
    }
}

fn field_access_node_type_name(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], node: IrExprNode, locals: BackendLocals) -> String {
    let base_type = field_access_base_type_name(program, function_value, nodes, node, locals);
    let field_index = struct_field_index_by_name(program, base_type, field_access_field_name(node));
    if base_type == "" || field_index < 0 {
        ""
    } else {
        struct_field_type_name_by_index(program, base_type, field_index)
    }
}

fn field_access_node_can_emit(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], node: IrExprNode, locals: BackendLocals, expected: String) -> Bool {
    field_access_node_llvm_type(program, function_value, nodes, node, locals) == expected
}

fn field_access_base_value_name(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], node: IrExprNode, locals: BackendLocals) -> String {
    match field_access_base_node(nodes, node) {
        Some(base) => node_value_name(program, function_value, nodes, base, locals),
        None => "",
    }
}

fn emit_field_access_node_value(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], node: IrExprNode, locals: BackendLocals) -> String {
    let base_type = field_access_base_type_name(program, function_value, nodes, node, locals);
    let field_index = struct_field_index_by_name(program, base_type, field_access_field_name(node));
    let field_ty = if field_index >= 0 {
        struct_field_llvm_type_by_index(program, base_type, field_index)
    } else {
        ""
    };
    let base_value = field_access_base_value_name(program, function_value, nodes, node, locals);
    if base_type == "" || field_ty == "" || base_value == "" || field_index < 0 {
        ""
    } else {
        let mut parts: Vec[String] = vec.new_vec();
        match field_access_base_node(nodes, node) {
            Some(base) => if true {
                parts = vec.push(parts, emit_value_node(program, function_value, nodes, base, locals));
                ()
            } else { () },
            None => (),
        };
        parts = vec.push(parts, "  ");
        parts = vec.push(parts, llvm_node_value_local(node));
        parts = vec.push(parts, " = extractvalue ");
        parts = vec.push(parts, llvm_type_for_repr_in_program(program, base_type));
        parts = vec.push(parts, " ");
        parts = vec.push(parts, base_value);
        parts = vec.push(parts, ", ");
        parts = vec.push(parts, string.int_to_string(field_index));
        parts = vec.push(parts, "\n");
        string.join(parts, "")
    }
}

fn field_access_expr_base_type_name(program: IrProgram, function_value: IrFunctionDef, value: IrExpr, locals: BackendLocals) -> String {
    match direct_expr_child_at(value.nodes, 0) {
        Some(base) => node_type_name(program, function_value, value.nodes, base, locals),
        None => "",
    }
}

fn field_access_expr_base_value_name(program: IrProgram, function_value: IrFunctionDef, value: IrExpr, locals: BackendLocals) -> String {
    match direct_expr_child_at(value.nodes, 0) {
        Some(base) => node_value_name(program, function_value, value.nodes, base, locals),
        None => "",
    }
}

fn field_access_expr_llvm_type(program: IrProgram, function_value: IrFunctionDef, value: IrExpr, locals: BackendLocals) -> String {
    let base_type = field_access_expr_base_type_name(program, function_value, value, locals);
    let field_index = struct_field_index_by_name(program, base_type, value.name);
    if base_type == "" || field_index < 0 {
        ""
    } else {
        struct_field_llvm_type_by_index(program, base_type, field_index)
    }
}

fn field_access_expr_type_name(program: IrProgram, function_value: IrFunctionDef, value: IrExpr, locals: BackendLocals) -> String {
    let base_type = field_access_expr_base_type_name(program, function_value, value, locals);
    let field_index = struct_field_index_by_name(program, base_type, value.name);
    if base_type == "" || field_index < 0 {
        ""
    } else {
        struct_field_type_name_by_index(program, base_type, field_index)
    }
}

fn field_access_expr_can_emit(program: IrProgram, function_value: IrFunctionDef, value: IrExpr, locals: BackendLocals, expected: String) -> Bool {
    field_access_expr_llvm_type(program, function_value, value, locals) == expected
}

fn emit_field_access_expr_value(program: IrProgram, function_value: IrFunctionDef, value: IrExpr, locals: BackendLocals) -> String {
    let base_type = field_access_expr_base_type_name(program, function_value, value, locals);
    let field_index = struct_field_index_by_name(program, base_type, value.name);
    let field_ty = if field_index >= 0 {
        struct_field_llvm_type_by_index(program, base_type, field_index)
    } else {
        ""
    };
    let base_value = field_access_expr_base_value_name(program, function_value, value, locals);
    if base_type == "" || field_ty == "" || base_value == "" || field_index < 0 {
        ""
    } else {
        let mut parts: Vec[String] = vec.new_vec();
        match direct_expr_child_at(value.nodes, 0) {
            Some(base) => if true {
                parts = vec.push(parts, emit_value_node(program, function_value, value.nodes, base, locals));
                ()
            } else { () },
            None => (),
        };
        parts = vec.push(parts, "  ");
        parts = vec.push(parts, llvm_expr_value_local(value));
        parts = vec.push(parts, " = extractvalue ");
        parts = vec.push(parts, llvm_type_for_repr_in_program(program, base_type));
        parts = vec.push(parts, " ");
        parts = vec.push(parts, base_value);
        parts = vec.push(parts, ", ");
        parts = vec.push(parts, string.int_to_string(field_index));
        parts = vec.push(parts, "\n");
        string.join(parts, "")
    }
}

fn llvm_int_bits(value: String) -> Int {
    if value == "i8" {
        8
    } else if value == "i16" {
        16
    } else if value == "i32" {
        32
    } else if value == "i64" {
        64
    } else {
        0
    }
}

fn type_name_is_signed_integer(value: String) -> Bool {
    value == "Int" || value == "Int8" || value == "Int16" || value == "Int32" || value == "Int64" || value == "Int128" || value == "isize" || value == "ProcExitStatus"
}

fn llvm_integer_extension_op(source_type_name: String, source_llvm: String, target_llvm: String) -> String {
    let source_bits = llvm_int_bits(source_llvm);
    let target_bits = llvm_int_bits(target_llvm);
    if source_bits > 0 && target_bits > source_bits {
        if type_name_is_signed_integer(source_type_name) {
            "sext"
        } else {
            "zext"
        }
    } else {
        ""
    }
}

fn function_param_return_cast_op(program: IrProgram, function_value: IrFunctionDef, name: String, ret: String) -> String {
    let source_llvm = function_param_llvm_type(program, function_value, name);
    if source_llvm == ret {
        ""
    } else {
        llvm_integer_extension_op(function_param_type_name(program, function_value, name), source_llvm, ret)
    }
}

fn return_name_can_emit_with_locals(program: IrProgram, function_value: IrFunctionDef, locals: BackendLocals, name: String, ret: String) -> Bool {
    let source_llvm = llvm_type_for_name(program, function_value, locals, name);
    source_llvm == ret || function_param_return_cast_op(program, function_value, name, ret) != ""
}

fn return_name_can_emit(program: IrProgram, function_value: IrFunctionDef, name: String, ret: String) -> Bool {
    return_name_can_emit_with_locals(program, function_value, backend_empty_locals(), name, ret)
}

fn direct_expr_child_at(nodes: Vec[IrExprNode], child_index: Int) -> Option[IrExprNode] {
    let mut index = 0;
    let mut seen = 0;
    let mut out: Option[IrExprNode] = None();
    while index < vec.vec_len(nodes) {
        match vec.get(nodes, index) {
            Some(node) => if node.depth == 1 {
                if seen == child_index {
                    out = Some(node);
                    index = vec.vec_len(nodes);
                } else {
                    seen = seen + 1;
                };
                ()
            } else {
                ()
            },
            None => (),
        };
        index = index + 1;
    };
    out
}

fn direct_expr_child_count(nodes: Vec[IrExprNode]) -> Int {
    let mut index = 0;
    let mut count = 0;
    while index < vec.vec_len(nodes) {
        match vec.get(nodes, index) {
            Some(node) => if node.depth == 1 {
                count = count + 1;
            } else {
                ()
            },
            None => (),
        };
        index = index + 1;
    };
    count
}

fn simple_node_llvm_value_with_locals(node: IrExprNode, function_value: IrFunctionDef, locals: BackendLocals) -> String {
    match node.kind {
        IrIntExpr => literal_text_or_name(node.text, node.name),
        IrBoolExpr => bool_literal_llvm_text(node.text, node.name),
        IrNameExpr => value_name_for_name(function_value, locals, node.text),
        _ => "",
    }
}

fn simple_node_llvm_value(node: IrExprNode, function_value: IrFunctionDef) -> String {
    simple_node_llvm_value_with_locals(node, function_value, backend_empty_locals())
}

fn simple_node_llvm_type_with_locals(program: IrProgram, node: IrExprNode, function_value: IrFunctionDef, locals: BackendLocals) -> String {
    match node.kind {
        IrIntExpr => "i64",
        IrBoolExpr => "i1",
        IrNameExpr => llvm_type_for_name(program, function_value, locals, node.text),
        _ => "",
    }
}

fn simple_node_llvm_type(program: IrProgram, node: IrExprNode, function_value: IrFunctionDef) -> String {
    simple_node_llvm_type_with_locals(program, node, function_value, backend_empty_locals())
}

fn simple_node_can_emit_with_locals(node: IrExprNode, function_value: IrFunctionDef, locals: BackendLocals) -> Bool {
    match node.kind {
        IrIntExpr => is_decimal_integer_text(literal_text_or_name(node.text, node.name)),
        IrBoolExpr => literal_text_or_name(node.text, node.name) == "true" || literal_text_or_name(node.text, node.name) == "false",
        IrNameExpr => if function_has_param_named(function_value, node.text) {
            true
        } else {
            !name_uses_storage(locals, node.text) && name_is_value_available(function_value, locals, node.text)
        },
        _ => false,
    }
}

fn simple_node_can_emit(node: IrExprNode, function_value: IrFunctionDef) -> Bool {
    simple_node_can_emit_with_locals(node, function_value, backend_empty_locals())
}

fn simple_expr_can_emit(value: IrExpr, function_value: IrFunctionDef) -> Bool {
    match value.kind {
        IrIntExpr => is_decimal_integer_text(literal_text_or_name(value.text, value.name)),
        IrBoolExpr => literal_text_or_name(value.text, value.name) == "true" || literal_text_or_name(value.text, value.name) == "false",
        IrUnitExpr => true,
        IrNameExpr => function_has_param_named(function_value, value.text),
        _ => false,
    }
}

fn value_node_llvm_type(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], node: IrExprNode, locals: BackendLocals) -> String {
    let explicit = llvm_type_for_repr_in_program(program, optional_type_name_for_id(program.types, node.type_id));
    if explicit != "" {
        explicit
    } else {
        match node.kind {
            IrIntExpr => "i64",
            IrBoolExpr => "i1",
            IrStringExpr => "%aic.String",
            IrNameExpr => llvm_type_for_name(program, function_value, locals, node.text),
            IrFieldAccessExpr => field_access_node_llvm_type(program, function_value, nodes, node, locals),
            IrBinaryExpr => binary_node_llvm_type(program, function_value, nodes, node, locals),
            IrUnaryExpr => if node.op == "!" { "i1" } else if node.op == "-" { "i64" } else { "" },
            IrCallExpr => if is_string_bool_intrinsic_name(node.name) {
                "i1"
            } else if is_string_len_intrinsic_name(node.name) {
                "i64"
            } else if is_string_join_intrinsic_name(node.name) {
                "%aic.String"
            } else if is_string_split_intrinsic_name(node.name) {
                "{ i64, i64, i64 }"
            } else if is_string_trim_intrinsic_name(node.name) {
                "%aic.String"
            } else if is_string_char_at_intrinsic_name(node.name) {
                llvm_type_for_repr_in_program(program, "Option[String]")
            } else if is_string_int_to_string_intrinsic_name(node.name) {
                "%aic.String"
            } else if node.name == "string.replace" {
                "%aic.String"
            } else if is_vec_len_intrinsic_name(node.name) {
                "i64"
            } else if is_vec_get_intrinsic_name(node.name) {
                vec_get_node_llvm_type(program, function_value, nodes, node, locals)
            } else if is_string_slice_intrinsic_name(node.name) {
                "%aic.String"
            } else if node.name == "vec.new_vec" {
                vec_new_vec_node_llvm_type(program, node)
            } else if node.name == "vec.push" {
                vec_push_node_llvm_type(program, function_value, nodes, node, locals)
            } else {
                let call_ret = call_target_return_type(program, node.name);
                if call_ret != "" {
                    call_ret
                } else {
                    enum_variant_constructor_llvm_type(program, node.name)
                }
            },
            IrIfExpr => if_node_value_llvm_type(program, function_value, nodes, node, locals),
            IrLoopExpr => llvm_type_for_repr_in_program(program, loop_node_value_type_name(program, function_value, nodes, node, locals)),
            IrMatchExpr => match_node_value_llvm_type(program, function_value, nodes, node, locals),
            IrStructLiteralExpr => llvm_type_for_repr_in_program(program, node.name),
            _ => "",
        }
    }
}

fn value_node_can_emit(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], node: IrExprNode, locals: BackendLocals) -> Bool {
    match node.kind {
        IrIntExpr => is_decimal_integer_text(literal_text_or_name(node.text, node.name)),
        IrBoolExpr => literal_text_or_name(node.text, node.name) == "true" || literal_text_or_name(node.text, node.name) == "false",
        IrStringExpr => true,
        IrNameExpr => name_is_value_available(function_value, locals, node.text),
        IrFieldAccessExpr => field_access_node_llvm_type(program, function_value, nodes, node, locals) != "",
        IrBinaryExpr => binary_node_can_emit_with_locals(program, function_value, nodes, node, locals),
        IrUnaryExpr => if node.op == "!" {
            match expr_node_child_at(nodes, node, 0) {
                Some(child) => bool_node_can_emit_with_locals(program, function_value, nodes, child, locals),
                None => false,
            }
        } else if node.op == "-" {
            match expr_node_child_at(nodes, node, 0) {
                Some(child) => value_node_can_emit(program, function_value, nodes, child, locals) && value_node_llvm_type(program, function_value, nodes, child, locals) == "i64",
                None => false,
            }
        } else {
            false
        },
        IrCallExpr => if is_string_bool_intrinsic_name(node.name) {
            string_bool_node_can_emit(program, function_value, nodes, node, locals)
        } else if is_string_len_intrinsic_name(node.name) {
            string_len_node_can_emit(program, function_value, nodes, node, locals)
        } else if is_string_join_intrinsic_name(node.name) {
            string_join_node_can_emit(program, function_value, nodes, node, locals)
        } else if is_string_split_intrinsic_name(node.name) {
            string_split_node_can_emit(program, function_value, nodes, node, locals)
        } else if is_string_trim_intrinsic_name(node.name) {
            string_trim_node_can_emit(program, function_value, nodes, node, locals)
        } else if is_string_char_at_intrinsic_name(node.name) {
            string_char_at_node_can_emit(program, function_value, nodes, node, locals)
        } else if is_string_int_to_string_intrinsic_name(node.name) {
            string_int_to_string_node_can_emit(program, function_value, nodes, node, locals)
        } else if is_vec_len_intrinsic_name(node.name) {
            vec_len_node_can_emit(program, function_value, nodes, node, locals)
        } else if is_vec_get_intrinsic_name(node.name) {
            vec_get_node_can_emit(program, function_value, nodes, node, locals)
        } else if is_string_slice_intrinsic_name(node.name) {
            string_slice_node_can_emit(program, function_value, nodes, node, locals)
        } else if node.name == "string.replace" {
            string_replace_node_can_emit(program, function_value, nodes, node, locals)
        } else if node.name == "vec.new_vec" {
            vec_new_vec_node_can_emit(program, node)
            } else if node.name == "vec.push" {
                vec_push_node_can_emit(program, function_value, nodes, node, locals)
            } else if call_target_exists(program, node.name) {
                direct_call_node_can_emit(program, function_value, nodes, node, locals)
            } else if enum_variant_constructor_llvm_type(program, node.name) != "" {
                enum_variant_constructor_node_can_emit(program, function_value, nodes, node, locals)
            } else {
                false
        },
        IrIfExpr => if_node_value_can_emit_with_locals(program, function_value, nodes, node, locals),
        IrLoopExpr => loop_node_can_emit_value_with_type(program, function_value, nodes, node, locals, value_node_llvm_type(program, function_value, nodes, node, locals), loop_node_value_type_name(program, function_value, nodes, node, locals)),
        IrMatchExpr => if option_vec_get_match_node_type_name(program, function_value, nodes, node, locals) != "" {
            option_vec_get_match_node_can_emit_value(program, function_value, nodes, node, locals)
        } else if option_match_node_type_name(program, function_value, nodes, node, locals) != "" {
            option_match_node_can_emit_value(program, function_value, nodes, node, locals)
        } else if result_string_match_node_can_emit(program, function_value, nodes, node, locals) {
            true
        } else if enum_match_node_type_name(program, function_value, nodes, node, locals) != "" {
            enum_match_node_can_emit_value(program, function_value, nodes, node, locals)
        } else {
            enum_bool_match_node_can_emit(program, function_value, nodes, node, locals)
        },
        IrStructLiteralExpr => struct_literal_node_can_emit(program, function_value, nodes, node, locals, value_node_llvm_type(program, function_value, nodes, node, locals)),
        _ => false,
    }
}

fn value_expr_llvm_type(program: IrProgram, value: IrExpr, function_value: IrFunctionDef, locals: BackendLocals) -> String {
    let explicit = llvm_type_for_repr_in_program(program, optional_type_name_for_id(program.types, value.type_id));
    if explicit != "" {
        explicit
    } else {
        match value.kind {
            IrIntExpr => "i64",
            IrBoolExpr => "i1",
            IrStringExpr => "%aic.String",
            IrUnitExpr => "void",
            IrNameExpr => llvm_type_for_name(program, function_value, locals, value.text),
            IrFieldAccessExpr => field_access_expr_llvm_type(program, function_value, value, locals),
            IrBinaryExpr => binary_expr_llvm_type(program, value, function_value, locals),
            IrUnaryExpr => if value.op == "!" { "i1" } else if value.op == "-" { "i64" } else { "" },
            IrCallExpr => if is_string_bool_intrinsic_name(value.name) {
                "i1"
            } else if is_string_len_intrinsic_name(value.name) {
                "i64"
            } else if is_string_join_intrinsic_name(value.name) {
                "%aic.String"
            } else if is_string_split_intrinsic_name(value.name) {
                "{ i64, i64, i64 }"
            } else if is_string_trim_intrinsic_name(value.name) {
                "%aic.String"
            } else if is_string_char_at_intrinsic_name(value.name) {
                llvm_type_for_repr_in_program(program, "Option[String]")
            } else if is_string_int_to_string_intrinsic_name(value.name) {
                "%aic.String"
            } else if value.name == "string.replace" {
                "%aic.String"
            } else if is_vec_len_intrinsic_name(value.name) {
                "i64"
            } else if is_vec_get_intrinsic_name(value.name) {
                vec_get_expr_llvm_type(program, value, function_value, locals)
            } else if is_string_slice_intrinsic_name(value.name) {
                "%aic.String"
            } else if value.name == "vec.new_vec" {
                vec_new_vec_expr_llvm_type(program, value)
            } else if value.name == "vec.push" {
                vec_push_expr_llvm_type(program, value, function_value, locals)
            } else {
                let call_ret = call_target_return_type(program, value.name);
                if call_ret != "" {
                    call_ret
                } else {
                    enum_variant_constructor_llvm_type(program, value.name)
                }
            },
            IrIfExpr => if_expr_value_llvm_type(program, value, function_value, locals),
            IrLoopExpr => llvm_type_for_repr_in_program(program, loop_expr_value_type_name(program, value, function_value, locals)),
            IrMatchExpr => match_expr_value_llvm_type(program, value, function_value, locals),
            IrStructLiteralExpr => llvm_type_for_repr_in_program(program, value.name),
            _ => "",
        }
    }
}

fn expr_value_name(program: IrProgram, function_value: IrFunctionDef, value: IrExpr, locals: BackendLocals) -> String {
    match value.kind {
        IrIntExpr => literal_text_or_name(value.text, value.name),
        IrBoolExpr => bool_literal_llvm_text(value.text, value.name),
        IrStringExpr => llvm_expr_value_local(value),
        IrNameExpr => if name_uses_storage(locals, value.text) { loaded_expr_name(value) } else { value_name_for_name(function_value, locals, value.text) },
        IrFieldAccessExpr => llvm_expr_value_local(value),
        IrBinaryExpr => llvm_expr_value_local(value),
        IrUnaryExpr => llvm_expr_value_local(value),
        IrIfExpr => llvm_expr_value_local(value),
        IrLoopExpr => llvm_expr_value_local(value),
        IrCallExpr => llvm_expr_value_local(value),
        IrMatchExpr => llvm_expr_value_local(value),
        IrStructLiteralExpr => struct_literal_value_name(llvm_expr_prefix(value.node), direct_expr_child_count(value.nodes), value_expr_llvm_type(program, value, function_value, locals)),
        _ => "",
    }
}

fn value_expr_can_emit(program: IrProgram, value: IrExpr, function_value: IrFunctionDef, locals: BackendLocals) -> Bool {
    match value.kind {
        IrIntExpr => is_decimal_integer_text(literal_text_or_name(value.text, value.name)),
        IrBoolExpr => literal_text_or_name(value.text, value.name) == "true" || literal_text_or_name(value.text, value.name) == "false",
        IrStringExpr => true,
        IrUnitExpr => true,
        IrNameExpr => name_is_value_available(function_value, locals, value.text),
        IrFieldAccessExpr => field_access_expr_llvm_type(program, function_value, value, locals) != "",
        IrBinaryExpr => binary_expr_can_emit_with_locals(program, value, function_value, locals),
        IrUnaryExpr => if value.op == "!" {
            match direct_expr_child_at(value.nodes, 0) {
                Some(child) => bool_node_can_emit_with_locals(program, function_value, value.nodes, child, locals),
                None => false,
            }
        } else if value.op == "-" {
            match direct_expr_child_at(value.nodes, 0) {
                Some(child) => value_node_can_emit(program, function_value, value.nodes, child, locals) && value_node_llvm_type(program, function_value, value.nodes, child, locals) == "i64",
                None => false,
            }
        } else {
            false
        },
        IrCallExpr => if is_string_bool_intrinsic_name(value.name) {
            string_bool_expr_can_emit(program, value, function_value, locals)
        } else if is_string_len_intrinsic_name(value.name) {
            string_len_expr_can_emit(program, value, function_value, locals)
        } else if is_string_join_intrinsic_name(value.name) {
            string_join_expr_can_emit(program, value, function_value, locals)
        } else if is_string_split_intrinsic_name(value.name) {
            string_split_expr_can_emit(program, value, function_value, locals)
        } else if is_string_trim_intrinsic_name(value.name) {
            string_trim_expr_can_emit(program, value, function_value, locals)
        } else if is_string_char_at_intrinsic_name(value.name) {
            string_char_at_expr_can_emit(program, value, function_value, locals)
        } else if is_string_int_to_string_intrinsic_name(value.name) {
            string_int_to_string_expr_can_emit(program, value, function_value, locals)
        } else if is_vec_len_intrinsic_name(value.name) {
            vec_len_expr_can_emit(program, value, function_value, locals)
        } else if is_vec_get_intrinsic_name(value.name) {
            vec_get_expr_can_emit(program, value, function_value, locals)
        } else if is_string_slice_intrinsic_name(value.name) {
            string_slice_expr_can_emit(program, value, function_value, locals)
        } else if value.name == "string.replace" {
            string_replace_expr_can_emit(program, value, function_value, locals)
        } else if value.name == "vec.new_vec" {
            vec_new_vec_expr_can_emit(program, value)
        } else if value.name == "vec.push" {
            vec_push_expr_can_emit(program, value, function_value, locals)
        } else if call_target_exists(program, value.name) {
            call_expr_can_emit_with_locals(program, value, function_value, locals)
        } else if enum_variant_constructor_llvm_type(program, value.name) != "" {
            enum_variant_constructor_expr_can_emit(program, value, function_value, locals)
        } else {
            false
        },
        IrIfExpr => if_expr_value_can_emit_with_locals(program, value, function_value, locals),
        IrLoopExpr => loop_expr_can_emit_value_with_type(program, value, function_value, locals, value_expr_llvm_type(program, value, function_value, locals), loop_expr_value_type_name(program, value, function_value, locals)),
        IrMatchExpr => if option_vec_get_match_expr_type_name(program, value, function_value, locals) != "" {
            option_vec_get_match_expr_can_emit_value(program, value, function_value, locals)
        } else if option_match_expr_type_name(program, value, function_value, locals) != "" {
            option_match_expr_can_emit_value(program, value, function_value, locals)
        } else if result_string_match_expr_can_emit(program, value, function_value, locals) {
            true
        } else if enum_match_expr_type_name(program, value, function_value, locals) != "" {
            enum_match_expr_can_emit_value(program, value, function_value, locals)
        } else {
            enum_bool_match_expr_can_emit(program, value, function_value, locals)
        },
        IrStructLiteralExpr => struct_literal_expr_can_emit(program, value, function_value, locals, value_expr_llvm_type(program, value, function_value, locals)),
        _ => false,
    }
}

fn match_node_value_type_name(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], node: IrExprNode, locals: BackendLocals) -> String {
    let option_vec_type = option_vec_get_match_node_type_name(program, function_value, nodes, node, locals);
    if option_vec_type != "" {
        option_vec_type
    } else {
        let option_type = option_match_node_type_name(program, function_value, nodes, node, locals);
        if option_type != "" {
            option_type
        } else if result_string_match_node_can_emit(program, function_value, nodes, node, locals) {
            "String"
        } else {
            enum_match_node_type_name(program, function_value, nodes, node, locals)
        }
    }
}

fn match_expr_value_type_name(program: IrProgram, value: IrExpr, function_value: IrFunctionDef, locals: BackendLocals) -> String {
    let option_vec_type = option_vec_get_match_expr_type_name(program, value, function_value, locals);
    if option_vec_type != "" {
        option_vec_type
    } else {
        let option_type = option_match_expr_type_name(program, value, function_value, locals);
        if option_type != "" {
            option_type
        } else if result_string_match_expr_can_emit(program, value, function_value, locals) {
            "String"
        } else {
            enum_match_expr_type_name(program, value, function_value, locals)
        }
    }
}

fn match_node_value_llvm_type(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], node: IrExprNode, locals: BackendLocals) -> String {
    llvm_type_for_repr_in_program(program, match_node_value_type_name(program, function_value, nodes, node, locals))
}

fn match_expr_value_llvm_type(program: IrProgram, value: IrExpr, function_value: IrFunctionDef, locals: BackendLocals) -> String {
    llvm_type_for_repr_in_program(program, match_expr_value_type_name(program, value, function_value, locals))
}

fn expr_node_index(nodes: Vec[IrExprNode], target: IrNodeId) -> Int {
    let mut index = 0;
    let mut out = -1;
    while out < 0 && index < vec.vec_len(nodes) {
        match vec.get(nodes, index) {
            Some(node) => if node.node.value == target.value {
                out = index;
            } else {
                ()
            },
            None => (),
        };
        index = index + 1;
    };
    out
}

fn expr_node_child_at(nodes: Vec[IrExprNode], parent: IrExprNode, child_index: Int) -> Option[IrExprNode] {
    let parent_index = expr_node_index(nodes, parent.node);
    let mut index = parent_index + 1;
    let mut seen = 0;
    let mut out: Option[IrExprNode] = None();
    while parent_index >= 0 && index < vec.vec_len(nodes) {
        match vec.get(nodes, index) {
            Some(node) => if node.depth <= parent.depth {
                index = vec.vec_len(nodes);
            } else if node.depth == parent.depth + 1 {
                if seen == child_index {
                    out = Some(node);
                    index = vec.vec_len(nodes);
                } else {
                    seen = seen + 1;
                };
                ()
            } else {
                ()
            },
            None => (),
        };
        index = index + 1;
    };
    out
}

fn string_replace_node_can_emit(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], node: IrExprNode, locals: BackendLocals) -> Bool {
    if node.name != "string.replace" || node.direct_child_count != 3 {
        false
    } else {
        let mut index = 0;
        let mut ok = true;
        while ok && index < 3 {
            match expr_node_child_at(nodes, node, index) {
                Some(child) => if string_call_child_can_emit(program, function_value, nodes, child, locals) {
                    ()
                } else {
                    ok = false;
                },
                None => if true {
                    ok = false;
                    ()
                } else { () },
            };
            index = index + 1;
        };
        ok
    }
}

fn string_bool_node_can_emit(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], node: IrExprNode, locals: BackendLocals) -> Bool {
    if !is_string_bool_intrinsic_name(node.name) || node.direct_child_count != 2 {
        false
    } else {
        match expr_node_child_at(nodes, node, 0) {
            Some(left) => match expr_node_child_at(nodes, node, 1) {
                Some(right) => string_call_child_can_emit(program, function_value, nodes, left, locals) && string_call_child_can_emit(program, function_value, nodes, right, locals),
                None => false,
            },
            None => false,
        }
    }
}

fn string_call_child_can_emit(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], node: IrExprNode, locals: BackendLocals) -> Bool {
    match node.kind {
        IrStringExpr => true,
        IrNameExpr => llvm_type_for_name(program, function_value, locals, node.text) == "%aic.String",
        IrFieldAccessExpr => field_access_node_can_emit(program, function_value, nodes, node, locals, "%aic.String"),
        IrCallExpr => if node.name == "string.replace" {
            string_replace_node_can_emit(program, function_value, nodes, node, locals)
        } else if is_string_join_intrinsic_name(node.name) {
            string_join_node_can_emit(program, function_value, nodes, node, locals)
        } else if is_string_trim_intrinsic_name(node.name) {
            string_trim_node_can_emit(program, function_value, nodes, node, locals)
        } else if is_string_int_to_string_intrinsic_name(node.name) {
            string_int_to_string_node_can_emit(program, function_value, nodes, node, locals)
        } else if is_string_slice_intrinsic_name(node.name) {
            string_slice_node_can_emit(program, function_value, nodes, node, locals)
        } else {
            string_direct_call_node_can_emit(program, function_value, nodes, node, locals)
        },
        _ => false,
    }
}

fn node_type_name(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], node: IrExprNode, locals: BackendLocals) -> String {
    let explicit = optional_type_name_for_id(program.types, node.type_id);
    if explicit != "" {
        explicit
    } else {
        match node.kind {
            IrIntExpr => "Int",
            IrBoolExpr => "Bool",
            IrStringExpr => "String",
            IrNameExpr => type_name_for_name(program, function_value, locals, node.text),
            IrFieldAccessExpr => field_access_node_type_name(program, function_value, nodes, node, locals),
            IrBinaryExpr => if binary_node_can_emit_with_locals(program, function_value, nodes, node, locals) {
                if binary_node_llvm_type(program, function_value, nodes, node, locals) == "i1" { "Bool" } else { "Int" }
            } else { "" },
            IrCallExpr => if node.name == "vec.push" {
                vec_push_node_type_name(program, function_value, nodes, node, locals)
            } else if node.name == "vec.new_vec" {
                vec_new_vec_node_type_name(program, node)
            } else if is_string_len_intrinsic_name(node.name) {
                "Int"
            } else if is_string_join_intrinsic_name(node.name) {
                "String"
            } else if is_string_split_intrinsic_name(node.name) {
                "Vec[String]"
            } else if is_string_trim_intrinsic_name(node.name) {
                "String"
            } else if is_string_char_at_intrinsic_name(node.name) {
                "Option[String]"
            } else if is_string_int_to_string_intrinsic_name(node.name) {
                "String"
            } else if node.name == "string.replace" {
                "String"
            } else if is_vec_len_intrinsic_name(node.name) {
                "Int"
            } else if is_vec_get_intrinsic_name(node.name) {
                vec_get_node_type_name(program, function_value, nodes, node, locals)
            } else if is_string_slice_intrinsic_name(node.name) {
                "String"
            } else {
                let call_name = call_target_return_type_name(program, node.name);
                if call_name != "" {
                    call_name
                } else {
                    enum_variant_constructor_type_name(program, node.name)
                }
            },
            IrIfExpr => if_node_value_type_name(program, function_value, nodes, node, locals),
            IrLoopExpr => loop_node_value_type_name(program, function_value, nodes, node, locals),
            IrMatchExpr => match_node_value_type_name(program, function_value, nodes, node, locals),
            IrStructLiteralExpr => node.name,
            _ => "",
        }
    }
}

fn vec_push_node_type_name(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], node: IrExprNode, locals: BackendLocals) -> String {
    match expr_node_child_at(nodes, node, 0) {
        Some(vec_child) => node_type_name(program, function_value, nodes, vec_child, locals),
        None => "",
    }
}

fn vec_push_node_llvm_type(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], node: IrExprNode, locals: BackendLocals) -> String {
    llvm_type_for_repr_in_program(program, vec_push_node_type_name(program, function_value, nodes, node, locals))
}

fn vec_push_node_can_emit(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], node: IrExprNode, locals: BackendLocals) -> Bool {
    if node.name != "vec.push" || node.direct_child_count != 2 {
        false
    } else {
        match expr_node_child_at(nodes, node, 0) {
            Some(vec_child) => match expr_node_child_at(nodes, node, 1) {
                Some(value_child) => if true {
                    let vec_name = node_type_name(program, function_value, nodes, vec_child, locals);
                    let elem_name = generic_arg_at(vec_name, 0);
                    let elem_ty = llvm_type_for_repr_in_program(program, elem_name);
                    base_type_name_text(vec_name) == "Vec"
                        && elem_ty != ""
                        && value_node_can_emit(program, function_value, nodes, vec_child, locals)
                        && value_node_llvm_type(program, function_value, nodes, vec_child, locals) == "{ i64, i64, i64 }"
                        && value_node_can_emit(program, function_value, nodes, value_child, locals)
                        && value_node_llvm_type(program, function_value, nodes, value_child, locals) == elem_ty
                } else { false },
                None => false,
            },
            None => false,
        }
    }
}

fn vec_push_expr_type_name(program: IrProgram, value: IrExpr, function_value: IrFunctionDef, locals: BackendLocals) -> String {
    match direct_expr_child_at(value.nodes, 0) {
        Some(vec_child) => node_type_name(program, function_value, value.nodes, vec_child, locals),
        None => "",
    }
}

fn vec_push_expr_llvm_type(program: IrProgram, value: IrExpr, function_value: IrFunctionDef, locals: BackendLocals) -> String {
    llvm_type_for_repr_in_program(program, vec_push_expr_type_name(program, value, function_value, locals))
}

fn vec_push_expr_can_emit(program: IrProgram, value: IrExpr, function_value: IrFunctionDef, locals: BackendLocals) -> Bool {
    if value.name != "vec.push" || direct_expr_child_count(value.nodes) != 2 {
        false
    } else {
        match direct_expr_child_at(value.nodes, 0) {
            Some(vec_child) => match direct_expr_child_at(value.nodes, 1) {
                Some(value_child) => if true {
                    let vec_name = node_type_name(program, function_value, value.nodes, vec_child, locals);
                    let elem_name = generic_arg_at(vec_name, 0);
                    let elem_ty = llvm_type_for_repr_in_program(program, elem_name);
                    base_type_name_text(vec_name) == "Vec"
                        && elem_ty != ""
                        && value_node_can_emit(program, function_value, value.nodes, vec_child, locals)
                        && value_node_llvm_type(program, function_value, value.nodes, vec_child, locals) == "{ i64, i64, i64 }"
                        && value_node_can_emit(program, function_value, value.nodes, value_child, locals)
                        && value_node_llvm_type(program, function_value, value.nodes, value_child, locals) == elem_ty
                } else { false },
                None => false,
            },
            None => false,
        }
    }
}

fn vec_get_node_type_name(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], node: IrExprNode, locals: BackendLocals) -> String {
    match expr_node_child_at(nodes, node, 0) {
        Some(vec_child) => if true {
            let vec_name = node_type_name(program, function_value, nodes, vec_child, locals);
            let elem_name = generic_arg_at(vec_name, 0);
            if base_type_name_text(vec_name) == "Vec" && elem_name != "" {
                concat3("Option[", elem_name, "]")
            } else {
                ""
            }
        } else { "" },
        None => "",
    }
}

fn vec_get_node_llvm_type(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], node: IrExprNode, locals: BackendLocals) -> String {
    llvm_type_for_repr_in_program(program, vec_get_node_type_name(program, function_value, nodes, node, locals))
}

fn vec_get_node_payload_llvm_type(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], node: IrExprNode, locals: BackendLocals) -> String {
    let option_name = vec_get_node_type_name(program, function_value, nodes, node, locals);
    llvm_payload_slot_type(program, generic_arg_at(option_name, 0))
}

fn vec_get_node_can_emit(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], node: IrExprNode, locals: BackendLocals) -> Bool {
    if !is_vec_get_intrinsic_name(node.name) || node.direct_child_count != 2 {
        false
    } else {
        match expr_node_child_at(nodes, node, 0) {
            Some(vec_child) => match expr_node_child_at(nodes, node, 1) {
                Some(index_child) => if true {
                    let vec_name = node_type_name(program, function_value, nodes, vec_child, locals);
                    let elem_name = generic_arg_at(vec_name, 0);
                    let elem_ty = llvm_type_for_repr_in_program(program, elem_name);
                    base_type_name_text(vec_name) == "Vec"
                        && elem_name != ""
                        && elem_ty != ""
                        && value_node_can_emit(program, function_value, nodes, vec_child, locals)
                        && value_node_llvm_type(program, function_value, nodes, vec_child, locals) == "{ i64, i64, i64 }"
                        && value_node_can_emit(program, function_value, nodes, index_child, locals)
                        && value_node_llvm_type(program, function_value, nodes, index_child, locals) == "i64"
                        && vec_get_node_llvm_type(program, function_value, nodes, node, locals) != ""
                } else { false },
                None => false,
            },
            None => false,
        }
    }
}

fn vec_get_expr_type_name(program: IrProgram, value: IrExpr, function_value: IrFunctionDef, locals: BackendLocals) -> String {
    match direct_expr_child_at(value.nodes, 0) {
        Some(vec_child) => if true {
            let vec_name = node_type_name(program, function_value, value.nodes, vec_child, locals);
            let elem_name = generic_arg_at(vec_name, 0);
            if base_type_name_text(vec_name) == "Vec" && elem_name != "" {
                concat3("Option[", elem_name, "]")
            } else {
                ""
            }
        } else { "" },
        None => "",
    }
}

fn vec_get_expr_llvm_type(program: IrProgram, value: IrExpr, function_value: IrFunctionDef, locals: BackendLocals) -> String {
    llvm_type_for_repr_in_program(program, vec_get_expr_type_name(program, value, function_value, locals))
}

fn vec_get_expr_payload_llvm_type(program: IrProgram, value: IrExpr, function_value: IrFunctionDef, locals: BackendLocals) -> String {
    let option_name = vec_get_expr_type_name(program, value, function_value, locals);
    llvm_payload_slot_type(program, generic_arg_at(option_name, 0))
}

fn vec_get_expr_can_emit(program: IrProgram, value: IrExpr, function_value: IrFunctionDef, locals: BackendLocals) -> Bool {
    if !is_vec_get_intrinsic_name(value.name) || direct_expr_child_count(value.nodes) != 2 {
        false
    } else {
        match direct_expr_child_at(value.nodes, 0) {
            Some(vec_child) => match direct_expr_child_at(value.nodes, 1) {
                Some(index_child) => if true {
                    let vec_name = node_type_name(program, function_value, value.nodes, vec_child, locals);
                    let elem_name = generic_arg_at(vec_name, 0);
                    let elem_ty = llvm_type_for_repr_in_program(program, elem_name);
                    base_type_name_text(vec_name) == "Vec"
                        && elem_name != ""
                        && elem_ty != ""
                        && value_node_can_emit(program, function_value, value.nodes, vec_child, locals)
                        && value_node_llvm_type(program, function_value, value.nodes, vec_child, locals) == "{ i64, i64, i64 }"
                        && value_node_can_emit(program, function_value, value.nodes, index_child, locals)
                        && value_node_llvm_type(program, function_value, value.nodes, index_child, locals) == "i64"
                        && vec_get_expr_llvm_type(program, value, function_value, locals) != ""
                } else { false },
                None => false,
            },
            None => false,
        }
    }
}

fn call_child_node_can_emit_expected(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], expected: String, expected_type_name: String, node: IrExprNode, locals: BackendLocals) -> Bool {
    if expected == "%aic.String" {
        string_call_child_can_emit(program, function_value, nodes, node, locals)
    } else if expected_vec_new_vec_node_can_emit(node, expected) {
        true
    } else if expected_enum_constructor_node_can_emit(program, function_value, nodes, node, locals, expected_type_name) {
        true
    } else if node_is_if_expr(node) {
        if_node_value_can_emit_with_expected_type(program, function_value, nodes, node, locals, expected, expected_type_name)
    } else if node_is_match_expr(node) && direct_option_match_node_can_emit_expected_path(nodes, node) {
        option_match_node_can_emit_value_expected(program, function_value, nodes, node, locals, expected, expected_type_name)
    } else if simple_node_can_emit_with_locals(node, function_value, locals) {
        let actual = simple_node_llvm_type_with_locals(program, node, function_value, locals);
        expected != "" && actual != "" && expected == actual
    } else if value_node_can_emit(program, function_value, nodes, node, locals) {
        expected != "" && value_node_llvm_type(program, function_value, nodes, node, locals) == expected
    } else {
        match node.kind {
            IrFieldAccessExpr => field_access_node_can_emit(program, function_value, nodes, node, locals, expected),
            IrCallExpr => call_node_return_type_matches(program, node, expected) && direct_call_node_can_emit(program, function_value, nodes, node, locals),
            _ => false,
        }
    }
}

fn call_child_node_can_emit(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], callee_name: String, param_index: Int, node: IrExprNode, locals: BackendLocals) -> Bool {
    call_child_node_can_emit_expected(program, function_value, nodes, call_target_param_type(program, callee_name, param_index), call_target_param_type_name(program, callee_name, param_index), node, locals)
}

fn call_child_needs_expected_type(node: IrExprNode) -> Bool {
    match node.kind {
        IrCallExpr => node.name == "vec.new_vec" || node.name == "Some" || node.name == "None" || node.name == "Ok" || node.name == "Err",
        _ => false,
    }
}

fn call_expr_child_needs_expected_type(node: IrExprNode) -> Bool {
    call_child_needs_expected_type(node)
}

fn call_node_children_can_emit_without_signature(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], node: IrExprNode, locals: BackendLocals) -> Bool {
    let mut index = 0;
    let mut ok = true;
    while ok && index < node.direct_child_count {
        match expr_node_child_at(nodes, node, index) {
            Some(child) => if call_child_needs_expected_type(child) {
                ok = false;
            } else {
                ok = value_node_can_emit(program, function_value, nodes, child, locals);
            },
            None => if true {
                ok = false;
                ()
            } else { () },
        };
        index = index + 1;
    };
    ok
}

fn call_expr_children_can_emit_without_signature(program: IrProgram, value: IrExpr, function_value: IrFunctionDef, locals: BackendLocals) -> Bool {
    let mut index = 0;
    let mut ok = true;
    while ok && index < direct_expr_child_count(value.nodes) {
        match direct_expr_child_at(value.nodes, index) {
            Some(child) => if call_expr_child_needs_expected_type(child) {
                ok = false;
            } else {
                ok = value_node_can_emit(program, function_value, value.nodes, child, locals);
            },
            None => if true {
                ok = false;
                ()
            } else { () },
        };
        index = index + 1;
    };
    ok
}

fn call_node_return_type_matches(program: IrProgram, node: IrExprNode, expected: String) -> Bool {
    let explicit = llvm_type_for_repr_in_program(program, optional_type_name_for_id(program.types, node.type_id));
    if expected == "" {
        false
    } else if explicit != "" {
        explicit == expected
    } else {
        call_target_return_type(program, node.name) == expected
    }
}

fn call_expr_return_type_matches(program: IrProgram, value: IrExpr, expected: String) -> Bool {
    let explicit = llvm_type_for_repr_in_program(program, optional_type_name_for_id(program.types, value.type_id));
    if expected == "" {
        false
    } else if explicit != "" {
        explicit == expected
    } else {
        call_target_return_type(program, value.name) == expected
    }
}

fn direct_call_node_can_emit(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], node: IrExprNode, locals: BackendLocals) -> Bool {
    let explicit = llvm_type_for_repr_in_program(program, optional_type_name_for_id(program.types, node.type_id));
    if node.name != "" && explicit != "" && call_node_children_can_emit_without_signature(program, function_value, nodes, node, locals) {
        true
    } else {
        let target: Option[IrFunctionDef] = call_target_function(program, node.name);
        if node.name == "" || call_target_return_type_resolved(program, node.name, target) == "" {
        false
        } else if node.direct_child_count != call_target_param_count_resolved(node.name, target) {
            false
        } else {
            let mut index = 0;
            let mut ok = true;
            while ok && index < node.direct_child_count {
                match expr_node_child_at(nodes, node, index) {
                    Some(child) => if call_child_node_can_emit_expected(program, function_value, nodes, call_target_param_type_resolved(program, node.name, target, index), call_target_param_type_name_resolved(program, target, index), child, locals) {
                        ()
                    } else {
                        ok = false;
                    },
                    None => if true {
                        ok = false;
                        ()
                    } else { () },
                };
                index = index + 1;
            };
            ok
        }
    }
}

fn string_direct_call_node_can_emit(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], node: IrExprNode, locals: BackendLocals) -> Bool {
    call_node_return_type_matches(program, node, "%aic.String") && direct_call_node_can_emit(program, function_value, nodes, node, locals)
}

fn string_replace_expr_can_emit(program: IrProgram, value: IrExpr, function_value: IrFunctionDef, locals: BackendLocals) -> Bool {
    if value.name != "string.replace" || direct_expr_child_count(value.nodes) != 3 {
        false
    } else {
        let mut index = 0;
        let mut ok = true;
        while ok && index < 3 {
            match direct_expr_child_at(value.nodes, index) {
                Some(node) => if string_call_child_can_emit(program, function_value, value.nodes, node, locals) {
                    ()
                } else {
                    ok = false;
                },
                None => if true {
                    ok = false;
                    ()
                } else { () },
            };
            index = index + 1;
        };
        ok
    }
}

fn call_target_return_type(program: IrProgram, callee_name: String) -> String {
    let mut index = 0;
    let mut out = "";
    while out == "" && index < vec.vec_len(program.items) {
        match vec.get(program.items, index) {
            Some(item) => match item {
                IrFunctionItemValue(function_value) => if function_value.name == callee_name {
                    out = llvm_type_for_id(program, function_value.return_type);
                } else {
                    ()
                },
                _ => (),
            },
            None => (),
        };
        index = index + 1;
    };
    if out == "" {
        known_call_return_type(program, callee_name)
    } else {
        out
    }
}

fn call_target_return_type_name(program: IrProgram, callee_name: String) -> String {
    let mut index = 0;
    let mut out = "";
    while out == "" && index < vec.vec_len(program.items) {
        match vec.get(program.items, index) {
            Some(item) => match item {
                IrFunctionItemValue(function_value) => if function_value.name == callee_name {
                    out = type_name_for_id(program.types, function_value.return_type);
                } else {
                    ()
                },
                _ => (),
            },
            None => (),
        };
        index = index + 1;
    };
    if out == "" {
        known_call_return_type_name(callee_name)
    } else {
        out
    }
}

fn call_target_function(program: IrProgram, callee_name: String) -> Option[IrFunctionDef] {
    let mut index = 0;
    let mut found = false;
    let mut out: Option[IrFunctionDef] = None();
    while !found && index < vec.vec_len(program.items) {
        match vec.get(program.items, index) {
            Some(item) => match item {
                IrFunctionItemValue(function_value) => if function_value.name == callee_name {
                    out = Some(function_value);
                    found = true;
                } else {
                    ()
                },
                _ => (),
            },
            None => (),
        };
        index = index + 1;
    };
    out
}

fn call_target_return_type_resolved(program: IrProgram, callee_name: String, target: Option[IrFunctionDef]) -> String {
    match target {
        Some(function_value) => llvm_type_for_id(program, function_value.return_type),
        None => known_call_return_type(program, callee_name),
    }
}

fn call_target_return_type_name_resolved(callee_name: String, target: Option[IrFunctionDef], types: Vec[IrTypeDef]) -> String {
    match target {
        Some(function_value) => type_name_for_id(types, function_value.return_type),
        None => known_call_return_type_name(callee_name),
    }
}

fn call_target_param_count_resolved(callee_name: String, target: Option[IrFunctionDef]) -> Int {
    match target {
        Some(function_value) => vec.vec_len(function_value.params),
        None => known_call_param_count(callee_name),
    }
}

fn call_target_param_type_resolved(program: IrProgram, callee_name: String, target: Option[IrFunctionDef], param_index: Int) -> String {
    match target {
        Some(function_value) => match vec.get(function_value.params, param_index) {
            Some(param) => llvm_type_for_id(program, param.type_id),
            None => "",
        },
        None => known_call_param_type(program, callee_name, param_index),
    }
}

fn call_target_param_type_name_resolved(program: IrProgram, target: Option[IrFunctionDef], param_index: Int) -> String {
    match target {
        Some(function_value) => match vec.get(function_value.params, param_index) {
            Some(param) => type_name_for_id(program.types, param.type_id),
            None => "",
        },
        None => "",
    }
}

fn call_target_param_type(program: IrProgram, callee_name: String, param_index: Int) -> String {
    let mut item_index = 0;
    let mut out = "";
    while out == "" && item_index < vec.vec_len(program.items) {
        match vec.get(program.items, item_index) {
            Some(item) => match item {
                IrFunctionItemValue(function_value) => if function_value.name == callee_name {
                    match vec.get(function_value.params, param_index) {
                        Some(param) => if true {
                            out = llvm_type_for_id(program, param.type_id);
                            ()
                        } else { () },
                        None => (),
                    }
                } else {
                    ()
                },
                _ => (),
            },
            None => (),
        };
        item_index = item_index + 1;
    };
    if out == "" {
        known_call_param_type(program, callee_name, param_index)
    } else {
        out
    }
}

fn call_target_param_type_name(program: IrProgram, callee_name: String, param_index: Int) -> String {
    let mut item_index = 0;
    let mut out = "";
    while out == "" && item_index < vec.vec_len(program.items) {
        match vec.get(program.items, item_index) {
            Some(item) => match item {
                IrFunctionItemValue(function_value) => if function_value.name == callee_name {
                    match vec.get(function_value.params, param_index) {
                        Some(param) => if true {
                            out = type_name_for_id(program.types, param.type_id);
                            ()
                        } else { () },
                        None => (),
                    }
                } else {
                    ()
                },
                _ => (),
            },
            None => (),
        };
        item_index = item_index + 1;
    };
    out
}

fn call_target_param_count(program: IrProgram, callee_name: String) -> Int {
    let mut item_index = 0;
    let mut out = 0;
    let mut found = false;
    while !found && item_index < vec.vec_len(program.items) {
        match vec.get(program.items, item_index) {
            Some(item) => match item {
                IrFunctionItemValue(function_value) => if function_value.name == callee_name {
                    out = vec.vec_len(function_value.params);
                    found = true;
                } else {
                    ()
                },
                _ => (),
            },
            None => (),
        };
        item_index = item_index + 1;
    };
    if found {
        out
    } else {
        known_call_param_count(callee_name)
    }
}

fn call_target_exists(program: IrProgram, callee_name: String) -> Bool {
    call_target_return_type(program, callee_name) != ""
}

fn string_bool_expr_can_emit(program: IrProgram, value: IrExpr, function_value: IrFunctionDef, locals: BackendLocals) -> Bool {
    if !is_string_bool_intrinsic_name(value.name) || direct_expr_child_count(value.nodes) != 2 {
        false
    } else {
        match direct_expr_child_at(value.nodes, 0) {
            Some(left) => match direct_expr_child_at(value.nodes, 1) {
                Some(right) => string_call_child_can_emit(program, function_value, value.nodes, left, locals) && string_call_child_can_emit(program, function_value, value.nodes, right, locals),
                None => false,
            },
            None => false,
        }
    }
}

