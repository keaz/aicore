module compiler.backend_llvm;

import compiler.source;
import compiler.diagnostics;
import compiler.ir;
import std.option;
import std.string;
import std.vec;

pub enum BackendArtifactKind {
    LlvmIrArtifact,
    NativeObjectArtifact,
    StaticLibraryArtifact,
    ExecutableArtifact,
}

pub enum BackendNativeLinkKind {
    NativeLibraryLink,
    NativeFrameworkLink,
    NativeObjectLink,
    NativeSearchPathLink,
}

pub struct BackendNativeLink {
    pub name: String,
    pub kind: BackendNativeLinkKind,
    pub path: String,
    pub static_link: Bool,
    pub span: SourceSpan,
}

pub struct BackendOptions {
    pub artifact_name: String,
    pub target_triple: String,
    pub artifact_kind: BackendArtifactKind,
    pub require_entry: Bool,
    pub native_links: Vec[BackendNativeLink],
}

pub struct BackendSymbol {
    pub source_name: String,
    pub llvm_name: String,
    pub kind: String,
    pub span: SourceSpan,
}

struct BackendLocalCheck {
    ok: Bool,
    locals: BackendLocals,
}

struct BackendStatementEmission {
    text: String,
    locals: BackendLocals,
}

struct BackendLocal {
    name: String,
    type_name: String,
    llvm_type: String,
    value_name: String,
}

struct BackendLocals {
    names: Vec[String],
    type_names: Vec[String],
    llvm_types: Vec[String],
    value_names: Vec[String],
}

pub struct BackendArtifact {
    pub format: String,
    pub schema_version: Int,
    pub artifact_name: String,
    pub file_name: String,
    pub artifact_kind: BackendArtifactKind,
    pub target_triple: String,
    pub llvm_ir: String,
    pub symbols: Vec[BackendSymbol],
    pub features: Vec[String],
    pub native_links: Vec[BackendNativeLink],
    pub digest: String,
    pub diagnostics: Vec[Diagnostic],
}

pub fn backend_native_link(name: String, kind: BackendNativeLinkKind, path: String, static_link: Bool, span_value: SourceSpan) -> BackendNativeLink {
    BackendNativeLink {
        name: name,
        kind: kind,
        path: path,
        static_link: static_link,
        span: span_value,
    }
}

pub fn backend_options(artifact_name: String, target_triple: String, artifact_kind: BackendArtifactKind, require_entry: Bool, native_links: Vec[BackendNativeLink]) -> BackendOptions {
    BackendOptions {
        artifact_name: artifact_name,
        target_triple: target_triple,
        artifact_kind: artifact_kind,
        require_entry: require_entry,
        native_links: native_links,
    }
}

fn backend_artifact_kind_name(value: BackendArtifactKind) -> String {
    match value {
        LlvmIrArtifact => "llvm-ir",
        NativeObjectArtifact => "object",
        StaticLibraryArtifact => "static-library",
        ExecutableArtifact => "executable",
    }
}

fn backend_native_link_kind_name(value: BackendNativeLinkKind) -> String {
    match value {
        NativeLibraryLink => "library",
        NativeFrameworkLink => "framework",
        NativeObjectLink => "object",
        NativeSearchPathLink => "search-path",
    }
}

fn backend_artifact_extension(value: BackendArtifactKind) -> String {
    match value {
        LlvmIrArtifact => ".ll",
        NativeObjectArtifact => ".o",
        StaticLibraryArtifact => ".a",
        ExecutableArtifact => "",
    }
}

fn backend_error(code: String, span_value: SourceSpan, message: String, help: String) -> Diagnostic {
    with_help(error(diagnostic_code(code), span_value, message), help)
}

fn push_backend_error(values: Vec[Diagnostic], code: String, span_value: SourceSpan, message: String, help: String) -> Vec[Diagnostic] {
    vec.push(values, backend_error(code, span_value, message, help))
}

fn validate_backend_ir_input(program: IrProgram) -> Vec[Diagnostic] {
    let mut diagnostics: Vec[Diagnostic] = vec.new_vec();
    if program.schema_version != current_ir_schema_version() {
        diagnostics = push_backend_error(diagnostics, "E5010", program.span, "backend emission requires schema_version 1 IR", "migrate older IR or reject future schema versions before backend lowering");
    } else {
        ()
    };
    if vec.vec_len(program.items) > 0 && vec.vec_len(program.source_map) == 0 {
        diagnostics = push_backend_error(diagnostics, "E5011", program.span, "backend emission requires source-map metadata for item-bearing programs", "preserve lowering source_map entries so backend diagnostics can locate generated nodes");
    } else {
        ()
    };
    let mut symbol_index = 0;
    while symbol_index < vec.vec_len(program.symbols) {
        match vec.get(program.symbols, symbol_index) {
            Some(symbol_value) => if symbol_value.name == "" {
                diagnostics = push_backend_error(diagnostics, "E5013", symbol_value.span, "backend emission requires named IR symbols", "retain symbol names during IR lowering");
            } else {
                ()
            },
            None => (),
        };
        symbol_index = symbol_index + 1;
    };
    let mut type_index = 0;
    while type_index < vec.vec_len(program.types) {
        match vec.get(program.types, type_index) {
            Some(type_value) => if type_value.name == "" {
                diagnostics = push_backend_error(diagnostics, "E5013", type_value.span, "backend emission requires named IR types", "retain canonical type repr metadata during IR lowering");
            } else {
                ()
            },
            None => (),
        };
        type_index = type_index + 1;
    };
    let mut source_index = 0;
    while source_index < vec.vec_len(program.source_map) {
        match vec.get(program.source_map, source_index) {
            Some(entry) => if entry.kind == "" || entry.name == "" {
                diagnostics = push_backend_error(diagnostics, "E5013", entry.span, "backend emission requires named source-map entries", "preserve source-map kind/name fields during IR lowering");
            } else {
                ()
            },
            None => (),
        };
        source_index = source_index + 1;
    };
    diagnostics
}

pub fn default_backend_options(name: String) -> BackendOptions {
    backend_options(name, "", LlvmIrArtifact(), true, vec.new_vec())
}

fn concat2(left: String, right: String) -> String {
    let mut parts: Vec[String] = vec.new_vec();
    parts = vec.push(parts, left);
    parts = vec.push(parts, right);
    string.join(parts, "")
}

fn concat3(first: String, second: String, third: String) -> String {
    let mut parts: Vec[String] = vec.new_vec();
    parts = vec.push(parts, first);
    parts = vec.push(parts, second);
    parts = vec.push(parts, third);
    string.join(parts, "")
}

pub fn backend_mangle_symbol(name: String) -> String {
    let mut out = string.replace(name, "::", "_");
    out = string.replace(out, ".", "_");
    out = string.replace(out, "[", "_");
    out = string.replace(out, "]", "");
    out = string.replace(out, ",", "_");
    out = string.replace(out, ":", "_");
    out = string.replace(out, " ", "_");
    out = string.replace(out, "-", "_");
    out = string.replace(out, "(", "_");
    out = string.replace(out, ")", "");
    if out == "main" {
        "aic_main"
    } else {
        concat2("aic_", out)
    }
}

pub fn backend_artifact_file_name(options: BackendOptions) -> String {
    let base = if options.artifact_name == "" {
        "aic_selfhost"
    } else {
        backend_mangle_symbol(options.artifact_name)
    };
    if match options.artifact_kind { StaticLibraryArtifact => true, _ => false } {
        concat3("lib", base, backend_artifact_extension(options.artifact_kind))
    } else {
        concat2(base, backend_artifact_extension(options.artifact_kind))
    }
}

fn backend_symbol(source_name: String, llvm_name: String, kind: String, span_value: SourceSpan) -> BackendSymbol {
    BackendSymbol {
        source_name: source_name,
        llvm_name: llvm_name,
        kind: kind,
        span: span_value,
    }
}

fn backend_local_record(name: String, type_name: String, llvm_type: String, value_name: String) -> BackendLocal {
    BackendLocal {
        name: name,
        type_name: type_name,
        llvm_type: llvm_type,
        value_name: value_name,
    }
}

fn backend_local(name: String, type_name: String, llvm_type: String, value_name: String) -> BackendLocal {
    backend_local_record(name, type_name, llvm_type, value_name)
}

fn backend_mutable_local(name: String, type_name: String, llvm_type: String, value_name: String, storage_name: String) -> BackendLocal {
    backend_local_record(name, type_name, llvm_type, storage_name)
}

fn backend_empty_locals() -> BackendLocals {
    BackendLocals {
        names: vec.new_vec(),
        type_names: vec.new_vec(),
        llvm_types: vec.new_vec(),
        value_names: vec.new_vec(),
    }
}

fn backend_locals_len(locals: BackendLocals) -> Int {
    vec.vec_len(locals.names)
}

fn backend_locals_push_parts(locals: BackendLocals, name: String, type_name: String, llvm_type: String, value_name: String) -> BackendLocals {
    let names = clone_string_vec(locals.names);
    let type_names = clone_string_vec(locals.type_names);
    let llvm_types = clone_string_vec(locals.llvm_types);
    let value_names = clone_string_vec(locals.value_names);
    BackendLocals {
        names: vec.push(names, name),
        type_names: vec.push(type_names, type_name),
        llvm_types: vec.push(llvm_types, llvm_type),
        value_names: vec.push(value_names, value_name),
    }
}

fn backend_locals_push(locals: BackendLocals, local: BackendLocal) -> BackendLocals {
    backend_locals_push_parts(locals, local.name, local.type_name, local.llvm_type, local.value_name)
}

fn backend_local_check(ok: Bool, locals: BackendLocals) -> BackendLocalCheck {
    BackendLocalCheck {
        ok: ok,
        locals: locals,
    }
}

fn backend_statement_emission(text: String, locals: BackendLocals) -> BackendStatementEmission {
    BackendStatementEmission {
        text: text,
        locals: locals,
    }
}

fn type_name_for_id(types: Vec[IrTypeDef], id: IrTypeId) -> String {
    let mut index = 0;
    let mut out = "<?>";
    while index < vec.vec_len(types) {
        match vec.get(types, index) {
            Some(value) => if value.id.value == id.value {
                out = value.name;
                index = vec.vec_len(types);
            } else {
                ()
            },
            None => (),
        };
        index = index + 1;
    };
    out
}

fn optional_type_name_for_id(types: Vec[IrTypeDef], id: Option[IrTypeId]) -> String {
    match id {
        Some(value) => type_name_for_id(types, value),
        None => "",
    }
}

fn llvm_type_for_repr(repr: String) -> String {
    if repr == "Int" || repr == "Int64" || repr == "UInt" || repr == "usize" || repr == "isize" {
        "i64"
    } else if repr == "Int32" || repr == "UInt32" || repr == "ProcExitStatus" {
        "i32"
    } else if repr == "Int16" || repr == "UInt16" {
        "i16"
    } else if repr == "Int8" || repr == "UInt8" {
        "i8"
    } else if repr == "Bool" {
        "i1"
    } else if repr == "String" {
        "%aic.String"
    } else if repr == "()" {
        "void"
    } else {
        ""
    }
}

fn base_type_name_text(value: String) -> String {
    let mut index = 0;
    let mut out = value;
    while index < string.len(value) {
        if string.substring(value, index, index + 1) == "[" {
            out = string.trim(string.substring(value, 0, index));
            index = string.len(value);
        } else {
            ()
        };
        index = index + 1;
    };
    out
}

fn generic_arg_at(value: String, target: Int) -> String {
    let mut bracket = -1;
    let mut index = 0;
    while bracket < 0 && index < string.len(value) {
        if string.substring(value, index, index + 1) == "[" {
            bracket = index;
        } else {
            ()
        };
        index = index + 1;
    };
    let mut out = "";
    if bracket >= 0 {
        let mut depth = 0;
        let mut seen = 0;
        let mut start = bracket + 1;
        index = bracket + 1;
        while out == "" && index < string.len(value) {
            let ch = string.substring(value, index, index + 1);
            if ch == "[" {
                depth = depth + 1;
            } else if ch == "]" {
                if depth == 0 {
                    if seen == target {
                        out = string.trim(string.substring(value, start, index));
                    } else {
                        ()
                    };
                    index = string.len(value);
                } else {
                    depth = depth - 1;
                }
            } else if ch == "," && depth == 0 {
                if seen == target {
                    out = string.trim(string.substring(value, start, index));
                    index = string.len(value);
                } else {
                    seen = seen + 1;
                    start = index + 1;
                }
            } else {
                ()
            };
            index = index + 1;
        }
    } else {
        ()
    };
    out
}

fn llvm_no_payload_enum_type(variant_count: Int) -> String {
    let mut parts: Vec[String] = vec.new_vec();
    parts = vec.push(parts, "{ i32");
    let mut index = 0;
    while index < variant_count {
        parts = vec.push(parts, ", i8");
        index = index + 1;
    };
    parts = vec.push(parts, " }");
    string.join(parts, "")
}

fn known_no_payload_enum_llvm_type(name: String) -> String {
    if name == "FsError" {
        llvm_no_payload_enum_type(7)
    } else if name == "ProcError" {
        llvm_no_payload_enum_type(5)
    } else if name == "IoError" {
        llvm_no_payload_enum_type(3)
    } else if name == "Writer" {
        llvm_no_payload_enum_type(2)
    } else {
        ""
    }
}

fn llvm_payload_slot_type(program: IrProgram, repr: String) -> String {
    let ty = llvm_type_for_repr_in_program(program, repr);
    if ty == "void" {
        "i8"
    } else {
        ty
    }
}

fn llvm_result_type(program: IrProgram, repr: String) -> String {
    let ok = generic_arg_at(repr, 0);
    let err = generic_arg_at(repr, 1);
    let ok_ty = llvm_payload_slot_type(program, ok);
    let err_ty = llvm_payload_slot_type(program, err);
    if ok_ty == "" || err_ty == "" {
        ""
    } else {
        concat3(concat3("{ i32, ", ok_ty, ", "), err_ty, " }")
    }
}

fn llvm_option_type(program: IrProgram, repr: String) -> String {
    let some = generic_arg_at(repr, 0);
    let some_ty = llvm_payload_slot_type(program, some);
    if some_ty == "" {
        ""
    } else {
        concat3("{ i32, ", some_ty, ", i8 }")
    }
}

fn known_struct_llvm_type(program: IrProgram, name: String) -> String {
    if name == "SourceLoadState" {
        "{ { i64, i64, i64 }, i64 }"
    } else if name == "SourceId" {
        "{ i64 }"
    } else if name == "SourceSpan" {
        "{ { i64 }, i64, i64 }"
    } else if name == "LineColumn" {
        "{ i64, i64 }"
    } else if name == "SourceLocation" {
        "{ { i64 }, i64, { i64, i64 } }"
    } else if name == "DiagnosticCode" {
        "{ %aic.String }"
    } else if name == "Diagnostic" {
        "{ { %aic.String }, { i32, i8, i8, i8 }, { { i64 }, i64, i64 }, %aic.String, { i32, i8, %aic.String } }"
    } else if name == "Token" {
        "{ { i32, i8, i8, i8, i8, i8, i8, i8, i8, i8, i8, i8, i8, i8 }, { { i64 }, i64, i64 }, %aic.String }"
    } else if name == "IrNodeId" {
        "{ i64 }"
    } else if name == "IrSymbolId" {
        "{ i64 }"
    } else if name == "IrTypeId" {
        "{ i64 }"
    } else if name == "IrSymbol" {
        "{ { i64 }, %aic.String, { i32, i8, i8, i8, i8, i8, i8, i8, i8, i8, i8, i8, i8 }, { { i64 }, i64, i64 } }"
    } else if name == "IrTypeDef" {
        "{ { i64 }, %aic.String, { i32, i8, i8, i8, i8, i8, i8, i8, %aic.String, %aic.String, %aic.String, %aic.String, i8 }, { { i64 }, i64, i64 } }"
    } else if name == "IrFunction" {
        "{ { i64 }, %aic.String, { i64 }, { { i64 }, i64, i64 } }"
    } else if name == "IrGenericParam" {
        "{ %aic.String, { i64, i64, i64 }, { { i64 }, i64, i64 } }"
    } else if name == "IrParam" {
        "{ { i64 }, %aic.String, { i64, i64, i64 }, { i64 }, { { i64 }, i64, i64 } }"
    } else if name == "IrField" {
        "{ { i64 }, %aic.String, { i32, i8, i8, i8 }, { i64, i64, i64 }, { i64 }, { i32, { { i64 }, { i32, i8, i8, i8, i8, i8, i8, i8, i8, i8, i8, i8, i8, i8, i8, i8, i8, i8, i8, i8, i8, i8, i8, i8, i8, i8, i8, i8 }, %aic.String, %aic.String, i64, { i64, i64, i64 }, { i64, i64, i64 }, { i64, i64, i64 }, { i32, { i64 }, i8 }, { { i64 }, i64, i64 }, %aic.String }, i8 }, { { i64 }, i64, i64 } }"
    } else if name == "IrVariant" {
        "{ { i64 }, %aic.String, { i64, i64, i64 }, { i32, { i64 }, i8 }, { { i64 }, i64, i64 } }"
    } else if name == "IrExprNode" {
        "{ { i64 }, { i32, i8, i8, i8, i8, i8, i8, i8, i8, i8, i8, i8, i8, i8, i8, i8, i8, i8, i8, i8, i8, i8, i8, i8, i8, i8, i8, i8 }, %aic.String, %aic.String, %aic.String, i64, i64, { i64, i64, i64 }, { i64, i64, i64 }, { i32, { i64 }, i8 }, { { i64 }, i64, i64 }, %aic.String }"
    } else if name == "IrPatternNode" {
        "{ { i64 }, { i32, i8, i8, i8, i8, i8, i8, i8, i8, i8, i8, i8 }, %aic.String, %aic.String, i64, i64, { { i64 }, i64, i64 }, %aic.String }"
    } else if name == "IrMatchArm" {
        "{ %aic.String, %aic.String, %aic.String, { i64, i64, i64 }, { { i64 }, i64, i64 }, %aic.String }"
    } else if name == "IrPattern" {
        "{ { i64 }, { i32, i8, i8, i8, i8, i8, i8, i8, i8, i8, i8, i8 }, %aic.String, i64, { i64, i64, i64 }, { { i64 }, i64, i64 }, %aic.String }"
    } else if name == "IrExpr" {
        "{ { i64 }, { i32, i8, i8, i8, i8, i8, i8, i8, i8, i8, i8, i8, i8, i8, i8, i8, i8, i8, i8, i8, i8, i8, i8, i8, i8, i8, i8, i8 }, %aic.String, %aic.String, i64, { i64, i64, i64 }, { i64, i64, i64 }, { i64, i64, i64 }, { i32, { i64 }, i8 }, { { i64 }, i64, i64 }, %aic.String }"
    } else if name == "IrStatement" {
        "{ { i32, i8, i8, i8, i8, i8 }, { i32, { i64 }, i8 }, %aic.String, %aic.String, i1, { i32, { i64 }, i8 }, { i32, { { i64 }, { i32, i8, i8, i8, i8, i8, i8, i8, i8, i8, i8, i8 }, %aic.String, i64, { i64, i64, i64 }, { { i64 }, i64, i64 }, %aic.String }, i8 }, { i32, { { i64 }, { i32, i8, i8, i8, i8, i8, i8, i8, i8, i8, i8, i8, i8, i8, i8, i8, i8, i8, i8, i8, i8, i8, i8, i8, i8, i8, i8, i8 }, %aic.String, %aic.String, i64, { i64, i64, i64 }, { i64, i64, i64 }, { i64, i64, i64 }, { i32, { i64 }, i8 }, { { i64 }, i64, i64 }, %aic.String }, i8 }, { { i64 }, i64, i64 }, %aic.String }"
    } else if name == "IrBlock" {
        "{ { i64 }, { i64, i64, i64 }, { i32, { { i64 }, { i32, i8, i8, i8, i8, i8, i8, i8, i8, i8, i8, i8, i8, i8, i8, i8, i8, i8, i8, i8, i8, i8, i8, i8, i8, i8, i8, i8 }, %aic.String, %aic.String, i64, { i64, i64, i64 }, { i64, i64, i64 }, { i64, i64, i64 }, { i32, { i64 }, i8 }, { { i64 }, i64, i64 }, %aic.String }, i8 }, { { i64 }, i64, i64 }, %aic.String }"
    } else if name == "IrFunctionDef" {
        "{ { i64 }, %aic.String, { i32, i8, i8, i8 }, { i64, i64, i64 }, i1, i1, i1, %aic.String, i1, %aic.String, { i64, i64, i64 }, { i64, i64, i64 }, { i64 }, { i64, i64, i64 }, { i64, i64, i64 }, { i32, { { i64 }, { i32, i8, i8, i8, i8, i8, i8, i8, i8, i8, i8, i8, i8, i8, i8, i8, i8, i8, i8, i8, i8, i8, i8, i8, i8, i8, i8, i8 }, %aic.String, %aic.String, i64, { i64, i64, i64 }, { i64, i64, i64 }, { i64, i64, i64 }, { i32, { i64 }, i8 }, { { i64 }, i64, i64 }, %aic.String }, i8 }, { i32, { { i64 }, { i32, i8, i8, i8, i8, i8, i8, i8, i8, i8, i8, i8, i8, i8, i8, i8, i8, i8, i8, i8, i8, i8, i8, i8, i8, i8, i8, i8 }, %aic.String, %aic.String, i64, { i64, i64, i64 }, { i64, i64, i64 }, { i64, i64, i64 }, { i32, { i64 }, i8 }, { { i64 }, i64, i64 }, %aic.String }, i8 }, { { i64 }, { i64, i64, i64 }, { i32, { { i64 }, { i32, i8, i8, i8, i8, i8, i8, i8, i8, i8, i8, i8, i8, i8, i8, i8, i8, i8, i8, i8, i8, i8, i8, i8, i8, i8, i8, i8 }, %aic.String, %aic.String, i64, { i64, i64, i64 }, { i64, i64, i64 }, { i64, i64, i64 }, { i32, { i64 }, i8 }, { { i64 }, i64, i64 }, %aic.String }, i8 }, { { i64 }, i64, i64 }, %aic.String }, i1, { { i64 }, i64, i64 } }"
    } else if name == "IrStructDef" {
        "{ { i64 }, %aic.String, { i32, i8, i8, i8 }, { i64, i64, i64 }, { i64, i64, i64 }, { i64, i64, i64 }, { i32, { { i64 }, { i32, i8, i8, i8, i8, i8, i8, i8, i8, i8, i8, i8, i8, i8, i8, i8, i8, i8, i8, i8, i8, i8, i8, i8, i8, i8, i8, i8 }, %aic.String, %aic.String, i64, { i64, i64, i64 }, { i64, i64, i64 }, { i64, i64, i64 }, { i32, { i64 }, i8 }, { { i64 }, i64, i64 }, %aic.String }, i8 }, { { i64 }, i64, i64 } }"
    } else if name == "IrEnumDef" {
