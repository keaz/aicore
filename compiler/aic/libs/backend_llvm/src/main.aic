fn emit_runtime_declarations(program: IrProgram) -> String {
    let mut parts: Vec[String] = vec.new_vec();
    if program_uses_string_type(program) {
        parts = vec.push(parts, "declare i64 @aic_rt_string_compare(i8*, i64, i64, i8*, i64, i64)\n");
    } else {
        ()
    };
    if program_uses_string_replace(program) {
        parts = vec.push(parts, "declare void @aic_rt_string_replace(i8*, i64, i64, i8*, i64, i64, i8*, i64, i64, i8**, i64*)\n");
    } else {
        ()
    };
    if program_uses_io_print(program) {
        parts = vec.push(parts, "declare void @aic_rt_print_str(i8*, i64, i64)\n");
        parts = vec.push(parts, "declare void @aic_rt_eprint_str(i8*, i64, i64)\n");
    } else {
        ()
    };
    if program_uses_env_arg_at(program) {
        parts = vec.push(parts, "declare i64 @aic_rt_env_arg_at(i64, i8**, i64*)\n");
    } else {
        ()
    };
    if program_uses_call_named(program, "read_text") {
        parts = vec.push(parts, "declare i64 @aic_rt_fs_read_text(i8*, i64, i64, i8**, i64*)\n");
    } else {
        ()
    };
    if program_uses_call_named(program, "temp_file") {
        parts = vec.push(parts, "declare i64 @aic_rt_fs_temp_file(i8*, i64, i64, i8**, i64*)\n");
    } else {
        ()
    };
    if program_uses_call_named(program, "write_text") {
        parts = vec.push(parts, "declare i64 @aic_rt_fs_write_text(i8*, i64, i64, i8*, i64, i64)\n");
    } else {
        ()
    };
    if program_uses_call_named(program, "delete") {
        parts = vec.push(parts, "declare i64 @aic_rt_fs_delete(i8*, i64, i64)\n");
    } else {
        ()
    };
    string.join(parts, "")
}

fn emit_type_declarations(program: IrProgram) -> String {
    if program_uses_string_type(program) {
        "%aic.String = type { i8*, i64, i64 }\n"
    } else {
        ""
    }
}

fn llvm_expr_prefix(node: IrNodeId) -> String {
    concat2("expr.", string.int_to_string(node.value))
}

fn llvm_node_prefix(node: IrNodeId) -> String {
    concat2("node.", string.int_to_string(node.value))
}

fn llvm_local(prefix: String, suffix: String) -> String {
    concat3("%", prefix, suffix)
}

fn llvm_expr_value_local(expr: IrExpr) -> String {
    llvm_local(llvm_expr_prefix(expr.node), ".value")
}

fn llvm_node_value_local(node: IrExprNode) -> String {
    llvm_local(llvm_node_prefix(node.node), ".value")
}

fn emit_string_literal_value(global_name: String, literal_text: String, prefix: String) -> String {
    let payload = string_literal_payload(literal_text);
    let mut parts: Vec[String] = vec.new_vec();
    parts = vec.push(parts, "  ");
    parts = vec.push(parts, llvm_local(prefix, ".ptr"));
    parts = vec.push(parts, " = getelementptr inbounds [");
    parts = vec.push(parts, string.int_to_string(string.len(payload)));
    parts = vec.push(parts, " x i8], [");
    parts = vec.push(parts, string.int_to_string(string.len(payload)));
    parts = vec.push(parts, " x i8]* ");
    parts = vec.push(parts, global_name);
    parts = vec.push(parts, ", i64 0, i64 0\n  ");
    parts = vec.push(parts, llvm_local(prefix, ".0"));
    parts = vec.push(parts, " = insertvalue %aic.String undef, i8* ");
    parts = vec.push(parts, llvm_local(prefix, ".ptr"));
    parts = vec.push(parts, ", 0\n  ");
    parts = vec.push(parts, llvm_local(prefix, ".1"));
    parts = vec.push(parts, " = insertvalue %aic.String ");
    parts = vec.push(parts, llvm_local(prefix, ".0"));
    parts = vec.push(parts, ", i64 ");
    parts = vec.push(parts, string.int_to_string(string.len(payload)));
    parts = vec.push(parts, ", 1\n  ");
    parts = vec.push(parts, llvm_local(prefix, ".value"));
    parts = vec.push(parts, " = insertvalue %aic.String ");
    parts = vec.push(parts, llvm_local(prefix, ".1"));
    parts = vec.push(parts, ", i64 ");
    parts = vec.push(parts, string.int_to_string(string.len(payload)));
    parts = vec.push(parts, ", 2\n");
    string.join(parts, "")
}

fn emit_string_extracts(value_name: String, prefix: String) -> String {
    let mut parts: Vec[String] = vec.new_vec();
    parts = vec.push(parts, "  ");
    parts = vec.push(parts, llvm_local(prefix, ".ptr"));
    parts = vec.push(parts, " = extractvalue %aic.String ");
    parts = vec.push(parts, value_name);
    parts = vec.push(parts, ", 0\n  ");
    parts = vec.push(parts, llvm_local(prefix, ".len"));
    parts = vec.push(parts, " = extractvalue %aic.String ");
    parts = vec.push(parts, value_name);
    parts = vec.push(parts, ", 1\n  ");
    parts = vec.push(parts, llvm_local(prefix, ".cap"));
    parts = vec.push(parts, " = extractvalue %aic.String ");
    parts = vec.push(parts, value_name);
    parts = vec.push(parts, ", 2\n");
    string.join(parts, "")
}

fn emit_string_replace_call(prefix: String, first_value: String, second_value: String, third_value: String) -> String {
    let first_prefix = concat2(prefix, ".arg0");
    let second_prefix = concat2(prefix, ".arg1");
    let third_prefix = concat2(prefix, ".arg2");
    let mut parts: Vec[String] = vec.new_vec();
    parts = vec.push(parts, emit_string_extracts(first_value, first_prefix));
    parts = vec.push(parts, emit_string_extracts(second_value, second_prefix));
    parts = vec.push(parts, emit_string_extracts(third_value, third_prefix));
    parts = vec.push(parts, "  ");
    parts = vec.push(parts, llvm_local(prefix, ".out.ptr"));
    parts = vec.push(parts, " = alloca i8*\n  ");
    parts = vec.push(parts, llvm_local(prefix, ".out.len"));
    parts = vec.push(parts, " = alloca i64\n  call void @aic_rt_string_replace(i8* ");
    parts = vec.push(parts, llvm_local(first_prefix, ".ptr"));
    parts = vec.push(parts, ", i64 ");
    parts = vec.push(parts, llvm_local(first_prefix, ".len"));
    parts = vec.push(parts, ", i64 ");
    parts = vec.push(parts, llvm_local(first_prefix, ".cap"));
    parts = vec.push(parts, ", i8* ");
    parts = vec.push(parts, llvm_local(second_prefix, ".ptr"));
    parts = vec.push(parts, ", i64 ");
    parts = vec.push(parts, llvm_local(second_prefix, ".len"));
    parts = vec.push(parts, ", i64 ");
    parts = vec.push(parts, llvm_local(second_prefix, ".cap"));
    parts = vec.push(parts, ", i8* ");
    parts = vec.push(parts, llvm_local(third_prefix, ".ptr"));
    parts = vec.push(parts, ", i64 ");
    parts = vec.push(parts, llvm_local(third_prefix, ".len"));
    parts = vec.push(parts, ", i64 ");
    parts = vec.push(parts, llvm_local(third_prefix, ".cap"));
    parts = vec.push(parts, ", i8** ");
    parts = vec.push(parts, llvm_local(prefix, ".out.ptr"));
    parts = vec.push(parts, ", i64* ");
    parts = vec.push(parts, llvm_local(prefix, ".out.len"));
    parts = vec.push(parts, ")\n  ");
    parts = vec.push(parts, llvm_local(prefix, ".ret.ptr"));
    parts = vec.push(parts, " = load i8*, i8** ");
    parts = vec.push(parts, llvm_local(prefix, ".out.ptr"));
    parts = vec.push(parts, "\n  ");
    parts = vec.push(parts, llvm_local(prefix, ".ret.len"));
    parts = vec.push(parts, " = load i64, i64* ");
    parts = vec.push(parts, llvm_local(prefix, ".out.len"));
    parts = vec.push(parts, "\n  ");
    parts = vec.push(parts, llvm_local(prefix, ".0"));
    parts = vec.push(parts, " = insertvalue %aic.String undef, i8* ");
    parts = vec.push(parts, llvm_local(prefix, ".ret.ptr"));
    parts = vec.push(parts, ", 0\n  ");
    parts = vec.push(parts, llvm_local(prefix, ".1"));
    parts = vec.push(parts, " = insertvalue %aic.String ");
    parts = vec.push(parts, llvm_local(prefix, ".0"));
    parts = vec.push(parts, ", i64 ");
    parts = vec.push(parts, llvm_local(prefix, ".ret.len"));
    parts = vec.push(parts, ", 1\n  ");
    parts = vec.push(parts, llvm_local(prefix, ".value"));
    parts = vec.push(parts, " = insertvalue %aic.String ");
    parts = vec.push(parts, llvm_local(prefix, ".1"));
    parts = vec.push(parts, ", i64 ");
    parts = vec.push(parts, llvm_local(prefix, ".ret.len"));
    parts = vec.push(parts, ", 2\n");
    string.join(parts, "")
}

fn string_node_value_name_with_locals(function_value: IrFunctionDef, locals: Vec[BackendLocal], node: IrExprNode) -> String {
    match node.kind {
        IrNameExpr => value_name_for_name(function_value, locals, node.text),
        _ => llvm_node_value_local(node),
    }
}

fn string_node_value_name(node: IrExprNode) -> String {
    match node.kind {
        IrNameExpr => concat2("%", backend_mangle_symbol(node.text)),
        _ => llvm_node_value_local(node),
    }
}

fn emit_string_node_value(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], node: IrExprNode, locals: Vec[BackendLocal]) -> String {
    match node.kind {
        IrStringExpr => emit_string_literal_value(llvm_string_node_global_name(function_value.name, node.node), node.text, llvm_node_prefix(node.node)),
        IrNameExpr => "",
        IrFieldAccessExpr => emit_field_access_node_value(program, function_value, nodes, node, locals),
        IrCallExpr => if node.name == "string.replace" {
            emit_string_replace_node_value(program, function_value, nodes, node, locals)
        } else {
            emit_string_direct_call_node_value(program, function_value, nodes, node, locals)
        },
        _ => "",
    }
}

fn emit_string_replace_node_value(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], node: IrExprNode, locals: Vec[BackendLocal]) -> String {
    let mut parts: Vec[String] = vec.new_vec();
    let first = match expr_node_child_at(nodes, node, 0) {
        Some(child) => if true {
            parts = vec.push(parts, emit_string_node_value(program, function_value, nodes, child, locals));
            string_node_value_name_with_locals(function_value, locals, child)
        } else { "" },
        None => "",
    };
    let second = match expr_node_child_at(nodes, node, 1) {
        Some(child) => if true {
            parts = vec.push(parts, emit_string_node_value(program, function_value, nodes, child, locals));
            string_node_value_name_with_locals(function_value, locals, child)
        } else { "" },
        None => "",
    };
    let third = match expr_node_child_at(nodes, node, 2) {
        Some(child) => if true {
            parts = vec.push(parts, emit_string_node_value(program, function_value, nodes, child, locals));
            string_node_value_name_with_locals(function_value, locals, child)
        } else { "" },
        None => "",
    };
    parts = vec.push(parts, emit_string_replace_call(llvm_node_prefix(node.node), first, second, third));
    string.join(parts, "")
}

fn emit_string_direct_call_node_value(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], node: IrExprNode, locals: Vec[BackendLocal]) -> String {
    let mut parts: Vec[String] = vec.new_vec();
    parts = vec.push(parts, emit_node_call_arg_values(program, function_value, nodes, node, locals));
    parts = vec.push(parts, "  ");
    parts = vec.push(parts, llvm_node_value_local(node));
    parts = vec.push(parts, " = call %aic.String @");
    parts = vec.push(parts, backend_mangle_symbol(node.name));
    parts = vec.push(parts, "(");
    parts = vec.push(parts, emit_node_call_args(program, function_value, nodes, node, locals));
    parts = vec.push(parts, ")\n");
    string.join(parts, "")
}

fn emit_direct_call_node_value(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], node: IrExprNode, locals: Vec[BackendLocal]) -> String {
    let ret = call_target_return_type(program, node.name);
    if ret == "%aic.String" {
        emit_string_direct_call_node_value(program, function_value, nodes, node, locals)
    } else {
        let mut parts: Vec[String] = vec.new_vec();
        parts = vec.push(parts, emit_node_call_arg_values(program, function_value, nodes, node, locals));
        parts = vec.push(parts, "  ");
        parts = vec.push(parts, llvm_node_value_local(node));
        parts = vec.push(parts, " = call ");
        parts = vec.push(parts, ret);
        parts = vec.push(parts, " @");
        parts = vec.push(parts, backend_mangle_symbol(node.name));
        parts = vec.push(parts, "(");
        parts = vec.push(parts, emit_node_call_args(program, function_value, nodes, node, locals));
        parts = vec.push(parts, ")\n");
        string.join(parts, "")
    }
}

fn emit_value_node(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], node: IrExprNode, locals: Vec[BackendLocal]) -> String {
    match node.kind {
        IrStringExpr => emit_string_node_value(program, function_value, nodes, node, locals),
        IrFieldAccessExpr => emit_field_access_node_value(program, function_value, nodes, node, locals),
        IrCallExpr => if node.name == "string.replace" {
            emit_string_replace_node_value(program, function_value, nodes, node, locals)
        } else {
            emit_direct_call_node_value(program, function_value, nodes, node, locals)
        },
        IrStructLiteralExpr => emit_struct_literal_node_value(program, function_value, nodes, node, locals, value_node_llvm_type(program, function_value, nodes, node, locals)),
        _ => "",
    }
}

fn emit_string_replace_expr_value(program: IrProgram, function_value: IrFunctionDef, expr: IrExpr, locals: Vec[BackendLocal]) -> String {
    let mut parts: Vec[String] = vec.new_vec();
    let first = match direct_expr_child_at(expr.nodes, 0) {
        Some(child) => if true {
            parts = vec.push(parts, emit_string_node_value(program, function_value, expr.nodes, child, locals));
            string_node_value_name_with_locals(function_value, locals, child)
        } else { "" },
        None => "",
    };
    let second = match direct_expr_child_at(expr.nodes, 1) {
        Some(child) => if true {
            parts = vec.push(parts, emit_string_node_value(program, function_value, expr.nodes, child, locals));
            string_node_value_name_with_locals(function_value, locals, child)
        } else { "" },
        None => "",
    };
    let third = match direct_expr_child_at(expr.nodes, 2) {
        Some(child) => if true {
            parts = vec.push(parts, emit_string_node_value(program, function_value, expr.nodes, child, locals));
            string_node_value_name_with_locals(function_value, locals, child)
        } else { "" },
        None => "",
    };
    parts = vec.push(parts, emit_string_replace_call(llvm_expr_prefix(expr.node), first, second, third));
    string.join(parts, "")
}

fn emit_string_direct_call_expr_value(program: IrProgram, function_value: IrFunctionDef, expr: IrExpr, locals: Vec[BackendLocal]) -> String {
    let mut parts: Vec[String] = vec.new_vec();
    parts = vec.push(parts, emit_call_arg_values(program, function_value, expr.nodes, expr.name, locals));
    parts = vec.push(parts, "  ");
    parts = vec.push(parts, llvm_expr_value_local(expr));
    parts = vec.push(parts, " = call %aic.String @");
    parts = vec.push(parts, backend_mangle_symbol(expr.name));
    parts = vec.push(parts, "(");
    parts = vec.push(parts, emit_call_args(program, function_value, expr.nodes, expr.name, locals));
    parts = vec.push(parts, ")\n");
    string.join(parts, "")
}

fn bool_node_value_name_with_locals(function_value: IrFunctionDef, locals: Vec[BackendLocal], node: IrExprNode) -> String {
    match node.kind {
        IrBoolExpr => if node.text == "true" { "1" } else { "0" },
        IrNameExpr => value_name_for_name(function_value, locals, node.text),
        _ => llvm_node_value_local(node),
    }
}

fn bool_node_value_name(node: IrExprNode) -> String {
    match node.kind {
        IrBoolExpr => if node.text == "true" { "1" } else { "0" },
        IrNameExpr => concat2("%", backend_mangle_symbol(node.text)),
        _ => llvm_node_value_local(node),
    }
}

fn emit_bool_node_value(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], node: IrExprNode, locals: Vec[BackendLocal]) -> String {
    match node.kind {
        IrBoolExpr => "",
        IrNameExpr => "",
        IrBinaryExpr => emit_compare_node_value(program, function_value, nodes, node, locals),
        _ => "",
    }
}

fn emit_compare_node_value(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], node: IrExprNode, locals: Vec[BackendLocal]) -> String {
    match expr_node_child_at(nodes, node, 0) {
        Some(left) => match expr_node_child_at(nodes, node, 1) {
            Some(right) => if string_call_child_can_emit(program, function_value, nodes, left, locals) && string_call_child_can_emit(program, function_value, nodes, right, locals) {
                emit_string_compare_node_value(program, function_value, nodes, node, left, right, locals)
            } else {
                emit_primitive_compare_node_value(program, function_value, nodes, node, left, right, locals)
            },
            None => "",
        },
        None => "",
    }
}

fn emit_primitive_compare_node_value(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], node: IrExprNode, left: IrExprNode, right: IrExprNode, locals: Vec[BackendLocal]) -> String {
    let ty = value_node_llvm_type(program, function_value, nodes, left, locals);
    let mut parts: Vec[String] = vec.new_vec();
    parts = vec.push(parts, emit_value_node(program, function_value, nodes, left, locals));
    parts = vec.push(parts, emit_value_node(program, function_value, nodes, right, locals));
    parts = vec.push(parts, "  ");
    parts = vec.push(parts, llvm_node_value_local(node));
    parts = vec.push(parts, " = icmp ");
    parts = vec.push(parts, compare_predicate(node.op));
    parts = vec.push(parts, " ");
    parts = vec.push(parts, ty);
    parts = vec.push(parts, " ");
    parts = vec.push(parts, node_value_name(program, function_value, nodes, left, locals));
    parts = vec.push(parts, ", ");
    parts = vec.push(parts, node_value_name(program, function_value, nodes, right, locals));
    parts = vec.push(parts, "\n");
    string.join(parts, "")
}

fn emit_string_compare_node_value(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], node: IrExprNode, left: IrExprNode, right: IrExprNode, locals: Vec[BackendLocal]) -> String {
    let left_name = string_node_value_name_with_locals(function_value, locals, left);
    let right_name = string_node_value_name_with_locals(function_value, locals, right);
    let mut parts: Vec[String] = vec.new_vec();
    parts = vec.push(parts, emit_string_node_value(program, function_value, nodes, left, locals));
    parts = vec.push(parts, emit_string_node_value(program, function_value, nodes, right, locals));
    parts = vec.push(parts, emit_string_extracts(left_name, concat2(llvm_node_prefix(node.node), ".lhs")));
    parts = vec.push(parts, emit_string_extracts(right_name, concat2(llvm_node_prefix(node.node), ".rhs")));
    parts = vec.push(parts, "  ");
    parts = vec.push(parts, llvm_local(llvm_node_prefix(node.node), ".raw"));
    parts = vec.push(parts, " = call i64 @aic_rt_string_compare(i8* ");
    parts = vec.push(parts, llvm_local(concat2(llvm_node_prefix(node.node), ".lhs"), ".ptr"));
    parts = vec.push(parts, ", i64 ");
    parts = vec.push(parts, llvm_local(concat2(llvm_node_prefix(node.node), ".lhs"), ".len"));
    parts = vec.push(parts, ", i64 ");
    parts = vec.push(parts, llvm_local(concat2(llvm_node_prefix(node.node), ".lhs"), ".cap"));
    parts = vec.push(parts, ", i8* ");
    parts = vec.push(parts, llvm_local(concat2(llvm_node_prefix(node.node), ".rhs"), ".ptr"));
    parts = vec.push(parts, ", i64 ");
    parts = vec.push(parts, llvm_local(concat2(llvm_node_prefix(node.node), ".rhs"), ".len"));
    parts = vec.push(parts, ", i64 ");
    parts = vec.push(parts, llvm_local(concat2(llvm_node_prefix(node.node), ".rhs"), ".cap"));
    parts = vec.push(parts, ")\n  ");
    parts = vec.push(parts, llvm_node_value_local(node));
    parts = vec.push(parts, " = icmp ");
    parts = vec.push(parts, string_compare_predicate(node.op));
    parts = vec.push(parts, " i64 ");
    parts = vec.push(parts, llvm_local(llvm_node_prefix(node.node), ".raw"));
    parts = vec.push(parts, ", 0\n");
    string.join(parts, "")
}

fn emit_return_name_value(program: IrProgram, function_value: IrFunctionDef, name: String, ret: String, prefix: String) -> String {
    let source_llvm = function_param_llvm_type(program, function_value, name);
    let source_value = concat2("%", backend_mangle_symbol(name));
    let cast_op = function_param_return_cast_op(program, function_value, name, ret);
    let mut parts: Vec[String] = vec.new_vec();
    if cast_op == "" {
        parts = vec.push(parts, "  ret ");
        parts = vec.push(parts, ret);
        parts = vec.push(parts, " ");
        parts = vec.push(parts, source_value);
        parts = vec.push(parts, "\n");
    } else {
        parts = vec.push(parts, "  ");
        parts = vec.push(parts, llvm_local(prefix, ".cast"));
        parts = vec.push(parts, " = ");
        parts = vec.push(parts, cast_op);
        parts = vec.push(parts, " ");
        parts = vec.push(parts, source_llvm);
        parts = vec.push(parts, " ");
        parts = vec.push(parts, source_value);
        parts = vec.push(parts, " to ");
        parts = vec.push(parts, ret);
        parts = vec.push(parts, "\n  ret ");
        parts = vec.push(parts, ret);
        parts = vec.push(parts, " ");
        parts = vec.push(parts, llvm_local(prefix, ".cast"));
        parts = vec.push(parts, "\n");
    };
    string.join(parts, "")
}

fn emit_return_node_with_locals(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], node: IrExprNode, ret: String, locals: Vec[BackendLocal]) -> String {
    let mut parts: Vec[String] = vec.new_vec();
    match node.kind {
        IrIntExpr => if true {
            parts = vec.push(parts, "  ret ");
            parts = vec.push(parts, ret);
            parts = vec.push(parts, " ");
            parts = vec.push(parts, node.text);
            parts = vec.push(parts, "\n");
            ()
        } else { () },
        IrBoolExpr => if true {
            parts = vec.push(parts, "  ret ");
            parts = vec.push(parts, ret);
            parts = vec.push(parts, " ");
            parts = vec.push(parts, if node.text == "true" { "1" } else { "0" });
            parts = vec.push(parts, "\n");
            ()
        } else { () },
        IrStringExpr => if true {
            parts = vec.push(parts, emit_string_literal_value(llvm_string_node_global_name(function_value.name, node.node), node.text, llvm_node_prefix(node.node)));
            parts = vec.push(parts, "  ret ");
            parts = vec.push(parts, ret);
            parts = vec.push(parts, " ");
            parts = vec.push(parts, llvm_node_value_local(node));
            parts = vec.push(parts, "\n");
            ()
        } else { () },
        IrNameExpr => if true {
            let value_name = value_name_for_name(function_value, locals, node.text);
            if value_name == value_name_for_param(function_value, node.text) {
                parts = vec.push(parts, emit_return_name_value(program, function_value, node.text, ret, llvm_node_prefix(node.node)));
            } else {
                parts = vec.push(parts, "  ret ");
                parts = vec.push(parts, ret);
                parts = vec.push(parts, " ");
                parts = vec.push(parts, value_name);
                parts = vec.push(parts, "\n");
            };
            ()
        } else { () },
        IrFieldAccessExpr => if true {
            parts = vec.push(parts, emit_field_access_node_value(program, function_value, nodes, node, locals));
            parts = vec.push(parts, "  ret ");
            parts = vec.push(parts, ret);
            parts = vec.push(parts, " ");
            parts = vec.push(parts, llvm_node_value_local(node));
            parts = vec.push(parts, "\n");
            ()
        } else { () },
        IrCallExpr => if true {
            parts = vec.push(parts, emit_value_node(program, function_value, nodes, node, locals));
            parts = vec.push(parts, "  ret ");
            parts = vec.push(parts, ret);
            parts = vec.push(parts, " ");
            parts = vec.push(parts, node_value_name(program, function_value, nodes, node, locals));
            parts = vec.push(parts, "\n");
            ()
        } else { () },
        IrIfExpr => if true {
            parts = vec.push(parts, emit_if_node_return(program, function_value, nodes, node, ret, locals));
            ()
        } else { () },
        IrStructLiteralExpr => if true {
            parts = vec.push(parts, emit_struct_literal_node_value(program, function_value, nodes, node, locals, ret));
            parts = vec.push(parts, "  ret ");
            parts = vec.push(parts, ret);
            parts = vec.push(parts, " ");
            parts = vec.push(parts, struct_literal_value_name(llvm_node_prefix(node.node), node.direct_child_count, ret));
            parts = vec.push(parts, "\n");
            ()
        } else { () },
        _ => (),
    };
    string.join(parts, "")
}

fn emit_return_node(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], node: IrExprNode, ret: String) -> String {
    emit_return_node_with_locals(program, function_value, nodes, node, ret, vec.new_vec())
}

fn emit_block_tail_return(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], block_node: IrExprNode, ret: String, locals: Vec[BackendLocal]) -> String {
    emit_block_node_return(program, function_value, nodes, block_node, ret, locals)
}

fn emit_branch_return(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], branch_node: IrExprNode, ret: String, locals: Vec[BackendLocal]) -> String {
    if is_block_expr_kind(branch_node.kind) {
        emit_block_tail_return(program, function_value, nodes, branch_node, ret, locals)
    } else {
        emit_return_node_with_locals(program, function_value, nodes, branch_node, ret, locals)
    }
}

fn emit_if_node_return(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], node: IrExprNode, ret: String, locals: Vec[BackendLocal]) -> String {
    match expr_node_child_at(nodes, node, 0) {
        Some(condition) => match expr_node_child_at(nodes, node, 1) {
            Some(then_block) => match expr_node_child_at(nodes, node, 2) {
                Some(else_block) => if true {
                    let then_label = concat2("if.then.", string.int_to_string(node.node.value));
                    let else_label = concat2("if.else.", string.int_to_string(node.node.value));
                    let mut parts: Vec[String] = vec.new_vec();
                    parts = vec.push(parts, emit_bool_node_value(program, function_value, nodes, condition, locals));
                    parts = vec.push(parts, "  br i1 ");
                    parts = vec.push(parts, bool_node_value_name_with_locals(function_value, locals, condition));
                    parts = vec.push(parts, ", label %");
                    parts = vec.push(parts, then_label);
                    parts = vec.push(parts, ", label %");
                    parts = vec.push(parts, else_label);
                    parts = vec.push(parts, "\n");
                    parts = vec.push(parts, then_label);
                    parts = vec.push(parts, ":\n");
                    parts = vec.push(parts, emit_branch_return(program, function_value, nodes, then_block, ret, locals));
                    parts = vec.push(parts, else_label);
                    parts = vec.push(parts, ":\n");
                    parts = vec.push(parts, emit_branch_return(program, function_value, nodes, else_block, ret, locals));
                    string.join(parts, "")
                } else { "" },
                None => "",
            },
            None => "",
        },
        None => "",
    }
}

fn emit_if_expr_return(program: IrProgram, function_value: IrFunctionDef, expr: IrExpr, ret: String, locals: Vec[BackendLocal]) -> String {
    match direct_expr_child_at(expr.nodes, 0) {
        Some(condition) => match direct_expr_child_at(expr.nodes, 1) {
            Some(then_block) => match direct_expr_child_at(expr.nodes, 2) {
                Some(else_block) => if true {
                    let then_label = concat2("if.then.", string.int_to_string(expr.node.value));
                    let else_label = concat2("if.else.", string.int_to_string(expr.node.value));
                    let mut parts: Vec[String] = vec.new_vec();
                    parts = vec.push(parts, emit_bool_node_value(program, function_value, expr.nodes, condition, locals));
                    parts = vec.push(parts, "  br i1 ");
                    parts = vec.push(parts, bool_node_value_name_with_locals(function_value, locals, condition));
                    parts = vec.push(parts, ", label %");
                    parts = vec.push(parts, then_label);
                    parts = vec.push(parts, ", label %");
                    parts = vec.push(parts, else_label);
                    parts = vec.push(parts, "\n");
                    parts = vec.push(parts, then_label);
                    parts = vec.push(parts, ":\n");
                    parts = vec.push(parts, emit_branch_return(program, function_value, expr.nodes, then_block, ret, locals));
                    parts = vec.push(parts, else_label);
                    parts = vec.push(parts, ":\n");
                    parts = vec.push(parts, emit_branch_return(program, function_value, expr.nodes, else_block, ret, locals));
                    string.join(parts, "")
                } else { "" },
                None => "",
            },
            None => "",
        },
        None => "",
    }
}

fn emit_let_node_value(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], node: IrExprNode, locals: Vec[BackendLocal]) -> String {
    emit_value_node(program, function_value, nodes, node, locals)
}

fn emit_block_node_return(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], block_node: IrExprNode, ret: String, locals: Vec[BackendLocal]) -> String {
    let mut out_locals = locals;
    let mut parts: Vec[String] = vec.new_vec();
    let mut index = 0;
    let mut done = false;
    while !done && index < block_node.direct_child_count {
        match expr_node_child_at(nodes, block_node, index) {
            Some(child) => if block_child_is_let(child) {
                parts = vec.push(parts, emit_let_node_value(program, function_value, nodes, child, out_locals));
                out_locals = push_node_local(program, function_value, nodes, child, out_locals);
                ()
            } else if block_child_is_tail(child) {
                parts = vec.push(parts, emit_return_node_with_locals(program, function_value, nodes, child, ret, out_locals));
                done = true;
                ()
            } else {
                ()
            },
            None => (),
        };
        index = index + 1;
    };
    string.join(parts, "")
}

fn io_print_runtime_name(name: String) -> String {
    if name == "eprint_str" {
        "@aic_rt_eprint_str"
    } else {
        "@aic_rt_print_str"
    }
}

fn emit_io_print_expr_return(program: IrProgram, function_value: IrFunctionDef, expr: IrExpr, locals: Vec[BackendLocal]) -> String {
    match direct_expr_child_at(expr.nodes, 0) {
        Some(child) => if true {
            let arg_name = string_node_value_name_with_locals(function_value, locals, child);
            let prefix = llvm_expr_prefix(expr.node);
            let mut parts: Vec[String] = vec.new_vec();
            parts = vec.push(parts, emit_string_node_value(program, function_value, expr.nodes, child, locals));
            parts = vec.push(parts, emit_string_extracts(arg_name, prefix));
            parts = vec.push(parts, "  call void ");
            parts = vec.push(parts, io_print_runtime_name(expr.name));
            parts = vec.push(parts, "(i8* ");
            parts = vec.push(parts, llvm_local(prefix, ".ptr"));
            parts = vec.push(parts, ", i64 ");
            parts = vec.push(parts, llvm_local(prefix, ".len"));
            parts = vec.push(parts, ", i64 ");
            parts = vec.push(parts, llvm_local(prefix, ".cap"));
            parts = vec.push(parts, ")\n  ret void\n");
            string.join(parts, "")
        } else { "" },
        None => "",
    }
}

fn fs_string_runtime_name(name: String) -> String {
    if name == "temp_file" {
        "@aic_rt_fs_temp_file"
    } else {
        "@aic_rt_fs_read_text"
    }
}

fn fs_bool_runtime_name(name: String) -> String {
    if name == "delete" {
        "@aic_rt_fs_delete"
    } else {
        "@aic_rt_fs_write_text"
    }
}

fn fs_error_value_name(prefix: String) -> String {
    llvm_local(prefix, ".err.value")
}

fn emit_fs_error_value(prefix: String, raw_code_name: String) -> String {
    let err_ty = known_no_payload_enum_llvm_type("FsError");
    let mut parts: Vec[String] = vec.new_vec();
    parts = vec.push(parts, "  ");
    parts = vec.push(parts, llvm_local(prefix, ".err.is_io"));
    parts = vec.push(parts, " = icmp eq i64 ");
    parts = vec.push(parts, raw_code_name);
    parts = vec.push(parts, ", 5\n  ");
    parts = vec.push(parts, llvm_local(prefix, ".err.minus64"));
    parts = vec.push(parts, " = sub i64 ");
    parts = vec.push(parts, raw_code_name);
    parts = vec.push(parts, ", 1\n  ");
    parts = vec.push(parts, llvm_local(prefix, ".err.minus"));
    parts = vec.push(parts, " = trunc i64 ");
    parts = vec.push(parts, llvm_local(prefix, ".err.minus64"));
    parts = vec.push(parts, " to i32\n  ");
    parts = vec.push(parts, llvm_local(prefix, ".err.tag"));
    parts = vec.push(parts, " = select i1 ");
    parts = vec.push(parts, llvm_local(prefix, ".err.is_io"));
    parts = vec.push(parts, ", i32 6, i32 ");
    parts = vec.push(parts, llvm_local(prefix, ".err.minus"));
    parts = vec.push(parts, "\n  ");
    parts = vec.push(parts, fs_error_value_name(prefix));
    parts = vec.push(parts, " = insertvalue ");
    parts = vec.push(parts, err_ty);
    parts = vec.push(parts, " undef, i32 ");
    parts = vec.push(parts, llvm_local(prefix, ".err.tag"));
    parts = vec.push(parts, ", 0\n");
    string.join(parts, "")
}

fn emit_fs_string_result_expr_return(program: IrProgram, function_value: IrFunctionDef, expr: IrExpr, locals: Vec[BackendLocal], ret: String) -> String {
    match direct_expr_child_at(expr.nodes, 0) {
        Some(child) => if true {
            let prefix = llvm_expr_prefix(expr.node);
            let arg_name = string_node_value_name_with_locals(function_value, locals, child);
            let arg_prefix = concat2(prefix, ".arg0");
            let ok_label = concat2("fs.ok.", string.int_to_string(expr.node.value));
            let err_label = concat2("fs.err.", string.int_to_string(expr.node.value));
            let err_ty = known_no_payload_enum_llvm_type("FsError");
            let mut parts: Vec[String] = vec.new_vec();
            parts = vec.push(parts, emit_string_node_value(program, function_value, expr.nodes, child, locals));
            parts = vec.push(parts, emit_string_extracts(arg_name, arg_prefix));
            parts = vec.push(parts, "  ");
            parts = vec.push(parts, llvm_local(prefix, ".out.ptr"));
            parts = vec.push(parts, " = alloca i8*\n  ");
            parts = vec.push(parts, llvm_local(prefix, ".out.len"));
            parts = vec.push(parts, " = alloca i64\n  ");
            parts = vec.push(parts, llvm_local(prefix, ".rc"));
            parts = vec.push(parts, " = call i64 ");
            parts = vec.push(parts, fs_string_runtime_name(expr.name));
            parts = vec.push(parts, "(i8* ");
            parts = vec.push(parts, llvm_local(arg_prefix, ".ptr"));
            parts = vec.push(parts, ", i64 ");
            parts = vec.push(parts, llvm_local(arg_prefix, ".len"));
            parts = vec.push(parts, ", i64 ");
            parts = vec.push(parts, llvm_local(arg_prefix, ".cap"));
            parts = vec.push(parts, ", i8** ");
            parts = vec.push(parts, llvm_local(prefix, ".out.ptr"));
            parts = vec.push(parts, ", i64* ");
            parts = vec.push(parts, llvm_local(prefix, ".out.len"));
            parts = vec.push(parts, ")\n  ");
            parts = vec.push(parts, llvm_local(prefix, ".is_ok"));
            parts = vec.push(parts, " = icmp eq i64 ");
            parts = vec.push(parts, llvm_local(prefix, ".rc"));
            parts = vec.push(parts, ", 0\n  br i1 ");
            parts = vec.push(parts, llvm_local(prefix, ".is_ok"));
            parts = vec.push(parts, ", label %");
            parts = vec.push(parts, ok_label);
            parts = vec.push(parts, ", label %");
            parts = vec.push(parts, err_label);
            parts = vec.push(parts, "\n");
            parts = vec.push(parts, ok_label);
            parts = vec.push(parts, ":\n  ");
            parts = vec.push(parts, llvm_local(prefix, ".ok.ptr"));
            parts = vec.push(parts, " = load i8*, i8** ");
            parts = vec.push(parts, llvm_local(prefix, ".out.ptr"));
            parts = vec.push(parts, "\n  ");
            parts = vec.push(parts, llvm_local(prefix, ".ok.len"));
            parts = vec.push(parts, " = load i64, i64* ");
            parts = vec.push(parts, llvm_local(prefix, ".out.len"));
            parts = vec.push(parts, "\n  ");
            parts = vec.push(parts, llvm_local(prefix, ".ok.str.0"));
            parts = vec.push(parts, " = insertvalue %aic.String undef, i8* ");
            parts = vec.push(parts, llvm_local(prefix, ".ok.ptr"));
            parts = vec.push(parts, ", 0\n  ");
            parts = vec.push(parts, llvm_local(prefix, ".ok.str.1"));
            parts = vec.push(parts, " = insertvalue %aic.String ");
            parts = vec.push(parts, llvm_local(prefix, ".ok.str.0"));
            parts = vec.push(parts, ", i64 ");
            parts = vec.push(parts, llvm_local(prefix, ".ok.len"));
            parts = vec.push(parts, ", 1\n  ");
            parts = vec.push(parts, llvm_local(prefix, ".ok.str.2"));
            parts = vec.push(parts, " = insertvalue %aic.String ");
            parts = vec.push(parts, llvm_local(prefix, ".ok.str.1"));
            parts = vec.push(parts, ", i64 ");
            parts = vec.push(parts, llvm_local(prefix, ".ok.len"));
            parts = vec.push(parts, ", 2\n  ");
            parts = vec.push(parts, llvm_local(prefix, ".ok.result.0"));
            parts = vec.push(parts, " = insertvalue ");
            parts = vec.push(parts, ret);
            parts = vec.push(parts, " undef, i32 0, 0\n  ");
            parts = vec.push(parts, llvm_local(prefix, ".ok.result.1"));
            parts = vec.push(parts, " = insertvalue ");
            parts = vec.push(parts, ret);
            parts = vec.push(parts, " ");
            parts = vec.push(parts, llvm_local(prefix, ".ok.result.0"));
            parts = vec.push(parts, ", %aic.String ");
            parts = vec.push(parts, llvm_local(prefix, ".ok.str.2"));
            parts = vec.push(parts, ", 1\n  ret ");
            parts = vec.push(parts, ret);
            parts = vec.push(parts, " ");
            parts = vec.push(parts, llvm_local(prefix, ".ok.result.1"));
            parts = vec.push(parts, "\n");
            parts = vec.push(parts, err_label);
            parts = vec.push(parts, ":\n");
            parts = vec.push(parts, emit_fs_error_value(prefix, llvm_local(prefix, ".rc")));
            parts = vec.push(parts, "  ");
            parts = vec.push(parts, llvm_local(prefix, ".err.result.0"));
            parts = vec.push(parts, " = insertvalue ");
            parts = vec.push(parts, ret);
            parts = vec.push(parts, " undef, i32 1, 0\n  ");
            parts = vec.push(parts, llvm_local(prefix, ".err.result.1"));
            parts = vec.push(parts, " = insertvalue ");
            parts = vec.push(parts, ret);
            parts = vec.push(parts, " ");
            parts = vec.push(parts, llvm_local(prefix, ".err.result.0"));
            parts = vec.push(parts, ", ");
            parts = vec.push(parts, err_ty);
            parts = vec.push(parts, " ");
            parts = vec.push(parts, fs_error_value_name(prefix));
            parts = vec.push(parts, ", 2\n  ret ");
            parts = vec.push(parts, ret);
            parts = vec.push(parts, " ");
            parts = vec.push(parts, llvm_local(prefix, ".err.result.1"));
            parts = vec.push(parts, "\n");
            string.join(parts, "")
        } else { "" },
        None => "",
    }
}

fn emit_fs_bool_result_expr_return(program: IrProgram, function_value: IrFunctionDef, expr: IrExpr, locals: Vec[BackendLocal], ret: String) -> String {
    match direct_expr_child_at(expr.nodes, 0) {
        Some(path_child) => if true {
            let prefix = llvm_expr_prefix(expr.node);
            let path_name = string_node_value_name_with_locals(function_value, locals, path_child);
            let path_prefix = concat2(prefix, ".path");
            let ok_label = concat2("fs.ok.", string.int_to_string(expr.node.value));
            let err_label = concat2("fs.err.", string.int_to_string(expr.node.value));
            let err_ty = known_no_payload_enum_llvm_type("FsError");
            let mut parts: Vec[String] = vec.new_vec();
            parts = vec.push(parts, emit_string_node_value(program, function_value, expr.nodes, path_child, locals));
            parts = vec.push(parts, emit_string_extracts(path_name, path_prefix));
            if expr.name == "write_text" {
                match direct_expr_child_at(expr.nodes, 1) {
                    Some(content_child) => if true {
                        let content_name = string_node_value_name_with_locals(function_value, locals, content_child);
                        let content_prefix = concat2(prefix, ".content");
                        parts = vec.push(parts, emit_string_node_value(program, function_value, expr.nodes, content_child, locals));
                        parts = vec.push(parts, emit_string_extracts(content_name, content_prefix));
                        parts = vec.push(parts, "  ");
                        parts = vec.push(parts, llvm_local(prefix, ".rc"));
                        parts = vec.push(parts, " = call i64 ");
                        parts = vec.push(parts, fs_bool_runtime_name(expr.name));
                        parts = vec.push(parts, "(i8* ");
                        parts = vec.push(parts, llvm_local(path_prefix, ".ptr"));
                        parts = vec.push(parts, ", i64 ");
                        parts = vec.push(parts, llvm_local(path_prefix, ".len"));
                        parts = vec.push(parts, ", i64 ");
                        parts = vec.push(parts, llvm_local(path_prefix, ".cap"));
                        parts = vec.push(parts, ", i8* ");
                        parts = vec.push(parts, llvm_local(content_prefix, ".ptr"));
                        parts = vec.push(parts, ", i64 ");
                        parts = vec.push(parts, llvm_local(content_prefix, ".len"));
                        parts = vec.push(parts, ", i64 ");
                        parts = vec.push(parts, llvm_local(content_prefix, ".cap"));
                        parts = vec.push(parts, ")\n");
                        ()
                    } else { () },
                    None => (),
                };
            } else {
                parts = vec.push(parts, "  ");
                parts = vec.push(parts, llvm_local(prefix, ".rc"));
                parts = vec.push(parts, " = call i64 ");
                parts = vec.push(parts, fs_bool_runtime_name(expr.name));
                parts = vec.push(parts, "(i8* ");
                parts = vec.push(parts, llvm_local(path_prefix, ".ptr"));
                parts = vec.push(parts, ", i64 ");
                parts = vec.push(parts, llvm_local(path_prefix, ".len"));
                parts = vec.push(parts, ", i64 ");
                parts = vec.push(parts, llvm_local(path_prefix, ".cap"));
                parts = vec.push(parts, ")\n");
            };
            parts = vec.push(parts, "  ");
            parts = vec.push(parts, llvm_local(prefix, ".is_ok"));
            parts = vec.push(parts, " = icmp eq i64 ");
            parts = vec.push(parts, llvm_local(prefix, ".rc"));
            parts = vec.push(parts, ", 0\n  br i1 ");
            parts = vec.push(parts, llvm_local(prefix, ".is_ok"));
            parts = vec.push(parts, ", label %");
            parts = vec.push(parts, ok_label);
            parts = vec.push(parts, ", label %");
            parts = vec.push(parts, err_label);
            parts = vec.push(parts, "\n");
            parts = vec.push(parts, ok_label);
            parts = vec.push(parts, ":\n  ");
            parts = vec.push(parts, llvm_local(prefix, ".ok.result.0"));
            parts = vec.push(parts, " = insertvalue ");
            parts = vec.push(parts, ret);
            parts = vec.push(parts, " undef, i32 0, 0\n  ");
            parts = vec.push(parts, llvm_local(prefix, ".ok.result.1"));
            parts = vec.push(parts, " = insertvalue ");
            parts = vec.push(parts, ret);
            parts = vec.push(parts, " ");
            parts = vec.push(parts, llvm_local(prefix, ".ok.result.0"));
            parts = vec.push(parts, ", i1 1, 1\n  ret ");
            parts = vec.push(parts, ret);
            parts = vec.push(parts, " ");
            parts = vec.push(parts, llvm_local(prefix, ".ok.result.1"));
            parts = vec.push(parts, "\n");
            parts = vec.push(parts, err_label);
            parts = vec.push(parts, ":\n");
            parts = vec.push(parts, emit_fs_error_value(prefix, llvm_local(prefix, ".rc")));
            parts = vec.push(parts, "  ");
            parts = vec.push(parts, llvm_local(prefix, ".err.result.0"));
            parts = vec.push(parts, " = insertvalue ");
            parts = vec.push(parts, ret);
            parts = vec.push(parts, " undef, i32 1, 0\n  ");
            parts = vec.push(parts, llvm_local(prefix, ".err.result.1"));
            parts = vec.push(parts, " = insertvalue ");
            parts = vec.push(parts, ret);
            parts = vec.push(parts, " ");
            parts = vec.push(parts, llvm_local(prefix, ".err.result.0"));
            parts = vec.push(parts, ", ");
            parts = vec.push(parts, err_ty);
            parts = vec.push(parts, " ");
            parts = vec.push(parts, fs_error_value_name(prefix));
            parts = vec.push(parts, ", 2\n  ret ");
            parts = vec.push(parts, ret);
            parts = vec.push(parts, " ");
            parts = vec.push(parts, llvm_local(prefix, ".err.result.1"));
            parts = vec.push(parts, "\n");
            string.join(parts, "")
        } else { "" },
        None => "",
    }
}

fn emit_empty_string_return(prefix: String) -> String {
    let mut parts: Vec[String] = vec.new_vec();
    parts = vec.push(parts, "  ");
    parts = vec.push(parts, llvm_local(prefix, ".empty.0"));
    parts = vec.push(parts, " = insertvalue %aic.String undef, i8* null, 0\n  ");
    parts = vec.push(parts, llvm_local(prefix, ".empty.1"));
    parts = vec.push(parts, " = insertvalue %aic.String ");
    parts = vec.push(parts, llvm_local(prefix, ".empty.0"));
    parts = vec.push(parts, ", i64 0, 1\n  ");
    parts = vec.push(parts, llvm_local(prefix, ".empty.value"));
    parts = vec.push(parts, " = insertvalue %aic.String ");
    parts = vec.push(parts, llvm_local(prefix, ".empty.1"));
    parts = vec.push(parts, ", i64 0, 2\n  ret %aic.String ");
    parts = vec.push(parts, llvm_local(prefix, ".empty.value"));
    parts = vec.push(parts, "\n");
    string.join(parts, "")
}

fn emit_env_arg_or_empty_return(program: IrProgram, function_value: IrFunctionDef, expr: IrExpr) -> String {
    match direct_expr_child_at(expr.nodes, 0) {
        Some(call_node) => match expr_node_child_at(expr.nodes, call_node, 0) {
            Some(index_node) => if true {
                let prefix = llvm_expr_prefix(expr.node);
                let some_label = concat2("match.some.", string.int_to_string(expr.node.value));
                let none_label = concat2("match.none.", string.int_to_string(expr.node.value));
                let mut parts: Vec[String] = vec.new_vec();
                parts = vec.push(parts, "  ");
                parts = vec.push(parts, llvm_local(prefix, ".arg.ptr"));
                parts = vec.push(parts, " = alloca i8*\n  ");
                parts = vec.push(parts, llvm_local(prefix, ".arg.len"));
                parts = vec.push(parts, " = alloca i64\n  ");
                parts = vec.push(parts, llvm_local(prefix, ".arg.ok"));
                parts = vec.push(parts, " = call i64 @aic_rt_env_arg_at(i64 ");
                parts = vec.push(parts, simple_node_llvm_value(index_node, function_value));
                parts = vec.push(parts, ", i8** ");
                parts = vec.push(parts, llvm_local(prefix, ".arg.ptr"));
                parts = vec.push(parts, ", i64* ");
                parts = vec.push(parts, llvm_local(prefix, ".arg.len"));
                parts = vec.push(parts, ")\n  ");
                parts = vec.push(parts, llvm_local(prefix, ".arg.present"));
                parts = vec.push(parts, " = icmp ne i64 ");
                parts = vec.push(parts, llvm_local(prefix, ".arg.ok"));
                parts = vec.push(parts, ", 0\n  br i1 ");
                parts = vec.push(parts, llvm_local(prefix, ".arg.present"));
                parts = vec.push(parts, ", label %");
                parts = vec.push(parts, some_label);
                parts = vec.push(parts, ", label %");
                parts = vec.push(parts, none_label);
                parts = vec.push(parts, "\n");
                parts = vec.push(parts, some_label);
                parts = vec.push(parts, ":\n  ");
                parts = vec.push(parts, llvm_local(prefix, ".some.ptr"));
                parts = vec.push(parts, " = load i8*, i8** ");
                parts = vec.push(parts, llvm_local(prefix, ".arg.ptr"));
                parts = vec.push(parts, "\n  ");
                parts = vec.push(parts, llvm_local(prefix, ".some.len"));
                parts = vec.push(parts, " = load i64, i64* ");
                parts = vec.push(parts, llvm_local(prefix, ".arg.len"));
                parts = vec.push(parts, "\n  ");
                parts = vec.push(parts, llvm_local(prefix, ".some.0"));
                parts = vec.push(parts, " = insertvalue %aic.String undef, i8* ");
                parts = vec.push(parts, llvm_local(prefix, ".some.ptr"));
                parts = vec.push(parts, ", 0\n  ");
                parts = vec.push(parts, llvm_local(prefix, ".some.1"));
                parts = vec.push(parts, " = insertvalue %aic.String ");
                parts = vec.push(parts, llvm_local(prefix, ".some.0"));
                parts = vec.push(parts, ", i64 ");
                parts = vec.push(parts, llvm_local(prefix, ".some.len"));
                parts = vec.push(parts, ", 1\n  ");
                parts = vec.push(parts, llvm_local(prefix, ".some.value"));
                parts = vec.push(parts, " = insertvalue %aic.String ");
                parts = vec.push(parts, llvm_local(prefix, ".some.1"));
                parts = vec.push(parts, ", i64 ");
                parts = vec.push(parts, llvm_local(prefix, ".some.len"));
                parts = vec.push(parts, ", 2\n  ret %aic.String ");
                parts = vec.push(parts, llvm_local(prefix, ".some.value"));
                parts = vec.push(parts, "\n");
                parts = vec.push(parts, none_label);
                parts = vec.push(parts, ":\n");
                parts = vec.push(parts, emit_empty_string_return(prefix));
                string.join(parts, "")
            } else { "" },
            None => "",
        },
        None => "",
    }
}

fn struct_literal_field_local(prefix: String, field_index: Int) -> String {
    llvm_local(prefix, concat2(".field.", string.int_to_string(field_index)))
}

fn struct_literal_value_name(prefix: String, field_count: Int, ret: String) -> String {
    if field_count == 0 {
        if ret == "{}" { "{}" } else { "undef" }
    } else {
        struct_literal_field_local(prefix, field_count - 1)
    }
}

fn struct_literal_child_value_name(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], child: IrExprNode, locals: Vec[BackendLocal], expected: String) -> String {
    if expected == "%aic.String" {
        string_node_value_name_with_locals(function_value, locals, child)
    } else {
        node_value_name(program, function_value, nodes, child, locals)
    }
}

fn emit_struct_literal_child_value(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], child: IrExprNode, locals: Vec[BackendLocal], expected: String) -> String {
    if expected == "%aic.String" {
        emit_string_node_value(program, function_value, nodes, child, locals)
    } else {
        emit_value_node(program, function_value, nodes, child, locals)
    }
}

fn emit_struct_literal_node_value(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], node: IrExprNode, locals: Vec[BackendLocal], ret: String) -> String {
    let prefix = llvm_node_prefix(node.node);
    let mut parts: Vec[String] = vec.new_vec();
    let mut index = 0;
    while index < node.direct_child_count {
        match expr_node_child_at(nodes, node, index) {
            Some(child) => if true {
                let field_ty = struct_field_llvm_type_by_index(program, node.name, index);
                let previous = if index == 0 {
                    "undef"
                } else {
                    struct_literal_field_local(prefix, index - 1)
                };
                parts = vec.push(parts, emit_struct_literal_child_value(program, function_value, nodes, child, locals, field_ty));
                parts = vec.push(parts, "  ");
                parts = vec.push(parts, struct_literal_field_local(prefix, index));
                parts = vec.push(parts, " = insertvalue ");
                parts = vec.push(parts, ret);
                parts = vec.push(parts, " ");
                parts = vec.push(parts, previous);
                parts = vec.push(parts, ", ");
                parts = vec.push(parts, field_ty);
                parts = vec.push(parts, " ");
                parts = vec.push(parts, struct_literal_child_value_name(program, function_value, nodes, child, locals, field_ty));
                parts = vec.push(parts, ", ");
                parts = vec.push(parts, string.int_to_string(index));
                parts = vec.push(parts, "\n");
                ()
            } else { () },
            None => (),
        };
        index = index + 1;
    };
    string.join(parts, "")
}

fn emit_struct_literal_expr_value(program: IrProgram, function_value: IrFunctionDef, expr: IrExpr, locals: Vec[BackendLocal], ret: String) -> String {
    let prefix = llvm_expr_prefix(expr.node);
    let mut parts: Vec[String] = vec.new_vec();
    let mut index = 0;
    while index < direct_expr_child_count(expr.nodes) {
        match direct_expr_child_at(expr.nodes, index) {
            Some(child) => if true {
                let field_ty = struct_field_llvm_type_by_index(program, expr.name, index);
                let previous = if index == 0 {
                    "undef"
                } else {
                    struct_literal_field_local(prefix, index - 1)
                };
                parts = vec.push(parts, emit_struct_literal_child_value(program, function_value, expr.nodes, child, locals, field_ty));
                parts = vec.push(parts, "  ");
                parts = vec.push(parts, struct_literal_field_local(prefix, index));
                parts = vec.push(parts, " = insertvalue ");
                parts = vec.push(parts, ret);
                parts = vec.push(parts, " ");
                parts = vec.push(parts, previous);
                parts = vec.push(parts, ", ");
                parts = vec.push(parts, field_ty);
                parts = vec.push(parts, " ");
                parts = vec.push(parts, struct_literal_child_value_name(program, function_value, expr.nodes, child, locals, field_ty));
                parts = vec.push(parts, ", ");
                parts = vec.push(parts, string.int_to_string(index));
                parts = vec.push(parts, "\n");
                ()
            } else { () },
            None => (),
        };
        index = index + 1;
    };
    string.join(parts, "")
}

fn emit_void_call_expr_statement(program: IrProgram, function_value: IrFunctionDef, expr: IrExpr, locals: Vec[BackendLocal]) -> String {
    let mut parts: Vec[String] = vec.new_vec();
    parts = vec.push(parts, emit_call_arg_values(program, function_value, expr.nodes, expr.name, locals));
    parts = vec.push(parts, "  call void @");
    parts = vec.push(parts, backend_mangle_symbol(expr.name));
    parts = vec.push(parts, "(");
    parts = vec.push(parts, emit_call_args(program, function_value, expr.nodes, expr.name, locals));
    parts = vec.push(parts, ")\n");
    string.join(parts, "")
}

fn emit_expr_value(program: IrProgram, function_value: IrFunctionDef, expr: IrExpr, locals: Vec[BackendLocal]) -> String {
    match expr.kind {
        IrStringExpr => emit_string_literal_value(llvm_string_global_name(function_value.name), expr.text, llvm_expr_prefix(expr.node)),
        IrCallExpr => if expr.name == "string.replace" {
            emit_string_replace_expr_value(program, function_value, expr, locals)
        } else if call_target_return_type(program, expr.name) == "%aic.String" {
            emit_string_direct_call_expr_value(program, function_value, expr, locals)
        } else {
            let mut parts: Vec[String] = vec.new_vec();
            parts = vec.push(parts, emit_call_arg_values(program, function_value, expr.nodes, expr.name, locals));
            parts = vec.push(parts, "  ");
            parts = vec.push(parts, llvm_expr_value_local(expr));
            parts = vec.push(parts, " = call ");
            parts = vec.push(parts, call_target_return_type(program, expr.name));
            parts = vec.push(parts, " @");
            parts = vec.push(parts, backend_mangle_symbol(expr.name));
            parts = vec.push(parts, "(");
            parts = vec.push(parts, emit_call_args(program, function_value, expr.nodes, expr.name, locals));
            parts = vec.push(parts, ")\n");
            string.join(parts, "")
        },
        IrStructLiteralExpr => emit_struct_literal_expr_value(program, function_value, expr, locals, value_expr_llvm_type(program, expr, function_value, locals)),
        _ => "",
    }
}

fn emit_statement_with_locals(program: IrProgram, function_value: IrFunctionDef, statement: IrStatement, locals: Vec[BackendLocal]) -> BackendStatementEmission {
    match statement.kind {
        IrLetStatement => match statement.expr {
            Some(expr) => if true {
                let text = emit_expr_value(program, function_value, expr, locals);
                backend_statement_emission(text, vec.push(locals, local_for_expr(program, function_value, expr, locals, statement.name)))
            } else { backend_statement_emission("", locals) },
            None => backend_statement_emission("", locals),
        },
        IrExprStatement => match statement.expr {
            Some(expr) => match expr.kind {
                IrCallExpr => if call_target_return_type(program, expr.name) == "void" {
                    backend_statement_emission(emit_void_call_expr_statement(program, function_value, expr, locals), locals)
                } else {
                    backend_statement_emission("", locals)
                },
                _ => backend_statement_emission("", locals),
            },
            None => backend_statement_emission("", locals),
        },
        _ => backend_statement_emission("", locals),
    }
}

fn emit_statement(program: IrProgram, function_value: IrFunctionDef, statement: IrStatement) -> String {
    match statement.kind {
        IrExprStatement => match statement.expr {
            Some(expr) => match expr.kind {
                IrCallExpr => if call_target_return_type(program, expr.name) == "void" {
                    emit_void_call_expr_statement(program, function_value, expr, vec.new_vec())
                } else {
                    ""
                },
                _ => "",
            },
            None => "",
        },
        _ => "",
    }
}

fn emit_block_statements(program: IrProgram, function_value: IrFunctionDef) -> BackendStatementEmission {
    let mut parts: Vec[String] = vec.new_vec();
    let mut locals: Vec[BackendLocal] = vec.new_vec();
    let mut index = 0;
    while index < vec.vec_len(function_value.body.statements) {
        match vec.get(function_value.body.statements, index) {
            Some(statement) => if true {
                let checked = statement_check_with_locals(program, function_value, statement, locals);
                if checked.ok {
                    let emitted = emit_statement_with_locals(program, function_value, statement, locals);
                    parts = vec.push(parts, emitted.text);
                    locals = emitted.locals;
                } else {
                    ()
                };
                ()
            } else {
                ()
            },
            None => (),
        };
        index = index + 1;
    };
    backend_statement_emission(string.join(parts, ""), locals)
}

fn emit_return_expr(program: IrProgram, function_value: IrFunctionDef, expr: IrExpr, locals: Vec[BackendLocal], ret: String) -> String {
    let mut parts: Vec[String] = vec.new_vec();
    match expr.kind {
        IrIntExpr => if true {
            parts = vec.push(parts, "  ret ");
            parts = vec.push(parts, ret);
            parts = vec.push(parts, " ");
            parts = vec.push(parts, expr.text);
            parts = vec.push(parts, "\n");
            ()
        } else { () },
        IrBoolExpr => if true {
            parts = vec.push(parts, "  ret ");
            parts = vec.push(parts, ret);
            parts = vec.push(parts, " ");
            parts = vec.push(parts, if expr.text == "true" { "1" } else { "0" });
            parts = vec.push(parts, "\n");
            ()
        } else { () },
        IrStringExpr => if true {
            let payload = string_literal_payload(expr.text);
            parts = vec.push(parts, "  %str.ptr = getelementptr inbounds [");
            parts = vec.push(parts, string.int_to_string(string.len(payload)));
            parts = vec.push(parts, " x i8], [");
            parts = vec.push(parts, string.int_to_string(string.len(payload)));
            parts = vec.push(parts, " x i8]* ");
            parts = vec.push(parts, llvm_string_global_name(function_value.name));
            parts = vec.push(parts, ", i64 0, i64 0\n");
            parts = vec.push(parts, "  %str.0 = insertvalue %aic.String undef, i8* %str.ptr, 0\n");
            parts = vec.push(parts, "  %str.1 = insertvalue %aic.String %str.0, i64 ");
            parts = vec.push(parts, string.int_to_string(string.len(payload)));
            parts = vec.push(parts, ", 1\n");
            parts = vec.push(parts, "  %str.2 = insertvalue %aic.String %str.1, i64 ");
            parts = vec.push(parts, string.int_to_string(string.len(payload)));
            parts = vec.push(parts, ", 2\n");
            parts = vec.push(parts, "  ret ");
            parts = vec.push(parts, ret);
            parts = vec.push(parts, " %str.2\n");
            ()
        } else { () },
        IrUnitExpr => if true {
            parts = vec.push(parts, "  ret void\n");
            ()
        } else { () },
        IrNameExpr => if true {
            let value_name = value_name_for_name(function_value, locals, expr.text);
            if value_name == value_name_for_param(function_value, expr.text) {
                parts = vec.push(parts, emit_return_name_value(program, function_value, expr.text, ret, llvm_expr_prefix(expr.node)));
            } else {
                parts = vec.push(parts, "  ret ");
                parts = vec.push(parts, ret);
                parts = vec.push(parts, " ");
                parts = vec.push(parts, value_name);
                parts = vec.push(parts, "\n");
            };
            ()
        } else { () },
        IrBinaryExpr => if true {
            match direct_expr_child_at(expr.nodes, 0) {
                Some(left) => match direct_expr_child_at(expr.nodes, 1) {
                    Some(right) => if true {
                        parts = vec.push(parts, "  %ret = ");
                        parts = vec.push(parts, binary_llvm_op(expr.op));
                        parts = vec.push(parts, " ");
                        parts = vec.push(parts, ret);
                        parts = vec.push(parts, " ");
                        parts = vec.push(parts, simple_node_llvm_value_with_locals(left, function_value, locals));
                        parts = vec.push(parts, ", ");
                        parts = vec.push(parts, simple_node_llvm_value_with_locals(right, function_value, locals));
                        parts = vec.push(parts, "\n  ret ");
                        parts = vec.push(parts, ret);
                        parts = vec.push(parts, " %ret\n");
                        ()
                    } else { () },
                    None => (),
                },
                None => (),
            };
            ()
        } else { () },
        IrCallExpr => if true {
            if is_io_print_intrinsic_name(expr.name) {
                parts = vec.push(parts, emit_io_print_expr_return(program, function_value, expr, locals));
            } else if is_fs_string_result_intrinsic_name(expr.name) {
                parts = vec.push(parts, emit_fs_string_result_expr_return(program, function_value, expr, locals, ret));
            } else if is_fs_bool_result_intrinsic_name(expr.name) {
                parts = vec.push(parts, emit_fs_bool_result_expr_return(program, function_value, expr, locals, ret));
            } else if expr.name == "string.replace" {
                parts = vec.push(parts, emit_string_replace_expr_value(program, function_value, expr, locals));
                parts = vec.push(parts, "  ret ");
                parts = vec.push(parts, ret);
                parts = vec.push(parts, " ");
                parts = vec.push(parts, llvm_expr_value_local(expr));
                parts = vec.push(parts, "\n");
            } else {
                let call_ret = call_target_return_type(program, expr.name);
                if call_ret == "%aic.String" {
                    parts = vec.push(parts, emit_string_direct_call_expr_value(program, function_value, expr, locals));
                    parts = vec.push(parts, "  ret ");
                    parts = vec.push(parts, ret);
                    parts = vec.push(parts, " ");
                    parts = vec.push(parts, llvm_expr_value_local(expr));
                    parts = vec.push(parts, "\n");
                } else {
                    parts = vec.push(parts, emit_call_arg_values(program, function_value, expr.nodes, expr.name, locals));
                    parts = vec.push(parts, "  %ret = call ");
                    parts = vec.push(parts, call_ret);
                    parts = vec.push(parts, " @");
                    parts = vec.push(parts, backend_mangle_symbol(expr.name));
                    parts = vec.push(parts, "(");
                    parts = vec.push(parts, emit_call_args(program, function_value, expr.nodes, expr.name, locals));
                    parts = vec.push(parts, ")\n  ret ");
                    parts = vec.push(parts, ret);
                    parts = vec.push(parts, " %ret\n");
                };
            };
            ()
        } else { () },
        IrIfExpr => if true {
            parts = vec.push(parts, emit_if_expr_return(program, function_value, expr, ret, locals));
            ()
        } else { () },
        IrMatchExpr => if true {
            if env_arg_or_empty_expr_can_emit(program, expr, function_value) {
                parts = vec.push(parts, emit_env_arg_or_empty_return(program, function_value, expr));
            } else {
                let selected = static_match_body(expr);
                parts = vec.push(parts, "  ret ");
                parts = vec.push(parts, ret);
                parts = vec.push(parts, " ");
                if selected == "true" {
                    parts = vec.push(parts, "1");
                } else if selected == "false" {
                    parts = vec.push(parts, "0");
                } else {
                    parts = vec.push(parts, selected);
                };
                parts = vec.push(parts, "\n");
            };
            ()
        } else { () },
        IrStructLiteralExpr => if true {
            parts = vec.push(parts, emit_struct_literal_expr_value(program, function_value, expr, locals, ret));
            parts = vec.push(parts, "  ret ");
            parts = vec.push(parts, ret);
            parts = vec.push(parts, " ");
            parts = vec.push(parts, struct_literal_value_name(llvm_expr_prefix(expr.node), direct_expr_child_count(expr.nodes), ret));
            parts = vec.push(parts, "\n");
            ()
        } else { () },
        _ => (),
    };
    string.join(parts, "")
}

fn emit_function_llvm(program: IrProgram, function_value: IrFunctionDef) -> String {
    let ret = llvm_type_for_id(program, function_value.return_type);
    let name = backend_mangle_symbol(function_value.name);
    let params = llvm_param_list(program, function_value.params);
    let mut parts: Vec[String] = vec.new_vec();
    parts = vec.push(parts, "define ");
    parts = vec.push(parts, ret);
    parts = vec.push(parts, " @");
    parts = vec.push(parts, name);
    parts = vec.push(parts, "(");
    parts = vec.push(parts, params);
    parts = vec.push(parts, ") {\nentry:\n");
    let emitted_statements = emit_block_statements(program, function_value);
    parts = vec.push(parts, emitted_statements.text);
    match function_value.body.tail_expr {
        Some(expr) => if true {
            parts = vec.push(parts, emit_return_expr(program, function_value, expr, emitted_statements.locals, ret));
            ()
        } else { () },
        None => if ret == "void" {
            parts = vec.push(parts, "  ret void\n");
        } else {
            ()
        },
    };
    parts = vec.push(parts, "}\n");
    string.join(parts, "")
}

fn collect_backend_symbols(program: IrProgram) -> Vec[BackendSymbol] {
    let mut symbols: Vec[BackendSymbol] = vec.new_vec();
    let mut index = 0;
    while index < vec.vec_len(program.items) {
        match vec.get(program.items, index) {
            Some(item) => match item {
                IrFunctionItemValue(function_value) => if function_value.runtime_visible {
                    symbols = vec.push(symbols, backend_symbol(function_value.name, backend_mangle_symbol(function_value.name), "function", function_value.span));
                } else {
                    ()
                },
                IrStructItemValue(struct_value) => if true {
                    symbols = vec.push(symbols, backend_symbol(struct_value.name, backend_mangle_symbol(struct_value.name), "struct", struct_value.span));
                    ()
                } else { () },
                IrEnumItemValue(enum_value) => if true {
                    symbols = vec.push(symbols, backend_symbol(enum_value.name, backend_mangle_symbol(enum_value.name), "enum", enum_value.span));
                    ()
                } else { () },
                IrTraitItemValue(trait_value) => if true {
                    symbols = vec.push(symbols, backend_symbol(trait_value.name, backend_mangle_symbol(trait_value.name), "trait", trait_value.span));
                    ()
                } else { () },
                IrImplItemValue(impl_value) => if true {
                    symbols = vec.push(symbols, backend_symbol(impl_value.head_text, backend_mangle_symbol(impl_value.head_text), "impl", impl_value.span));
                    ()
                } else { () },
                IrTypeAliasItemValue(alias_value) => if true {
                    symbols = vec.push(symbols, backend_symbol(alias_value.name, backend_mangle_symbol(alias_value.name), "type_alias", alias_value.span));
                    ()
                } else { () },
                IrConstItemValue(const_value) => if true {
                    symbols = vec.push(symbols, backend_symbol(const_value.name, backend_mangle_symbol(const_value.name), "const", const_value.span));
                    ()
                } else { () },
            },
            None => (),
        };
        index = index + 1;
    };
    symbols
}

fn emit_item_metadata(program: IrProgram) -> String {
    let mut parts: Vec[String] = vec.new_vec();
    let mut index = 0;
    while index < vec.vec_len(program.items) {
        match vec.get(program.items, index) {
            Some(item) => match item {
                IrStructItemValue(value) => if true {
                    parts = vec.push(parts, "; struct ");
                    parts = vec.push(parts, value.name);
                    parts = vec.push(parts, " fields=");
                    parts = vec.push(parts, string.int_to_string(vec.vec_len(value.fields)));
                    parts = vec.push(parts, "\n");
                    ()
                } else { () },
                IrEnumItemValue(value) => if true {
                    parts = vec.push(parts, "; enum ");
                    parts = vec.push(parts, value.name);
                    parts = vec.push(parts, " variants=");
                    parts = vec.push(parts, string.int_to_string(vec.vec_len(value.variants)));
                    parts = vec.push(parts, "\n");
                    ()
                } else { () },
                IrTraitItemValue(value) => if true {
                    parts = vec.push(parts, "; trait ");
                    parts = vec.push(parts, value.name);
                    parts = vec.push(parts, " methods=");
                    parts = vec.push(parts, string.int_to_string(vec.vec_len(value.methods)));
                    parts = vec.push(parts, "\n");
                    ()
                } else { () },
                IrImplItemValue(value) => if true {
                    parts = vec.push(parts, "; impl ");
                    parts = vec.push(parts, value.head_text);
                    parts = vec.push(parts, " methods=");
                    parts = vec.push(parts, string.int_to_string(vec.vec_len(value.methods)));
                    parts = vec.push(parts, "\n");
                    ()
                } else { () },
                IrTypeAliasItemValue(value) => if true {
                    parts = vec.push(parts, "; type_alias ");
                    parts = vec.push(parts, value.name);
                    parts = vec.push(parts, "\n");
                    ()
                } else { () },
                IrConstItemValue(value) => if true {
                    parts = vec.push(parts, "@");
                    parts = vec.push(parts, backend_mangle_symbol(value.name));
                    parts = vec.push(parts, " = internal constant i64 0\n");
                    ()
                } else { () },
                IrFunctionItemValue(_) => (),
            },
            None => (),
        };
        index = index + 1;
    };
    string.join(parts, "")
}

fn emit_functions_llvm(program: IrProgram) -> String {
    let mut parts: Vec[String] = vec.new_vec();
    let mut index = 0;
    while index < vec.vec_len(program.items) {
        match vec.get(program.items, index) {
            Some(item) => match item {
                IrFunctionItemValue(function_value) => if function_value.runtime_visible {
                    parts = vec.push(parts, emit_function_llvm(program, function_value));
                    parts = vec.push(parts, "\n");
                } else {
                    ()
                },
                _ => (),
            },
            None => (),
        };
        index = index + 1;
    };
    string.join(parts, "")
}

fn native_links_summary(links: Vec[BackendNativeLink]) -> String {
    let mut parts: Vec[String] = vec.new_vec();
    let mut index = 0;
    while index < vec.vec_len(links) {
        match vec.get(links, index) {
            Some(link) => if true {
                parts = vec.push(parts, "; native_link ");
                parts = vec.push(parts, backend_native_link_kind_name(link.kind));
                parts = vec.push(parts, " ");
                parts = vec.push(parts, link.name);
                if link.path != "" {
                    parts = vec.push(parts, " path=");
                    parts = vec.push(parts, link.path);
                } else {
                    ()
                };
                if link.static_link {
                    parts = vec.push(parts, " static=true");
                } else {
                    ()
                };
                parts = vec.push(parts, "\n");
                ()
            } else {
                ()
            },
            None => (),
        };
        index = index + 1;
    };
    string.join(parts, "")
}

pub fn emit_llvm_text(program: IrProgram, options: BackendOptions) -> String {
    let mut parts: Vec[String] = vec.new_vec();
    parts = vec.push(parts, "; AICore self-host LLVM IR (deterministic)\n");
    parts = vec.push(parts, "; format=aicore-selfhost-backend-llvm-v1\n");
    parts = vec.push(parts, "; module=");
    parts = vec.push(parts, program.module_path);
    parts = vec.push(parts, "\n");
    parts = vec.push(parts, "; artifact=");
    parts = vec.push(parts, backend_artifact_file_name(options));
    parts = vec.push(parts, "\n");
    if options.target_triple == "" {
        parts = vec.push(parts, "; target=native\n\n");
    } else {
        parts = vec.push(parts, "target triple = \"");
        parts = vec.push(parts, options.target_triple);
        parts = vec.push(parts, "\"\n\n");
    };
    parts = vec.push(parts, native_links_summary(options.native_links));
    parts = vec.push(parts, emit_type_declarations(program));
    parts = vec.push(parts, emit_runtime_declarations(program));
    parts = vec.push(parts, emit_string_globals(program));
    parts = vec.push(parts, emit_item_metadata(program));
    parts = vec.push(parts, "\n");
    parts = vec.push(parts, emit_functions_llvm(program));
    string.join(parts, "")
}

pub fn backend_artifact_digest(program: IrProgram, options: BackendOptions, llvm_text: String) -> String {
    let mut parts: Vec[String] = vec.new_vec();
    parts = vec.push(parts, "backend-v1;module=");
    parts = vec.push(parts, program.module_path);
    parts = vec.push(parts, ";artifact=");
    parts = vec.push(parts, backend_artifact_file_name(options));
    parts = vec.push(parts, ";kind=");
    parts = vec.push(parts, backend_artifact_kind_name(options.artifact_kind));
    parts = vec.push(parts, ";items=");
    parts = vec.push(parts, string.int_to_string(vec.vec_len(program.items)));
    parts = vec.push(parts, ";symbols=");
    parts = vec.push(parts, string.int_to_string(vec.vec_len(program.symbols)));
    parts = vec.push(parts, ";features=");
    parts = vec.push(parts, string.join(backend_program_features(program, options), ","));
    parts = vec.push(parts, ";bytes=");
    parts = vec.push(parts, string.int_to_string(string.len(llvm_text)));
    string.join(parts, "")
}

pub fn emit_backend_artifact(program: IrProgram, options: BackendOptions, max_errors: Int) -> BackendArtifact {
    let diagnostics = validate_backend_program(program, options, max_errors);
    let llvm_text = if vec.vec_len(diagnostics) == 0 {
        emit_llvm_text(program, options)
    } else {
        ""
    };
    BackendArtifact {
        format: "aicore-selfhost-backend-llvm-v1",
        schema_version: 1,
        artifact_name: options.artifact_name,
        file_name: backend_artifact_file_name(options),
        artifact_kind: options.artifact_kind,
        target_triple: options.target_triple,
        llvm_ir: llvm_text,
        symbols: collect_backend_symbols(program),
        features: backend_program_features(program, options),
        native_links: options.native_links,
        digest: backend_artifact_digest(program, options, llvm_text),
        diagnostics: diagnostics,
    }
}

pub fn backend_artifact_ok(value: BackendArtifact) -> Bool {
    vec.vec_len(value.diagnostics) == 0 && value.llvm_ir != ""
}

pub fn backend_diagnostic_count(value: BackendArtifact) -> Int {
    vec.vec_len(value.diagnostics)
}

pub fn backend_has_diagnostic_code(value: BackendArtifact, code: String) -> Bool {
    let mut index = 0;
    let mut found = false;
    while !found && index < vec.vec_len(value.diagnostics) {
        match vec.get(value.diagnostics, index) {
            Some(diagnostic_value) => if diagnostic_value.code.value == code {
                found = true;
            } else {
                ()
            },
            None => (),
        };
        index = index + 1;
    };
    found
}
