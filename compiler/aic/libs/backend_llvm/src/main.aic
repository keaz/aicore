fn emit_proc_output_value(prefix: String, output_ty: String, status_slot: String, stdout_ptr_slot: String, stdout_len_slot: String, stderr_ptr_slot: String, stderr_len_slot: String) -> String {
    let stdout_prefix = concat2(prefix, ".stdout");
    let stderr_prefix = concat2(prefix, ".stderr");
    let mut parts: Vec[String] = vec.new_vec();
    parts = vec.push(parts, "  ");
    parts = vec.push(parts, llvm_local(prefix, ".status.i64"));
    parts = vec.push(parts, " = load i64, i64* ");
    parts = vec.push(parts, status_slot);
    parts = vec.push(parts, "\n  ");
    parts = vec.push(parts, llvm_local(prefix, ".status.i32"));
    parts = vec.push(parts, " = trunc i64 ");
    parts = vec.push(parts, llvm_local(prefix, ".status.i64"));
    parts = vec.push(parts, " to i32\n  ");
    parts = vec.push(parts, llvm_local(stdout_prefix, ".ptr"));
    parts = vec.push(parts, " = load i8*, i8** ");
    parts = vec.push(parts, stdout_ptr_slot);
    parts = vec.push(parts, "\n  ");
    parts = vec.push(parts, llvm_local(stdout_prefix, ".len"));
    parts = vec.push(parts, " = load i64, i64* ");
    parts = vec.push(parts, stdout_len_slot);
    parts = vec.push(parts, "\n");
    parts = vec.push(parts, emit_string_from_ptr_len(stdout_prefix, llvm_local(stdout_prefix, ".ptr"), llvm_local(stdout_prefix, ".len")));
    parts = vec.push(parts, "  ");
    parts = vec.push(parts, llvm_local(stderr_prefix, ".ptr"));
    parts = vec.push(parts, " = load i8*, i8** ");
    parts = vec.push(parts, stderr_ptr_slot);
    parts = vec.push(parts, "\n  ");
    parts = vec.push(parts, llvm_local(stderr_prefix, ".len"));
    parts = vec.push(parts, " = load i64, i64* ");
    parts = vec.push(parts, stderr_len_slot);
    parts = vec.push(parts, "\n");
    parts = vec.push(parts, emit_string_from_ptr_len(stderr_prefix, llvm_local(stderr_prefix, ".ptr"), llvm_local(stderr_prefix, ".len")));
    parts = vec.push(parts, "  ");
    parts = vec.push(parts, llvm_local(prefix, ".0"));
    parts = vec.push(parts, " = insertvalue ");
    parts = vec.push(parts, output_ty);
    parts = vec.push(parts, " undef, i32 ");
    parts = vec.push(parts, llvm_local(prefix, ".status.i32"));
    parts = vec.push(parts, ", 0\n  ");
    parts = vec.push(parts, llvm_local(prefix, ".1"));
    parts = vec.push(parts, " = insertvalue ");
    parts = vec.push(parts, output_ty);
    parts = vec.push(parts, " ");
    parts = vec.push(parts, llvm_local(prefix, ".0"));
    parts = vec.push(parts, ", %aic.String ");
    parts = vec.push(parts, llvm_local(stdout_prefix, ".2"));
    parts = vec.push(parts, ", 1\n  ");
    parts = vec.push(parts, llvm_local(prefix, ".value"));
    parts = vec.push(parts, " = insertvalue ");
    parts = vec.push(parts, output_ty);
    parts = vec.push(parts, " ");
    parts = vec.push(parts, llvm_local(prefix, ".1"));
    parts = vec.push(parts, ", %aic.String ");
    parts = vec.push(parts, llvm_local(stderr_prefix, ".2"));
    parts = vec.push(parts, ", 2\n");
    string.join(parts, "")
}

fn emit_proc_run_call(prefix: String, command_name: String, command_prefix: String) -> String {
    let mut parts: Vec[String] = vec.new_vec();
    parts = vec.push(parts, emit_string_extracts(command_name, command_prefix));
    parts = vec.push(parts, "  ");
    parts = vec.push(parts, llvm_local(prefix, ".status"));
    parts = vec.push(parts, " = alloca i64\n  ");
    parts = vec.push(parts, llvm_local(prefix, ".stdout.ptr"));
    parts = vec.push(parts, " = alloca i8*\n  ");
    parts = vec.push(parts, llvm_local(prefix, ".stdout.len"));
    parts = vec.push(parts, " = alloca i64\n  ");
    parts = vec.push(parts, llvm_local(prefix, ".stderr.ptr"));
    parts = vec.push(parts, " = alloca i8*\n  ");
    parts = vec.push(parts, llvm_local(prefix, ".stderr.len"));
    parts = vec.push(parts, " = alloca i64\n  ");
    parts = vec.push(parts, llvm_local(prefix, ".rc"));
    parts = vec.push(parts, " = call i64 @aic_rt_proc_run(i8* ");
    parts = vec.push(parts, llvm_local(command_prefix, ".ptr"));
    parts = vec.push(parts, ", i64 ");
    parts = vec.push(parts, llvm_local(command_prefix, ".len"));
    parts = vec.push(parts, ", i64 ");
    parts = vec.push(parts, llvm_local(command_prefix, ".cap"));
    parts = vec.push(parts, ", i64* ");
    parts = vec.push(parts, llvm_local(prefix, ".status"));
    parts = vec.push(parts, ", i8** ");
    parts = vec.push(parts, llvm_local(prefix, ".stdout.ptr"));
    parts = vec.push(parts, ", i64* ");
    parts = vec.push(parts, llvm_local(prefix, ".stdout.len"));
    parts = vec.push(parts, ", i8** ");
    parts = vec.push(parts, llvm_local(prefix, ".stderr.ptr"));
    parts = vec.push(parts, ", i64* ");
    parts = vec.push(parts, llvm_local(prefix, ".stderr.len"));
    parts = vec.push(parts, ")\n");
    string.join(parts, "")
}

fn emit_proc_run_match_node_int_return(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], node: IrExprNode, ret: String, locals: BackendLocals) -> String {
    match expr_node_child_at(nodes, node, 0) {
        Some(scrutinee) => match expr_node_child_at(nodes, scrutinee, 0) {
            Some(command_child) => match result_match_node_body_node_for_variant(nodes, node, "Ok") {
                Some(ok_body) => match result_match_node_body_node_for_variant(nodes, node, "Err") {
                    Some(err_body) => if true {
                        let prefix = llvm_node_prefix(node.node);
                        let command_name = string_node_value_name_with_locals(function_value, locals, command_child);
                        let command_prefix = concat2(prefix, ".command");
                        let ok_label = concat2("match.ok.", string.int_to_string(node.node.value));
                        let err_label = concat2("match.err.", string.int_to_string(node.node.value));
                        let out_prefix = concat2(prefix, ".out");
                        let out_ty = llvm_type_for_repr_in_program(program, "ProcOutput");
                        let ok_payload_name = result_match_node_payload_name(node, "Ok");
                        let mut parts: Vec[String] = vec.new_vec();
                        parts = vec.push(parts, emit_string_node_value(program, function_value, nodes, command_child, locals));
                        parts = vec.push(parts, emit_proc_run_call(prefix, command_name, command_prefix));
                        parts = vec.push(parts, "  ");
                        parts = vec.push(parts, llvm_local(prefix, ".is_ok"));
                        parts = vec.push(parts, " = icmp eq i64 ");
                        parts = vec.push(parts, llvm_local(prefix, ".rc"));
                        parts = vec.push(parts, ", 0\n  br i1 ");
                        parts = vec.push(parts, llvm_local(prefix, ".is_ok"));
                        parts = vec.push(parts, ", label %");
                        parts = vec.push(parts, ok_label);
                        parts = vec.push(parts, ", label %");
                        parts = vec.push(parts, err_label);
                        parts = vec.push(parts, "\n");
                        parts = vec.push(parts, ok_label);
                        parts = vec.push(parts, ":\n");
                        parts = vec.push(parts, emit_proc_output_value(out_prefix, out_ty, llvm_local(prefix, ".status"), llvm_local(prefix, ".stdout.ptr"), llvm_local(prefix, ".stdout.len"), llvm_local(prefix, ".stderr.ptr"), llvm_local(prefix, ".stderr.len")));
                        let ok_locals = backend_locals_push(locals, backend_local(ok_payload_name, "ProcOutput", out_ty, llvm_local(out_prefix, ".value")));
                        parts = vec.push(parts, emit_return_node_with_locals(program, function_value, nodes, ok_body, ret, ok_locals));
                        parts = vec.push(parts, err_label);
                        parts = vec.push(parts, ":\n");
                        parts = vec.push(parts, emit_return_node_with_locals(program, function_value, nodes, err_body, ret, locals));
                        string.join(parts, "")
                    } else { "" },
                    None => "",
                },
                None => "",
            },
            None => "",
        },
        None => "",
    }
}

