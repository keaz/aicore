fn option_vec_get_match_expr_can_emit_return(program: IrProgram, value: IrExpr, function_value: IrFunctionDef, ret: String, locals: BackendLocals) -> Bool {
    if ret == "" || ret == "void" || !option_match_arms_are_some_none(value.match_arms) || value.direct_child_count < 3 {
        false
    } else {
        match direct_expr_child_at(value.nodes, 0) {
            Some(scrutinee) => if is_vec_get_intrinsic_name(scrutinee.name) && vec_get_node_can_emit(program, function_value, value.nodes, scrutinee, locals) {
                let option_name = vec_get_node_type_name(program, function_value, value.nodes, scrutinee, locals);
                let payload_type_name = generic_arg_at(option_name, 0);
                let payload_ty = llvm_payload_slot_type(program, payload_type_name);
                if base_type_name_text(option_name) != "Option" || payload_ty == "" {
                    false
                } else {
                    match result_match_expr_body_node_for_variant(value, "Some") {
                        Some(some_body) => match result_match_expr_body_node_for_variant(value, "None") {
                            Some(none_body) => if true {
                                let payload_name = option_match_payload_name_from_expr(value);
                                let payload_locals = push_option_payload_local(program, clone_backend_locals(locals), payload_name, payload_type_name, vec_get_loaded_name(llvm_node_prefix(scrutinee.node)));
                                branch_node_can_emit_with_locals(program, function_value, value.nodes, some_body, ret, payload_locals) && branch_node_can_emit_with_locals(program, function_value, value.nodes, none_body, ret, locals)
                            } else { false },
                            None => false,
                        },
                        None => false,
                    }
                }
            } else {
                false
            },
            None => false,
        }
    }
}

