fn block_child_is_let(node: IrExprNode) -> Bool {
    string.starts_with(node.role, "let:")
}

fn block_child_is_assign(node: IrExprNode) -> Bool {
    string.starts_with(node.role, "assign:")
}

fn block_child_is_tail(node: IrExprNode) -> Bool {
    node.role == "tail"
}

fn block_child_is_return(node: IrExprNode) -> Bool {
    node.role == "return"
}

fn block_child_is_expr(node: IrExprNode) -> Bool {
    node.role == "expr"
}

fn block_node_return_child_is_terminal(block_node: IrExprNode, index: Int) -> Bool {
    index + 1 == block_node.direct_child_count
}

fn block_let_name_from_role(role: String) -> String {
    let mut index = 4;
    let mut out = "";
    let mut done = !string.starts_with(role, "let:");
    while !done && index < string.len(role) {
        let part = string.substring(role, index, index + 1);
        if part == ":" {
            done = true;
        } else {
            out = concat2(out, part);
            index = index + 1;
        }
    };
    out
}

fn block_let_type_name_from_role(role: String) -> String {
    let mut index = 4;
    let mut colon_count = 0;
    let mut out = "";
    let mut done = !string.starts_with(role, "let:");
    while !done && index < string.len(role) {
        let part = string.substring(role, index, index + 1);
        if part == ":" {
            colon_count = colon_count + 1;
            if colon_count >= 2 {
                done = true;
            } else {
                ()
            };
            index = index + 1;
            ()
        } else if colon_count == 1 {
            out = concat2(out, part);
            index = index + 1;
        } else {
            index = index + 1;
        }
    };
    if out == "<unknown>" { "" } else { out }
}

fn block_let_is_mutable_from_role(role: String) -> Bool {
    string.ends_with(role, ":mut")
}

fn block_assign_target_from_role(role: String) -> String {
    let mut index = 7;
    let mut out = "";
    let mut done = !string.starts_with(role, "assign:");
    while !done && index < string.len(role) {
        let part = string.substring(role, index, index + 1);
        if part == ":" {
            done = true;
        } else {
            out = concat2(out, part);
            index = index + 1;
        }
    };
    out
}

fn vec_new_vec_node_type_name(program: IrProgram, node: IrExprNode) -> String {
    let explicit = optional_type_name_for_id(program.types, node.type_id);
    if base_type_name_text(explicit) == "Vec" {
        explicit
    } else {
        let type_name = block_let_type_name_from_role(node.role);
        if base_type_name_text(type_name) == "Vec" {
            type_name
        } else {
            ""
        }
    }
}

fn vec_new_vec_node_llvm_type(program: IrProgram, node: IrExprNode) -> String {
    llvm_type_for_repr_in_program(program, vec_new_vec_node_type_name(program, node))
}

fn vec_new_vec_node_can_emit(program: IrProgram, node: IrExprNode) -> Bool {
    node.name == "vec.new_vec" && node.direct_child_count == 0 && vec_new_vec_node_llvm_type(program, node) == "{ i64, i64, i64 }"
}

fn vec_new_vec_expr_type_name(program: IrProgram, value: IrExpr) -> String {
    let type_name = optional_type_name_for_id(program.types, value.type_id);
    if base_type_name_text(type_name) == "Vec" {
        type_name
    } else {
        ""
    }
}

fn vec_new_vec_expr_llvm_type(program: IrProgram, value: IrExpr) -> String {
    llvm_type_for_repr_in_program(program, vec_new_vec_expr_type_name(program, value))
}

fn vec_new_vec_expr_can_emit(program: IrProgram, value: IrExpr) -> Bool {
    value.name == "vec.new_vec" && direct_expr_child_count(value.nodes) == 0 && vec_new_vec_expr_llvm_type(program, value) == "{ i64, i64, i64 }"
}

fn expr_is_vec_new_vec_call(value: IrExpr) -> Bool {
    match value.kind {
        IrCallExpr => value.name == "vec.new_vec",
        _ => false,
    }
}

fn expr_is_if_expr(value: IrExpr) -> Bool {
    match value.kind {
        IrIfExpr => true,
        _ => false,
    }
}

fn expr_is_match_expr(value: IrExpr) -> Bool {
    match value.kind {
        IrMatchExpr => true,
        _ => false,
    }
}

fn node_is_vec_new_vec_call(value: IrExprNode) -> Bool {
    match value.kind {
        IrCallExpr => value.name == "vec.new_vec",
        _ => false,
    }
}

fn node_is_if_expr(value: IrExprNode) -> Bool {
    match value.kind {
        IrIfExpr => true,
        _ => false,
    }
}

fn node_is_match_expr(value: IrExprNode) -> Bool {
    match value.kind {
        IrMatchExpr => true,
        _ => false,
    }
}

fn expected_vec_new_vec_node_can_emit(value: IrExprNode, expected: String) -> Bool {
    node_is_vec_new_vec_call(value) && value.direct_child_count == 0 && expected == "{ i64, i64, i64 }"
}

fn expected_option_constructor_node_can_emit(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], node: IrExprNode, locals: BackendLocals, expected_type_name: String) -> Bool {
    if base_type_name_text(expected_type_name) != "Option" {
        false
    } else if node.name == "None" {
        node.direct_child_count == 0
    } else if node.name == "Some" && node.direct_child_count == 1 {
        match expr_node_child_at(nodes, node, 0) {
            Some(child) => if true {
                let payload_name = generic_arg_at(expected_type_name, 0);
                let payload_ty = llvm_payload_slot_type(program, payload_name);
                payload_ty != "" && struct_literal_child_can_emit(program, function_value, nodes, child, locals, payload_ty, payload_name)
            } else { false },
            None => false,
        }
    } else {
        false
    }
}

fn expected_result_constructor_node_can_emit(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], node: IrExprNode, locals: BackendLocals, expected_type_name: String) -> Bool {
    if base_type_name_text(expected_type_name) != "Result" {
        false
    } else if (node.name == "Ok" || node.name == "Err") && node.direct_child_count == 1 {
        match expr_node_child_at(nodes, node, 0) {
            Some(child) => if true {
                let payload_name = if node.name == "Ok" { generic_arg_at(expected_type_name, 0) } else { generic_arg_at(expected_type_name, 1) };
                let payload_ty = llvm_payload_slot_type(program, payload_name);
                payload_ty != "" && struct_literal_child_can_emit(program, function_value, nodes, child, locals, payload_ty, payload_name)
            } else { false },
            None => false,
        }
    } else {
        false
    }
}

fn expected_enum_constructor_node_can_emit(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], node: IrExprNode, locals: BackendLocals, expected_type_name: String) -> Bool {
    expected_option_constructor_node_can_emit(program, function_value, nodes, node, locals, expected_type_name) || expected_result_constructor_node_can_emit(program, function_value, nodes, node, locals, expected_type_name)
}

fn expected_option_constructor_expr_can_emit(program: IrProgram, function_value: IrFunctionDef, value: IrExpr, locals: BackendLocals, expected_type_name: String) -> Bool {
    if base_type_name_text(expected_type_name) != "Option" {
        false
    } else if value.name == "None" {
        direct_expr_child_count(value.nodes) == 0
    } else if value.name == "Some" && direct_expr_child_count(value.nodes) == 1 {
        match direct_expr_child_at(value.nodes, 0) {
            Some(child) => if true {
                let payload_name = generic_arg_at(expected_type_name, 0);
                let payload_ty = llvm_payload_slot_type(program, payload_name);
                payload_ty != "" && struct_literal_child_can_emit(program, function_value, value.nodes, child, locals, payload_ty, payload_name)
            } else { false },
            None => false,
        }
    } else {
        false
    }
}

fn expected_result_constructor_expr_can_emit(program: IrProgram, function_value: IrFunctionDef, value: IrExpr, locals: BackendLocals, expected_type_name: String) -> Bool {
    if base_type_name_text(expected_type_name) != "Result" {
        false
    } else if (value.name == "Ok" || value.name == "Err") && direct_expr_child_count(value.nodes) == 1 {
        match direct_expr_child_at(value.nodes, 0) {
            Some(child) => if true {
                let payload_name = if value.name == "Ok" { generic_arg_at(expected_type_name, 0) } else { generic_arg_at(expected_type_name, 1) };
                let payload_ty = llvm_payload_slot_type(program, payload_name);
                payload_ty != "" && struct_literal_child_can_emit(program, function_value, value.nodes, child, locals, payload_ty, payload_name)
            } else { false },
            None => false,
        }
    } else {
        false
    }
}

fn expected_enum_constructor_expr_can_emit(program: IrProgram, function_value: IrFunctionDef, value: IrExpr, locals: BackendLocals, expected_type_name: String) -> Bool {
    expected_option_constructor_expr_can_emit(program, function_value, value, locals, expected_type_name) || expected_result_constructor_expr_can_emit(program, function_value, value, locals, expected_type_name)
}

fn statement_declared_type_name(program: IrProgram, statement: IrStatement) -> String {
    optional_type_name_for_id(program.types, statement.type_id)
}

fn vec_new_vec_statement_type_name(program: IrProgram, statement: IrStatement) -> String {
    let type_name = statement_declared_type_name(program, statement);
    if base_type_name_text(type_name) == "Vec" {
        type_name
    } else {
        ""
    }
}

fn vec_new_vec_statement_llvm_type(program: IrProgram, statement: IrStatement) -> String {
    llvm_type_for_repr_in_program(program, vec_new_vec_statement_type_name(program, statement))
}

fn vec_new_vec_statement_can_emit(program: IrProgram, statement: IrStatement, value: IrExpr) -> Bool {
    expr_is_vec_new_vec_call(value) && direct_expr_child_count(value.nodes) == 0 && vec_new_vec_statement_llvm_type(program, statement) == "{ i64, i64, i64 }"
}

fn emit_empty_vec_value(prefix: String, vec_ty: String) -> String {
    let mut parts: Vec[String] = vec.new_vec();
    parts = vec.push(parts, "  ");
    parts = vec.push(parts, llvm_local(prefix, ".0"));
    parts = vec.push(parts, " = insertvalue ");
    parts = vec.push(parts, vec_ty);
    parts = vec.push(parts, " undef, i64 0, 0\n  ");
    parts = vec.push(parts, llvm_local(prefix, ".1"));
    parts = vec.push(parts, " = insertvalue ");
    parts = vec.push(parts, vec_ty);
    parts = vec.push(parts, " ");
    parts = vec.push(parts, llvm_local(prefix, ".0"));
    parts = vec.push(parts, ", i64 0, 1\n  ");
    parts = vec.push(parts, llvm_local(prefix, ".value"));
    parts = vec.push(parts, " = insertvalue ");
    parts = vec.push(parts, vec_ty);
    parts = vec.push(parts, " ");
    parts = vec.push(parts, llvm_local(prefix, ".1"));
    parts = vec.push(parts, ", i64 0, 2\n");
    string.join(parts, "")
}

fn node_value_name(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], node: IrExprNode, locals: BackendLocals) -> String {
    match node.kind {
        IrIntExpr => literal_text_or_name(node.text, node.name),
        IrBoolExpr => bool_literal_llvm_text(node.text, node.name),
        IrStringExpr => string_node_value_name(node),
        IrNameExpr => if name_uses_storage(locals, node.text) { loaded_node_name(node) } else { value_name_for_name(function_value, locals, node.text) },
        IrFieldAccessExpr => llvm_node_value_local(node),
        IrBinaryExpr => llvm_node_value_local(node),
        IrCallExpr => llvm_node_value_local(node),
        IrUnaryExpr => llvm_node_value_local(node),
        IrIfExpr => llvm_node_value_local(node),
        IrLoopExpr => llvm_node_value_local(node),
        IrMatchExpr => llvm_node_value_local(node),
        IrStructLiteralExpr => struct_literal_value_name(llvm_node_prefix(node.node), node.direct_child_count, value_node_llvm_type(program, function_value, nodes, node, locals)),
        _ => "",
    }
}

fn backend_local_for_node_with_mutability(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], node: IrExprNode, locals: BackendLocals, name: String, mutable: Bool) -> BackendLocal {
    let declared_type_name = block_let_type_name_from_role(node.role);
    let expected_declared_enum = declared_type_name != "" && expected_enum_constructor_node_can_emit(program, function_value, nodes, node, locals, declared_type_name);
    let inferred_type_name = match node.kind {
        IrNameExpr => type_name_for_name(program, function_value, locals, node.text),
        IrCallExpr => if node.name == "vec.push" {
            vec_push_node_type_name(program, function_value, nodes, node, locals)
        } else if node.name == "vec.new_vec" {
            vec_new_vec_node_type_name(program, node)
        } else if is_string_len_intrinsic_name(node.name) {
            "Int"
        } else if is_string_join_intrinsic_name(node.name) {
            "String"
        } else if is_string_split_intrinsic_name(node.name) {
            "Vec[String]"
        } else if is_string_trim_intrinsic_name(node.name) {
            "String"
        } else if is_string_char_at_intrinsic_name(node.name) {
            "Option[String]"
        } else if is_string_int_to_string_intrinsic_name(node.name) {
            "String"
        } else if node.name == "string.replace" {
            "String"
        } else if is_vec_len_intrinsic_name(node.name) {
            "Int"
        } else if is_string_slice_intrinsic_name(node.name) {
            "String"
        } else if enum_variant_constructor_type_name(program, node.name) != "" {
            enum_variant_constructor_type_name(program, node.name)
        } else {
            call_target_return_type_name(program, node.name)
        },
        IrStringExpr => "String",
        IrIntExpr => "Int",
        IrBoolExpr => "Bool",
        IrBinaryExpr => node_type_name(program, function_value, nodes, node, locals),
        IrIfExpr => if_node_value_type_name(program, function_value, nodes, node, locals),
        IrLoopExpr => loop_node_value_type_name(program, function_value, nodes, node, locals),
        IrMatchExpr => match_node_value_type_name(program, function_value, nodes, node, locals),
        IrFieldAccessExpr => field_access_node_type_name(program, function_value, nodes, node, locals),
        IrStructLiteralExpr => node.name,
        _ => "",
    };
    let type_name = if declared_type_name != "" { declared_type_name } else { inferred_type_name };
    let declared_llvm_type = llvm_type_for_repr_in_program(program, declared_type_name);
    let llvm_type = if declared_llvm_type != "" { declared_llvm_type } else { value_node_llvm_type(program, function_value, nodes, node, locals) };
    let value_name = if expected_declared_enum {
        expected_enum_constructor_node_value_name(node)
    } else {
        node_value_name(program, function_value, nodes, node, locals)
    };
    if mutable {
        backend_mutable_local(name, type_name, llvm_type, value_name, mutable_storage_name(name, node.node))
    } else {
        backend_local(name, type_name, llvm_type, value_name)
    }
}

fn backend_local_for_node(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], node: IrExprNode, locals: BackendLocals, name: String) -> BackendLocal {
    backend_local_for_node_with_mutability(program, function_value, nodes, node, locals, name, false)
}

fn let_node_can_emit(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], node: IrExprNode, locals: BackendLocals) -> Bool {
    if !block_child_is_let(node) {
        false
    } else {
        let declared_type_name = block_let_type_name_from_role(node.role);
        if declared_type_name != "" && expected_enum_constructor_node_can_emit(program, function_value, nodes, node, locals, declared_type_name) {
            llvm_type_for_repr_in_program(program, declared_type_name) != ""
        } else {
            value_node_can_emit(program, function_value, nodes, node, locals)
        }
    }
}

fn push_node_local(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], node: IrExprNode, locals: BackendLocals) -> BackendLocals {
    if !block_child_is_let(node) {
        locals
    } else {
        backend_locals_push(locals, backend_local_for_node_with_mutability(program, function_value, nodes, node, locals, block_let_name_from_role(node.role), block_let_is_mutable_from_role(node.role)))
    }
}

fn expr_node_statement_can_emit_with_locals(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], node: IrExprNode, locals: BackendLocals) -> Bool {
    match node.kind {
        IrCallExpr => if call_node_return_type_matches(program, node, "void") && direct_call_node_can_emit(program, function_value, nodes, node, locals) {
            true
        } else {
            fs_bool_node_can_emit(program, function_value, nodes, node, locals)
        },
        IrIfExpr => if_node_statement_can_emit_with_locals(program, function_value, nodes, node, locals),
        IrWhileExpr => while_node_can_emit_with_locals(program, function_value, nodes, node, locals),
        IrLoopExpr => loop_node_can_emit_unit_with_locals(program, function_value, nodes, node, locals),
        IrForExpr => for_node_can_emit_with_locals(program, function_value, nodes, node, locals),
        IrMatchExpr => option_vec_get_match_node_can_emit_statement(program, function_value, nodes, node, locals)
            || option_match_node_can_emit_statement(program, function_value, nodes, node, locals)
            || enum_match_node_can_emit_statement(program, function_value, nodes, node, locals),
        IrUnitExpr => true,
        _ => false,
    }
}

fn unit_statement_tail_node_can_emit_with_locals(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], node: IrExprNode, locals: BackendLocals) -> Bool {
    match node.kind {
        IrUnitExpr => true,
        IrCallExpr => call_node_return_type_matches(program, node, "void") && direct_call_node_can_emit(program, function_value, nodes, node, locals),
        IrIfExpr => if_node_statement_can_emit_with_locals(program, function_value, nodes, node, locals),
        IrWhileExpr => while_node_can_emit_with_locals(program, function_value, nodes, node, locals),
        IrLoopExpr => loop_node_can_emit_unit_with_locals(program, function_value, nodes, node, locals),
        IrForExpr => for_node_can_emit_with_locals(program, function_value, nodes, node, locals),
        IrMatchExpr => option_vec_get_match_node_can_emit_statement(program, function_value, nodes, node, locals)
            || option_match_node_can_emit_statement(program, function_value, nodes, node, locals)
            || enum_match_node_can_emit_statement(program, function_value, nodes, node, locals),
        _ => false,
    }
}

fn unit_statement_branch_node_can_emit_with_locals(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], branch_node: IrExprNode, locals: BackendLocals) -> Bool {
    if is_block_expr_kind(branch_node.kind) {
        unit_block_node_local_check(program, function_value, nodes, branch_node, locals).ok
    } else {
        unit_statement_tail_node_can_emit_with_locals(program, function_value, nodes, branch_node, locals)
    }
}

fn unit_block_node_local_check(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], block_node: IrExprNode, locals: BackendLocals) -> BackendLocalCheck {
    if !is_block_expr_kind(block_node.kind) {
        backend_local_check(unit_statement_tail_node_can_emit_with_locals(program, function_value, nodes, block_node, locals), locals)
    } else {
        let mut out = clone_backend_locals(locals);
        let mut index = 0;
        let mut ok = true;
        let mut done = false;
        while ok && !done && index < block_node.direct_child_count {
            match expr_node_child_at(nodes, block_node, index) {
                Some(child) => if block_child_is_expr(child) {
                    ok = expr_node_statement_can_emit_with_locals(program, function_value, nodes, child, out);
                    ()
                } else if block_child_is_let(child) {
                    if let_node_can_emit(program, function_value, nodes, child, out) {
                        out = push_node_local(program, function_value, nodes, child, out);
                    } else {
                        ok = false;
                    };
                    ()
                } else if block_child_is_assign(child) {
                    ok = assign_node_can_emit(program, function_value, nodes, child, out, block_assign_target_from_role(child.role));
                    ()
                } else if block_child_is_tail(child) {
                    ok = unit_statement_tail_node_can_emit_with_locals(program, function_value, nodes, child, out);
                    ()
                } else if block_child_is_return(child) {
                    let ret = llvm_type_for_id(program, function_value.return_type);
                    ok = return_node_can_emit_with_locals(program, function_value, nodes, child, ret, out);
                    done = ok;
                    ()
                } else if node_is_unit_or_false_loop(child) {
                    ()
                } else {
                    ok = false;
                },
                None => if true {
                    ok = false;
                    ()
                } else { () },
            };
            index = index + 1;
        };
        backend_local_check(ok, out)
    }
}

fn if_node_statement_can_emit_with_locals(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], node: IrExprNode, locals: BackendLocals) -> Bool {
    if node.direct_child_count != 3 {
        false
    } else {
        match expr_node_child_at(nodes, node, 0) {
            Some(condition) => match expr_node_child_at(nodes, node, 1) {
                Some(then_block) => match expr_node_child_at(nodes, node, 2) {
                    Some(else_block) => bool_node_can_emit_with_locals(program, function_value, nodes, condition, locals)
                        && unit_statement_branch_node_can_emit_with_locals(program, function_value, nodes, then_block, locals)
                        && unit_statement_branch_node_can_emit_with_locals(program, function_value, nodes, else_block, locals),
                    None => false,
                },
                None => false,
            },
            None => false,
        }
    }
}

fn if_expr_statement_can_emit_with_locals(program: IrProgram, function_value: IrFunctionDef, expr: IrExpr, locals: BackendLocals) -> Bool {
    if expr.direct_child_count != 3 {
        false
    } else {
        match direct_expr_child_at(expr.nodes, 0) {
            Some(condition) => match direct_expr_child_at(expr.nodes, 1) {
                Some(then_block) => match direct_expr_child_at(expr.nodes, 2) {
                    Some(else_block) => bool_node_can_emit_with_locals(program, function_value, expr.nodes, condition, locals)
                        && unit_statement_branch_node_can_emit_with_locals(program, function_value, expr.nodes, then_block, locals)
                        && unit_statement_branch_node_can_emit_with_locals(program, function_value, expr.nodes, else_block, locals),
                    None => false,
                },
                None => false,
            },
            None => false,
        }
    }
}

fn node_is_continue_control(node: IrExprNode) -> Bool {
    match node.kind {
        IrContinueExpr => node.direct_child_count == 0,
        _ => false,
    }
}

fn node_is_value_break(node: IrExprNode) -> Bool {
    match node.kind {
        IrBreakExpr => node.direct_child_count == 1,
        _ => false,
    }
}

fn break_value_node_child(nodes: Vec[IrExprNode], node: IrExprNode) -> Option[IrExprNode] {
    if node_is_value_break(node) {
        expr_node_child_at(nodes, node, 0)
    } else {
        None()
    }
}

fn break_value_node_type_name(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], node: IrExprNode, locals: BackendLocals) -> String {
    match break_value_node_child(nodes, node) {
        Some(child) => node_type_name(program, function_value, nodes, child, locals),
        None => "",
    }
}

fn loop_value_branch_type_name(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], branch_node: IrExprNode, locals: BackendLocals) -> String {
    if node_is_value_break(branch_node) {
        break_value_node_type_name(program, function_value, nodes, branch_node, locals)
    } else if is_block_expr_kind(branch_node.kind) {
        let mut out = "";
        let mut out_locals = clone_backend_locals(locals);
        let mut index = 0;
        while out == "" && index < branch_node.direct_child_count {
            match expr_node_child_at(nodes, branch_node, index) {
                Some(child) => if block_child_is_let(child) {
                    if let_node_can_emit(program, function_value, nodes, child, out_locals) {
                        out_locals = push_node_local(program, function_value, nodes, child, out_locals);
                    } else {
                        ()
                    };
                    ()
                } else if block_child_is_expr(child) || block_child_is_tail(child) {
                    out = loop_value_branch_type_name(program, function_value, nodes, child, out_locals);
                    ()
                } else {
                    ()
                },
                None => (),
            };
            index = index + 1;
        };
        out
    } else {
        match branch_node.kind {
            IrIfExpr => match expr_node_child_at(nodes, branch_node, 1) {
                Some(then_block) => match expr_node_child_at(nodes, branch_node, 2) {
                    Some(else_block) => if true {
                        let then_type = loop_value_branch_type_name(program, function_value, nodes, then_block, locals);
                        let else_type = loop_value_branch_type_name(program, function_value, nodes, else_block, locals);
                        if then_type != "" && then_type == else_type {
                            then_type
                        } else if then_type != "" {
                            then_type
                        } else {
                            else_type
                        }
                    } else { "" },
                    None => "",
                },
                None => "",
            },
            _ => "",
        }
    }
}

fn loop_expr_value_type_name(program: IrProgram, value: IrExpr, function_value: IrFunctionDef, locals: BackendLocals) -> String {
    match direct_expr_child_at(value.nodes, 0) {
        Some(body) => loop_value_branch_type_name(program, function_value, value.nodes, body, locals),
        None => "",
    }
}

fn loop_node_value_type_name(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], node: IrExprNode, locals: BackendLocals) -> String {
    match expr_node_child_at(nodes, node, 0) {
        Some(body) => loop_value_branch_type_name(program, function_value, nodes, body, locals),
        None => "",
    }
}

fn loop_value_branch_can_emit_with_type(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], branch_node: IrExprNode, locals: BackendLocals, expected: String, expected_type_name: String) -> Bool {
    if node_is_value_break(branch_node) {
        match break_value_node_child(nodes, branch_node) {
            Some(child) => if expected_enum_constructor_node_can_emit(program, function_value, nodes, child, locals, expected_type_name) {
                llvm_type_for_repr_in_program(program, expected_type_name) == expected
            } else {
                value_node_llvm_type(program, function_value, nodes, child, locals) == expected && value_node_can_emit(program, function_value, nodes, child, locals)
            },
            None => false,
        }
    } else if node_is_continue_control(branch_node) {
        true
    } else if is_block_expr_kind(branch_node.kind) {
        let mut out = clone_backend_locals(locals);
        let mut index = 0;
        let mut ok = true;
        let mut done = false;
        while ok && !done && index < branch_node.direct_child_count {
            match expr_node_child_at(nodes, branch_node, index) {
                Some(child) => if block_child_is_let(child) {
                    if let_node_can_emit(program, function_value, nodes, child, out) {
                        out = push_node_local(program, function_value, nodes, child, out);
                    } else {
                        ok = false;
                    };
                    ()
                } else if block_child_is_assign(child) {
                    ok = assign_node_can_emit(program, function_value, nodes, child, out, block_assign_target_from_role(child.role));
                    ()
                } else if block_child_is_return(child) {
                    ok = return_node_can_emit_with_locals(program, function_value, nodes, child, llvm_type_for_id(program, function_value.return_type), out);
                    done = ok;
                    ()
                } else if block_child_is_expr(child) || block_child_is_tail(child) {
                    ok = loop_value_branch_can_emit_with_type(program, function_value, nodes, child, out, expected, expected_type_name);
                    if node_is_value_break(child) || node_is_continue_control(child) {
                        done = ok;
                    } else {
                        ()
                    };
                    ()
                } else {
                    ok = false;
                },
                None => if true {
                    ok = false;
                    ()
                } else { () },
            };
            index = index + 1;
        };
        ok
    } else {
        match branch_node.kind {
            IrUnitExpr => true,
            IrCallExpr => if call_node_return_type_matches(program, branch_node, "void") {
                direct_call_node_can_emit(program, function_value, nodes, branch_node, locals)
            } else {
                fs_bool_node_can_emit(program, function_value, nodes, branch_node, locals)
            },
            IrIfExpr => if branch_node.direct_child_count != 3 {
                false
            } else {
                match expr_node_child_at(nodes, branch_node, 0) {
                    Some(condition) => match expr_node_child_at(nodes, branch_node, 1) {
                        Some(then_block) => match expr_node_child_at(nodes, branch_node, 2) {
                            Some(else_block) => bool_node_can_emit_with_locals(program, function_value, nodes, condition, locals)
                                && loop_value_branch_can_emit_with_type(program, function_value, nodes, then_block, locals, expected, expected_type_name)
                                && loop_value_branch_can_emit_with_type(program, function_value, nodes, else_block, locals, expected, expected_type_name),
                            None => false,
                        },
                        None => false,
                    },
                    None => false,
                }
            },
            IrWhileExpr => while_node_can_emit_with_locals(program, function_value, nodes, branch_node, locals),
            IrLoopExpr => loop_node_can_emit_unit_with_locals(program, function_value, nodes, branch_node, locals),
            IrForExpr => for_node_can_emit_with_locals(program, function_value, nodes, branch_node, locals),
            IrMatchExpr => option_vec_get_match_node_can_emit_statement(program, function_value, nodes, branch_node, locals)
                || option_match_node_can_emit_statement(program, function_value, nodes, branch_node, locals)
                || enum_match_node_can_emit_statement(program, function_value, nodes, branch_node, locals),
            _ => false,
        }
    }
}

fn loop_expr_can_emit_value_with_type(program: IrProgram, value: IrExpr, function_value: IrFunctionDef, locals: BackendLocals, expected: String, expected_type_name: String) -> Bool {
    if value.direct_child_count != 1 || expected == "" || expected_type_name == "" || loop_expr_value_type_name(program, value, function_value, locals) == "" {
        false
    } else {
        match direct_expr_child_at(value.nodes, 0) {
            Some(body) => loop_value_branch_can_emit_with_type(program, function_value, value.nodes, body, locals, expected, expected_type_name),
            None => false,
        }
    }
}

fn loop_node_can_emit_value_with_type(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], node: IrExprNode, locals: BackendLocals, expected: String, expected_type_name: String) -> Bool {
    if node.direct_child_count != 1 || expected == "" || expected_type_name == "" || loop_node_value_type_name(program, function_value, nodes, node, locals) == "" {
        false
    } else {
        match expr_node_child_at(nodes, node, 0) {
            Some(body) => loop_value_branch_can_emit_with_type(program, function_value, nodes, body, locals, expected, expected_type_name),
            None => false,
        }
    }
}

fn loop_node_can_emit_unit_with_locals(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], node: IrExprNode, locals: BackendLocals) -> Bool {
    if node.direct_child_count != 1 {
        false
    } else {
        match expr_node_child_at(nodes, node, 0) {
            Some(body) => unit_loop_block_node_local_check(program, function_value, nodes, body, locals).ok,
            None => false,
        }
    }
}

fn loop_expr_can_emit_unit_with_locals(program: IrProgram, function_value: IrFunctionDef, expr: IrExpr, locals: BackendLocals) -> Bool {
    if expr.direct_child_count != 1 {
        false
    } else {
        match direct_expr_child_at(expr.nodes, 0) {
            Some(body) => unit_loop_block_node_local_check(program, function_value, expr.nodes, body, locals).ok,
            None => false,
        }
    }
}

fn while_node_can_emit_with_locals(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], node: IrExprNode, locals: BackendLocals) -> Bool {
    if node.direct_child_count != 2 {
        string.starts_with(node.text, "while false")
    } else {
        match expr_node_child_at(nodes, node, 0) {
            Some(condition) => match expr_node_child_at(nodes, node, 1) {
                Some(body) => bool_node_can_emit_with_locals(program, function_value, nodes, condition, locals) && unit_loop_block_node_local_check(program, function_value, nodes, body, locals).ok,
                None => false,
            },
            None => false,
        }
    }
}

fn while_expr_can_emit_with_locals(program: IrProgram, function_value: IrFunctionDef, expr: IrExpr, locals: BackendLocals) -> Bool {
    if expr.direct_child_count != 2 {
        string.starts_with(expr.text, "while false")
    } else {
        match direct_expr_child_at(expr.nodes, 0) {
            Some(condition) => match direct_expr_child_at(expr.nodes, 1) {
                Some(body) => bool_node_can_emit_with_locals(program, function_value, expr.nodes, condition, locals) && unit_loop_block_node_local_check(program, function_value, expr.nodes, body, locals).ok,
                None => false,
            },
            None => false,
        }
    }
}

fn node_is_range_expr(node: IrExprNode) -> Bool {
    match node.kind {
        IrBinaryExpr => node.op == "..",
        _ => false,
    }
}

fn for_range_node_can_emit_with_locals(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], range_node: IrExprNode, locals: BackendLocals) -> Bool {
    if !node_is_range_expr(range_node) || range_node.direct_child_count != 2 {
        false
    } else {
        match expr_node_child_at(nodes, range_node, 0) {
            Some(start_node) => match expr_node_child_at(nodes, range_node, 1) {
                Some(end_node) => value_node_can_emit(program, function_value, nodes, start_node, locals)
                    && value_node_can_emit(program, function_value, nodes, end_node, locals)
                    && value_node_llvm_type(program, function_value, nodes, start_node, locals) == "i64"
                    && value_node_llvm_type(program, function_value, nodes, end_node, locals) == "i64",
                None => false,
            },
            None => false,
        }
    }
}

fn for_expr_range_node_can_emit_with_locals(program: IrProgram, function_value: IrFunctionDef, expr: IrExpr, range_node: IrExprNode, locals: BackendLocals) -> Bool {
    for_range_node_can_emit_with_locals(program, function_value, expr.nodes, range_node, locals)
}

fn for_node_item_value_name(node: IrExprNode) -> String {
    llvm_local(llvm_node_prefix(node.node), ".range.cur")
}

fn for_expr_item_value_name(expr: IrExpr) -> String {
    llvm_local(llvm_expr_prefix(expr.node), ".range.cur")
}

fn for_iter_item_value_name(prefix: String) -> String {
    vec_get_loaded_name(concat2(prefix, ".iter.get"))
}

fn for_node_body_locals(node: IrExprNode, locals: BackendLocals) -> BackendLocals {
    if node.name == "" {
        locals
    } else {
        backend_locals_push(locals, backend_local(node.name, "Int", "i64", for_node_item_value_name(node)))
    }
}

fn for_expr_body_locals(expr: IrExpr, locals: BackendLocals) -> BackendLocals {
    if expr.name == "" {
        locals
    } else {
        backend_locals_push(locals, backend_local(expr.name, "Int", "i64", for_expr_item_value_name(expr)))
    }
}

fn for_node_iterable_type_name(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], node: IrExprNode, locals: BackendLocals) -> String {
    match expr_node_child_at(nodes, node, 0) {
        Some(iterable_node) => node_type_name(program, function_value, nodes, iterable_node, locals),
        None => "",
    }
}

fn for_expr_iterable_type_name(program: IrProgram, function_value: IrFunctionDef, expr: IrExpr, locals: BackendLocals) -> String {
    match direct_expr_child_at(expr.nodes, 0) {
        Some(iterable_node) => node_type_name(program, function_value, expr.nodes, iterable_node, locals),
        None => "",
    }
}

fn for_iter_vec_elem_type_name(iterable_type_name: String) -> String {
    if base_type_name_text(iterable_type_name) == "Vec" {
        generic_arg_at(iterable_type_name, 0)
    } else {
        ""
    }
}

fn for_node_iter_body_locals(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], node: IrExprNode, locals: BackendLocals) -> BackendLocals {
    if node.name == "" {
        locals
    } else {
        let elem_name = for_iter_vec_elem_type_name(for_node_iterable_type_name(program, function_value, nodes, node, locals));
        let elem_ty = llvm_type_for_repr_in_program(program, elem_name);
        backend_locals_push(locals, backend_local(node.name, elem_name, elem_ty, for_iter_item_value_name(llvm_node_prefix(node.node))))
    }
}

fn for_expr_iter_body_locals(program: IrProgram, function_value: IrFunctionDef, expr: IrExpr, locals: BackendLocals) -> BackendLocals {
    if expr.name == "" {
        locals
    } else {
        let elem_name = for_iter_vec_elem_type_name(for_expr_iterable_type_name(program, function_value, expr, locals));
        let elem_ty = llvm_type_for_repr_in_program(program, elem_name);
        backend_locals_push(locals, backend_local(expr.name, elem_name, elem_ty, for_iter_item_value_name(llvm_expr_prefix(expr.node))))
    }
}

fn for_iter_node_can_emit_with_locals(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], iterable_node: IrExprNode, locals: BackendLocals) -> Bool {
    if node_is_range_expr(iterable_node) {
        false
    } else {
        let iterable_type_name = node_type_name(program, function_value, nodes, iterable_node, locals);
        let elem_name = for_iter_vec_elem_type_name(iterable_type_name);
        let elem_ty = llvm_type_for_repr_in_program(program, elem_name);
        base_type_name_text(iterable_type_name) == "Vec"
            && elem_name == "Int"
            && elem_ty == "i64"
            && value_node_can_emit(program, function_value, nodes, iterable_node, locals)
            && value_node_llvm_type(program, function_value, nodes, iterable_node, locals) == "{ i64, i64, i64 }"
    }
}

fn for_iter_expr_can_emit_with_locals(program: IrProgram, function_value: IrFunctionDef, expr: IrExpr, iterable_node: IrExprNode, locals: BackendLocals) -> Bool {
    for_iter_node_can_emit_with_locals(program, function_value, expr.nodes, iterable_node, locals)
}

fn for_node_can_emit_with_locals(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], node: IrExprNode, locals: BackendLocals) -> Bool {
    if node.direct_child_count != 2 || node.name == "" {
        false
    } else {
        match expr_node_child_at(nodes, node, 0) {
            Some(iterable_node) => match expr_node_child_at(nodes, node, 1) {
                Some(body_node) => if for_range_node_can_emit_with_locals(program, function_value, nodes, iterable_node, locals) {
                    unit_loop_statement_branch_node_can_emit_with_locals(program, function_value, nodes, body_node, for_node_body_locals(node, locals))
                } else if for_iter_node_can_emit_with_locals(program, function_value, nodes, iterable_node, locals) {
                    unit_loop_statement_branch_node_can_emit_with_locals(program, function_value, nodes, body_node, for_node_iter_body_locals(program, function_value, nodes, node, locals))
                } else {
                    false
                },
                None => false,
            },
            None => false,
        }
    }
}

fn for_expr_can_emit_with_locals(program: IrProgram, function_value: IrFunctionDef, expr: IrExpr, locals: BackendLocals) -> Bool {
    if expr.direct_child_count != 2 || expr.name == "" {
        false
    } else {
        match direct_expr_child_at(expr.nodes, 0) {
            Some(iterable_node) => match direct_expr_child_at(expr.nodes, 1) {
                Some(body_node) => if for_expr_range_node_can_emit_with_locals(program, function_value, expr, iterable_node, locals) {
                    unit_loop_statement_branch_node_can_emit_with_locals(program, function_value, expr.nodes, body_node, for_expr_body_locals(expr, locals))
                } else if for_iter_expr_can_emit_with_locals(program, function_value, expr, iterable_node, locals) {
                    unit_loop_statement_branch_node_can_emit_with_locals(program, function_value, expr.nodes, body_node, for_expr_iter_body_locals(program, function_value, expr, locals))
                } else {
                    false
                },
                None => false,
            },
            None => false,
        }
    }
}

fn node_is_unit_loop_control(node: IrExprNode) -> Bool {
    match node.kind {
        IrBreakExpr => node.direct_child_count == 0,
        IrContinueExpr => node.direct_child_count == 0,
        _ => false,
    }
}

fn loop_node_child_is_terminal(block_node: IrExprNode, index: Int) -> Bool {
    index + 1 == block_node.direct_child_count
}

fn expr_node_loop_statement_can_emit_with_locals(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], node: IrExprNode, locals: BackendLocals) -> Bool {
    if node_is_unit_loop_control(node) {
        true
    } else {
        match node.kind {
            IrCallExpr => if call_node_return_type_matches(program, node, "void") && direct_call_node_can_emit(program, function_value, nodes, node, locals) {
                true
            } else {
                fs_bool_node_can_emit(program, function_value, nodes, node, locals)
            },
            IrIfExpr => if_node_loop_statement_can_emit_with_locals(program, function_value, nodes, node, locals),
            IrWhileExpr => while_node_can_emit_with_locals(program, function_value, nodes, node, locals),
            IrLoopExpr => loop_node_can_emit_unit_with_locals(program, function_value, nodes, node, locals),
            IrForExpr => for_node_can_emit_with_locals(program, function_value, nodes, node, locals),
            IrMatchExpr => option_vec_get_match_node_can_emit_statement(program, function_value, nodes, node, locals)
                || option_match_node_can_emit_statement(program, function_value, nodes, node, locals)
                || enum_match_node_can_emit_statement(program, function_value, nodes, node, locals),
            IrUnitExpr => true,
            _ => false,
        }
    }
}

fn unit_loop_statement_tail_node_can_emit_with_locals(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], node: IrExprNode, locals: BackendLocals) -> Bool {
    if node_is_unit_loop_control(node) {
        true
    } else {
        match node.kind {
            IrUnitExpr => true,
            IrCallExpr => call_node_return_type_matches(program, node, "void") && direct_call_node_can_emit(program, function_value, nodes, node, locals),
            IrIfExpr => if_node_loop_statement_can_emit_with_locals(program, function_value, nodes, node, locals),
            IrWhileExpr => while_node_can_emit_with_locals(program, function_value, nodes, node, locals),
            IrLoopExpr => loop_node_can_emit_unit_with_locals(program, function_value, nodes, node, locals),
            IrForExpr => for_node_can_emit_with_locals(program, function_value, nodes, node, locals),
            IrMatchExpr => option_vec_get_match_node_can_emit_statement(program, function_value, nodes, node, locals)
                || option_match_node_can_emit_statement(program, function_value, nodes, node, locals)
                || enum_match_node_can_emit_statement(program, function_value, nodes, node, locals),
            _ => false,
        }
    }
}

fn unit_loop_statement_branch_node_can_emit_with_locals(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], branch_node: IrExprNode, locals: BackendLocals) -> Bool {
    if is_block_expr_kind(branch_node.kind) {
        unit_loop_block_node_local_check(program, function_value, nodes, branch_node, locals).ok
    } else {
        unit_loop_statement_tail_node_can_emit_with_locals(program, function_value, nodes, branch_node, locals)
    }
}

fn unit_loop_block_node_local_check(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], block_node: IrExprNode, locals: BackendLocals) -> BackendLocalCheck {
    if !is_block_expr_kind(block_node.kind) {
        backend_local_check(unit_loop_statement_tail_node_can_emit_with_locals(program, function_value, nodes, block_node, locals), locals)
    } else {
        let mut out = clone_backend_locals(locals);
        let mut index = 0;
        let mut ok = true;
        let mut done = false;
        while ok && !done && index < block_node.direct_child_count {
            match expr_node_child_at(nodes, block_node, index) {
                Some(child) => if block_child_is_expr(child) {
                    ok = expr_node_loop_statement_can_emit_with_locals(program, function_value, nodes, child, out);
                    if node_is_unit_loop_control(child) {
                        done = ok;
                    } else {
                        ()
                    };
                    ()
                } else if block_child_is_let(child) {
                    if let_node_can_emit(program, function_value, nodes, child, out) {
                        out = push_node_local(program, function_value, nodes, child, out);
                    } else {
                        ok = false;
                    };
                    ()
                } else if block_child_is_assign(child) {
                    ok = assign_node_can_emit(program, function_value, nodes, child, out, block_assign_target_from_role(child.role));
                    ()
                } else if block_child_is_tail(child) {
                    ok = unit_loop_statement_tail_node_can_emit_with_locals(program, function_value, nodes, child, out);
                    if node_is_unit_loop_control(child) {
                        done = ok;
                    } else {
                        ()
                    };
                    ()
                } else if block_child_is_return(child) {
                    let ret = llvm_type_for_id(program, function_value.return_type);
                    ok = return_node_can_emit_with_locals(program, function_value, nodes, child, ret, out);
                    done = ok;
                    ()
                } else if node_is_unit_or_false_loop(child) {
                    ()
                } else {
                    ok = false;
                },
                None => if true {
                    ok = false;
                    ()
                } else { () },
            };
            index = index + 1;
        };
        backend_local_check(ok, out)
    }
}

fn if_node_loop_statement_can_emit_with_locals(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], node: IrExprNode, locals: BackendLocals) -> Bool {
    if node.direct_child_count != 3 {
        false
    } else {
        match expr_node_child_at(nodes, node, 0) {
            Some(condition) => match expr_node_child_at(nodes, node, 1) {
                Some(then_block) => match expr_node_child_at(nodes, node, 2) {
                    Some(else_block) => bool_node_can_emit_with_locals(program, function_value, nodes, condition, locals)
                        && unit_loop_statement_branch_node_can_emit_with_locals(program, function_value, nodes, then_block, locals)
                        && unit_loop_statement_branch_node_can_emit_with_locals(program, function_value, nodes, else_block, locals),
                    None => false,
                },
                None => false,
            },
            None => false,
        }
    }
}

fn if_expr_loop_statement_can_emit_with_locals(program: IrProgram, function_value: IrFunctionDef, expr: IrExpr, locals: BackendLocals) -> Bool {
    if expr.direct_child_count != 3 {
        false
    } else {
        match direct_expr_child_at(expr.nodes, 0) {
            Some(condition) => match direct_expr_child_at(expr.nodes, 1) {
                Some(then_block) => match direct_expr_child_at(expr.nodes, 2) {
                    Some(else_block) => bool_node_can_emit_with_locals(program, function_value, expr.nodes, condition, locals)
                        && unit_loop_statement_branch_node_can_emit_with_locals(program, function_value, expr.nodes, then_block, locals)
                        && unit_loop_statement_branch_node_can_emit_with_locals(program, function_value, expr.nodes, else_block, locals),
                    None => false,
                },
                None => false,
            },
            None => false,
        }
    }
}

fn node_is_unit_or_false_loop(node: IrExprNode) -> Bool {
    match node.kind {
        IrUnitExpr => true,
        _ => string.starts_with(node.text, "while false"),
    }
}

fn block_node_local_check(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], block_node: IrExprNode, ret: String, locals: BackendLocals) -> BackendLocalCheck {
    let mut out = clone_backend_locals(locals);
    let mut ok = true;
    let mut index = 0;
    let mut saw_tail = false;
    let mut done = false;
    while ok && !done && index < block_node.direct_child_count {
        match expr_node_child_at(nodes, block_node, index) {
            Some(child) => if block_child_is_let(child) {
                if let_node_can_emit(program, function_value, nodes, child, out) {
                    out = push_node_local(program, function_value, nodes, child, out);
                } else {
                    ok = false;
                };
                ()
            } else if block_child_is_assign(child) {
                ok = assign_node_can_emit(program, function_value, nodes, child, out, block_assign_target_from_role(child.role));
                ()
            } else if block_child_is_tail(child) {
                saw_tail = true;
                if return_node_can_emit_with_locals(program, function_value, nodes, child, ret, out) {
                    done = true;
                } else {
                    ok = false;
                };
                ()
            } else if block_child_is_return(child) {
                saw_tail = true;
                if return_node_can_emit_with_locals(program, function_value, nodes, child, ret, out) {
                    done = true;
                } else {
                    ok = false;
                };
                ()
            } else if block_child_is_expr(child) {
                if expr_node_statement_can_emit_with_locals(program, function_value, nodes, child, out) {
                    ()
                } else {
                    ok = false;
                };
                ()
            } else if node_is_unit_or_false_loop(child) {
                ()
            } else {
                ok = false;
            },
            None => if true {
                ok = false;
                ()
            } else { () },
        };
        index = index + 1;
    };
    backend_local_check(ok && saw_tail, out)
}

fn block_node_can_emit_return(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], block_node: IrExprNode, ret: String, locals: BackendLocals) -> Bool {
    block_node_local_check(program, function_value, nodes, block_node, ret, locals).ok
}

fn env_arg_or_empty_expr_can_emit(program: IrProgram, value: IrExpr, function_value: IrFunctionDef) -> Bool {
    let is_match = match value.kind {
        IrMatchExpr => true,
        _ => false,
    };
    if !is_match || llvm_type_for_id(program, function_value.return_type) != "%aic.String" {
        false
    } else if !match_has_arm(value, "Some(value)", "value") || !match_has_arm(value, "None", "\"\"") {
        false
    } else {
        match direct_expr_child_at(value.nodes, 0) {
            Some(call_node) => if is_call_expr_kind(call_node.kind) && call_node.name == "arg_at" && call_node.direct_child_count == 1 {
                match expr_node_child_at(value.nodes, call_node, 0) {
                    Some(index_node) => simple_node_can_emit(index_node, function_value) && simple_node_llvm_type(program, index_node, function_value) == "i64",
                    None => false,
                }
            } else {
                false
            },
            None => false,
        }
    }
}

fn statement_expr_can_emit_as_noop(value: IrExpr) -> Bool {
    match value.kind {
        IrUnitExpr => true,
        IrWhileExpr => string.starts_with(value.text, "while false"),
        IrLoopExpr => false,
        IrForExpr => false,
        IrBreakExpr => false,
        IrContinueExpr => false,
        _ => false,
    }
}

fn let_noop_child_can_ignore(node: IrExprNode) -> Bool {
    match node.kind {
        IrIntExpr => true,
        IrBoolExpr => true,
        IrStringExpr => true,
        IrUnitExpr => true,
        IrNameExpr => true,
        _ => false,
    }
}

fn tuple_let_expr_can_emit_as_noop(value: IrExpr) -> Bool {
    let mut index = 0;
    let mut ok = true;
    while ok && index < direct_expr_child_count(value.nodes) {
        match direct_expr_child_at(value.nodes, index) {
            Some(child) => if let_noop_child_can_ignore(child) {
                ()
            } else {
                ok = false;
            },
            None => if true {
                ok = false;
                ()
            } else { () },
        };
        index = index + 1;
    };
    ok
}

fn let_expr_can_emit_as_noop(value: IrExpr) -> Bool {
    match value.kind {
        IrClosureExpr => true,
        IrTupleExpr => tuple_let_expr_can_emit_as_noop(value),
        _ => false,
    }
}

fn statement_can_emit_as_noop(statement: IrStatement) -> Bool {
    match statement.kind {
        IrLetStatement => if statement.mutable {
            false
        } else {
            match statement.expr {
                Some(expr) => let_expr_can_emit_as_noop(expr),
                None => true,
            }
        },
        IrExprStatement => match statement.expr {
            Some(expr) => statement_expr_can_emit_as_noop(expr),
            None => true,
        },
        IrAssertStatement => false,
        IrAssignStatement => false,
        IrReturnStatement => false,
    }
}

fn statement_is_return(value: IrStatement) -> Bool {
    match value.kind {
        IrReturnStatement => true,
        _ => false,
    }
}

fn block_return_statement_is_terminal(block: IrBlock, index: Int) -> Bool {
    match block.tail_expr {
        Some(_) => false,
        None => index + 1 == vec.vec_len(block.statements),
    }
}

fn return_statement_can_emit_with_locals(program: IrProgram, function_value: IrFunctionDef, statement: IrStatement, locals: BackendLocals) -> Bool {
    match statement.expr {
        Some(expr) => return_expr_can_emit_with_locals(program, expr, function_value, locals),
        None => llvm_type_for_id(program, function_value.return_type) == "void",
    }
}

fn block_has_terminal_return(block: IrBlock) -> Bool {
    let count = vec.vec_len(block.statements);
    if count == 0 {
        false
    } else {
        match block.tail_expr {
            Some(_) => false,
            None => match vec.get(block.statements, count - 1) {
                Some(statement) => statement_is_return(statement),
                None => false,
            },
        }
    }
}

fn block_has_explicit_return(block: IrBlock) -> Bool {
    let mut index = 0;
    let mut found = false;
    while !found && index < vec.vec_len(block.statements) {
        match vec.get(block.statements, index) {
            Some(statement) => if statement_is_return(statement) {
                found = true;
            } else {
                ()
            },
            None => (),
        };
        index = index + 1;
    };
    found
}

fn expr_statement_can_emit_with_locals(program: IrProgram, function_value: IrFunctionDef, expr: IrExpr, locals: BackendLocals) -> Bool {
    match expr.kind {
        IrCallExpr => if call_expr_return_type_matches(program, expr, "void") {
            call_expr_can_emit_with_locals(program, expr, function_value, locals)
        } else if fs_bool_expr_can_emit(program, function_value, expr, locals) {
            true
        } else {
            false
        },
        IrIfExpr => if_expr_statement_can_emit_with_locals(program, function_value, expr, locals),
        IrWhileExpr => while_expr_can_emit_with_locals(program, function_value, expr, locals),
        IrLoopExpr => loop_expr_can_emit_unit_with_locals(program, function_value, expr, locals),
        IrForExpr => for_expr_can_emit_with_locals(program, function_value, expr, locals),
        IrMatchExpr => option_vec_get_match_expr_can_emit_statement(program, expr, function_value, locals)
            || option_match_expr_can_emit_statement(program, expr, function_value, locals)
            || enum_match_expr_can_emit_statement(program, expr, function_value, locals),
        _ => statement_expr_can_emit_as_noop(expr),
    }
}

fn expr_statement_can_emit(program: IrProgram, function_value: IrFunctionDef, expr: IrExpr) -> Bool {
    expr_statement_can_emit_with_locals(program, function_value, expr, backend_empty_locals())
}

fn let_statement_value_can_emit(program: IrProgram, function_value: IrFunctionDef, statement: IrStatement, locals: BackendLocals) -> Bool {
    match statement.expr {
        Some(expr) => if expr_is_vec_new_vec_call(expr) {
            vec_new_vec_statement_can_emit(program, statement, expr)
        } else if expected_enum_constructor_expr_can_emit(program, function_value, expr, locals, statement_declared_type_name(program, statement)) {
            true
        } else if expr_is_if_expr(expr) && statement_declared_type_name(program, statement) != "" {
            if_expr_value_can_emit_with_expected_type(program, expr, function_value, locals, llvm_type_for_repr_in_program(program, statement_declared_type_name(program, statement)), statement_declared_type_name(program, statement))
        } else if expr_is_match_expr(expr) && statement_declared_type_name(program, statement) != "" && direct_option_match_expr_can_emit_expected_path(expr) {
            option_match_expr_can_emit_value_expected(program, expr, function_value, locals, llvm_type_for_repr_in_program(program, statement_declared_type_name(program, statement)), statement_declared_type_name(program, statement))
        } else if expr_is_match_expr(expr) && statement_declared_type_name(program, statement) != "" {
            value_expr_can_emit(program, expr, function_value, locals) && value_expr_llvm_type(program, expr, function_value, locals) == llvm_type_for_repr_in_program(program, statement_declared_type_name(program, statement))
        } else {
            value_expr_can_emit(program, expr, function_value, locals)
        },
        None => true,
    }
}

fn local_for_expr_with_mutability(program: IrProgram, function_value: IrFunctionDef, expr: IrExpr, locals: BackendLocals, name: String, mutable: Bool) -> BackendLocal {
    let type_name = match expr.kind {
        IrNameExpr => type_name_for_name(program, function_value, locals, expr.text),
        IrCallExpr => if expr.name == "vec.push" {
            vec_push_expr_type_name(program, expr, function_value, locals)
        } else if expr.name == "vec.new_vec" {
            vec_new_vec_expr_type_name(program, expr)
        } else if is_string_len_intrinsic_name(expr.name) {
            "Int"
        } else if is_string_join_intrinsic_name(expr.name) {
            "String"
        } else if is_string_split_intrinsic_name(expr.name) {
            "Vec[String]"
        } else if is_string_trim_intrinsic_name(expr.name) {
            "String"
        } else if is_string_char_at_intrinsic_name(expr.name) {
            "Option[String]"
        } else if is_string_int_to_string_intrinsic_name(expr.name) {
            "String"
        } else if expr.name == "string.replace" {
            "String"
        } else if is_vec_len_intrinsic_name(expr.name) {
            "Int"
        } else if is_vec_get_intrinsic_name(expr.name) {
            vec_get_expr_type_name(program, expr, function_value, locals)
        } else if is_string_slice_intrinsic_name(expr.name) {
            "String"
        } else if enum_variant_constructor_type_name(program, expr.name) != "" {
            enum_variant_constructor_type_name(program, expr.name)
        } else {
            call_target_return_type_name(program, expr.name)
        },
        IrStringExpr => "String",
        IrIntExpr => "Int",
        IrBoolExpr => "Bool",
        IrBinaryExpr => if binary_expr_can_emit_with_locals(program, expr, function_value, locals) {
            if binary_expr_llvm_type(program, expr, function_value, locals) == "i1" { "Bool" } else { "Int" }
        } else { "" },
        IrIfExpr => if_expr_value_type_name(program, expr, function_value, locals),
        IrLoopExpr => loop_expr_value_type_name(program, expr, function_value, locals),
        IrMatchExpr => match_expr_value_type_name(program, expr, function_value, locals),
        IrFieldAccessExpr => field_access_expr_type_name(program, function_value, expr, locals),
        IrStructLiteralExpr => expr.name,
        _ => "",
    };
    let llvm_type = value_expr_llvm_type(program, expr, function_value, locals);
    let value_name = expr_value_name(program, function_value, expr, locals);
    if mutable {
        backend_mutable_local(name, type_name, llvm_type, value_name, mutable_storage_name(name, expr.node))
    } else {
        backend_local(name, type_name, llvm_type, value_name)
    }
}

fn local_for_expr(program: IrProgram, function_value: IrFunctionDef, expr: IrExpr, locals: BackendLocals, name: String) -> BackendLocal {
    local_for_expr_with_mutability(program, function_value, expr, locals, name, false)
}

fn local_for_statement_expr_with_mutability(program: IrProgram, function_value: IrFunctionDef, statement: IrStatement, expr: IrExpr, locals: BackendLocals, name: String, mutable: Bool) -> BackendLocal {
    if expr_is_vec_new_vec_call(expr) && vec_new_vec_statement_can_emit(program, statement, expr) {
        let type_name = vec_new_vec_statement_type_name(program, statement);
        let llvm_type = vec_new_vec_statement_llvm_type(program, statement);
        let value_name = expr_value_name(program, function_value, expr, locals);
        if mutable {
            backend_mutable_local(name, type_name, llvm_type, value_name, mutable_storage_name(name, expr.node))
        } else {
            backend_local(name, type_name, llvm_type, value_name)
        }
    } else if expected_enum_constructor_expr_can_emit(program, function_value, expr, locals, statement_declared_type_name(program, statement)) {
        let type_name = statement_declared_type_name(program, statement);
        let llvm_type = llvm_type_for_repr_in_program(program, type_name);
        let value_name = expected_enum_constructor_expr_value_name(expr);
        if mutable {
            backend_mutable_local(name, type_name, llvm_type, value_name, mutable_storage_name(name, expr.node))
        } else {
            backend_local(name, type_name, llvm_type, value_name)
        }
    } else if expr_is_if_expr(expr) && statement_declared_type_name(program, statement) != "" && if_expr_value_can_emit_with_expected_type(program, expr, function_value, locals, llvm_type_for_repr_in_program(program, statement_declared_type_name(program, statement)), statement_declared_type_name(program, statement)) {
        let type_name = statement_declared_type_name(program, statement);
        let llvm_type = llvm_type_for_repr_in_program(program, type_name);
        let value_name = expr_value_name(program, function_value, expr, locals);
        if mutable {
            backend_mutable_local(name, type_name, llvm_type, value_name, mutable_storage_name(name, expr.node))
        } else {
            backend_local(name, type_name, llvm_type, value_name)
        }
    } else if expr_is_match_expr(expr) && statement_declared_type_name(program, statement) != "" && direct_option_match_expr_can_emit_expected_path(expr) && option_match_expr_can_emit_value_expected(program, expr, function_value, locals, llvm_type_for_repr_in_program(program, statement_declared_type_name(program, statement)), statement_declared_type_name(program, statement)) {
        let type_name = statement_declared_type_name(program, statement);
        let llvm_type = llvm_type_for_repr_in_program(program, type_name);
        let value_name = expr_value_name(program, function_value, expr, locals);
        if mutable {
            backend_mutable_local(name, type_name, llvm_type, value_name, mutable_storage_name(name, expr.node))
        } else {
            backend_local(name, type_name, llvm_type, value_name)
        }
    } else {
        local_for_expr_with_mutability(program, function_value, expr, locals, name, mutable)
    }
}

fn let_statement_expr_llvm_type(program: IrProgram, function_value: IrFunctionDef, statement: IrStatement, expr: IrExpr, locals: BackendLocals) -> String {
    if expr_is_vec_new_vec_call(expr) && vec_new_vec_statement_can_emit(program, statement, expr) {
        vec_new_vec_statement_llvm_type(program, statement)
    } else if expected_enum_constructor_expr_can_emit(program, function_value, expr, locals, statement_declared_type_name(program, statement)) {
        llvm_type_for_repr_in_program(program, statement_declared_type_name(program, statement))
    } else if expr_is_if_expr(expr) && statement_declared_type_name(program, statement) != "" && if_expr_value_can_emit_with_expected_type(program, expr, function_value, locals, llvm_type_for_repr_in_program(program, statement_declared_type_name(program, statement)), statement_declared_type_name(program, statement)) {
        llvm_type_for_repr_in_program(program, statement_declared_type_name(program, statement))
    } else if expr_is_match_expr(expr) && statement_declared_type_name(program, statement) != "" && direct_option_match_expr_can_emit_expected_path(expr) && option_match_expr_can_emit_value_expected(program, expr, function_value, locals, llvm_type_for_repr_in_program(program, statement_declared_type_name(program, statement)), statement_declared_type_name(program, statement)) {
        llvm_type_for_repr_in_program(program, statement_declared_type_name(program, statement))
    } else {
        value_expr_llvm_type(program, expr, function_value, locals)
    }
}

fn emit_let_statement_expr_value(program: IrProgram, function_value: IrFunctionDef, statement: IrStatement, expr: IrExpr, locals: BackendLocals) -> String {
    if expr_is_vec_new_vec_call(expr) && vec_new_vec_statement_can_emit(program, statement, expr) {
        emit_empty_vec_value(llvm_expr_prefix(expr.node), vec_new_vec_statement_llvm_type(program, statement))
    } else if expected_enum_constructor_expr_can_emit(program, function_value, expr, locals, statement_declared_type_name(program, statement)) {
        emit_expected_enum_constructor_expr_value(program, function_value, expr, locals, llvm_type_for_repr_in_program(program, statement_declared_type_name(program, statement)), statement_declared_type_name(program, statement))
    } else if expr_is_if_expr(expr) && statement_declared_type_name(program, statement) != "" && if_expr_value_can_emit_with_expected_type(program, expr, function_value, locals, llvm_type_for_repr_in_program(program, statement_declared_type_name(program, statement)), statement_declared_type_name(program, statement)) {
        emit_if_expr_value_with_expected_type(program, function_value, expr, locals, llvm_type_for_repr_in_program(program, statement_declared_type_name(program, statement)), statement_declared_type_name(program, statement))
    } else if expr_is_match_expr(expr) && statement_declared_type_name(program, statement) != "" && direct_option_match_expr_can_emit_expected_path(expr) {
        emit_option_match_expr_value_expected(program, function_value, expr, locals, llvm_type_for_repr_in_program(program, statement_declared_type_name(program, statement)), statement_declared_type_name(program, statement))
    } else {
        emit_expr_value(program, function_value, expr, locals)
    }
}

fn assign_node_can_emit(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], node: IrExprNode, locals: BackendLocals, target: String) -> Bool {
    let storage_name = storage_name_for_name(locals, target);
    let target_ty = llvm_type_for_name(program, function_value, locals, target);
    let value_ty = value_node_llvm_type(program, function_value, nodes, node, locals);
    let target_type_name = type_name_for_name(program, function_value, locals, target);
    storage_name != "" && target_ty != "" && if expected_enum_constructor_node_can_emit(program, function_value, nodes, node, locals, target_type_name) {
        llvm_type_for_repr_in_program(program, target_type_name) == target_ty
    } else if node_is_if_expr(node) {
        if_node_value_can_emit_with_expected_type(program, function_value, nodes, node, locals, target_ty, target_type_name)
    } else if node_is_match_expr(node) && direct_option_match_node_can_emit_expected_path(nodes, node) {
        option_match_node_can_emit_value_expected(program, function_value, nodes, node, locals, target_ty, target_type_name)
    } else {
        value_ty == target_ty && value_node_can_emit(program, function_value, nodes, node, locals)
    }
}

fn assign_expr_can_emit(program: IrProgram, function_value: IrFunctionDef, expr: IrExpr, locals: BackendLocals, target: String) -> Bool {
    let storage_name = storage_name_for_name(locals, target);
    let target_ty = llvm_type_for_name(program, function_value, locals, target);
    let value_ty = value_expr_llvm_type(program, expr, function_value, locals);
    let target_type_name = type_name_for_name(program, function_value, locals, target);
    storage_name != "" && target_ty != "" && if expected_enum_constructor_expr_can_emit(program, function_value, expr, locals, target_type_name) {
        llvm_type_for_repr_in_program(program, target_type_name) == target_ty
    } else if expr_is_if_expr(expr) {
        if_expr_value_can_emit_with_expected_type(program, expr, function_value, locals, target_ty, target_type_name)
    } else if expr_is_match_expr(expr) && direct_option_match_expr_can_emit_expected_path(expr) {
        option_match_expr_can_emit_value_expected(program, expr, function_value, locals, target_ty, target_type_name)
    } else {
        value_ty == target_ty && value_expr_can_emit(program, expr, function_value, locals)
    }
}

fn statement_check_with_locals(program: IrProgram, function_value: IrFunctionDef, statement: IrStatement, locals: BackendLocals) -> BackendLocalCheck {
    if statement_can_emit_as_noop(statement) {
        backend_local_check(true, locals)
    } else {
        match statement.kind {
            IrLetStatement => if statement.name != "" && let_statement_value_can_emit(program, function_value, statement, locals) {
                match statement.expr {
                    Some(expr) => backend_local_check(true, backend_locals_push(locals, local_for_statement_expr_with_mutability(program, function_value, statement, expr, locals, statement.name, statement.mutable))),
                    None => backend_local_check(true, locals),
                }
            } else {
                backend_local_check(false, locals)
            },
            IrAssignStatement => match statement.expr {
                Some(expr) => backend_local_check(assign_expr_can_emit(program, function_value, expr, locals, statement.target), locals),
                None => backend_local_check(false, locals),
            },
            IrExprStatement => match statement.expr {
                Some(expr) => backend_local_check(expr_statement_can_emit_with_locals(program, function_value, expr, locals), locals),
                None => backend_local_check(true, locals),
            },
            IrReturnStatement => backend_local_check(return_statement_can_emit_with_locals(program, function_value, statement, locals), locals),
            _ => backend_local_check(false, locals),
        }
    }
}

fn statement_can_emit_with_locals(program: IrProgram, function_value: IrFunctionDef, statement: IrStatement, locals: BackendLocals) -> Bool {
    statement_check_with_locals(program, function_value, statement, locals).ok
}

fn statement_can_emit(program: IrProgram, function_value: IrFunctionDef, statement: IrStatement) -> Bool {
    if statement_can_emit_as_noop(statement) {
        true
    } else {
        match statement.kind {
            IrExprStatement => match statement.expr {
                Some(expr) => expr_statement_can_emit(program, function_value, expr),
                None => true,
            },
            IrLetStatement => let_statement_value_can_emit(program, function_value, statement, backend_empty_locals()),
            IrAssignStatement => match statement.expr {
                Some(expr) => assign_expr_can_emit(program, function_value, expr, backend_empty_locals(), statement.target),
                None => false,
            },
            _ => false,
        }
    }
}

fn return_expr_can_emit_with_locals(program: IrProgram, value: IrExpr, function_value: IrFunctionDef, locals: BackendLocals) -> Bool {
    let ret = llvm_type_for_id(program, function_value.return_type);
    match value.kind {
        IrIntExpr => is_decimal_integer_text(literal_text_or_name(value.text, value.name)),
        IrBoolExpr => literal_text_or_name(value.text, value.name) == "true" || literal_text_or_name(value.text, value.name) == "false",
        IrStringExpr => ret == "%aic.String",
        IrUnitExpr => true,
        IrNameExpr => return_name_can_emit_with_locals(program, function_value, locals, value.text, ret),
        IrFieldAccessExpr => field_access_expr_can_emit(program, function_value, value, locals, ret),
        IrBinaryExpr => binary_expr_can_emit_with_locals(program, value, function_value, locals),
        IrUnaryExpr => if value.op == "!" {
            ret == "i1" && value_expr_can_emit(program, value, function_value, locals)
        } else if value.op == "-" {
            ret == "i64" && value_expr_can_emit(program, value, function_value, locals)
        } else {
            false
        },
        IrCallExpr => if expected_enum_constructor_expr_can_emit(program, function_value, value, locals, function_result_type_name(program, function_value)) {
            llvm_type_for_repr_in_program(program, function_result_type_name(program, function_value)) == ret
        } else if value.name == "Ok" || value.name == "Err" {
            result_constructor_expr_can_emit(program, value, function_value, ret, locals)
        } else if is_string_bool_intrinsic_name(value.name) {
            ret == "i1" && string_bool_expr_can_emit(program, value, function_value, locals)
        } else if is_io_print_intrinsic_name(value.name) {
            ret == "void" && call_expr_can_emit_with_locals(program, value, function_value, locals)
        } else if is_fs_string_result_intrinsic_name(value.name) {
            ret == llvm_type_for_repr_in_program(program, "Result[String, FsError]") && call_expr_can_emit_with_locals(program, value, function_value, locals)
        } else if is_fs_bool_result_intrinsic_name(value.name) {
            ret == llvm_type_for_repr_in_program(program, "Result[Bool, FsError]") && call_expr_can_emit_with_locals(program, value, function_value, locals)
        } else if is_proc_result_intrinsic_name(value.name) {
            ret == llvm_type_for_repr_in_program(program, "Result[ProcOutput, ProcError]") && call_expr_can_emit_with_locals(program, value, function_value, locals)
        } else if is_string_len_intrinsic_name(value.name) {
            ret == "i64" && string_len_expr_can_emit(program, value, function_value, locals)
        } else if value.name == "string.replace" {
            ret == "%aic.String" && string_replace_expr_can_emit(program, value, function_value, locals)
        } else if is_string_join_intrinsic_name(value.name) {
            ret == "%aic.String" && string_join_expr_can_emit(program, value, function_value, locals)
        } else if is_string_split_intrinsic_name(value.name) {
            ret == llvm_type_for_repr_in_program(program, "Vec[String]") && string_split_expr_can_emit(program, value, function_value, locals)
        } else if is_string_trim_intrinsic_name(value.name) {
            ret == "%aic.String" && string_trim_expr_can_emit(program, value, function_value, locals)
        } else if is_string_char_at_intrinsic_name(value.name) {
            ret == llvm_type_for_repr_in_program(program, "Option[String]") && string_char_at_expr_can_emit(program, value, function_value, locals)
        } else if is_string_int_to_string_intrinsic_name(value.name) {
            ret == "%aic.String" && string_int_to_string_expr_can_emit(program, value, function_value, locals)
        } else if is_vec_len_intrinsic_name(value.name) {
            ret == "i64" && vec_len_expr_can_emit(program, value, function_value, locals)
        } else if is_string_slice_intrinsic_name(value.name) {
            ret == "%aic.String" && string_slice_expr_can_emit(program, value, function_value, locals)
        } else if value.name == "vec.new_vec" {
            vec_new_vec_expr_llvm_type(program, value) == ret && vec_new_vec_expr_can_emit(program, value)
        } else if value.name == "vec.push" {
            vec_push_expr_llvm_type(program, value, function_value, locals) == ret && vec_push_expr_can_emit(program, value, function_value, locals)
        } else if is_vec_get_intrinsic_name(value.name) {
            vec_get_expr_llvm_type(program, value, function_value, locals) == ret && vec_get_expr_can_emit(program, value, function_value, locals)
        } else {
            let call_ret = call_target_return_type(program, value.name);
            if call_ret != "" {
                call_ret == ret && call_expr_can_emit_with_locals(program, value, function_value, locals)
            } else if enum_variant_constructor_llvm_type(program, value.name) == ret {
                enum_variant_constructor_expr_can_emit(program, value, function_value, locals)
            } else {
                false
            }
        },
        IrIfExpr => if_expr_can_emit_with_locals(program, value, function_value, locals),
        IrLoopExpr => loop_expr_can_emit_value_with_type(program, value, function_value, locals, ret, function_result_type_name(program, function_value)),
        IrMatchExpr => if direct_result_match_expr_can_emit_result_return(program, value, function_value, ret, locals) {
            true
        } else if result_match_expr_can_emit_return(program, value, function_value, ret, locals) {
            true
        } else if option_vec_get_match_expr_can_emit_return(program, value, function_value, ret, locals) {
            true
        } else if option_match_expr_can_emit_return(program, value, function_value, ret, locals) {
            true
        } else if result_bool_match_expr_can_emit_return(program, value, function_value, ret, locals) {
            true
        } else if match_expr_can_emit(value) {
            true
        } else if env_arg_or_empty_expr_can_emit(program, value, function_value) {
            true
        } else if fs_string_match_expr_can_emit_int_return(program, value, function_value, ret, locals) {
            true
        } else if proc_run_match_expr_can_emit_int_return(program, value, function_value, ret, locals) {
            true
        } else if direct_result_match_expr_can_emit_return(program, value, function_value, ret, locals) {
            true
        } else if ret == "%aic.String" && result_string_match_expr_can_emit(program, value, function_value, locals) {
            true
        } else if enum_bool_match_expr_can_emit_return(program, value, function_value, ret, locals) {
            true
        } else {
            ret == "i1" && enum_bool_match_expr_can_emit(program, value, function_value, locals)
        },
        IrStructLiteralExpr => struct_literal_expr_can_emit(program, value, function_value, locals, ret),
        _ => false,
    }
}

fn return_expr_can_emit(program: IrProgram, value: IrExpr, function_value: IrFunctionDef) -> Bool {
    return_expr_can_emit_with_locals(program, value, function_value, backend_param_locals(program, function_value))
}

fn block_can_emit(program: IrProgram, block: IrBlock, function_value: IrFunctionDef) -> Bool {
    let mut index = 0;
    let mut ok = true;
    let mut returned = false;
    let mut locals: BackendLocals = backend_param_locals(program, function_value);
    while ok && !returned && index < vec.vec_len(block.statements) {
        match vec.get(block.statements, index) {
            Some(statement) => if true {
                let checked = statement_check_with_locals(program, function_value, statement, locals);
                ok = checked.ok;
                locals = checked.locals;
                if ok && statement_is_return(statement) {
                    returned = true;
                } else {
                    ()
                };
            } else {
                ()
            },
            None => (),
        };
        index = index + 1;
    };
    if ok {
        if returned {
            true
        } else {
            match block.tail_expr {
                Some(expr) => return_expr_can_emit_with_locals(program, expr, function_value, locals),
                None => llvm_type_for_id(program, function_value.return_type) == "void",
            }
        }
    } else {
        false
    }
}

fn append_expr_diagnostics(out: Vec[Diagnostic], expr: IrExpr, max_errors: Int) -> Vec[Diagnostic] {
    let mut diagnostics = out;
    if vec.vec_len(diagnostics) < max_errors && !is_supported_backend_expr_kind(expr.kind) {
        diagnostics = push_backend_error(diagnostics, "E5101", expr.span, unsupported_backend_expr_message(expr.kind), unsupported_backend_expr_help(expr.kind));
    } else {
        ()
    };
    let mut index = 0;
    while index < vec.vec_len(expr.nodes) {
        match vec.get(expr.nodes, index) {
            Some(node) => if vec.vec_len(diagnostics) < max_errors && !is_supported_backend_expr_kind(node.kind) {
                diagnostics = push_backend_error(diagnostics, "E5101", node.span, unsupported_backend_expr_message(node.kind), unsupported_backend_expr_help(node.kind));
            } else {
                ()
            },
            None => (),
        };
        index = index + 1;
    };
    diagnostics
}

fn unsupported_backend_expr_message(kind: IrExprKind) -> String {
    match kind {
        IrUnsafeBlockExpr => "self-host backend intentionally does not lower unsafe blocks in backend-covered executable code",
        IrTemplateExpr => "self-host backend intentionally does not lower template literals in backend-covered executable code",
        _ => "self-host backend has no lowering hook for this expression kind",
    }
}

fn unsupported_backend_expr_help(kind: IrExprKind) -> String {
    match kind {
        IrUnsafeBlockExpr => "keep unsafe blocks out of the self-host backend corpus or lower them before backend emission",
        IrTemplateExpr => "desugar template literals to string operations before self-host backend emission",
        _ => "add a backend lowering case before emitting LLVM for this IR node",
    }
}

fn unsupported_backend_statement_message(statement: IrStatement) -> String {
    match statement.kind {
        IrAssertStatement => "self-host backend intentionally does not lower assert statements in backend-covered executable code",
        IrExprStatement => match statement.expr {
            Some(expr) => match expr.kind {
                IrForExpr => "self-host backend only lowers range-for and Vec[Int] iterator-for statements",
                _ => "self-host backend cannot emit this executable statement yet",
            },
            None => "self-host backend cannot emit this executable statement yet",
        },
        _ => "self-host backend cannot emit this executable statement yet",
    }
}

fn unsupported_backend_statement_help(statement: IrStatement) -> String {
    match statement.kind {
        IrAssertStatement => "evaluate assertions before backend emission or keep them out of backend-covered executable functions",
        IrExprStatement => match statement.expr {
            Some(expr) => match expr.kind {
                IrForExpr => "use `for name in start..end` or `for name in values` where values is backend-covered Vec[Int]",
                _ => "add statement lowering for this IR shape before emitting a backend artifact",
            },
            None => "add statement lowering for this IR shape before emitting a backend artifact",
        },
        _ => "add statement lowering for this IR shape before emitting a backend artifact",
    }
}

fn append_optional_expr_diagnostics(out: Vec[Diagnostic], expr: Option[IrExpr], max_errors: Int) -> Vec[Diagnostic] {
    match expr {
        Some(value) => append_expr_diagnostics(out, value, max_errors),
        None => out,
    }
}

fn append_block_diagnostics(out: Vec[Diagnostic], block: IrBlock, max_errors: Int) -> Vec[Diagnostic] {
    let mut diagnostics = out;
    let mut index = 0;
    while index < vec.vec_len(block.statements) {
        match vec.get(block.statements, index) {
            Some(statement) => if true {
                diagnostics = append_optional_expr_diagnostics(diagnostics, statement.expr, max_errors);
                ()
            } else {
                ()
            },
            None => (),
        };
        index = index + 1;
    };
    append_optional_expr_diagnostics(diagnostics, block.tail_expr, max_errors)
}

fn append_backend_block_emission_diagnostics(out: Vec[Diagnostic], program: IrProgram, function_value: IrFunctionDef, max_errors: Int) -> Vec[Diagnostic] {
    let mut diagnostics = out;
    let mut index = 0;
    let mut locals: BackendLocals = backend_param_locals(program, function_value);
    let mut statements_ok = true;
    let mut return_seen = false;
    while !return_seen && index < vec.vec_len(function_value.body.statements) {
        match vec.get(function_value.body.statements, index) {
            Some(statement) => if statements_ok && vec.vec_len(diagnostics) < max_errors {
                let checked = statement_check_with_locals(program, function_value, statement, locals);
                if checked.ok {
                    if statement_is_return(statement) {
                        return_seen = true;
                        locals = checked.locals;
                    } else {
                        locals = checked.locals;
                    };
                } else {
                    statements_ok = false;
                    diagnostics = push_backend_error(diagnostics, "E5101", statement.span, unsupported_backend_statement_message(statement), unsupported_backend_statement_help(statement));
                };
                ()
            } else {
                ()
            },
            None => (),
        };
        index = index + 1;
    };
    match function_value.body.tail_expr {
        Some(expr) => if !return_seen && statements_ok && vec.vec_len(diagnostics) < max_errors && !return_expr_can_emit_with_locals(program, expr, function_value, locals) {
            diagnostics = push_backend_error(diagnostics, "E5101", expr.span, "self-host backend cannot emit this function return expression yet", "add expression lowering for this IR shape before emitting a backend artifact");
        } else {
            ()
        },
        None => if !return_seen && vec.vec_len(diagnostics) < max_errors && llvm_type_for_id(program, function_value.return_type) != "void" {
            diagnostics = push_backend_error(diagnostics, "E5101", function_value.body.span, "self-host backend requires a return expression for non-void functions", "add a tail expression or lower explicit return statements");
        } else {
            ()
        },
    };
    diagnostics
}

fn append_function_diagnostics(out: Vec[Diagnostic], program: IrProgram, function_value: IrFunctionDef, max_errors: Int) -> Vec[Diagnostic] {
    let mut diagnostics = out;
    if function_value.is_extern && function_value.extern_abi != "" && function_value.extern_abi != "C" {
        diagnostics = push_backend_error(diagnostics, "E5102", function_value.span, "self-host backend only supports extern C ABI metadata", "use extern \"C\" or keep this declaration out of the backend-covered corpus");
    } else {
        ()
    };
    let ret = llvm_type_for_id(program, function_value.return_type);
    if ret == "" {
        diagnostics = push_backend_error(diagnostics, "E5102", function_value.span, "self-host backend cannot lower this function return type to LLVM", "restrict backend-covered functions to primitive return values until aggregate return lowering is implemented");
    } else {
        ()
    };
    let mut param_index = 0;
    while param_index < vec.vec_len(function_value.params) {
        match vec.get(function_value.params, param_index) {
            Some(param) => if llvm_type_for_id(program, param.type_id) == "" {
                diagnostics = push_backend_error(diagnostics, "E5102", param.span, "self-host backend cannot lower this parameter type to LLVM", "use primitive parameters for backend-covered executable functions");
            } else {
                ()
            },
            None => (),
        };
        param_index = param_index + 1;
    };
    diagnostics = append_optional_expr_diagnostics(diagnostics, function_value.requires_expr, max_errors);
    diagnostics = append_optional_expr_diagnostics(diagnostics, function_value.ensures_expr, max_errors);
    diagnostics = append_block_diagnostics(diagnostics, function_value.body, max_errors);
    append_backend_block_emission_diagnostics(diagnostics, program, function_value, max_errors)
}

fn append_link_diagnostics(out: Vec[Diagnostic], links: Vec[BackendNativeLink]) -> Vec[Diagnostic] {
    let mut diagnostics = out;
    let mut index = 0;
    while index < vec.vec_len(links) {
        match vec.get(links, index) {
            Some(link) => if link.name == "" {
                diagnostics = push_backend_error(diagnostics, "E5103", link.span, "native link metadata requires a non-empty name", "preserve package manifest native-link names before backend emission");
            } else if link.path == "" && match link.kind { NativeObjectLink => true, NativeSearchPathLink => true, _ => false } {
                diagnostics = push_backend_error(diagnostics, "E5103", link.span, "native object/search-path link metadata requires a path", "preserve package manifest native-link paths before backend emission");
            } else {
                ()
            },
            None => (),
        };
        index = index + 1;
    };
    diagnostics
}

fn program_has_entry(program: IrProgram) -> Bool {
    match program_entry_function(program) {
        Some(_) => true,
        None => false,
    }
}

fn program_entry_function(program: IrProgram) -> Option[IrFunctionDef] {
    let mut index = 0;
    let mut found = false;
    let mut out: Option[IrFunctionDef] = None();
    while !found && index < vec.vec_len(program.items) {
        match vec.get(program.items, index) {
            Some(item) => match item {
                IrFunctionItemValue(function_value) => if function_value.runtime_visible && function_value.name == "main" {
                    out = Some(function_value);
                    found = true;
                } else {
                    ()
                },
                _ => (),
            },
            None => (),
        };
        index = index + 1;
    };
    out
}

fn entry_return_type_can_emit(program: IrProgram, function_value: IrFunctionDef) -> Bool {
    let ret = llvm_type_for_id(program, function_value.return_type);
    vec.vec_len(function_value.params) == 0 && (ret == "void" || ret == "i1" || ret == "i8" || ret == "i16" || ret == "i32" || ret == "i64")
}

pub fn validate_backend_program(program: IrProgram, options: BackendOptions, max_errors: Int) -> Vec[Diagnostic] {
    let mut diagnostics = validate_backend_ir_input(program);
    if options.artifact_name == "" {
        diagnostics = push_backend_error(diagnostics, "E5104", program.span, "backend artifact name must not be empty", "choose a deterministic artifact name before backend emission");
    } else {
        ()
    };
    if options.require_entry && !program_has_entry(program) {
        diagnostics = push_backend_error(diagnostics, "E5104", program.span, "backend executable artifact requires a runtime-visible main function", "lower a checked program with a main function or emit a library artifact");
    } else {
        ()
    };
    if options.require_entry {
        match program_entry_function(program) {
            Some(function_value) => if entry_return_type_can_emit(program, function_value) {
                ()
            } else {
                diagnostics = push_backend_error(diagnostics, "E5101", function_value.span, "backend executable entry requires a zero-argument main returning Int, Bool, or Unit", "change main to a supported executable entry signature before LLVM emission");
            },
            None => (),
        };
    } else {
        ()
    };
    match options.artifact_kind {
        LlvmIrArtifact => (),
        NativeObjectArtifact => if true {
            diagnostics = push_backend_error(diagnostics, "E5105", program.span, "self-host backend emits LLVM IR text artifacts in this package", "materialize object files through the driver after LLVM IR emission");
            ()
        } else { () },
        StaticLibraryArtifact => if true {
            diagnostics = push_backend_error(diagnostics, "E5105", program.span, "self-host backend emits LLVM IR text artifacts in this package", "archive object files through the driver after LLVM IR emission");
            ()
        } else { () },
        ExecutableArtifact => if true {
            diagnostics = push_backend_error(diagnostics, "E5105", program.span, "self-host backend emits LLVM IR text artifacts in this package", "link executables through the driver after LLVM IR emission");
            ()
        } else { () },
    };
    diagnostics = append_link_diagnostics(diagnostics, options.native_links);
    let mut type_index = 0;
    while type_index < vec.vec_len(program.types) {
        match vec.get(program.types, type_index) {
            Some(type_value) => match type_value.kind {
                IrUnknownType => if true {
                    diagnostics = push_backend_error(diagnostics, "E5102", type_value.span, "self-host backend cannot lower unknown IR types", "complete type metadata before backend emission");
                    ()
                } else { () },
                _ => (),
            },
            None => (),
        };
        type_index = type_index + 1;
    };
    let mut item_index = 0;
    while item_index < vec.vec_len(program.items) {
        match vec.get(program.items, item_index) {
            Some(item) => match item {
                IrFunctionItemValue(function_value) => if function_value.runtime_visible {
                    diagnostics = append_function_diagnostics(diagnostics, program, function_value, max_errors);
                } else {
                    ()
                },
                IrTraitItemValue(_) => (),
                IrImplItemValue(_) => (),
                IrConstItemValue(const_value) => if true {
                    diagnostics = append_optional_expr_diagnostics(diagnostics, const_value.initializer, max_errors);
                    ()
                } else { () },
                IrStructItemValue(_) => (),
                IrEnumItemValue(_) => (),
                IrTypeAliasItemValue(_) => (),
            },
            None => (),
        };
        item_index = item_index + 1;
    };
    diagnostics
}

fn has_struct_item(program: IrProgram) -> Bool {
    let mut index = 0;
    let mut found = false;
    while !found && index < vec.vec_len(program.items) {
        match vec.get(program.items, index) {
            Some(item) => match item {
                IrStructItemValue(_) => if true { found = true; () } else { () },
                _ => (),
            },
            None => (),
        };
        index = index + 1;
    };
    found
}

fn has_enum_item(program: IrProgram) -> Bool {
    let mut index = 0;
    let mut found = false;
    while !found && index < vec.vec_len(program.items) {
        match vec.get(program.items, index) {
            Some(item) => match item {
                IrEnumItemValue(_) => if true { found = true; () } else { () },
                _ => (),
            },
            None => (),
        };
        index = index + 1;
    };
    found
}

fn has_trait_or_impl_item(program: IrProgram) -> Bool {
    let mut index = 0;
    let mut found = false;
    while !found && index < vec.vec_len(program.items) {
        match vec.get(program.items, index) {
            Some(item) => match item {
                IrTraitItemValue(_) => if true { found = true; () } else { () },
                IrImplItemValue(_) => if true { found = true; () } else { () },
                _ => (),
            },
            None => (),
        };
        index = index + 1;
    };
    found
}

fn has_alias_or_const_item(program: IrProgram) -> Bool {
    let mut index = 0;
    let mut found = false;
    while !found && index < vec.vec_len(program.items) {
        match vec.get(program.items, index) {
            Some(item) => match item {
                IrTypeAliasItemValue(_) => if true { found = true; () } else { () },
                IrConstItemValue(_) => if true { found = true; () } else { () },
                _ => (),
            },
            None => (),
        };
        index = index + 1;
    };
    found
}

fn has_tuple_type(program: IrProgram) -> Bool {
    let mut index = 0;
    let mut found = false;
    while !found && index < vec.vec_len(program.types) {
        match vec.get(program.types, index) {
            Some(type_value) => match type_value.kind {
                IrTupleType(_) => if true { found = true; () } else { () },
                _ => (),
            },
            None => (),
        };
        index = index + 1;
    };
    found
}

fn has_function_instantiation(program: IrProgram) -> Bool {
    vec.vec_len(program.generic_instantiations) > 0
}

fn has_generic_item(program: IrProgram) -> Bool {
    let mut index = 0;
    let mut found = false;
    while !found && index < vec.vec_len(program.items) {
        match vec.get(program.items, index) {
            Some(item) => match item {
                IrFunctionItemValue(function_value) => if vec.vec_len(function_value.generics) > 0 { found = true; } else { () },
                IrStructItemValue(struct_value) => if vec.vec_len(struct_value.generics) > 0 { found = true; } else { () },
                IrEnumItemValue(enum_value) => if vec.vec_len(enum_value.generics) > 0 { found = true; } else { () },
                IrTraitItemValue(trait_value) => if vec.vec_len(trait_value.generics) > 0 { found = true; } else { () },
                IrImplItemValue(impl_value) => if vec.vec_len(impl_value.generics) > 0 { found = true; } else { () },
                IrTypeAliasItemValue(alias_value) => if vec.vec_len(alias_value.generics) > 0 { found = true; } else { () },
                IrConstItemValue(_) => (),
            },
            None => (),
        };
        index = index + 1;
    };
    found
}

fn has_async_function(program: IrProgram) -> Bool {
    let mut index = 0;
    let mut found = false;
    while !found && index < vec.vec_len(program.items) {
        match vec.get(program.items, index) {
            Some(item) => match item {
                IrFunctionItemValue(function_value) => if function_value.is_async { found = true; } else { () },
                _ => (),
            },
            None => (),
        };
        index = index + 1;
    };
    found
}

fn expr_kind_matches_name(value: IrExprKind, kind_name: String) -> Bool {
    match value {
        IrIntExpr => kind_name == "int",
        IrFloatExpr => kind_name == "float",
        IrBoolExpr => kind_name == "bool",
        IrStringExpr => kind_name == "string",
        IrCharExpr => kind_name == "char",
        IrTemplateExpr => kind_name == "template",
        IrUnitExpr => kind_name == "unit",
        IrNameExpr => kind_name == "name",
        IrCallExpr => kind_name == "call",
        IrClosureExpr => kind_name == "closure",
        IrIfExpr => kind_name == "if",
        IrWhileExpr => kind_name == "while",
        IrForExpr => kind_name == "for",
        IrLoopExpr => kind_name == "loop",
        IrBreakExpr => kind_name == "break",
        IrContinueExpr => kind_name == "continue",
        IrMatchExpr => kind_name == "match",
        IrBinaryExpr => kind_name == "binary",
        IrUnaryExpr => kind_name == "unary",
        IrBorrowExpr => kind_name == "borrow",
        IrAwaitExpr => kind_name == "await",
        IrTryExpr => kind_name == "try",
        IrStructLiteralExpr => kind_name == "struct_literal",
        IrTupleExpr => kind_name == "tuple",
        IrFieldAccessExpr => kind_name == "field_access",
        IrBlockExpr => kind_name == "block",
        IrUnsafeBlockExpr => kind_name == "unsafe_block",
    }
}

fn expr_has_kind(expr: IrExpr, kind_name: String) -> Bool {
    let mut found = expr_kind_matches_name(expr.kind, kind_name);
    let mut index = 0;
    while !found && index < vec.vec_len(expr.nodes) {
        match vec.get(expr.nodes, index) {
            Some(node) => if expr_kind_matches_name(node.kind, kind_name) {
                found = true;
            } else {
                ()
            },
            None => (),
        };
        index = index + 1;
    };
    found
}

fn optional_expr_has_kind(expr: Option[IrExpr], kind_name: String) -> Bool {
    match expr {
        Some(value) => expr_has_kind(value, kind_name),
        None => false,
    }
}

fn block_has_expr_kind(block: IrBlock, kind_name: String) -> Bool {
    let mut found = false;
    let mut index = 0;
    while !found && index < vec.vec_len(block.statements) {
        match vec.get(block.statements, index) {
            Some(statement) => if optional_expr_has_kind(statement.expr, kind_name) {
                found = true;
            } else {
                ()
            },
            None => (),
        };
        index = index + 1;
    };
    if found {
        true
    } else {
        optional_expr_has_kind(block.tail_expr, kind_name)
    }
}

fn function_has_expr_kind(function_value: IrFunctionDef, kind_name: String) -> Bool {
    optional_expr_has_kind(function_value.requires_expr, kind_name)
        || optional_expr_has_kind(function_value.ensures_expr, kind_name)
        || block_has_expr_kind(function_value.body, kind_name)
}

fn field_has_expr_kind(field: IrField, kind_name: String) -> Bool {
    optional_expr_has_kind(field.default_value, kind_name)
}

fn fields_have_expr_kind(fields: Vec[IrField], kind_name: String) -> Bool {
    let mut index = 0;
    let mut found = false;
    while !found && index < vec.vec_len(fields) {
        match vec.get(fields, index) {
            Some(field) => if field_has_expr_kind(field, kind_name) {
                found = true;
            } else {
                ()
            },
            None => (),
        };
        index = index + 1;
    };
    found
}

fn functions_have_expr_kind(functions: Vec[IrFunctionDef], kind_name: String) -> Bool {
    let mut index = 0;
    let mut found = false;
    while !found && index < vec.vec_len(functions) {
        match vec.get(functions, index) {
            Some(function_value) => if function_has_expr_kind(function_value, kind_name) {
                found = true;
            } else {
                ()
            },
            None => (),
        };
        index = index + 1;
    };
    found
}

fn has_expr_kind(program: IrProgram, kind_name: String) -> Bool {
    let mut index = 0;
    let mut found = false;
    while !found && index < vec.vec_len(program.items) {
        match vec.get(program.items, index) {
            Some(item) => match item {
                IrFunctionItemValue(function_value) => if function_has_expr_kind(function_value, kind_name) {
                    found = true;
                } else {
                    ()
                },
                IrStructItemValue(struct_value) => if fields_have_expr_kind(struct_value.fields, kind_name) || optional_expr_has_kind(struct_value.invariant_expr, kind_name) {
                    found = true;
                } else {
                    ()
                },
                IrTraitItemValue(trait_value) => if functions_have_expr_kind(trait_value.methods, kind_name) {
                    found = true;
                } else {
                    ()
                },
                IrImplItemValue(impl_value) => if functions_have_expr_kind(impl_value.methods, kind_name) {
                    found = true;
                } else {
                    ()
                },
                IrConstItemValue(const_value) => if optional_expr_has_kind(const_value.initializer, kind_name) {
                    found = true;
                } else {
                    ()
                },
                _ => (),
            },
            None => (),
        };
        index = index + 1;
    };
    found
}

fn item_has_handle_metadata(item: IrItem) -> Bool {
    match item {
        IrFunctionItemValue(function_value) => string.contains(function_value.name, "Handle"),
        IrStructItemValue(struct_value) => string.contains(struct_value.name, "Handle"),
        IrEnumItemValue(enum_value) => string.contains(enum_value.name, "Handle"),
        IrTraitItemValue(trait_value) => string.contains(trait_value.name, "Handle"),
        IrImplItemValue(impl_value) => string.contains(impl_value.head_text, "Handle"),
        IrTypeAliasItemValue(alias_value) => string.contains(alias_value.name, "Handle"),
        IrConstItemValue(const_value) => string.contains(const_value.name, "Handle"),
    }
}

fn has_resource_handle_metadata(program: IrProgram) -> Bool {
    let mut found = false;
    let mut type_index = 0;
    while !found && type_index < vec.vec_len(program.types) {
        match vec.get(program.types, type_index) {
            Some(type_value) => if string.contains(type_value.name, "Handle") {
                found = true;
            } else {
                match type_value.kind {
                    IrNamedType(name) => if string.contains(name, "Handle") { found = true; } else { () },
                    _ => (),
                }
            },
            None => (),
        };
        type_index = type_index + 1;
    };
    let mut item_index = 0;
    while !found && item_index < vec.vec_len(program.items) {
        match vec.get(program.items, item_index) {
            Some(item) => if item_has_handle_metadata(item) {
                found = true;
            } else {
                ()
            },
            None => (),
        };
        item_index = item_index + 1;
    };
    found
}

pub fn backend_program_features(program: IrProgram, options: BackendOptions) -> Vec[String] {
    let mut features: Vec[String] = vec.new_vec();
    features = vec.push(features, "primitive-lowering");
    features = vec.push(features, "function-lowering");
    if has_struct_item(program) { features = vec.push(features, "struct-lowering"); } else { () };
    if has_enum_item(program) { features = vec.push(features, "enum-lowering"); } else { () };
    if has_tuple_type(program) || has_expr_kind(program, "tuple") { features = vec.push(features, "tuple-lowering"); } else { () };
    if has_generic_item(program) { features = vec.push(features, "generic-definition-metadata"); } else { () };
    if has_function_instantiation(program) { features = vec.push(features, "generic-monomorph-metadata"); } else { () };
    if has_expr_kind(program, "closure") { features = vec.push(features, "closure-lowering"); } else { () };
    if has_async_function(program) || has_expr_kind(program, "await") { features = vec.push(features, "async-future-lowering"); } else { () };
    if has_trait_or_impl_item(program) { features = vec.push(features, "trait-dispatch-metadata"); } else { () };
    if has_resource_handle_metadata(program) { features = vec.push(features, "resource-handle-metadata"); } else { () };
    if has_alias_or_const_item(program) { features = vec.push(features, "const-global-metadata"); } else { () };
    if vec.vec_len(options.native_links) > 0 { features = vec.push(features, "native-link-metadata"); } else { () };
    features
}

fn llvm_param_list(program: IrProgram, params: Vec[IrParam]) -> String {
    let mut parts: Vec[String] = vec.new_vec();
    let mut index = 0;
    while index < vec.vec_len(params) {
        match vec.get(params, index) {
            Some(param) => if true {
                if index > 0 { parts = vec.push(parts, ", "); } else { () };
                parts = vec.push(parts, llvm_type_for_id(program, param.type_id));
                parts = vec.push(parts, " %");
                parts = vec.push(parts, backend_mangle_symbol(param.name));
                ()
            } else {
                ()
            },
            None => (),
        };
        index = index + 1;
    };
    string.join(parts, "")
}

fn binary_llvm_op(op: String) -> String {
    if op == "+" || op == "Add" {
        "add"
    } else if op == "-" || op == "Sub" {
        "sub"
    } else if op == "*" || op == "Mul" {
        "mul"
    } else {
        ""
    }
}

fn bool_llvm_op(op: String) -> String {
    if op == "||" || op == "Or" {
        "or"
    } else if op == "&&" || op == "And" {
        "and"
    } else {
        ""
    }
}

fn emit_call_arg_values(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], callee_name: String, locals: BackendLocals) -> String {
    let mut parts: Vec[String] = vec.new_vec();
    let target: Option[IrFunctionDef] = call_target_function(program, callee_name);
    let mut index = 0;
    while index < direct_expr_child_count(nodes) {
        match direct_expr_child_at(nodes, index) {
            Some(node) => if true {
                let expected = call_target_param_type_resolved(program, callee_name, target, index);
                let expected_type_name = call_target_param_type_name_resolved(program, target, index);
                if expected_vec_new_vec_node_can_emit(node, expected) {
                    parts = vec.push(parts, emit_empty_vec_value(llvm_node_prefix(node.node), expected));
                } else if expected_enum_constructor_node_can_emit(program, function_value, nodes, node, locals, expected_type_name) {
                    parts = vec.push(parts, emit_expected_enum_constructor_node_value(program, function_value, nodes, node, locals, expected, expected_type_name));
                } else if node_is_if_expr(node) {
                    parts = vec.push(parts, emit_if_node_value_with_expected_type(program, function_value, nodes, node, locals, expected, expected_type_name));
                } else if node_is_match_expr(node) && direct_option_match_node_can_emit_expected_path(nodes, node) {
                    parts = vec.push(parts, emit_option_match_node_value_expected(program, function_value, nodes, node, locals, expected, expected_type_name));
                } else {
                    parts = vec.push(parts, emit_value_node(program, function_value, nodes, node, locals));
                };
                ()
            } else {
                ()
            },
            None => (),
        };
        index = index + 1;
    };
    string.join(parts, "")
}

fn emit_node_call_arg_values(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], node: IrExprNode, locals: BackendLocals) -> String {
    let mut parts: Vec[String] = vec.new_vec();
    let target: Option[IrFunctionDef] = call_target_function(program, node.name);
    let mut index = 0;
    while index < node.direct_child_count {
        match expr_node_child_at(nodes, node, index) {
            Some(child) => if true {
                let expected = call_target_param_type_resolved(program, node.name, target, index);
                let expected_type_name = call_target_param_type_name_resolved(program, target, index);
                if expected_vec_new_vec_node_can_emit(child, expected) {
                    parts = vec.push(parts, emit_empty_vec_value(llvm_node_prefix(child.node), expected));
                } else if expected_enum_constructor_node_can_emit(program, function_value, nodes, child, locals, expected_type_name) {
                    parts = vec.push(parts, emit_expected_enum_constructor_node_value(program, function_value, nodes, child, locals, expected, expected_type_name));
                } else if node_is_if_expr(child) {
                    parts = vec.push(parts, emit_if_node_value_with_expected_type(program, function_value, nodes, child, locals, expected, expected_type_name));
                } else if node_is_match_expr(child) && direct_option_match_node_can_emit_expected_path(nodes, child) {
                    parts = vec.push(parts, emit_option_match_node_value_expected(program, function_value, nodes, child, locals, expected, expected_type_name));
                } else {
                    parts = vec.push(parts, emit_value_node(program, function_value, nodes, child, locals));
                };
                ()
            } else {
                ()
            },
            None => (),
        };
        index = index + 1;
    };
    string.join(parts, "")
}

fn call_arg_node_value_name(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], node: IrExprNode, locals: BackendLocals, expected: String, expected_type_name: String) -> String {
    match node.kind {
        IrCallExpr => if expected_vec_new_vec_node_can_emit(node, expected) {
            llvm_node_value_local(node)
        } else if expected_enum_constructor_node_can_emit(program, function_value, nodes, node, locals, expected_type_name) {
            expected_enum_constructor_node_value_name(node)
        } else {
            node_value_name(program, function_value, nodes, node, locals)
        },
        IrBinaryExpr => llvm_node_value_local(node),
        IrIfExpr => llvm_node_value_local(node),
        IrMatchExpr => llvm_node_value_local(node),
        _ => if expected == "%aic.String" {
            string_node_value_name_with_locals(function_value, locals, node)
        } else {
            node_value_name(program, function_value, nodes, node, locals)
        },
    }
}

fn emit_call_args(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], callee_name: String, locals: BackendLocals) -> String {
    let mut parts: Vec[String] = vec.new_vec();
    let target: Option[IrFunctionDef] = call_target_function(program, callee_name);
    let mut index = 0;
    while index < direct_expr_child_count(nodes) {
        match direct_expr_child_at(nodes, index) {
            Some(node) => if true {
                let expected = call_target_param_type_resolved(program, callee_name, target, index);
                let expected_type_name = call_target_param_type_name_resolved(program, target, index);
                if index > 0 {
                    parts = vec.push(parts, ", ");
                } else {
                    ()
                };
                parts = vec.push(parts, expected);
                parts = vec.push(parts, " ");
                parts = vec.push(parts, call_arg_node_value_name(program, function_value, nodes, node, locals, expected, expected_type_name));
                ()
            } else {
                ()
            },
            None => (),
        };
        index = index + 1;
    };
    string.join(parts, "")
}

fn emit_node_call_args(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], node: IrExprNode, locals: BackendLocals) -> String {
    let mut parts: Vec[String] = vec.new_vec();
    let target: Option[IrFunctionDef] = call_target_function(program, node.name);
    let mut index = 0;
    while index < node.direct_child_count {
        match expr_node_child_at(nodes, node, index) {
            Some(child) => if true {
                let expected = call_target_param_type_resolved(program, node.name, target, index);
                let expected_type_name = call_target_param_type_name_resolved(program, target, index);
                if index > 0 {
                    parts = vec.push(parts, ", ");
                } else {
                    ()
                };
                parts = vec.push(parts, expected);
                parts = vec.push(parts, " ");
                parts = vec.push(parts, call_arg_node_value_name(program, function_value, nodes, child, locals, expected, expected_type_name));
                ()
            } else {
                ()
            },
            None => (),
        };
        index = index + 1;
    };
    string.join(parts, "")
}

fn llvm_string_global_name(function_name: String) -> String {
    concat2("@.aic.str.", backend_mangle_symbol(function_name))
}

fn llvm_string_node_global_name(function_name: String, node: IrNodeId) -> String {
    concat3(llvm_string_global_name(function_name), ".", string.int_to_string(node.value))
}

fn llvm_escape_string_data(value: String) -> String {
    let mut parts: Vec[String] = vec.new_vec();
    let mut index = 0;
    while index < string.len(value) {
        let ch = string.substring(value, index, index + 1);
        if ch == "\n" {
            parts = vec.push(parts, "\\0A");
        } else if ch == "\r" {
            parts = vec.push(parts, "\\0D");
        } else if ch == "\t" {
            parts = vec.push(parts, "\\09");
        } else if ch == "\"" {
            parts = vec.push(parts, "\\22");
        } else if ch == "\\" {
            parts = vec.push(parts, "\\5C");
        } else {
            parts = vec.push(parts, ch);
        };
        index = index + 1;
    };
    string.join(parts, "")
}

fn unescape_string_literal_body(value: String) -> String {
    let mut parts: Vec[String] = vec.new_vec();
    let mut index = 0;
    while index < string.len(value) {
        let ch = string.substring(value, index, index + 1);
        if ch == "\\" && index + 1 < string.len(value) {
            let next = string.substring(value, index + 1, index + 2);
            if next == "n" {
                parts = vec.push(parts, "\n");
            } else if next == "r" {
                parts = vec.push(parts, "\r");
            } else if next == "t" {
                parts = vec.push(parts, "\t");
            } else if next == "\"" {
                parts = vec.push(parts, "\"");
            } else if next == "\\" {
                parts = vec.push(parts, "\\");
            } else {
                parts = vec.push(parts, next);
            };
            index = index + 2;
        } else {
            parts = vec.push(parts, ch);
            index = index + 1;
        };
    };
    string.join(parts, "")
}

fn string_literal_payload(value: String) -> String {
    if string.len(value) >= 2 && string.starts_with(value, "\"") && string.ends_with(value, "\"") {
        unescape_string_literal_body(string.substring(value, 1, string.len(value) - 1))
    } else {
        value
    }
}

fn emit_named_string_literal_global(global_name: String, value: String) -> String {
    let payload = string_literal_payload(value);
    let mut parts: Vec[String] = vec.new_vec();
    parts = vec.push(parts, global_name);
    parts = vec.push(parts, " = private unnamed_addr constant [");
    parts = vec.push(parts, string.int_to_string(string.len(payload)));
    parts = vec.push(parts, " x i8] c\"");
    parts = vec.push(parts, llvm_escape_string_data(payload));
    parts = vec.push(parts, "\"\n");
    string.join(parts, "")
}

fn emit_string_literal_global(function_value: IrFunctionDef, value: String) -> String {
    emit_named_string_literal_global(llvm_string_global_name(function_value.name), value)
}

fn emit_string_node_globals_for_expr(function_value: IrFunctionDef, expr: IrExpr) -> String {
    let mut parts: Vec[String] = vec.new_vec();
    let mut index = 0;
    while index < vec.vec_len(expr.nodes) {
        match vec.get(expr.nodes, index) {
            Some(node) => if is_string_expr_kind(node.kind) {
                parts = vec.push(parts, emit_named_string_literal_global(llvm_string_node_global_name(function_value.name, node.node), node.text));
            } else {
                ()
            },
            None => (),
        };
        index = index + 1;
    };
    string.join(parts, "")
}

fn emit_string_globals_for_statement(function_value: IrFunctionDef, statement: IrStatement) -> String {
    match statement.expr {
        Some(expr) => match expr.kind {
            IrStringExpr => concat2(emit_string_literal_global(function_value, expr.text), emit_string_node_globals_for_expr(function_value, expr)),
            _ => emit_string_node_globals_for_expr(function_value, expr),
        },
        None => "",
    }
}

fn emit_string_globals_for_statements(function_value: IrFunctionDef) -> String {
    let mut parts: Vec[String] = vec.new_vec();
    let mut index = 0;
    while index < vec.vec_len(function_value.body.statements) {
        match vec.get(function_value.body.statements, index) {
            Some(statement) => if true {
                parts = vec.push(parts, emit_string_globals_for_statement(function_value, statement));
                ()
            } else { () },
            None => (),
        };
        index = index + 1;
    };
    string.join(parts, "")
}

fn emit_string_globals_for_function(function_value: IrFunctionDef) -> String {
    let statement_globals = emit_string_globals_for_statements(function_value);
    let tail_globals = match function_value.body.tail_expr {
        Some(expr) => match expr.kind {
            IrStringExpr => concat2(emit_string_literal_global(function_value, expr.text), emit_string_node_globals_for_expr(function_value, expr)),
            _ => emit_string_node_globals_for_expr(function_value, expr),
        },
        None => "",
    };
    concat2(statement_globals, tail_globals)
}

fn emit_string_globals(program: IrProgram) -> String {
    let mut parts: Vec[String] = vec.new_vec();
    let mut index = 0;
    while index < vec.vec_len(program.items) {
        match vec.get(program.items, index) {
            Some(item) => match item {
                IrFunctionItemValue(function_value) => if function_value.runtime_visible {
                    parts = vec.push(parts, emit_string_globals_for_function(function_value));
                } else {
                    ()
                },
                _ => (),
            },
            None => (),
        };
        index = index + 1;
    };
    string.join(parts, "")
}

fn program_uses_string_type(program: IrProgram) -> Bool {
    let mut index = 0;
    let mut found = false;
    while !found && index < vec.vec_len(program.types) {
        match vec.get(program.types, index) {
            Some(type_value) => if type_value.name == "String" {
                found = true;
            } else {
                ()
            },
            None => (),
        };
        index = index + 1;
    };
    found
}

fn expr_uses_string_replace(expr: IrExpr) -> Bool {
    let mut found = is_call_expr_kind(expr.kind) && expr.name == "string.replace";
    let mut index = 0;
    while !found && index < vec.vec_len(expr.nodes) {
        match vec.get(expr.nodes, index) {
            Some(node) => if is_call_expr_kind(node.kind) && node.name == "string.replace" {
                found = true;
            } else {
                ()
            },
            None => (),
        };
        index = index + 1;
    };
    found
}

fn expr_uses_io_print(expr: IrExpr) -> Bool {
    let mut found = is_call_expr_kind(expr.kind) && is_io_print_intrinsic_name(expr.name);
    let mut index = 0;
    while !found && index < vec.vec_len(expr.nodes) {
        match vec.get(expr.nodes, index) {
            Some(node) => if is_call_expr_kind(node.kind) && is_io_print_intrinsic_name(node.name) {
                found = true;
            } else {
                ()
            },
            None => (),
        };
        index = index + 1;
    };
    found
}

fn expr_uses_env_arg_at(expr: IrExpr) -> Bool {
    let mut found = is_call_expr_kind(expr.kind) && expr.name == "arg_at";
    let mut index = 0;
    while !found && index < vec.vec_len(expr.nodes) {
        match vec.get(expr.nodes, index) {
            Some(node) => if is_call_expr_kind(node.kind) && node.name == "arg_at" {
                found = true;
            } else {
                ()
            },
            None => (),
        };
        index = index + 1;
    };
    found
}

fn expr_uses_call_named(expr: IrExpr, name: String) -> Bool {
    let mut found = is_call_expr_kind(expr.kind) && expr.name == name;
    let mut index = 0;
    while !found && index < vec.vec_len(expr.nodes) {
        match vec.get(expr.nodes, index) {
            Some(node) => if is_call_expr_kind(node.kind) && node.name == name {
                found = true;
            } else {
                ()
            },
            None => (),
        };
        index = index + 1;
    };
    found
}

fn node_is_iterator_for(nodes: Vec[IrExprNode], node: IrExprNode) -> Bool {
    match node.kind {
        IrForExpr => match expr_node_child_at(nodes, node, 0) {
            Some(iterable_node) => !node_is_range_expr(iterable_node),
            None => false,
        },
        _ => false,
    }
}

fn expr_uses_iterator_for(expr: IrExpr) -> Bool {
    let mut found = false;
    match expr.kind {
        IrForExpr => match direct_expr_child_at(expr.nodes, 0) {
            Some(iterable_node) => if !node_is_range_expr(iterable_node) {
                found = true;
            } else {
                ()
            },
            None => (),
        },
        _ => (),
    };
    let mut index = 0;
    while !found && index < vec.vec_len(expr.nodes) {
        match vec.get(expr.nodes, index) {
            Some(node) => if node_is_iterator_for(expr.nodes, node) {
                found = true;
            } else {
                ()
            },
            None => (),
        };
        index = index + 1;
    };
    found
}

fn statement_uses_call_named(statement: IrStatement, name: String) -> Bool {
    match statement.expr {
        Some(expr) => expr_uses_call_named(expr, name),
        None => false,
    }
}

fn statement_uses_iterator_for(statement: IrStatement) -> Bool {
    match statement.expr {
        Some(expr) => expr_uses_iterator_for(expr),
        None => false,
    }
}

fn block_uses_call_named(block: IrBlock, name: String) -> Bool {
    let mut found = false;
    let mut index = 0;
    while !found && index < vec.vec_len(block.statements) {
        match vec.get(block.statements, index) {
            Some(statement) => if statement_uses_call_named(statement, name) {
                found = true;
            } else {
                ()
            },
            None => (),
        };
        index = index + 1;
    };
    if found {
        true
    } else {
        match block.tail_expr {
            Some(expr) => expr_uses_call_named(expr, name),
            None => false,
        }
    }
}

fn block_uses_iterator_for(block: IrBlock) -> Bool {
    let mut found = false;
    let mut index = 0;
    while !found && index < vec.vec_len(block.statements) {
        match vec.get(block.statements, index) {
            Some(statement) => if statement_uses_iterator_for(statement) {
                found = true;
            } else {
                ()
            },
            None => (),
        };
        index = index + 1;
    };
    if found {
        true
    } else {
        match block.tail_expr {
            Some(expr) => expr_uses_iterator_for(expr),
            None => false,
        }
    }
}

fn program_uses_call_named(program: IrProgram, name: String) -> Bool {
    let mut index = 0;
    let mut found = false;
    while !found && index < vec.vec_len(program.items) {
        match vec.get(program.items, index) {
            Some(item) => match item {
                IrFunctionItemValue(function_value) => if block_uses_call_named(function_value.body, name) {
                    found = true;
                } else {
                    ()
                },
                _ => (),
            },
            None => (),
        };
        index = index + 1;
    };
    found
}

fn program_uses_iterator_for(program: IrProgram) -> Bool {
    let mut index = 0;
    let mut found = false;
    while !found && index < vec.vec_len(program.items) {
        match vec.get(program.items, index) {
            Some(item) => match item {
                IrFunctionItemValue(function_value) => if block_uses_iterator_for(function_value.body) {
                    found = true;
                } else {
                    ()
                },
                _ => (),
            },
            None => (),
        };
        index = index + 1;
    };
    found
}

fn program_uses_string_replace(program: IrProgram) -> Bool {
    let mut index = 0;
    let mut found = false;
    while !found && index < vec.vec_len(program.items) {
        match vec.get(program.items, index) {
            Some(item) => match item {
                IrFunctionItemValue(function_value) => match function_value.body.tail_expr {
                    Some(expr) => if expr_uses_string_replace(expr) {
                        found = true;
                    } else {
                        ()
                    },
                    None => (),
                },
                _ => (),
            },
            None => (),
        };
        index = index + 1;
    };
    found
}

fn program_uses_io_print(program: IrProgram) -> Bool {
    let mut index = 0;
    let mut found = false;
    while !found && index < vec.vec_len(program.items) {
        match vec.get(program.items, index) {
            Some(item) => match item {
                IrFunctionItemValue(function_value) => match function_value.body.tail_expr {
                    Some(expr) => if expr_uses_io_print(expr) {
                        found = true;
                    } else {
                        ()
                    },
                    None => (),
                },
                _ => (),
            },
            None => (),
        };
        index = index + 1;
    };
    found
}

fn program_uses_env_arg_at(program: IrProgram) -> Bool {
    let mut index = 0;
    let mut found = false;
    while !found && index < vec.vec_len(program.items) {
        match vec.get(program.items, index) {
            Some(item) => match item {
                IrFunctionItemValue(function_value) => match function_value.body.tail_expr {
                    Some(expr) => if expr_uses_env_arg_at(expr) {
                        found = true;
                    } else {
                        ()
                    },
                    None => (),
                },
                _ => (),
            },
            None => (),
        };
        index = index + 1;
    };
    found
}

fn emit_runtime_declarations(program: IrProgram) -> String {
    let mut parts: Vec[String] = vec.new_vec();
    parts = vec.push(parts, "declare void @aic_rt_stack_ensure_min(i64)\n");
    parts = vec.push(parts, "declare i64 @aic_rt_string_compare(i8*, i64, i64, i8*, i64, i64)\n");
    if program_uses_string_replace(program) {
        parts = vec.push(parts, "declare void @aic_rt_string_replace(i8*, i64, i64, i8*, i64, i64, i8*, i64, i64, i8**, i64*)\n");
    } else {
        ()
    };
    if program_uses_call_named(program, "string.contains") {
        parts = vec.push(parts, "declare i64 @aic_rt_string_contains(i8*, i64, i64, i8*, i64, i64)\n");
    } else {
        ()
    };
    if program_uses_call_named(program, "string.starts_with") {
        parts = vec.push(parts, "declare i64 @aic_rt_string_starts_with(i8*, i64, i64, i8*, i64, i64)\n");
    } else {
        ()
    };
    if program_uses_call_named(program, "string.ends_with") {
        parts = vec.push(parts, "declare i64 @aic_rt_string_ends_with(i8*, i64, i64, i8*, i64, i64)\n");
    } else {
        ()
    };
    if program_uses_call_named(program, "string.join") {
        parts = vec.push(parts, "declare void @aic_rt_string_join(i8*, i64, i64, i8*, i64, i64, i8**, i64*)\n");
    } else {
        ()
    };
    if program_uses_call_named(program, "string.split") {
        parts = vec.push(parts, "declare void @aic_rt_string_split(i8*, i64, i64, i8*, i64, i64, i8**, i64*)\n");
    } else {
        ()
    };
    if program_uses_call_named(program, "string.trim") {
        parts = vec.push(parts, "declare void @aic_rt_string_trim(i8*, i64, i64, i8**, i64*)\n");
    } else {
        ()
    };
    if program_uses_call_named(program, "string.char_at") {
        parts = vec.push(parts, "declare i64 @aic_rt_string_char_at(i8*, i64, i64, i64, i8**, i64*)\n");
    } else {
        ()
    };
    if program_uses_call_named(program, "string.int_to_string") {
        parts = vec.push(parts, "declare void @aic_rt_string_int_to_string(i64, i8**, i64*)\n");
    } else {
        ()
    };
    if program_uses_call_named(program, "string.substring") {
        parts = vec.push(parts, "declare void @aic_rt_string_substring(i8*, i64, i64, i64, i64, i8**, i64*)\n");
    } else {
        ()
    };
    if program_uses_call_named(program, "bytes.byte_substring") {
        parts = vec.push(parts, "declare void @aic_rt_string_byte_substring(i8*, i64, i64, i64, i64, i8**, i64*)\n");
    } else {
        ()
    };
    if program_uses_io_print(program) {
        parts = vec.push(parts, "declare void @aic_rt_print_str(i8*, i64, i64)\n");
        parts = vec.push(parts, "declare void @aic_rt_eprint_str(i8*, i64, i64)\n");
    } else {
        ()
    };
    if program_uses_env_arg_at(program) {
        parts = vec.push(parts, "declare i64 @aic_rt_env_arg_at(i64, i8**, i64*)\n");
    } else {
        ()
    };
    if program_has_entry(program) {
        parts = vec.push(parts, "declare void @aic_rt_env_set_args(i32, i8**)\n");
    } else {
        ()
    };
    if program_uses_call_named(program, "read_text") {
        parts = vec.push(parts, "declare i64 @aic_rt_fs_read_text(i8*, i64, i64, i8**, i64*)\n");
    } else {
        ()
    };
    if program_uses_call_named(program, "temp_file") {
        parts = vec.push(parts, "declare i64 @aic_rt_fs_temp_file(i8*, i64, i64, i8**, i64*)\n");
    } else {
        ()
    };
    if program_uses_call_named(program, "write_text") {
        parts = vec.push(parts, "declare i64 @aic_rt_fs_write_text(i8*, i64, i64, i8*, i64, i64)\n");
    } else {
        ()
    };
    if program_uses_call_named(program, "delete") {
        parts = vec.push(parts, "declare i64 @aic_rt_fs_delete(i8*, i64, i64)\n");
    } else {
        ()
    };
    if program_uses_call_named(program, "proc.run") {
        parts = vec.push(parts, "declare i64 @aic_rt_proc_run(i8*, i64, i64, i64*, i8**, i64*, i8**, i64*)\n");
    } else {
        ()
    };
    if program_uses_call_named(program, "vec.push") {
        parts = vec.push(parts, "declare i64 @aic_rt_vec_push(i8**, i64*, i64*, i64, i8*)\n");
    } else {
        ()
    };
    if program_uses_call_named(program, "vec.get") || program_uses_iterator_for(program) {
        parts = vec.push(parts, "declare i64 @aic_rt_vec_get(i8*, i64, i64, i64, i64, i8*)\n");
    } else {
        ()
    };
    string.join(parts, "")
}

fn emit_type_declarations(program: IrProgram) -> String {
    "%aic.String = type { i8*, i64, i64 }\n"
}

fn llvm_expr_prefix(node: IrNodeId) -> String {
    concat2("expr.", string.int_to_string(node.value))
}

fn llvm_node_prefix(node: IrNodeId) -> String {
    concat2("node.", string.int_to_string(node.value))
}

fn llvm_local(prefix: String, suffix: String) -> String {
    concat3("%", prefix, suffix)
}

fn llvm_expr_value_local(expr: IrExpr) -> String {
    llvm_local(llvm_expr_prefix(expr.node), ".value")
}

fn llvm_node_value_local(node: IrExprNode) -> String {
    llvm_local(llvm_node_prefix(node.node), ".value")
}

fn emit_string_literal_value(global_name: String, literal_text: String, prefix: String) -> String {
    let payload = string_literal_payload(literal_text);
    let mut parts: Vec[String] = vec.new_vec();
    parts = vec.push(parts, "  ");
    parts = vec.push(parts, llvm_local(prefix, ".ptr"));
    parts = vec.push(parts, " = getelementptr inbounds [");
    parts = vec.push(parts, string.int_to_string(string.len(payload)));
    parts = vec.push(parts, " x i8], [");
    parts = vec.push(parts, string.int_to_string(string.len(payload)));
    parts = vec.push(parts, " x i8]* ");
    parts = vec.push(parts, global_name);
    parts = vec.push(parts, ", i64 0, i64 0\n  ");
    parts = vec.push(parts, llvm_local(prefix, ".0"));
    parts = vec.push(parts, " = insertvalue %aic.String undef, i8* ");
    parts = vec.push(parts, llvm_local(prefix, ".ptr"));
    parts = vec.push(parts, ", 0\n  ");
    parts = vec.push(parts, llvm_local(prefix, ".1"));
    parts = vec.push(parts, " = insertvalue %aic.String ");
    parts = vec.push(parts, llvm_local(prefix, ".0"));
    parts = vec.push(parts, ", i64 ");
    parts = vec.push(parts, string.int_to_string(string.len(payload)));
    parts = vec.push(parts, ", 1\n  ");
    parts = vec.push(parts, llvm_local(prefix, ".value"));
    parts = vec.push(parts, " = insertvalue %aic.String ");
    parts = vec.push(parts, llvm_local(prefix, ".1"));
    parts = vec.push(parts, ", i64 ");
    parts = vec.push(parts, string.int_to_string(string.len(payload)));
    parts = vec.push(parts, ", 2\n");
    string.join(parts, "")
}

fn emit_string_extracts(value_name: String, prefix: String) -> String {
    let mut parts: Vec[String] = vec.new_vec();
    parts = vec.push(parts, "  ");
    parts = vec.push(parts, llvm_local(prefix, ".ptr"));
    parts = vec.push(parts, " = extractvalue %aic.String ");
    parts = vec.push(parts, value_name);
    parts = vec.push(parts, ", 0\n  ");
    parts = vec.push(parts, llvm_local(prefix, ".len"));
    parts = vec.push(parts, " = extractvalue %aic.String ");
    parts = vec.push(parts, value_name);
    parts = vec.push(parts, ", 1\n  ");
    parts = vec.push(parts, llvm_local(prefix, ".cap"));
    parts = vec.push(parts, " = extractvalue %aic.String ");
    parts = vec.push(parts, value_name);
    parts = vec.push(parts, ", 2\n");
    string.join(parts, "")
}

fn emit_load_name_node_value(program: IrProgram, function_value: IrFunctionDef, node: IrExprNode, locals: BackendLocals) -> String {
    let storage_name = storage_name_for_name(locals, node.text);
    if storage_name == "" {
        ""
    } else {
        let ty = llvm_type_for_name(program, function_value, locals, node.text);
        let mut parts: Vec[String] = vec.new_vec();
        parts = vec.push(parts, "  ");
        parts = vec.push(parts, loaded_node_name(node));
        parts = vec.push(parts, " = load ");
        parts = vec.push(parts, ty);
        parts = vec.push(parts, ", ");
        parts = vec.push(parts, ty);
        parts = vec.push(parts, "* ");
        parts = vec.push(parts, storage_name);
        parts = vec.push(parts, "\n");
        string.join(parts, "")
    }
}

fn emit_load_name_expr_value(program: IrProgram, function_value: IrFunctionDef, expr: IrExpr, locals: BackendLocals) -> String {
    let storage_name = storage_name_for_name(locals, expr.text);
    if storage_name == "" {
        ""
    } else {
        let ty = llvm_type_for_name(program, function_value, locals, expr.text);
        let mut parts: Vec[String] = vec.new_vec();
        parts = vec.push(parts, "  ");
        parts = vec.push(parts, loaded_expr_name(expr));
        parts = vec.push(parts, " = load ");
        parts = vec.push(parts, ty);
        parts = vec.push(parts, ", ");
        parts = vec.push(parts, ty);
        parts = vec.push(parts, "* ");
        parts = vec.push(parts, storage_name);
        parts = vec.push(parts, "\n");
        string.join(parts, "")
    }
}

fn emit_string_replace_call(prefix: String, first_value: String, second_value: String, third_value: String) -> String {
    let first_prefix = concat2(prefix, ".arg0");
    let second_prefix = concat2(prefix, ".arg1");
    let third_prefix = concat2(prefix, ".arg2");
    let mut parts: Vec[String] = vec.new_vec();
    parts = vec.push(parts, emit_string_extracts(first_value, first_prefix));
    parts = vec.push(parts, emit_string_extracts(second_value, second_prefix));
    parts = vec.push(parts, emit_string_extracts(third_value, third_prefix));
    parts = vec.push(parts, "  ");
    parts = vec.push(parts, llvm_local(prefix, ".out.ptr"));
    parts = vec.push(parts, " = alloca i8*\n  ");
    parts = vec.push(parts, llvm_local(prefix, ".out.len"));
    parts = vec.push(parts, " = alloca i64\n  call void @aic_rt_string_replace(i8* ");
    parts = vec.push(parts, llvm_local(first_prefix, ".ptr"));
    parts = vec.push(parts, ", i64 ");
    parts = vec.push(parts, llvm_local(first_prefix, ".len"));
    parts = vec.push(parts, ", i64 ");
    parts = vec.push(parts, llvm_local(first_prefix, ".cap"));
    parts = vec.push(parts, ", i8* ");
    parts = vec.push(parts, llvm_local(second_prefix, ".ptr"));
    parts = vec.push(parts, ", i64 ");
    parts = vec.push(parts, llvm_local(second_prefix, ".len"));
    parts = vec.push(parts, ", i64 ");
    parts = vec.push(parts, llvm_local(second_prefix, ".cap"));
    parts = vec.push(parts, ", i8* ");
    parts = vec.push(parts, llvm_local(third_prefix, ".ptr"));
    parts = vec.push(parts, ", i64 ");
    parts = vec.push(parts, llvm_local(third_prefix, ".len"));
    parts = vec.push(parts, ", i64 ");
    parts = vec.push(parts, llvm_local(third_prefix, ".cap"));
    parts = vec.push(parts, ", i8** ");
    parts = vec.push(parts, llvm_local(prefix, ".out.ptr"));
    parts = vec.push(parts, ", i64* ");
    parts = vec.push(parts, llvm_local(prefix, ".out.len"));
    parts = vec.push(parts, ")\n  ");
    parts = vec.push(parts, llvm_local(prefix, ".ret.ptr"));
    parts = vec.push(parts, " = load i8*, i8** ");
    parts = vec.push(parts, llvm_local(prefix, ".out.ptr"));
    parts = vec.push(parts, "\n  ");
    parts = vec.push(parts, llvm_local(prefix, ".ret.len"));
    parts = vec.push(parts, " = load i64, i64* ");
    parts = vec.push(parts, llvm_local(prefix, ".out.len"));
    parts = vec.push(parts, "\n  ");
    parts = vec.push(parts, llvm_local(prefix, ".0"));
    parts = vec.push(parts, " = insertvalue %aic.String undef, i8* ");
    parts = vec.push(parts, llvm_local(prefix, ".ret.ptr"));
    parts = vec.push(parts, ", 0\n  ");
    parts = vec.push(parts, llvm_local(prefix, ".1"));
    parts = vec.push(parts, " = insertvalue %aic.String ");
    parts = vec.push(parts, llvm_local(prefix, ".0"));
    parts = vec.push(parts, ", i64 ");
    parts = vec.push(parts, llvm_local(prefix, ".ret.len"));
    parts = vec.push(parts, ", 1\n  ");
    parts = vec.push(parts, llvm_local(prefix, ".value"));
    parts = vec.push(parts, " = insertvalue %aic.String ");
    parts = vec.push(parts, llvm_local(prefix, ".1"));
    parts = vec.push(parts, ", i64 ");
    parts = vec.push(parts, llvm_local(prefix, ".ret.len"));
    parts = vec.push(parts, ", 2\n");
    string.join(parts, "")
}

fn emit_string_join_call(prefix: String, parts_value: String, separator_value: String) -> String {
    let parts_prefix = concat2(prefix, ".parts");
    let separator_prefix = concat2(prefix, ".separator");
    let mut out: Vec[String] = vec.new_vec();
    out = vec.push(out, emit_string_extracts(separator_value, separator_prefix));
    out = vec.push(out, "  ");
    out = vec.push(out, llvm_local(parts_prefix, ".ptr.int"));
    out = vec.push(out, " = extractvalue { i64, i64, i64 } ");
    out = vec.push(out, parts_value);
    out = vec.push(out, ", 0\n  ");
    out = vec.push(out, llvm_local(parts_prefix, ".len"));
    out = vec.push(out, " = extractvalue { i64, i64, i64 } ");
    out = vec.push(out, parts_value);
    out = vec.push(out, ", 1\n  ");
    out = vec.push(out, llvm_local(parts_prefix, ".cap"));
    out = vec.push(out, " = extractvalue { i64, i64, i64 } ");
    out = vec.push(out, parts_value);
    out = vec.push(out, ", 2\n  ");
    out = vec.push(out, llvm_local(parts_prefix, ".ptr"));
    out = vec.push(out, " = inttoptr i64 ");
    out = vec.push(out, llvm_local(parts_prefix, ".ptr.int"));
    out = vec.push(out, " to i8*\n  ");
    out = vec.push(out, llvm_local(prefix, ".out.ptr"));
    out = vec.push(out, " = alloca i8*\n  ");
    out = vec.push(out, llvm_local(prefix, ".out.len"));
    out = vec.push(out, " = alloca i64\n  call void @aic_rt_string_join(i8* ");
    out = vec.push(out, llvm_local(parts_prefix, ".ptr"));
    out = vec.push(out, ", i64 ");
    out = vec.push(out, llvm_local(parts_prefix, ".len"));
    out = vec.push(out, ", i64 ");
    out = vec.push(out, llvm_local(parts_prefix, ".cap"));
    out = vec.push(out, ", i8* ");
    out = vec.push(out, llvm_local(separator_prefix, ".ptr"));
    out = vec.push(out, ", i64 ");
    out = vec.push(out, llvm_local(separator_prefix, ".len"));
    out = vec.push(out, ", i64 ");
    out = vec.push(out, llvm_local(separator_prefix, ".cap"));
    out = vec.push(out, ", i8** ");
    out = vec.push(out, llvm_local(prefix, ".out.ptr"));
    out = vec.push(out, ", i64* ");
    out = vec.push(out, llvm_local(prefix, ".out.len"));
    out = vec.push(out, ")\n  ");
    out = vec.push(out, llvm_local(prefix, ".ret.ptr"));
    out = vec.push(out, " = load i8*, i8** ");
    out = vec.push(out, llvm_local(prefix, ".out.ptr"));
    out = vec.push(out, "\n  ");
    out = vec.push(out, llvm_local(prefix, ".ret.len"));
    out = vec.push(out, " = load i64, i64* ");
    out = vec.push(out, llvm_local(prefix, ".out.len"));
    out = vec.push(out, "\n  ");
    out = vec.push(out, llvm_local(prefix, ".0"));
    out = vec.push(out, " = insertvalue %aic.String undef, i8* ");
    out = vec.push(out, llvm_local(prefix, ".ret.ptr"));
    out = vec.push(out, ", 0\n  ");
    out = vec.push(out, llvm_local(prefix, ".1"));
    out = vec.push(out, " = insertvalue %aic.String ");
    out = vec.push(out, llvm_local(prefix, ".0"));
    out = vec.push(out, ", i64 ");
    out = vec.push(out, llvm_local(prefix, ".ret.len"));
    out = vec.push(out, ", 1\n  ");
    out = vec.push(out, llvm_local(prefix, ".value"));
    out = vec.push(out, " = insertvalue %aic.String ");
    out = vec.push(out, llvm_local(prefix, ".1"));
    out = vec.push(out, ", i64 ");
    out = vec.push(out, llvm_local(prefix, ".ret.len"));
    out = vec.push(out, ", 2\n");
    string.join(out, "")
}

fn emit_string_struct_value(prefix: String, ptr_value: String, len_value: String, cap_value: String) -> String {
    let mut parts: Vec[String] = vec.new_vec();
    parts = vec.push(parts, "  ");
    parts = vec.push(parts, llvm_local(prefix, ".0"));
    parts = vec.push(parts, " = insertvalue %aic.String undef, i8* ");
    parts = vec.push(parts, ptr_value);
    parts = vec.push(parts, ", 0\n  ");
    parts = vec.push(parts, llvm_local(prefix, ".1"));
    parts = vec.push(parts, " = insertvalue %aic.String ");
    parts = vec.push(parts, llvm_local(prefix, ".0"));
    parts = vec.push(parts, ", i64 ");
    parts = vec.push(parts, len_value);
    parts = vec.push(parts, ", 1\n  ");
    parts = vec.push(parts, llvm_local(prefix, ".value"));
    parts = vec.push(parts, " = insertvalue %aic.String ");
    parts = vec.push(parts, llvm_local(prefix, ".1"));
    parts = vec.push(parts, ", i64 ");
    parts = vec.push(parts, cap_value);
    parts = vec.push(parts, ", 2\n");
    string.join(parts, "")
}

fn emit_vec_string_value_from_raw_parts(prefix: String, items_ptr_value: String, count_value: String) -> String {
    let vec_ty = "{ i64, i64, i64 }";
    let mut parts: Vec[String] = vec.new_vec();
    parts = vec.push(parts, "  ");
    parts = vec.push(parts, llvm_local(prefix, ".ptr.int"));
    parts = vec.push(parts, " = ptrtoint i8* ");
    parts = vec.push(parts, items_ptr_value);
    parts = vec.push(parts, " to i64\n  ");
    parts = vec.push(parts, llvm_local(prefix, ".0"));
    parts = vec.push(parts, " = insertvalue ");
    parts = vec.push(parts, vec_ty);
    parts = vec.push(parts, " undef, i64 ");
    parts = vec.push(parts, llvm_local(prefix, ".ptr.int"));
    parts = vec.push(parts, ", 0\n  ");
    parts = vec.push(parts, llvm_local(prefix, ".1"));
    parts = vec.push(parts, " = insertvalue ");
    parts = vec.push(parts, vec_ty);
    parts = vec.push(parts, " ");
    parts = vec.push(parts, llvm_local(prefix, ".0"));
    parts = vec.push(parts, ", i64 ");
    parts = vec.push(parts, count_value);
    parts = vec.push(parts, ", 1\n  ");
    parts = vec.push(parts, llvm_local(prefix, ".value"));
    parts = vec.push(parts, " = insertvalue ");
    parts = vec.push(parts, vec_ty);
    parts = vec.push(parts, " ");
    parts = vec.push(parts, llvm_local(prefix, ".1"));
    parts = vec.push(parts, ", i64 ");
    parts = vec.push(parts, count_value);
    parts = vec.push(parts, ", 2\n");
    string.join(parts, "")
}

fn emit_string_split_call(prefix: String, text_value: String, delimiter_value: String) -> String {
    let text_prefix = concat2(prefix, ".text");
    let delimiter_prefix = concat2(prefix, ".delimiter");
    let mut parts: Vec[String] = vec.new_vec();
    parts = vec.push(parts, emit_string_extracts(text_value, text_prefix));
    parts = vec.push(parts, emit_string_extracts(delimiter_value, delimiter_prefix));
    parts = vec.push(parts, "  ");
    parts = vec.push(parts, llvm_local(prefix, ".out.items"));
    parts = vec.push(parts, " = alloca i8*\n  ");
    parts = vec.push(parts, llvm_local(prefix, ".out.count"));
    parts = vec.push(parts, " = alloca i64\n  call void @aic_rt_string_split(i8* ");
    parts = vec.push(parts, llvm_local(text_prefix, ".ptr"));
    parts = vec.push(parts, ", i64 ");
    parts = vec.push(parts, llvm_local(text_prefix, ".len"));
    parts = vec.push(parts, ", i64 ");
    parts = vec.push(parts, llvm_local(text_prefix, ".cap"));
    parts = vec.push(parts, ", i8* ");
    parts = vec.push(parts, llvm_local(delimiter_prefix, ".ptr"));
    parts = vec.push(parts, ", i64 ");
    parts = vec.push(parts, llvm_local(delimiter_prefix, ".len"));
    parts = vec.push(parts, ", i64 ");
    parts = vec.push(parts, llvm_local(delimiter_prefix, ".cap"));
    parts = vec.push(parts, ", i8** ");
    parts = vec.push(parts, llvm_local(prefix, ".out.items"));
    parts = vec.push(parts, ", i64* ");
    parts = vec.push(parts, llvm_local(prefix, ".out.count"));
    parts = vec.push(parts, ")\n  ");
    parts = vec.push(parts, llvm_local(prefix, ".ret.items"));
    parts = vec.push(parts, " = load i8*, i8** ");
    parts = vec.push(parts, llvm_local(prefix, ".out.items"));
    parts = vec.push(parts, "\n  ");
    parts = vec.push(parts, llvm_local(prefix, ".ret.count"));
    parts = vec.push(parts, " = load i64, i64* ");
    parts = vec.push(parts, llvm_local(prefix, ".out.count"));
    parts = vec.push(parts, "\n");
    parts = vec.push(parts, emit_vec_string_value_from_raw_parts(prefix, llvm_local(prefix, ".ret.items"), llvm_local(prefix, ".ret.count")));
    string.join(parts, "")
}

fn emit_string_trim_call(prefix: String, text_value: String) -> String {
    let text_prefix = concat2(prefix, ".arg0");
    let mut parts: Vec[String] = vec.new_vec();
    parts = vec.push(parts, emit_string_extracts(text_value, text_prefix));
    parts = vec.push(parts, "  ");
    parts = vec.push(parts, llvm_local(prefix, ".out.ptr"));
    parts = vec.push(parts, " = alloca i8*\n  ");
    parts = vec.push(parts, llvm_local(prefix, ".out.len"));
    parts = vec.push(parts, " = alloca i64\n  call void @aic_rt_string_trim(i8* ");
    parts = vec.push(parts, llvm_local(text_prefix, ".ptr"));
    parts = vec.push(parts, ", i64 ");
    parts = vec.push(parts, llvm_local(text_prefix, ".len"));
    parts = vec.push(parts, ", i64 ");
    parts = vec.push(parts, llvm_local(text_prefix, ".cap"));
    parts = vec.push(parts, ", i8** ");
    parts = vec.push(parts, llvm_local(prefix, ".out.ptr"));
    parts = vec.push(parts, ", i64* ");
    parts = vec.push(parts, llvm_local(prefix, ".out.len"));
    parts = vec.push(parts, ")\n  ");
    parts = vec.push(parts, llvm_local(prefix, ".ret.ptr"));
    parts = vec.push(parts, " = load i8*, i8** ");
    parts = vec.push(parts, llvm_local(prefix, ".out.ptr"));
    parts = vec.push(parts, "\n  ");
    parts = vec.push(parts, llvm_local(prefix, ".ret.len"));
    parts = vec.push(parts, " = load i64, i64* ");
    parts = vec.push(parts, llvm_local(prefix, ".out.len"));
    parts = vec.push(parts, "\n");
    parts = vec.push(parts, emit_string_struct_value(prefix, llvm_local(prefix, ".ret.ptr"), llvm_local(prefix, ".ret.len"), llvm_local(prefix, ".ret.len")));
    string.join(parts, "")
}

fn emit_option_value_from_condition(program: IrProgram, prefix: String, option_ty: String, elem_ty: String, payload_value: String, condition_value: String) -> String {
    let some_label = concat2("option.some.", prefix);
    let none_label = concat2("option.none.", prefix);
    let cont_label = concat2("option.cont.", prefix);
    let mut parts: Vec[String] = vec.new_vec();
    parts = vec.push(parts, "  ");
    parts = vec.push(parts, llvm_local(prefix, ".option.slot"));
    parts = vec.push(parts, " = alloca ");
    parts = vec.push(parts, option_ty);
    parts = vec.push(parts, "\n  br i1 ");
    parts = vec.push(parts, condition_value);
    parts = vec.push(parts, ", label %");
    parts = vec.push(parts, some_label);
    parts = vec.push(parts, ", label %");
    parts = vec.push(parts, none_label);
    parts = vec.push(parts, "\n");
    parts = vec.push(parts, some_label);
    parts = vec.push(parts, ":\n  ");
    parts = vec.push(parts, llvm_local(prefix, ".some.0"));
    parts = vec.push(parts, " = insertvalue ");
    parts = vec.push(parts, option_ty);
    parts = vec.push(parts, " undef, i32 ");
    parts = vec.push(parts, string.int_to_string(enum_variant_index(program, "Option", "Some")));
    parts = vec.push(parts, ", 0\n  ");
    parts = vec.push(parts, llvm_local(prefix, ".some.1"));
    parts = vec.push(parts, " = insertvalue ");
    parts = vec.push(parts, option_ty);
    parts = vec.push(parts, " ");
    parts = vec.push(parts, llvm_local(prefix, ".some.0"));
    parts = vec.push(parts, ", ");
    parts = vec.push(parts, elem_ty);
    parts = vec.push(parts, " ");
    parts = vec.push(parts, payload_value);
    parts = vec.push(parts, ", 1\n  store ");
    parts = vec.push(parts, option_ty);
    parts = vec.push(parts, " ");
    parts = vec.push(parts, llvm_local(prefix, ".some.1"));
    parts = vec.push(parts, ", ");
    parts = vec.push(parts, option_ty);
    parts = vec.push(parts, "* ");
    parts = vec.push(parts, llvm_local(prefix, ".option.slot"));
    parts = vec.push(parts, "\n  br label %");
    parts = vec.push(parts, cont_label);
    parts = vec.push(parts, "\n");
    parts = vec.push(parts, none_label);
    parts = vec.push(parts, ":\n  ");
    parts = vec.push(parts, llvm_local(prefix, ".none.0"));
    parts = vec.push(parts, " = insertvalue ");
    parts = vec.push(parts, option_ty);
    parts = vec.push(parts, " undef, i32 ");
    parts = vec.push(parts, string.int_to_string(enum_variant_index(program, "Option", "None")));
    parts = vec.push(parts, ", 0\n  store ");
    parts = vec.push(parts, option_ty);
    parts = vec.push(parts, " ");
    parts = vec.push(parts, llvm_local(prefix, ".none.0"));
    parts = vec.push(parts, ", ");
    parts = vec.push(parts, option_ty);
    parts = vec.push(parts, "* ");
    parts = vec.push(parts, llvm_local(prefix, ".option.slot"));
    parts = vec.push(parts, "\n  br label %");
    parts = vec.push(parts, cont_label);
    parts = vec.push(parts, "\n");
    parts = vec.push(parts, cont_label);
    parts = vec.push(parts, ":\n  ");
    parts = vec.push(parts, llvm_local(prefix, ".value"));
    parts = vec.push(parts, " = load ");
    parts = vec.push(parts, option_ty);
    parts = vec.push(parts, ", ");
    parts = vec.push(parts, option_ty);
    parts = vec.push(parts, "* ");
    parts = vec.push(parts, llvm_local(prefix, ".option.slot"));
    parts = vec.push(parts, "\n");
    string.join(parts, "")
}

fn emit_string_char_at_call(program: IrProgram, prefix: String, text_value: String, index_value: String) -> String {
    let text_prefix = concat2(prefix, ".arg0");
    let payload_prefix = concat2(prefix, ".payload");
    let option_ty = llvm_type_for_repr_in_program(program, "Option[String]");
    let mut parts: Vec[String] = vec.new_vec();
    parts = vec.push(parts, emit_string_extracts(text_value, text_prefix));
    parts = vec.push(parts, "  ");
    parts = vec.push(parts, llvm_local(prefix, ".out.ptr"));
    parts = vec.push(parts, " = alloca i8*\n  ");
    parts = vec.push(parts, llvm_local(prefix, ".out.len"));
    parts = vec.push(parts, " = alloca i64\n  ");
    parts = vec.push(parts, llvm_local(prefix, ".found"));
    parts = vec.push(parts, " = call i64 @aic_rt_string_char_at(i8* ");
    parts = vec.push(parts, llvm_local(text_prefix, ".ptr"));
    parts = vec.push(parts, ", i64 ");
    parts = vec.push(parts, llvm_local(text_prefix, ".len"));
    parts = vec.push(parts, ", i64 ");
    parts = vec.push(parts, llvm_local(text_prefix, ".cap"));
    parts = vec.push(parts, ", i64 ");
    parts = vec.push(parts, index_value);
    parts = vec.push(parts, ", i8** ");
    parts = vec.push(parts, llvm_local(prefix, ".out.ptr"));
    parts = vec.push(parts, ", i64* ");
    parts = vec.push(parts, llvm_local(prefix, ".out.len"));
    parts = vec.push(parts, ")\n  ");
    parts = vec.push(parts, llvm_local(prefix, ".ret.ptr"));
    parts = vec.push(parts, " = load i8*, i8** ");
    parts = vec.push(parts, llvm_local(prefix, ".out.ptr"));
    parts = vec.push(parts, "\n  ");
    parts = vec.push(parts, llvm_local(prefix, ".ret.len"));
    parts = vec.push(parts, " = load i64, i64* ");
    parts = vec.push(parts, llvm_local(prefix, ".out.len"));
    parts = vec.push(parts, "\n");
    parts = vec.push(parts, emit_string_struct_value(payload_prefix, llvm_local(prefix, ".ret.ptr"), llvm_local(prefix, ".ret.len"), llvm_local(prefix, ".ret.len")));
    parts = vec.push(parts, "  ");
    parts = vec.push(parts, llvm_local(prefix, ".found.bool"));
    parts = vec.push(parts, " = icmp ne i64 ");
    parts = vec.push(parts, llvm_local(prefix, ".found"));
    parts = vec.push(parts, ", 0\n");
    parts = vec.push(parts, emit_option_value_from_condition(program, prefix, option_ty, "%aic.String", llvm_local(payload_prefix, ".value"), llvm_local(prefix, ".found.bool")));
    string.join(parts, "")
}

fn emit_string_int_to_string_call(prefix: String, value_name: String) -> String {
    let mut parts: Vec[String] = vec.new_vec();
    parts = vec.push(parts, "  ");
    parts = vec.push(parts, llvm_local(prefix, ".out.ptr"));
    parts = vec.push(parts, " = alloca i8*\n  ");
    parts = vec.push(parts, llvm_local(prefix, ".out.len"));
    parts = vec.push(parts, " = alloca i64\n  call void @aic_rt_string_int_to_string(i64 ");
    parts = vec.push(parts, value_name);
    parts = vec.push(parts, ", i8** ");
    parts = vec.push(parts, llvm_local(prefix, ".out.ptr"));
    parts = vec.push(parts, ", i64* ");
    parts = vec.push(parts, llvm_local(prefix, ".out.len"));
    parts = vec.push(parts, ")\n  ");
    parts = vec.push(parts, llvm_local(prefix, ".ret.ptr"));
    parts = vec.push(parts, " = load i8*, i8** ");
    parts = vec.push(parts, llvm_local(prefix, ".out.ptr"));
    parts = vec.push(parts, "\n  ");
    parts = vec.push(parts, llvm_local(prefix, ".ret.len"));
    parts = vec.push(parts, " = load i64, i64* ");
    parts = vec.push(parts, llvm_local(prefix, ".out.len"));
    parts = vec.push(parts, "\n");
    parts = vec.push(parts, emit_string_struct_value(prefix, llvm_local(prefix, ".ret.ptr"), llvm_local(prefix, ".ret.len"), llvm_local(prefix, ".ret.len")));
    string.join(parts, "")
}

fn string_node_value_name_with_locals(function_value: IrFunctionDef, locals: BackendLocals, node: IrExprNode) -> String {
    match node.kind {
        IrNameExpr => if name_uses_storage(locals, node.text) { loaded_node_name(node) } else { value_name_for_name(function_value, locals, node.text) },
        _ => llvm_node_value_local(node),
    }
}

fn string_node_value_name(node: IrExprNode) -> String {
    match node.kind {
        IrNameExpr => concat2("%", backend_mangle_symbol(node.text)),
        _ => llvm_node_value_local(node),
    }
}

fn emit_string_node_value(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], node: IrExprNode, locals: BackendLocals) -> String {
    match node.kind {
        IrStringExpr => emit_string_literal_value(llvm_string_node_global_name(function_value.name, node.node), node.text, llvm_node_prefix(node.node)),
        IrNameExpr => emit_load_name_node_value(program, function_value, node, locals),
        IrFieldAccessExpr => emit_field_access_node_value(program, function_value, nodes, node, locals),
        IrCallExpr => if is_string_bool_intrinsic_name(node.name) {
            emit_string_bool_node_value(program, function_value, nodes, node, locals)
        } else if node.name == "string.replace" {
            emit_string_replace_node_value(program, function_value, nodes, node, locals)
        } else if is_string_join_intrinsic_name(node.name) {
            emit_string_join_node_value(program, function_value, nodes, node, locals)
        } else if is_string_trim_intrinsic_name(node.name) {
            emit_string_trim_node_value(program, function_value, nodes, node, locals)
        } else if is_string_int_to_string_intrinsic_name(node.name) {
            emit_string_int_to_string_node_value(program, function_value, nodes, node, locals)
        } else if is_string_slice_intrinsic_name(node.name) {
            emit_string_slice_node_value(program, function_value, nodes, node, locals)
        } else {
            emit_string_direct_call_node_value(program, function_value, nodes, node, locals)
        },
        _ => "",
    }
}

fn emit_string_replace_node_value(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], node: IrExprNode, locals: BackendLocals) -> String {
    let mut parts: Vec[String] = vec.new_vec();
    let first = match expr_node_child_at(nodes, node, 0) {
        Some(child) => if true {
            parts = vec.push(parts, emit_string_node_value(program, function_value, nodes, child, locals));
            string_node_value_name_with_locals(function_value, locals, child)
        } else { "" },
        None => "",
    };
    let second = match expr_node_child_at(nodes, node, 1) {
        Some(child) => if true {
            parts = vec.push(parts, emit_string_node_value(program, function_value, nodes, child, locals));
            string_node_value_name_with_locals(function_value, locals, child)
        } else { "" },
        None => "",
    };
    let third = match expr_node_child_at(nodes, node, 2) {
        Some(child) => if true {
            parts = vec.push(parts, emit_string_node_value(program, function_value, nodes, child, locals));
            string_node_value_name_with_locals(function_value, locals, child)
        } else { "" },
        None => "",
    };
    parts = vec.push(parts, emit_string_replace_call(llvm_node_prefix(node.node), first, second, third));
    string.join(parts, "")
}

fn emit_string_join_node_value(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], node: IrExprNode, locals: BackendLocals) -> String {
    let mut parts: Vec[String] = vec.new_vec();
    let parts_value = match expr_node_child_at(nodes, node, 0) {
        Some(child) => if true {
            parts = vec.push(parts, emit_value_node(program, function_value, nodes, child, locals));
            node_value_name(program, function_value, nodes, child, locals)
        } else { "" },
        None => "",
    };
    let separator_value = match expr_node_child_at(nodes, node, 1) {
        Some(child) => if true {
            parts = vec.push(parts, emit_string_node_value(program, function_value, nodes, child, locals));
            string_node_value_name_with_locals(function_value, locals, child)
        } else { "" },
        None => "",
    };
    parts = vec.push(parts, emit_string_join_call(llvm_node_prefix(node.node), parts_value, separator_value));
    string.join(parts, "")
}

fn emit_string_direct_call_node_value(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], node: IrExprNode, locals: BackendLocals) -> String {
    let mut parts: Vec[String] = vec.new_vec();
    parts = vec.push(parts, emit_node_call_arg_values(program, function_value, nodes, node, locals));
    parts = vec.push(parts, "  ");
    parts = vec.push(parts, llvm_node_value_local(node));
    parts = vec.push(parts, " = call %aic.String @");
    parts = vec.push(parts, backend_mangle_symbol(node.name));
    parts = vec.push(parts, "(");
    parts = vec.push(parts, emit_node_call_args(program, function_value, nodes, node, locals));
    parts = vec.push(parts, ")\n");
    string.join(parts, "")
}

fn emit_direct_call_node_value(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], node: IrExprNode, locals: BackendLocals) -> String {
    let ret = call_target_return_type(program, node.name);
    if ret == "%aic.String" {
        emit_string_direct_call_node_value(program, function_value, nodes, node, locals)
    } else {
        let mut parts: Vec[String] = vec.new_vec();
        parts = vec.push(parts, emit_node_call_arg_values(program, function_value, nodes, node, locals));
        parts = vec.push(parts, "  ");
        parts = vec.push(parts, llvm_node_value_local(node));
        parts = vec.push(parts, " = call ");
        parts = vec.push(parts, ret);
        parts = vec.push(parts, " @");
        parts = vec.push(parts, backend_mangle_symbol(node.name));
        parts = vec.push(parts, "(");
        parts = vec.push(parts, emit_node_call_args(program, function_value, nodes, node, locals));
        parts = vec.push(parts, ")\n");
        string.join(parts, "")
    }
}

fn emit_binary_node_value(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], node: IrExprNode, locals: BackendLocals) -> String {
    if binary_logical_op_can_emit(node.op) {
        emit_logical_node_value(program, function_value, nodes, node, locals)
    } else if binary_compare_op_can_emit(node.op) {
        emit_compare_node_value(program, function_value, nodes, node, locals)
    } else {
        match expr_node_child_at(nodes, node, 0) {
            Some(left) => match expr_node_child_at(nodes, node, 1) {
                Some(right) => if true {
                    let ty = value_node_llvm_type(program, function_value, nodes, left, locals);
                    let mut parts: Vec[String] = vec.new_vec();
                    parts = vec.push(parts, emit_value_node(program, function_value, nodes, left, locals));
                    parts = vec.push(parts, emit_value_node(program, function_value, nodes, right, locals));
                    parts = vec.push(parts, "  ");
                    parts = vec.push(parts, llvm_node_value_local(node));
                    parts = vec.push(parts, " = ");
                    parts = vec.push(parts, binary_llvm_op(node.op));
                    parts = vec.push(parts, " ");
                    parts = vec.push(parts, ty);
                    parts = vec.push(parts, " ");
                    parts = vec.push(parts, node_value_name(program, function_value, nodes, left, locals));
                    parts = vec.push(parts, ", ");
                    parts = vec.push(parts, node_value_name(program, function_value, nodes, right, locals));
                    parts = vec.push(parts, "\n");
                    string.join(parts, "")
                } else { "" },
                None => "",
            },
            None => "",
        }
    }
}

fn emit_vec_from_slots(prefix: String, vec_ty: String, ptr_slot: String, len_slot: String, cap_slot: String) -> String {
    let mut parts: Vec[String] = vec.new_vec();
    parts = vec.push(parts, "  ");
    parts = vec.push(parts, llvm_local(prefix, ".load.ptr"));
    parts = vec.push(parts, " = load i8*, i8** ");
    parts = vec.push(parts, ptr_slot);
    parts = vec.push(parts, "\n  ");
    parts = vec.push(parts, llvm_local(prefix, ".load.len"));
    parts = vec.push(parts, " = load i64, i64* ");
    parts = vec.push(parts, len_slot);
    parts = vec.push(parts, "\n  ");
    parts = vec.push(parts, llvm_local(prefix, ".load.cap"));
    parts = vec.push(parts, " = load i64, i64* ");
    parts = vec.push(parts, cap_slot);
    parts = vec.push(parts, "\n  ");
    parts = vec.push(parts, llvm_local(prefix, ".ptr.int"));
    parts = vec.push(parts, " = ptrtoint i8* ");
    parts = vec.push(parts, llvm_local(prefix, ".load.ptr"));
    parts = vec.push(parts, " to i64\n  ");
    parts = vec.push(parts, llvm_local(prefix, ".vec.0"));
    parts = vec.push(parts, " = insertvalue ");
    parts = vec.push(parts, vec_ty);
    parts = vec.push(parts, " undef, i64 ");
    parts = vec.push(parts, llvm_local(prefix, ".ptr.int"));
    parts = vec.push(parts, ", 0\n  ");
    parts = vec.push(parts, llvm_local(prefix, ".vec.1"));
    parts = vec.push(parts, " = insertvalue ");
    parts = vec.push(parts, vec_ty);
    parts = vec.push(parts, " ");
    parts = vec.push(parts, llvm_local(prefix, ".vec.0"));
    parts = vec.push(parts, ", i64 ");
    parts = vec.push(parts, llvm_local(prefix, ".load.len"));
    parts = vec.push(parts, ", 1\n  ");
    parts = vec.push(parts, llvm_local(prefix, ".value"));
    parts = vec.push(parts, " = insertvalue ");
    parts = vec.push(parts, vec_ty);
    parts = vec.push(parts, " ");
    parts = vec.push(parts, llvm_local(prefix, ".vec.1"));
    parts = vec.push(parts, ", i64 ");
    parts = vec.push(parts, llvm_local(prefix, ".load.cap"));
    parts = vec.push(parts, ", 2\n");
    string.join(parts, "")
}

fn emit_vec_push_node_value(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], node: IrExprNode, locals: BackendLocals) -> String {
    match expr_node_child_at(nodes, node, 0) {
        Some(vec_child) => match expr_node_child_at(nodes, node, 1) {
            Some(value_child) => if true {
                let prefix = llvm_node_prefix(node.node);
                let vec_ty = vec_push_node_llvm_type(program, function_value, nodes, node, locals);
                let elem_ty = value_node_llvm_type(program, function_value, nodes, value_child, locals);
                let vec_name = node_value_name(program, function_value, nodes, vec_child, locals);
                let value_name = node_value_name(program, function_value, nodes, value_child, locals);
                let mut parts: Vec[String] = vec.new_vec();
                parts = vec.push(parts, emit_value_node(program, function_value, nodes, vec_child, locals));
                parts = vec.push(parts, emit_value_node(program, function_value, nodes, value_child, locals));
                parts = vec.push(parts, "  ");
                parts = vec.push(parts, llvm_local(prefix, ".ptr.int.in"));
                parts = vec.push(parts, " = extractvalue ");
                parts = vec.push(parts, vec_ty);
                parts = vec.push(parts, " ");
                parts = vec.push(parts, vec_name);
                parts = vec.push(parts, ", 0\n  ");
                parts = vec.push(parts, llvm_local(prefix, ".len.in"));
                parts = vec.push(parts, " = extractvalue ");
                parts = vec.push(parts, vec_ty);
                parts = vec.push(parts, " ");
                parts = vec.push(parts, vec_name);
                parts = vec.push(parts, ", 1\n  ");
                parts = vec.push(parts, llvm_local(prefix, ".cap.in"));
                parts = vec.push(parts, " = extractvalue ");
                parts = vec.push(parts, vec_ty);
                parts = vec.push(parts, " ");
                parts = vec.push(parts, vec_name);
                parts = vec.push(parts, ", 2\n  ");
                parts = vec.push(parts, llvm_local(prefix, ".ptr.in"));
                parts = vec.push(parts, " = inttoptr i64 ");
                parts = vec.push(parts, llvm_local(prefix, ".ptr.int.in"));
                parts = vec.push(parts, " to i8*\n  ");
                parts = vec.push(parts, llvm_local(prefix, ".ptr.slot"));
                parts = vec.push(parts, " = alloca i8*\n  ");
                parts = vec.push(parts, llvm_local(prefix, ".len.slot"));
                parts = vec.push(parts, " = alloca i64\n  ");
                parts = vec.push(parts, llvm_local(prefix, ".cap.slot"));
                parts = vec.push(parts, " = alloca i64\n  store i8* ");
                parts = vec.push(parts, llvm_local(prefix, ".ptr.in"));
                parts = vec.push(parts, ", i8** ");
                parts = vec.push(parts, llvm_local(prefix, ".ptr.slot"));
                parts = vec.push(parts, "\n  store i64 ");
                parts = vec.push(parts, llvm_local(prefix, ".len.in"));
                parts = vec.push(parts, ", i64* ");
                parts = vec.push(parts, llvm_local(prefix, ".len.slot"));
                parts = vec.push(parts, "\n  store i64 ");
                parts = vec.push(parts, llvm_local(prefix, ".cap.in"));
                parts = vec.push(parts, ", i64* ");
                parts = vec.push(parts, llvm_local(prefix, ".cap.slot"));
                parts = vec.push(parts, "\n  ");
                parts = vec.push(parts, llvm_local(prefix, ".elem.slot"));
                parts = vec.push(parts, " = alloca ");
                parts = vec.push(parts, elem_ty);
                parts = vec.push(parts, "\n  store ");
                parts = vec.push(parts, elem_ty);
                parts = vec.push(parts, " ");
                parts = vec.push(parts, value_name);
                parts = vec.push(parts, ", ");
                parts = vec.push(parts, elem_ty);
                parts = vec.push(parts, "* ");
                parts = vec.push(parts, llvm_local(prefix, ".elem.slot"));
                parts = vec.push(parts, "\n  ");
                parts = vec.push(parts, llvm_local(prefix, ".elem.ptr"));
                parts = vec.push(parts, " = bitcast ");
                parts = vec.push(parts, elem_ty);
                parts = vec.push(parts, "* ");
                parts = vec.push(parts, llvm_local(prefix, ".elem.slot"));
                parts = vec.push(parts, " to i8*\n  ");
                parts = vec.push(parts, llvm_local(prefix, ".elem.next"));
                parts = vec.push(parts, " = getelementptr ");
                parts = vec.push(parts, elem_ty);
                parts = vec.push(parts, ", ");
                parts = vec.push(parts, elem_ty);
                parts = vec.push(parts, "* null, i64 1\n  ");
                parts = vec.push(parts, llvm_local(prefix, ".elem.size"));
                parts = vec.push(parts, " = ptrtoint ");
                parts = vec.push(parts, elem_ty);
                parts = vec.push(parts, "* ");
                parts = vec.push(parts, llvm_local(prefix, ".elem.next"));
                parts = vec.push(parts, " to i64\n  ");
                parts = vec.push(parts, llvm_local(prefix, ".err"));
                parts = vec.push(parts, " = call i64 @aic_rt_vec_push(i8** ");
                parts = vec.push(parts, llvm_local(prefix, ".ptr.slot"));
                parts = vec.push(parts, ", i64* ");
                parts = vec.push(parts, llvm_local(prefix, ".len.slot"));
                parts = vec.push(parts, ", i64* ");
                parts = vec.push(parts, llvm_local(prefix, ".cap.slot"));
                parts = vec.push(parts, ", i64 ");
                parts = vec.push(parts, llvm_local(prefix, ".elem.size"));
                parts = vec.push(parts, ", i8* ");
                parts = vec.push(parts, llvm_local(prefix, ".elem.ptr"));
                parts = vec.push(parts, ")\n");
                parts = vec.push(parts, emit_vec_from_slots(prefix, vec_ty, llvm_local(prefix, ".ptr.slot"), llvm_local(prefix, ".len.slot"), llvm_local(prefix, ".cap.slot")));
                string.join(parts, "")
            } else { "" },
            None => "",
        },
        None => "",
    }
}

fn emit_vec_push_expr_value(program: IrProgram, function_value: IrFunctionDef, expr: IrExpr, locals: BackendLocals) -> String {
    match direct_expr_child_at(expr.nodes, 0) {
        Some(vec_child) => match direct_expr_child_at(expr.nodes, 1) {
            Some(value_child) => if true {
                let prefix = llvm_expr_prefix(expr.node);
                let vec_ty = vec_push_expr_llvm_type(program, expr, function_value, locals);
                let elem_ty = value_node_llvm_type(program, function_value, expr.nodes, value_child, locals);
                let vec_name = node_value_name(program, function_value, expr.nodes, vec_child, locals);
                let value_name = node_value_name(program, function_value, expr.nodes, value_child, locals);
                let mut parts: Vec[String] = vec.new_vec();
                parts = vec.push(parts, emit_value_node(program, function_value, expr.nodes, vec_child, locals));
                parts = vec.push(parts, emit_value_node(program, function_value, expr.nodes, value_child, locals));
                parts = vec.push(parts, "  ");
                parts = vec.push(parts, llvm_local(prefix, ".ptr.int.in"));
                parts = vec.push(parts, " = extractvalue ");
                parts = vec.push(parts, vec_ty);
                parts = vec.push(parts, " ");
                parts = vec.push(parts, vec_name);
                parts = vec.push(parts, ", 0\n  ");
                parts = vec.push(parts, llvm_local(prefix, ".len.in"));
                parts = vec.push(parts, " = extractvalue ");
                parts = vec.push(parts, vec_ty);
                parts = vec.push(parts, " ");
                parts = vec.push(parts, vec_name);
                parts = vec.push(parts, ", 1\n  ");
                parts = vec.push(parts, llvm_local(prefix, ".cap.in"));
                parts = vec.push(parts, " = extractvalue ");
                parts = vec.push(parts, vec_ty);
                parts = vec.push(parts, " ");
                parts = vec.push(parts, vec_name);
                parts = vec.push(parts, ", 2\n  ");
                parts = vec.push(parts, llvm_local(prefix, ".ptr.in"));
                parts = vec.push(parts, " = inttoptr i64 ");
                parts = vec.push(parts, llvm_local(prefix, ".ptr.int.in"));
                parts = vec.push(parts, " to i8*\n  ");
                parts = vec.push(parts, llvm_local(prefix, ".ptr.slot"));
                parts = vec.push(parts, " = alloca i8*\n  ");
                parts = vec.push(parts, llvm_local(prefix, ".len.slot"));
                parts = vec.push(parts, " = alloca i64\n  ");
                parts = vec.push(parts, llvm_local(prefix, ".cap.slot"));
                parts = vec.push(parts, " = alloca i64\n  store i8* ");
                parts = vec.push(parts, llvm_local(prefix, ".ptr.in"));
                parts = vec.push(parts, ", i8** ");
                parts = vec.push(parts, llvm_local(prefix, ".ptr.slot"));
                parts = vec.push(parts, "\n  store i64 ");
                parts = vec.push(parts, llvm_local(prefix, ".len.in"));
                parts = vec.push(parts, ", i64* ");
                parts = vec.push(parts, llvm_local(prefix, ".len.slot"));
                parts = vec.push(parts, "\n  store i64 ");
                parts = vec.push(parts, llvm_local(prefix, ".cap.in"));
                parts = vec.push(parts, ", i64* ");
                parts = vec.push(parts, llvm_local(prefix, ".cap.slot"));
                parts = vec.push(parts, "\n  ");
                parts = vec.push(parts, llvm_local(prefix, ".elem.slot"));
                parts = vec.push(parts, " = alloca ");
                parts = vec.push(parts, elem_ty);
                parts = vec.push(parts, "\n  store ");
                parts = vec.push(parts, elem_ty);
                parts = vec.push(parts, " ");
                parts = vec.push(parts, value_name);
                parts = vec.push(parts, ", ");
                parts = vec.push(parts, elem_ty);
                parts = vec.push(parts, "* ");
                parts = vec.push(parts, llvm_local(prefix, ".elem.slot"));
                parts = vec.push(parts, "\n  ");
                parts = vec.push(parts, llvm_local(prefix, ".elem.ptr"));
                parts = vec.push(parts, " = bitcast ");
                parts = vec.push(parts, elem_ty);
                parts = vec.push(parts, "* ");
                parts = vec.push(parts, llvm_local(prefix, ".elem.slot"));
                parts = vec.push(parts, " to i8*\n  ");
                parts = vec.push(parts, llvm_local(prefix, ".elem.next"));
                parts = vec.push(parts, " = getelementptr ");
                parts = vec.push(parts, elem_ty);
                parts = vec.push(parts, ", ");
                parts = vec.push(parts, elem_ty);
                parts = vec.push(parts, "* null, i64 1\n  ");
                parts = vec.push(parts, llvm_local(prefix, ".elem.size"));
                parts = vec.push(parts, " = ptrtoint ");
                parts = vec.push(parts, elem_ty);
                parts = vec.push(parts, "* ");
                parts = vec.push(parts, llvm_local(prefix, ".elem.next"));
                parts = vec.push(parts, " to i64\n  ");
                parts = vec.push(parts, llvm_local(prefix, ".err"));
                parts = vec.push(parts, " = call i64 @aic_rt_vec_push(i8** ");
                parts = vec.push(parts, llvm_local(prefix, ".ptr.slot"));
                parts = vec.push(parts, ", i64* ");
                parts = vec.push(parts, llvm_local(prefix, ".len.slot"));
                parts = vec.push(parts, ", i64* ");
                parts = vec.push(parts, llvm_local(prefix, ".cap.slot"));
                parts = vec.push(parts, ", i64 ");
                parts = vec.push(parts, llvm_local(prefix, ".elem.size"));
                parts = vec.push(parts, ", i8* ");
                parts = vec.push(parts, llvm_local(prefix, ".elem.ptr"));
                parts = vec.push(parts, ")\n");
                parts = vec.push(parts, emit_vec_from_slots(prefix, vec_ty, llvm_local(prefix, ".ptr.slot"), llvm_local(prefix, ".len.slot"), llvm_local(prefix, ".cap.slot")));
                string.join(parts, "")
            } else { "" },
            None => "",
        },
        None => "",
    }
}

fn vec_get_loaded_name(prefix: String) -> String {
    llvm_local(prefix, ".loaded")
}

fn vec_get_found_bool_name(prefix: String) -> String {
    llvm_local(prefix, ".found.ok")
}

fn emit_vec_get_probe(prefix: String, vec_ty: String, elem_ty: String, vec_value: String, index_value: String) -> String {
    let mut parts: Vec[String] = vec.new_vec();
    parts = vec.push(parts, "  ");
    parts = vec.push(parts, llvm_local(prefix, ".ptr.int"));
    parts = vec.push(parts, " = extractvalue ");
    parts = vec.push(parts, vec_ty);
    parts = vec.push(parts, " ");
    parts = vec.push(parts, vec_value);
    parts = vec.push(parts, ", 0\n  ");
    parts = vec.push(parts, llvm_local(prefix, ".len"));
    parts = vec.push(parts, " = extractvalue ");
    parts = vec.push(parts, vec_ty);
    parts = vec.push(parts, " ");
    parts = vec.push(parts, vec_value);
    parts = vec.push(parts, ", 1\n  ");
    parts = vec.push(parts, llvm_local(prefix, ".cap"));
    parts = vec.push(parts, " = extractvalue ");
    parts = vec.push(parts, vec_ty);
    parts = vec.push(parts, " ");
    parts = vec.push(parts, vec_value);
    parts = vec.push(parts, ", 2\n  ");
    parts = vec.push(parts, llvm_local(prefix, ".ptr"));
    parts = vec.push(parts, " = inttoptr i64 ");
    parts = vec.push(parts, llvm_local(prefix, ".ptr.int"));
    parts = vec.push(parts, " to i8*\n  ");
    parts = vec.push(parts, llvm_local(prefix, ".elem.slot"));
    parts = vec.push(parts, " = alloca ");
    parts = vec.push(parts, elem_ty);
    parts = vec.push(parts, "\n  ");
    parts = vec.push(parts, llvm_local(prefix, ".elem.ptr"));
    parts = vec.push(parts, " = bitcast ");
    parts = vec.push(parts, elem_ty);
    parts = vec.push(parts, "* ");
    parts = vec.push(parts, llvm_local(prefix, ".elem.slot"));
    parts = vec.push(parts, " to i8*\n  ");
    parts = vec.push(parts, llvm_local(prefix, ".elem.next"));
    parts = vec.push(parts, " = getelementptr ");
    parts = vec.push(parts, elem_ty);
    parts = vec.push(parts, ", ");
    parts = vec.push(parts, elem_ty);
    parts = vec.push(parts, "* null, i64 1\n  ");
    parts = vec.push(parts, llvm_local(prefix, ".elem.size"));
    parts = vec.push(parts, " = ptrtoint ");
    parts = vec.push(parts, elem_ty);
    parts = vec.push(parts, "* ");
    parts = vec.push(parts, llvm_local(prefix, ".elem.next"));
    parts = vec.push(parts, " to i64\n  ");
    parts = vec.push(parts, llvm_local(prefix, ".found"));
    parts = vec.push(parts, " = call i64 @aic_rt_vec_get(i8* ");
    parts = vec.push(parts, llvm_local(prefix, ".ptr"));
    parts = vec.push(parts, ", i64 ");
    parts = vec.push(parts, llvm_local(prefix, ".len"));
    parts = vec.push(parts, ", i64 ");
    parts = vec.push(parts, llvm_local(prefix, ".cap"));
    parts = vec.push(parts, ", i64 ");
    parts = vec.push(parts, index_value);
    parts = vec.push(parts, ", i64 ");
    parts = vec.push(parts, llvm_local(prefix, ".elem.size"));
    parts = vec.push(parts, ", i8* ");
    parts = vec.push(parts, llvm_local(prefix, ".elem.ptr"));
    parts = vec.push(parts, ")\n  ");
    parts = vec.push(parts, vec_get_found_bool_name(prefix));
    parts = vec.push(parts, " = icmp ne i64 ");
    parts = vec.push(parts, llvm_local(prefix, ".found"));
    parts = vec.push(parts, ", 0\n  ");
    parts = vec.push(parts, vec_get_loaded_name(prefix));
    parts = vec.push(parts, " = load ");
    parts = vec.push(parts, elem_ty);
    parts = vec.push(parts, ", ");
    parts = vec.push(parts, elem_ty);
    parts = vec.push(parts, "* ");
    parts = vec.push(parts, llvm_local(prefix, ".elem.slot"));
    parts = vec.push(parts, "\n");
    string.join(parts, "")
}

fn emit_option_value_from_vec_get_probe(program: IrProgram, prefix: String, option_ty: String, elem_ty: String) -> String {
    let some_label = concat2("option.some.", prefix);
    let none_label = concat2("option.none.", prefix);
    let cont_label = concat2("option.cont.", prefix);
    let mut parts: Vec[String] = vec.new_vec();
    parts = vec.push(parts, "  ");
    parts = vec.push(parts, llvm_local(prefix, ".option.slot"));
    parts = vec.push(parts, " = alloca ");
    parts = vec.push(parts, option_ty);
    parts = vec.push(parts, "\n  br i1 ");
    parts = vec.push(parts, vec_get_found_bool_name(prefix));
    parts = vec.push(parts, ", label %");
    parts = vec.push(parts, some_label);
    parts = vec.push(parts, ", label %");
    parts = vec.push(parts, none_label);
    parts = vec.push(parts, "\n");
    parts = vec.push(parts, some_label);
    parts = vec.push(parts, ":\n  ");
    parts = vec.push(parts, llvm_local(prefix, ".some.0"));
    parts = vec.push(parts, " = insertvalue ");
    parts = vec.push(parts, option_ty);
    parts = vec.push(parts, " undef, i32 ");
    parts = vec.push(parts, string.int_to_string(enum_variant_index(program, "Option", "Some")));
    parts = vec.push(parts, ", 0\n  ");
    parts = vec.push(parts, llvm_local(prefix, ".some.1"));
    parts = vec.push(parts, " = insertvalue ");
    parts = vec.push(parts, option_ty);
    parts = vec.push(parts, " ");
    parts = vec.push(parts, llvm_local(prefix, ".some.0"));
    parts = vec.push(parts, ", ");
    parts = vec.push(parts, elem_ty);
    parts = vec.push(parts, " ");
    parts = vec.push(parts, vec_get_loaded_name(prefix));
    parts = vec.push(parts, ", 1\n  store ");
    parts = vec.push(parts, option_ty);
    parts = vec.push(parts, " ");
    parts = vec.push(parts, llvm_local(prefix, ".some.1"));
    parts = vec.push(parts, ", ");
    parts = vec.push(parts, option_ty);
    parts = vec.push(parts, "* ");
    parts = vec.push(parts, llvm_local(prefix, ".option.slot"));
    parts = vec.push(parts, "\n  br label %");
    parts = vec.push(parts, cont_label);
    parts = vec.push(parts, "\n");
    parts = vec.push(parts, none_label);
    parts = vec.push(parts, ":\n  ");
    parts = vec.push(parts, llvm_local(prefix, ".none.0"));
    parts = vec.push(parts, " = insertvalue ");
    parts = vec.push(parts, option_ty);
    parts = vec.push(parts, " undef, i32 ");
    parts = vec.push(parts, string.int_to_string(enum_variant_index(program, "Option", "None")));
    parts = vec.push(parts, ", 0\n  store ");
    parts = vec.push(parts, option_ty);
    parts = vec.push(parts, " ");
    parts = vec.push(parts, llvm_local(prefix, ".none.0"));
    parts = vec.push(parts, ", ");
    parts = vec.push(parts, option_ty);
    parts = vec.push(parts, "* ");
    parts = vec.push(parts, llvm_local(prefix, ".option.slot"));
    parts = vec.push(parts, "\n  br label %");
    parts = vec.push(parts, cont_label);
    parts = vec.push(parts, "\n");
    parts = vec.push(parts, cont_label);
    parts = vec.push(parts, ":\n  ");
    parts = vec.push(parts, llvm_local(prefix, ".value"));
    parts = vec.push(parts, " = load ");
    parts = vec.push(parts, option_ty);
    parts = vec.push(parts, ", ");
    parts = vec.push(parts, option_ty);
    parts = vec.push(parts, "* ");
    parts = vec.push(parts, llvm_local(prefix, ".option.slot"));
    parts = vec.push(parts, "\n");
    string.join(parts, "")
}

fn emit_vec_get_node_value(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], node: IrExprNode, locals: BackendLocals) -> String {
    match expr_node_child_at(nodes, node, 0) {
        Some(vec_child) => match expr_node_child_at(nodes, node, 1) {
            Some(index_child) => if true {
                let prefix = llvm_node_prefix(node.node);
                let vec_ty = value_node_llvm_type(program, function_value, nodes, vec_child, locals);
                let option_ty = vec_get_node_llvm_type(program, function_value, nodes, node, locals);
                let elem_ty = vec_get_node_payload_llvm_type(program, function_value, nodes, node, locals);
                let mut parts: Vec[String] = vec.new_vec();
                parts = vec.push(parts, emit_value_node(program, function_value, nodes, vec_child, locals));
                parts = vec.push(parts, emit_value_node(program, function_value, nodes, index_child, locals));
                parts = vec.push(parts, emit_vec_get_probe(prefix, vec_ty, elem_ty, node_value_name(program, function_value, nodes, vec_child, locals), node_value_name(program, function_value, nodes, index_child, locals)));
                parts = vec.push(parts, emit_option_value_from_vec_get_probe(program, prefix, option_ty, elem_ty));
                string.join(parts, "")
            } else { "" },
            None => "",
        },
        None => "",
    }
}

fn emit_vec_get_expr_value(program: IrProgram, function_value: IrFunctionDef, expr: IrExpr, locals: BackendLocals) -> String {
    match direct_expr_child_at(expr.nodes, 0) {
        Some(vec_child) => match direct_expr_child_at(expr.nodes, 1) {
            Some(index_child) => if true {
                let prefix = llvm_expr_prefix(expr.node);
                let vec_ty = value_node_llvm_type(program, function_value, expr.nodes, vec_child, locals);
                let option_ty = vec_get_expr_llvm_type(program, expr, function_value, locals);
                let elem_ty = vec_get_expr_payload_llvm_type(program, expr, function_value, locals);
                let mut parts: Vec[String] = vec.new_vec();
                parts = vec.push(parts, emit_value_node(program, function_value, expr.nodes, vec_child, locals));
                parts = vec.push(parts, emit_value_node(program, function_value, expr.nodes, index_child, locals));
                parts = vec.push(parts, emit_vec_get_probe(prefix, vec_ty, elem_ty, node_value_name(program, function_value, expr.nodes, vec_child, locals), node_value_name(program, function_value, expr.nodes, index_child, locals)));
                parts = vec.push(parts, emit_option_value_from_vec_get_probe(program, prefix, option_ty, elem_ty));
                string.join(parts, "")
            } else { "" },
            None => "",
        },
        None => "",
    }
}

fn enum_variant_value_name(prefix: String) -> String {
    llvm_local(prefix, ".value")
}

fn enum_variant_child_value_name(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], child: IrExprNode, locals: BackendLocals, expected: String) -> String {
    if expected == "%aic.String" {
        string_node_value_name_with_locals(function_value, locals, child)
    } else if expected_vec_new_vec_node_can_emit(child, expected) {
        llvm_node_value_local(child)
    } else {
        node_value_name(program, function_value, nodes, child, locals)
    }
}

fn emit_enum_variant_child_value(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], child: IrExprNode, locals: BackendLocals, expected: String) -> String {
    if expected == "%aic.String" {
        emit_string_node_value(program, function_value, nodes, child, locals)
    } else if expected_vec_new_vec_node_can_emit(child, expected) {
        emit_empty_vec_value(llvm_node_prefix(child.node), expected)
    } else {
        emit_value_node(program, function_value, nodes, child, locals)
    }
}

fn emit_enum_variant_constructor_slots(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], variant_name: String, prefix: String, locals: BackendLocals, payload_child: Option[IrExprNode]) -> String {
    let parent_name = enum_variant_parent_name(program, variant_name);
    let variant_index = enum_variant_index(program, parent_name, variant_name);
    let enum_ty = enum_variant_constructor_llvm_type(program, variant_name);
    let variant_count = enum_variant_count(program, parent_name);
    let mut parts: Vec[String] = vec.new_vec();
    parts = vec.push(parts, "  ");
    parts = vec.push(parts, llvm_local(prefix, ".tag"));
    parts = vec.push(parts, " = insertvalue ");
    parts = vec.push(parts, enum_ty);
    parts = vec.push(parts, " undef, i32 ");
    parts = vec.push(parts, string.int_to_string(variant_index));
    parts = vec.push(parts, ", 0\n");
    let mut previous = llvm_local(prefix, ".tag");
    let mut index = 0;
    while index < variant_count {
        let slot_ty = enum_variant_slot_llvm_type(program, parent_name, index);
        let slot_value = if index == variant_index {
            match payload_child {
                Some(child) => enum_variant_child_value_name(program, function_value, nodes, child, locals, slot_ty),
                None => if slot_ty == "i8" { "0" } else { "undef" },
            }
        } else {
            if slot_ty == "i8" { "0" } else { "undef" }
        };
        let slot_local = if index + 1 == variant_count {
            enum_variant_value_name(prefix)
        } else {
            llvm_local(prefix, concat2(".slot.", string.int_to_string(index)))
        };
        parts = vec.push(parts, "  ");
        parts = vec.push(parts, slot_local);
        parts = vec.push(parts, " = insertvalue ");
        parts = vec.push(parts, enum_ty);
        parts = vec.push(parts, " ");
        parts = vec.push(parts, previous);
        parts = vec.push(parts, ", ");
        parts = vec.push(parts, slot_ty);
        parts = vec.push(parts, " ");
        parts = vec.push(parts, slot_value);
        parts = vec.push(parts, ", ");
        parts = vec.push(parts, string.int_to_string(index + 1));
        parts = vec.push(parts, "\n");
        previous = slot_local;
        index = index + 1;
    };
    string.join(parts, "")
}

fn emit_enum_variant_constructor_node_value(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], node: IrExprNode, locals: BackendLocals) -> String {
    let parent_name = enum_variant_parent_name(program, node.name);
    let payload_name = enum_variant_payload_type_name(program, parent_name, node.name);
    let payload_child: Option[IrExprNode] = if payload_name == "" || payload_name == "()" {
        None()
    } else {
        expr_node_child_at(nodes, node, 0)
    };
    let prefix = llvm_node_prefix(node.node);
    let mut parts: Vec[String] = vec.new_vec();
    match payload_child {
        Some(child) => if true {
            parts = vec.push(parts, emit_enum_variant_child_value(program, function_value, nodes, child, locals, llvm_payload_slot_type(program, payload_name)));
            ()
        } else {
            ()
        },
        None => (),
    };
    parts = vec.push(parts, emit_enum_variant_constructor_slots(program, function_value, nodes, node.name, prefix, locals, payload_child));
    string.join(parts, "")
}

fn emit_enum_variant_constructor_expr_value(program: IrProgram, function_value: IrFunctionDef, expr: IrExpr, locals: BackendLocals) -> String {
    let parent_name = enum_variant_parent_name(program, expr.name);
    let payload_name = enum_variant_payload_type_name(program, parent_name, expr.name);
    let payload_child: Option[IrExprNode] = if payload_name == "" || payload_name == "()" {
        None()
    } else {
        direct_expr_child_at(expr.nodes, 0)
    };
    let prefix = llvm_expr_prefix(expr.node);
    let mut parts: Vec[String] = vec.new_vec();
    match payload_child {
        Some(child) => if true {
            parts = vec.push(parts, emit_enum_variant_child_value(program, function_value, expr.nodes, child, locals, llvm_payload_slot_type(program, payload_name)));
            ()
        } else {
            ()
        },
        None => (),
    };
    parts = vec.push(parts, emit_enum_variant_constructor_slots(program, function_value, expr.nodes, expr.name, prefix, locals, payload_child));
    string.join(parts, "")
}

fn emit_value_node(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], node: IrExprNode, locals: BackendLocals) -> String {
    match node.kind {
        IrNameExpr => emit_load_name_node_value(program, function_value, node, locals),
        IrStringExpr => emit_string_node_value(program, function_value, nodes, node, locals),
        IrFieldAccessExpr => emit_field_access_node_value(program, function_value, nodes, node, locals),
        IrBinaryExpr => emit_binary_node_value(program, function_value, nodes, node, locals),
        IrUnaryExpr => if node.op == "-" {
            emit_unary_int_node_value(program, function_value, nodes, node, locals)
        } else {
            emit_unary_bool_node_value(program, function_value, nodes, node, locals)
        },
        IrCallExpr => if node.name == "string.replace" {
            emit_string_replace_node_value(program, function_value, nodes, node, locals)
        } else if is_string_join_intrinsic_name(node.name) {
            emit_string_join_node_value(program, function_value, nodes, node, locals)
        } else if is_string_split_intrinsic_name(node.name) {
            emit_string_split_node_value(program, function_value, nodes, node, locals)
        } else if is_string_trim_intrinsic_name(node.name) {
            emit_string_trim_node_value(program, function_value, nodes, node, locals)
        } else if is_string_char_at_intrinsic_name(node.name) {
            emit_string_char_at_node_value(program, function_value, nodes, node, locals)
        } else if is_string_int_to_string_intrinsic_name(node.name) {
            emit_string_int_to_string_node_value(program, function_value, nodes, node, locals)
        } else if is_string_len_intrinsic_name(node.name) {
            emit_string_len_node_value(program, function_value, nodes, node, locals)
        } else if is_vec_len_intrinsic_name(node.name) {
            emit_vec_len_node_value(program, function_value, nodes, node, locals)
        } else if is_string_slice_intrinsic_name(node.name) {
            emit_string_slice_node_value(program, function_value, nodes, node, locals)
        } else if node.name == "vec.new_vec" {
            emit_empty_vec_value(llvm_node_prefix(node.node), vec_new_vec_node_llvm_type(program, node))
        } else if node.name == "vec.push" {
            emit_vec_push_node_value(program, function_value, nodes, node, locals)
        } else if is_vec_get_intrinsic_name(node.name) {
            emit_vec_get_node_value(program, function_value, nodes, node, locals)
        } else if enum_variant_constructor_node_can_emit(program, function_value, nodes, node, locals) {
            emit_enum_variant_constructor_node_value(program, function_value, nodes, node, locals)
        } else {
            emit_direct_call_node_value(program, function_value, nodes, node, locals)
        },
        IrIfExpr => emit_if_node_value(program, function_value, nodes, node, locals),
        IrLoopExpr => emit_loop_node_value(program, function_value, nodes, node, locals),
        IrMatchExpr => if option_vec_get_match_node_type_name(program, function_value, nodes, node, locals) != "" {
            emit_option_vec_get_match_node_value(program, function_value, nodes, node, locals)
        } else if option_match_node_type_name(program, function_value, nodes, node, locals) != "" {
            emit_option_match_node_value(program, function_value, nodes, node, locals)
        } else if result_string_match_node_can_emit(program, function_value, nodes, node, locals) {
            emit_result_string_match_node_value(program, function_value, nodes, node, locals)
        } else if enum_match_node_type_name(program, function_value, nodes, node, locals) != "" {
            emit_enum_match_node_value(program, function_value, nodes, node, locals)
        } else if enum_bool_match_node_can_emit(program, function_value, nodes, node, locals) {
            emit_enum_bool_match_node_value(program, function_value, nodes, node, locals)
        } else {
            emit_result_string_match_node_value(program, function_value, nodes, node, locals)
        },
        IrStructLiteralExpr => emit_struct_literal_node_value(program, function_value, nodes, node, locals, value_node_llvm_type(program, function_value, nodes, node, locals)),
        _ => "",
    }
}

fn emit_string_replace_expr_value(program: IrProgram, function_value: IrFunctionDef, expr: IrExpr, locals: BackendLocals) -> String {
    let mut parts: Vec[String] = vec.new_vec();
    let first = match direct_expr_child_at(expr.nodes, 0) {
        Some(child) => if true {
            parts = vec.push(parts, emit_string_node_value(program, function_value, expr.nodes, child, locals));
            string_node_value_name_with_locals(function_value, locals, child)
        } else { "" },
        None => "",
    };
    let second = match direct_expr_child_at(expr.nodes, 1) {
        Some(child) => if true {
            parts = vec.push(parts, emit_string_node_value(program, function_value, expr.nodes, child, locals));
            string_node_value_name_with_locals(function_value, locals, child)
        } else { "" },
        None => "",
    };
    let third = match direct_expr_child_at(expr.nodes, 2) {
        Some(child) => if true {
            parts = vec.push(parts, emit_string_node_value(program, function_value, expr.nodes, child, locals));
            string_node_value_name_with_locals(function_value, locals, child)
        } else { "" },
        None => "",
    };
    parts = vec.push(parts, emit_string_replace_call(llvm_expr_prefix(expr.node), first, second, third));
    string.join(parts, "")
}

fn emit_string_join_expr_value(program: IrProgram, function_value: IrFunctionDef, expr: IrExpr, locals: BackendLocals) -> String {
    let mut parts: Vec[String] = vec.new_vec();
    let parts_value = match direct_expr_child_at(expr.nodes, 0) {
        Some(child) => if true {
            parts = vec.push(parts, emit_value_node(program, function_value, expr.nodes, child, locals));
            node_value_name(program, function_value, expr.nodes, child, locals)
        } else { "" },
        None => "",
    };
    let separator_value = match direct_expr_child_at(expr.nodes, 1) {
        Some(child) => if true {
            parts = vec.push(parts, emit_string_node_value(program, function_value, expr.nodes, child, locals));
            string_node_value_name_with_locals(function_value, locals, child)
        } else { "" },
        None => "",
    };
    parts = vec.push(parts, emit_string_join_call(llvm_expr_prefix(expr.node), parts_value, separator_value));
    string.join(parts, "")
}

fn emit_string_split_node_value(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], node: IrExprNode, locals: BackendLocals) -> String {
    let mut parts: Vec[String] = vec.new_vec();
    let text_value = match expr_node_child_at(nodes, node, 0) {
        Some(child) => if true {
            parts = vec.push(parts, emit_string_node_value(program, function_value, nodes, child, locals));
            string_node_value_name_with_locals(function_value, locals, child)
        } else { "" },
        None => "",
    };
    let delimiter_value = match expr_node_child_at(nodes, node, 1) {
        Some(child) => if true {
            parts = vec.push(parts, emit_string_node_value(program, function_value, nodes, child, locals));
            string_node_value_name_with_locals(function_value, locals, child)
        } else { "" },
        None => "",
    };
    parts = vec.push(parts, emit_string_split_call(llvm_node_prefix(node.node), text_value, delimiter_value));
    string.join(parts, "")
}

fn emit_string_split_expr_value(program: IrProgram, function_value: IrFunctionDef, expr: IrExpr, locals: BackendLocals) -> String {
    let mut parts: Vec[String] = vec.new_vec();
    let text_value = match direct_expr_child_at(expr.nodes, 0) {
        Some(child) => if true {
            parts = vec.push(parts, emit_string_node_value(program, function_value, expr.nodes, child, locals));
            string_node_value_name_with_locals(function_value, locals, child)
        } else { "" },
        None => "",
    };
    let delimiter_value = match direct_expr_child_at(expr.nodes, 1) {
        Some(child) => if true {
            parts = vec.push(parts, emit_string_node_value(program, function_value, expr.nodes, child, locals));
            string_node_value_name_with_locals(function_value, locals, child)
        } else { "" },
        None => "",
    };
    parts = vec.push(parts, emit_string_split_call(llvm_expr_prefix(expr.node), text_value, delimiter_value));
    string.join(parts, "")
}

fn emit_string_trim_node_value(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], node: IrExprNode, locals: BackendLocals) -> String {
    match expr_node_child_at(nodes, node, 0) {
        Some(child) => if true {
            let value_name = string_node_value_name_with_locals(function_value, locals, child);
            let mut parts: Vec[String] = vec.new_vec();
            parts = vec.push(parts, emit_string_node_value(program, function_value, nodes, child, locals));
            parts = vec.push(parts, emit_string_trim_call(llvm_node_prefix(node.node), value_name));
            string.join(parts, "")
        } else { "" },
        None => "",
    }
}

fn emit_string_trim_expr_value(program: IrProgram, function_value: IrFunctionDef, expr: IrExpr, locals: BackendLocals) -> String {
    match direct_expr_child_at(expr.nodes, 0) {
        Some(child) => if true {
            let value_name = string_node_value_name_with_locals(function_value, locals, child);
            let mut parts: Vec[String] = vec.new_vec();
            parts = vec.push(parts, emit_string_node_value(program, function_value, expr.nodes, child, locals));
            parts = vec.push(parts, emit_string_trim_call(llvm_expr_prefix(expr.node), value_name));
            string.join(parts, "")
        } else { "" },
        None => "",
    }
}

fn emit_string_char_at_node_value(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], node: IrExprNode, locals: BackendLocals) -> String {
    match expr_node_child_at(nodes, node, 0) {
        Some(text_child) => match expr_node_child_at(nodes, node, 1) {
            Some(index_child) => if true {
                let text_value = string_node_value_name_with_locals(function_value, locals, text_child);
                let index_value = node_value_name(program, function_value, nodes, index_child, locals);
                let mut parts: Vec[String] = vec.new_vec();
                parts = vec.push(parts, emit_string_node_value(program, function_value, nodes, text_child, locals));
                parts = vec.push(parts, emit_value_node(program, function_value, nodes, index_child, locals));
                parts = vec.push(parts, emit_string_char_at_call(program, llvm_node_prefix(node.node), text_value, index_value));
                string.join(parts, "")
            } else { "" },
            None => "",
        },
        None => "",
    }
}

fn emit_string_char_at_expr_value(program: IrProgram, function_value: IrFunctionDef, expr: IrExpr, locals: BackendLocals) -> String {
    match direct_expr_child_at(expr.nodes, 0) {
        Some(text_child) => match direct_expr_child_at(expr.nodes, 1) {
            Some(index_child) => if true {
                let text_value = string_node_value_name_with_locals(function_value, locals, text_child);
                let index_value = node_value_name(program, function_value, expr.nodes, index_child, locals);
                let mut parts: Vec[String] = vec.new_vec();
                parts = vec.push(parts, emit_string_node_value(program, function_value, expr.nodes, text_child, locals));
                parts = vec.push(parts, emit_value_node(program, function_value, expr.nodes, index_child, locals));
                parts = vec.push(parts, emit_string_char_at_call(program, llvm_expr_prefix(expr.node), text_value, index_value));
                string.join(parts, "")
            } else { "" },
            None => "",
        },
        None => "",
    }
}

fn emit_string_int_to_string_node_value(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], node: IrExprNode, locals: BackendLocals) -> String {
    match expr_node_child_at(nodes, node, 0) {
        Some(child) => if true {
            let value_name = node_value_name(program, function_value, nodes, child, locals);
            let mut parts: Vec[String] = vec.new_vec();
            parts = vec.push(parts, emit_value_node(program, function_value, nodes, child, locals));
            parts = vec.push(parts, emit_string_int_to_string_call(llvm_node_prefix(node.node), value_name));
            string.join(parts, "")
        } else { "" },
        None => "",
    }
}

fn emit_string_int_to_string_expr_value(program: IrProgram, function_value: IrFunctionDef, expr: IrExpr, locals: BackendLocals) -> String {
    match direct_expr_child_at(expr.nodes, 0) {
        Some(child) => if true {
            let value_name = node_value_name(program, function_value, expr.nodes, child, locals);
            let mut parts: Vec[String] = vec.new_vec();
            parts = vec.push(parts, emit_value_node(program, function_value, expr.nodes, child, locals));
            parts = vec.push(parts, emit_string_int_to_string_call(llvm_expr_prefix(expr.node), value_name));
            string.join(parts, "")
        } else { "" },
        None => "",
    }
}

fn emit_string_direct_call_expr_value(program: IrProgram, function_value: IrFunctionDef, expr: IrExpr, locals: BackendLocals) -> String {
    let mut parts: Vec[String] = vec.new_vec();
    parts = vec.push(parts, emit_call_arg_values(program, function_value, expr.nodes, expr.name, locals));
    parts = vec.push(parts, "  ");
    parts = vec.push(parts, llvm_expr_value_local(expr));
    parts = vec.push(parts, " = call %aic.String @");
    parts = vec.push(parts, backend_mangle_symbol(expr.name));
    parts = vec.push(parts, "(");
    parts = vec.push(parts, emit_call_args(program, function_value, expr.nodes, expr.name, locals));
    parts = vec.push(parts, ")\n");
    string.join(parts, "")
}

fn bool_node_value_name_with_locals(function_value: IrFunctionDef, locals: BackendLocals, node: IrExprNode) -> String {
    match node.kind {
        IrBoolExpr => bool_literal_llvm_text(node.text, node.name),
        IrNameExpr => if name_uses_storage(locals, node.text) { loaded_node_name(node) } else { value_name_for_name(function_value, locals, node.text) },
        _ => llvm_node_value_local(node),
    }
}

fn bool_node_value_name(node: IrExprNode) -> String {
    match node.kind {
        IrBoolExpr => bool_literal_llvm_text(node.text, node.name),
        IrNameExpr => concat2("%", backend_mangle_symbol(node.text)),
        _ => llvm_node_value_local(node),
    }
}

fn emit_logical_node_value(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], node: IrExprNode, locals: BackendLocals) -> String {
    match expr_node_child_at(nodes, node, 0) {
        Some(left) => match expr_node_child_at(nodes, node, 1) {
            Some(right) => if true {
                let mut parts: Vec[String] = vec.new_vec();
                parts = vec.push(parts, emit_bool_node_value(program, function_value, nodes, left, locals));
                parts = vec.push(parts, emit_bool_node_value(program, function_value, nodes, right, locals));
                parts = vec.push(parts, "  ");
                parts = vec.push(parts, llvm_node_value_local(node));
                parts = vec.push(parts, " = ");
                parts = vec.push(parts, bool_llvm_op(node.op));
                parts = vec.push(parts, " i1 ");
                parts = vec.push(parts, bool_node_value_name_with_locals(function_value, locals, left));
                parts = vec.push(parts, ", ");
                parts = vec.push(parts, bool_node_value_name_with_locals(function_value, locals, right));
                parts = vec.push(parts, "\n");
                string.join(parts, "")
            } else { "" },
            None => "",
        },
        None => "",
    }
}

fn emit_unary_bool_node_value(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], node: IrExprNode, locals: BackendLocals) -> String {
    match expr_node_child_at(nodes, node, 0) {
        Some(child) => if node.op == "!" {
            let mut parts: Vec[String] = vec.new_vec();
            parts = vec.push(parts, emit_bool_node_value(program, function_value, nodes, child, locals));
            parts = vec.push(parts, "  ");
            parts = vec.push(parts, llvm_node_value_local(node));
            parts = vec.push(parts, " = xor i1 ");
            parts = vec.push(parts, bool_node_value_name_with_locals(function_value, locals, child));
            parts = vec.push(parts, ", 1\n");
            string.join(parts, "")
        } else {
            ""
        },
        None => "",
    }
}

fn emit_unary_bool_expr_value(program: IrProgram, function_value: IrFunctionDef, expr: IrExpr, locals: BackendLocals) -> String {
    match direct_expr_child_at(expr.nodes, 0) {
        Some(child) => if expr.op == "!" {
            let mut parts: Vec[String] = vec.new_vec();
            parts = vec.push(parts, emit_bool_node_value(program, function_value, expr.nodes, child, locals));
            parts = vec.push(parts, "  ");
            parts = vec.push(parts, llvm_expr_value_local(expr));
            parts = vec.push(parts, " = xor i1 ");
            parts = vec.push(parts, bool_node_value_name_with_locals(function_value, locals, child));
            parts = vec.push(parts, ", 1\n");
            string.join(parts, "")
        } else {
            ""
        },
        None => "",
    }
}

fn emit_unary_int_node_value(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], node: IrExprNode, locals: BackendLocals) -> String {
    match expr_node_child_at(nodes, node, 0) {
        Some(child) => if node.op == "-" {
            let mut parts: Vec[String] = vec.new_vec();
            parts = vec.push(parts, emit_value_node(program, function_value, nodes, child, locals));
            parts = vec.push(parts, "  ");
            parts = vec.push(parts, llvm_node_value_local(node));
            parts = vec.push(parts, " = sub i64 0, ");
            parts = vec.push(parts, node_value_name(program, function_value, nodes, child, locals));
            parts = vec.push(parts, "\n");
            string.join(parts, "")
        } else {
            ""
        },
        None => "",
    }
}

fn emit_unary_int_expr_value(program: IrProgram, function_value: IrFunctionDef, expr: IrExpr, locals: BackendLocals) -> String {
    match direct_expr_child_at(expr.nodes, 0) {
        Some(child) => if expr.op == "-" {
            let mut parts: Vec[String] = vec.new_vec();
            parts = vec.push(parts, emit_value_node(program, function_value, expr.nodes, child, locals));
            parts = vec.push(parts, "  ");
            parts = vec.push(parts, llvm_expr_value_local(expr));
            parts = vec.push(parts, " = sub i64 0, ");
            parts = vec.push(parts, node_value_name(program, function_value, expr.nodes, child, locals));
            parts = vec.push(parts, "\n");
            string.join(parts, "")
        } else {
            ""
        },
        None => "",
    }
}

fn emit_bool_node_value(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], node: IrExprNode, locals: BackendLocals) -> String {
    match node.kind {
        IrBoolExpr => "",
        IrNameExpr => emit_load_name_node_value(program, function_value, node, locals),
        IrFieldAccessExpr => emit_field_access_node_value(program, function_value, nodes, node, locals),
        IrUnaryExpr => emit_unary_bool_node_value(program, function_value, nodes, node, locals),
        IrCallExpr => if is_string_bool_intrinsic_name(node.name) {
            emit_string_bool_node_value(program, function_value, nodes, node, locals)
        } else {
            emit_direct_call_node_value(program, function_value, nodes, node, locals)
        },
        IrBinaryExpr => if binary_logical_op_can_emit(node.op) {
            emit_logical_node_value(program, function_value, nodes, node, locals)
        } else {
            emit_compare_node_value(program, function_value, nodes, node, locals)
        },
        IrIfExpr => emit_if_node_value(program, function_value, nodes, node, locals),
        IrMatchExpr => if option_vec_get_match_node_type_name(program, function_value, nodes, node, locals) != "" {
            emit_option_vec_get_match_node_value(program, function_value, nodes, node, locals)
        } else if option_match_node_type_name(program, function_value, nodes, node, locals) != "" {
            emit_option_match_node_value(program, function_value, nodes, node, locals)
        } else {
            emit_enum_bool_match_node_value(program, function_value, nodes, node, locals)
        },
        _ => "",
    }
}

fn emit_string_bool_node_value(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], node: IrExprNode, locals: BackendLocals) -> String {
    match expr_node_child_at(nodes, node, 0) {
        Some(left) => match expr_node_child_at(nodes, node, 1) {
            Some(right) => if true {
                let left_name = string_node_value_name_with_locals(function_value, locals, left);
                let right_name = string_node_value_name_with_locals(function_value, locals, right);
                let prefix = llvm_node_prefix(node.node);
                let mut parts: Vec[String] = vec.new_vec();
                parts = vec.push(parts, emit_string_node_value(program, function_value, nodes, left, locals));
                parts = vec.push(parts, emit_string_node_value(program, function_value, nodes, right, locals));
                parts = vec.push(parts, emit_string_extracts(left_name, concat2(prefix, ".lhs")));
                parts = vec.push(parts, emit_string_extracts(right_name, concat2(prefix, ".rhs")));
                parts = vec.push(parts, "  ");
                parts = vec.push(parts, llvm_local(prefix, ".raw"));
                parts = vec.push(parts, " = call i64 ");
                parts = vec.push(parts, string_bool_runtime_name(node.name));
                parts = vec.push(parts, "(i8* ");
                parts = vec.push(parts, llvm_local(concat2(prefix, ".lhs"), ".ptr"));
                parts = vec.push(parts, ", i64 ");
                parts = vec.push(parts, llvm_local(concat2(prefix, ".lhs"), ".len"));
                parts = vec.push(parts, ", i64 ");
                parts = vec.push(parts, llvm_local(concat2(prefix, ".lhs"), ".cap"));
                parts = vec.push(parts, ", i8* ");
                parts = vec.push(parts, llvm_local(concat2(prefix, ".rhs"), ".ptr"));
                parts = vec.push(parts, ", i64 ");
                parts = vec.push(parts, llvm_local(concat2(prefix, ".rhs"), ".len"));
                parts = vec.push(parts, ", i64 ");
                parts = vec.push(parts, llvm_local(concat2(prefix, ".rhs"), ".cap"));
                parts = vec.push(parts, ")\n  ");
                parts = vec.push(parts, llvm_node_value_local(node));
                parts = vec.push(parts, " = icmp ne i64 ");
                parts = vec.push(parts, llvm_local(prefix, ".raw"));
                parts = vec.push(parts, ", 0\n");
                string.join(parts, "")
            } else { "" },
            None => "",
        },
        None => "",
    }
}

fn emit_string_bool_expr_value(program: IrProgram, function_value: IrFunctionDef, expr: IrExpr, locals: BackendLocals) -> String {
    match direct_expr_child_at(expr.nodes, 0) {
        Some(left) => match direct_expr_child_at(expr.nodes, 1) {
            Some(right) => if true {
                let left_name = string_node_value_name_with_locals(function_value, locals, left);
                let right_name = string_node_value_name_with_locals(function_value, locals, right);
                let prefix = llvm_expr_prefix(expr.node);
                let mut parts: Vec[String] = vec.new_vec();
                parts = vec.push(parts, emit_string_node_value(program, function_value, expr.nodes, left, locals));
                parts = vec.push(parts, emit_string_node_value(program, function_value, expr.nodes, right, locals));
                parts = vec.push(parts, emit_string_extracts(left_name, concat2(prefix, ".lhs")));
                parts = vec.push(parts, emit_string_extracts(right_name, concat2(prefix, ".rhs")));
                parts = vec.push(parts, "  ");
                parts = vec.push(parts, llvm_local(prefix, ".raw"));
                parts = vec.push(parts, " = call i64 ");
                parts = vec.push(parts, string_bool_runtime_name(expr.name));
                parts = vec.push(parts, "(i8* ");
                parts = vec.push(parts, llvm_local(concat2(prefix, ".lhs"), ".ptr"));
                parts = vec.push(parts, ", i64 ");
                parts = vec.push(parts, llvm_local(concat2(prefix, ".lhs"), ".len"));
                parts = vec.push(parts, ", i64 ");
                parts = vec.push(parts, llvm_local(concat2(prefix, ".lhs"), ".cap"));
                parts = vec.push(parts, ", i8* ");
                parts = vec.push(parts, llvm_local(concat2(prefix, ".rhs"), ".ptr"));
                parts = vec.push(parts, ", i64 ");
                parts = vec.push(parts, llvm_local(concat2(prefix, ".rhs"), ".len"));
                parts = vec.push(parts, ", i64 ");
                parts = vec.push(parts, llvm_local(concat2(prefix, ".rhs"), ".cap"));
                parts = vec.push(parts, ")\n  ");
                parts = vec.push(parts, llvm_expr_value_local(expr));
                parts = vec.push(parts, " = icmp ne i64 ");
                parts = vec.push(parts, llvm_local(prefix, ".raw"));
                parts = vec.push(parts, ", 0\n");
                string.join(parts, "")
            } else { "" },
            None => "",
        },
        None => "",
    }
}

fn emit_string_len_node_value(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], node: IrExprNode, locals: BackendLocals) -> String {
    match expr_node_child_at(nodes, node, 0) {
        Some(child) => if true {
            let value_name = string_node_value_name_with_locals(function_value, locals, child);
            let mut parts: Vec[String] = vec.new_vec();
            parts = vec.push(parts, emit_string_node_value(program, function_value, nodes, child, locals));
            parts = vec.push(parts, "  ");
            parts = vec.push(parts, llvm_node_value_local(node));
            parts = vec.push(parts, " = extractvalue %aic.String ");
            parts = vec.push(parts, value_name);
            parts = vec.push(parts, ", 1\n");
            string.join(parts, "")
        } else { "" },
        None => "",
    }
}

