                        && branch_value_node_can_emit_with_expected_type(program, function_value, value.nodes, then_block, expected, expected_type_name, locals)
                        && branch_value_node_can_emit_with_expected_type(program, function_value, value.nodes, else_block, expected, expected_type_name, locals),
                    None => false,
                },
                None => false,
            },
            None => false,
        }
    }
}

fn if_node_value_can_emit_with_locals(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], node: IrExprNode, locals: BackendLocals) -> Bool {
    let expected = if_node_value_llvm_type(program, function_value, nodes, node, locals);
