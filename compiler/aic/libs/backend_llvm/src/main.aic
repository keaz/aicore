fn match_has_arm(value: IrExpr, pattern: String, body: String) -> Bool {
    let mut index = 0;
    let mut found = false;
    while !found && index < vec.vec_len(value.match_arms) {
        match vec.get(value.match_arms, index) {
            Some(arm) => if arm.pattern_text == pattern && arm.body_text == body {
                found = true;
            } else {
                ()
            },
            None => (),
        };
        index = index + 1;
    };
    found
}

fn match_arm_is_variant(arm: IrMatchArm, variant: String) -> Bool {
    arm.guard_text == "" && (arm.pattern_text == variant || string.starts_with(arm.pattern_text, concat2(variant, "(")))
}

fn match_arm_variant_text(pattern: String) -> String {
    let mut index = 0;
    let mut out = string.trim(pattern);
    while index < string.len(pattern) {
        if string.substring(pattern, index, index + 1) == "(" {
            out = string.trim(string.substring(pattern, 0, index));
            index = string.len(pattern);
        } else {
            index = index + 1;
        }
    };
    out
}

fn match_arm_payload_binding(arm: IrMatchArm, variant: String) -> String {
    let prefix = concat2(variant, "(");
    if string.starts_with(arm.pattern_text, prefix) && string.ends_with(arm.pattern_text, ")") && string.len(arm.pattern_text) > string.len(prefix) + 1 {
        let raw = string.trim(string.substring(arm.pattern_text, string.len(prefix), string.len(arm.pattern_text) - 1));
        if raw == "_" { "" } else { raw }
    } else {
        ""
    }
}

fn enum_match_arm_payload_name(arm: IrMatchArm) -> String {
    let variant = match_arm_variant_text(arm.pattern_text);
    let from_patterns = result_match_payload_name_from_patterns(arm.pattern_nodes, variant);
    if from_patterns != "" {
        from_patterns
    } else {
        match_arm_payload_binding(arm, variant)
    }
}

fn enum_match_arm_payload_type_name(program: IrProgram, parent_name: String, arm: IrMatchArm) -> String {
    if arm.pattern_text == "_" {
        ""
    } else {
        enum_variant_payload_type_name(program, parent_name, match_arm_variant_text(arm.pattern_text))
    }
}

fn enum_match_arm_payload_value_name(prefix: String, index: Int) -> String {
    llvm_local(prefix, concat2(".payload.", string.int_to_string(index)))
}

fn enum_match_arm_locals(program: IrProgram, parent_name: String, arm: IrMatchArm, locals: BackendLocals, value_name: String) -> BackendLocals {
    let payload_name = enum_match_arm_payload_name(arm);
    let payload_type_name = enum_match_arm_payload_type_name(program, parent_name, arm);
    if payload_name == "" || payload_type_name == "" || payload_type_name == "()" {
        locals
    } else {
        backend_locals_push_parts(locals, payload_name, payload_type_name, llvm_payload_slot_type(program, payload_type_name), value_name)
    }
}

fn emit_enum_match_arm_payload_extract(program: IrProgram, parent_name: String, arm: IrMatchArm, prefix: String, index: Int, enum_ty: String, scrutinee_value: String) -> String {
    let payload_name = enum_match_arm_payload_name(arm);
    let payload_type_name = enum_match_arm_payload_type_name(program, parent_name, arm);
    if payload_name == "" || payload_type_name == "" || payload_type_name == "()" {
        ""
    } else {
        let variant_index = enum_variant_index(program, parent_name, match_arm_variant_text(arm.pattern_text));
        let payload_ty = llvm_payload_slot_type(program, payload_type_name);
        let mut parts: Vec[String] = vec.new_vec();
        parts = vec.push(parts, "  ");
        parts = vec.push(parts, enum_match_arm_payload_value_name(prefix, index));
        parts = vec.push(parts, " = extractvalue ");
        parts = vec.push(parts, enum_ty);
        parts = vec.push(parts, " ");
        parts = vec.push(parts, scrutinee_value);
        parts = vec.push(parts, ", ");
        parts = vec.push(parts, string.int_to_string(variant_index + 1));
        parts = vec.push(parts, "\n");
        string.join(parts, "")
    }
}

fn result_match_has_variant(arms: Vec[IrMatchArm], variant: String) -> Bool {
    let mut index = 0;
    let mut found = false;
    while !found && index < vec.vec_len(arms) {
        match vec.get(arms, index) {
            Some(arm) => if match_arm_is_variant(arm, variant) {
                found = true;
            } else {
                ()
            },
            None => (),
        };
        index = index + 1;
    };
    found
}

fn result_match_arms_are_ok_err(arms: Vec[IrMatchArm]) -> Bool {
    if vec.vec_len(arms) != 2 || !result_match_has_variant(arms, "Ok") || !result_match_has_variant(arms, "Err") {
        false
    } else {
        let mut index = 0;
        let mut ok = true;
        while ok && index < vec.vec_len(arms) {
            match vec.get(arms, index) {
                Some(arm) => if arm.guard_text == "" {
                    ()
                } else {
                    ok = false;
                },
                None => (),
            };
            index = index + 1;
        };
        ok
    }
}

fn result_match_payload_name(arms: Vec[IrMatchArm], variant: String) -> String {
    result_match_payload_name_from_arm_patterns(arms, variant)
}

fn result_match_payload_name_from_arm_patterns(arms: Vec[IrMatchArm], variant: String) -> String {
    let mut index = 0;
    let mut out = "";
    while out == "" && index < vec.vec_len(arms) {
        match vec.get(arms, index) {
            Some(arm) => if arm.guard_text == "" {
                out = result_match_payload_name_from_patterns(arm.pattern_nodes, variant);
            } else {
                ()
            },
            None => (),
        };
        index = index + 1;
    };
    out
}

fn result_match_payload_name_from_arm_text(arms: Vec[IrMatchArm], variant: String) -> String {
    let mut index = 0;
    let mut out = "";
    while out == "" && index < vec.vec_len(arms) {
        match vec.get(arms, index) {
            Some(arm) => if match_arm_is_variant(arm, variant) {
                out = match_arm_payload_binding(arm, variant);
            } else {
                ()
            },
            None => (),
        };
        index = index + 1;
    };
    out
}

fn result_match_payload_name_from_patterns(patterns: Vec[IrPatternNode], variant: String) -> String {
    let mut index = 0;
    let mut out = "";
    let mut variant_depth = -1;
    while out == "" && index < vec.vec_len(patterns) {
        match vec.get(patterns, index) {
            Some(pattern) => if variant_depth >= 0 {
                if pattern.depth <= variant_depth {
                    variant_depth = -1;
                } else if pattern.depth == variant_depth + 1 {
                    match pattern.kind {
                        IrVarPattern => if pattern.name == "_" || pattern.text == "_" {
                            out = "";
                        } else if pattern.name != "" {
                            out = pattern.name;
                        } else {
                            out = pattern.text;
                        },
                        _ => (),
                    };
                    index = vec.vec_len(patterns);
                } else {
                    ()
                }
            } else {
                match pattern.kind {
                    IrVariantPattern => if pattern.name == variant || pattern.text == variant || string.starts_with(pattern.text, concat2(variant, "(")) {
                        variant_depth = pattern.depth;
                    } else {
                        ()
                    },
                    _ => (),
                }
            },
            None => (),
        };
        index = index + 1;
    };
    out
}

fn result_match_payload_name_from_text(text: String, variant: String) -> String {
    let prefix = concat2(variant, "(");
    let mut index = 0;
    let mut out = "";
    while out == "" && index + string.len(prefix) < string.len(text) {
        if string.substring(text, index, index + string.len(prefix)) == prefix {
            let mut end = index + string.len(prefix);
            let mut done = false;
            while !done && end < string.len(text) {
                if string.substring(text, end, end + 1) == ")" {
                    let raw = string.trim(string.substring(text, index + string.len(prefix), end));
                    if raw == "_" {
                        out = "";
                    } else {
                        out = raw;
                    };
                    done = true;
                } else {
                    end = end + 1;
                }
            };
            index = string.len(text);
        } else {
            index = index + 1;
        }
    };
    out
}

fn result_match_node_payload_name(node: IrExprNode, variant: String) -> String {
    let from_arm = result_match_payload_name(node.match_arms, variant);
    if from_arm != "" {
        from_arm
    } else {
        result_match_payload_name_from_patterns(node.patterns, variant)
    }
}

fn result_match_expr_payload_name(value: IrExpr, variant: String) -> String {
    let from_arm = result_match_payload_name(value.match_arms, variant);
    if from_arm != "" {
        from_arm
    } else {
        result_match_payload_name_from_patterns(value.patterns, variant)
    }
}

fn result_match_node_payload_name_or_default(node: IrExprNode, variant: String, fallback: String) -> String {
    let found = result_match_node_payload_name(node, variant);
    if found == "" {
        fallback
    } else {
        found
    }
}

fn option_match_has_variant(arms: Vec[IrMatchArm], variant: String) -> Bool {
    result_match_has_variant(arms, variant)
}

fn option_match_arms_are_some_none(arms: Vec[IrMatchArm]) -> Bool {
    if vec.vec_len(arms) != 2 || !option_match_has_variant(arms, "Some") || !option_match_has_variant(arms, "None") {
        false
    } else {
        let mut index = 0;
        let mut ok = true;
        while ok && index < vec.vec_len(arms) {
            match vec.get(arms, index) {
                Some(arm) => if arm.guard_text == "" {
                    ()
                } else {
                    ok = false;
                },
                None => (),
            };
            index = index + 1;
        };
        ok
    }
}

fn option_match_payload_name_from_expr(value: IrExpr) -> String {
    result_match_expr_payload_name(value, "Some")
}

fn option_match_payload_name_from_node(node: IrExprNode) -> String {
    result_match_node_payload_name(node, "Some")
}

fn direct_option_match_node_can_emit_expected_path(nodes: Vec[IrExprNode], node: IrExprNode) -> Bool {
    if !option_match_arms_are_some_none(node.match_arms) {
        false
    } else {
        match expr_node_child_at(nodes, node, 0) {
            Some(scrutinee) => !is_vec_get_intrinsic_name(scrutinee.name),
            None => false,
        }
    }
}

fn direct_option_match_expr_can_emit_expected_path(value: IrExpr) -> Bool {
    if !option_match_arms_are_some_none(value.match_arms) {
        false
    } else {
        match direct_expr_child_at(value.nodes, 0) {
            Some(scrutinee) => !is_vec_get_intrinsic_name(scrutinee.name),
            None => false,
        }
    }
}

fn result_match_expr_body_node_for_variant(value: IrExpr, variant: String) -> Option[IrExprNode] {
    let mut arm_index = 0;
    let mut child_index = 1;
    let mut out: Option[IrExprNode] = None();
    while arm_index < vec.vec_len(value.match_arms) {
        match vec.get(value.match_arms, arm_index) {
            Some(arm) => if match_arm_is_variant(arm, variant) {
                out = direct_expr_child_at(value.nodes, child_index);
                arm_index = vec.vec_len(value.match_arms);
            } else {
                child_index = child_index + 1;
            },
            None => (),
        };
        arm_index = arm_index + 1;
    };
    out
}

fn result_match_node_body_node_for_variant(nodes: Vec[IrExprNode], node: IrExprNode, variant: String) -> Option[IrExprNode] {
    let mut arm_index = 0;
    let mut child_index = 1;
    let mut out: Option[IrExprNode] = None();
    while arm_index < vec.vec_len(node.match_arms) {
        match vec.get(node.match_arms, arm_index) {
            Some(arm) => if match_arm_is_variant(arm, variant) {
                out = expr_node_child_at(nodes, node, child_index);
                arm_index = vec.vec_len(node.match_arms);
            } else {
                child_index = child_index + 1;
            },
            None => (),
        };
        arm_index = arm_index + 1;
    };
    out
}

fn push_result_string_payload_local(locals: BackendLocals, payload_name: String, value_name: String) -> BackendLocals {
    if payload_name == "" {
        locals
    } else {
        backend_locals_push_parts(locals, payload_name, "String", "%aic.String", value_name)
    }
}

fn push_result_fs_error_payload_local(locals: BackendLocals, payload_name: String, value_name: String) -> BackendLocals {
    if payload_name == "" {
        locals
    } else {
        backend_locals_push_parts(locals, payload_name, "FsError", known_no_payload_enum_llvm_type("FsError"), value_name)
    }
}

fn push_option_payload_local(program: IrProgram, locals: BackendLocals, payload_name: String, payload_type_name: String, value_name: String) -> BackendLocals {
    if payload_name == "" {
        locals
    } else {
        backend_locals_push_parts(locals, payload_name, payload_type_name, llvm_payload_slot_type(program, payload_type_name), value_name)
    }
}

fn function_result_type_name(program: IrProgram, function_value: IrFunctionDef) -> String {
    type_name_for_id(program.types, function_value.return_type)
}

fn result_constructor_slot_index(name: String) -> Int {
    if name == "Ok" { 1 } else { 2 }
}

fn result_constructor_tag(name: String) -> String {
    if name == "Ok" { "0" } else { "1" }
}

fn result_constructor_payload_type_name(result_name: String, constructor: String) -> String {
    if constructor == "Ok" {
        generic_arg_at(result_name, 0)
    } else {
        generic_arg_at(result_name, 1)
    }
}

fn result_constructor_node_can_emit(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], node: IrExprNode, ret: String, locals: BackendLocals) -> Bool {
    let result_name = function_result_type_name(program, function_value);
    if (node.name != "Ok" && node.name != "Err") || node.direct_child_count != 1 || base_type_name_text(result_name) != "Result" || llvm_type_for_repr_in_program(program, result_name) != ret {
        false
    } else {
        match expr_node_child_at(nodes, node, 0) {
            Some(_) => true,
            None => false,
        }
    }
}

fn result_constructor_expr_can_emit(program: IrProgram, value: IrExpr, function_value: IrFunctionDef, ret: String, locals: BackendLocals) -> Bool {
    let result_name = function_result_type_name(program, function_value);
    if (value.name != "Ok" && value.name != "Err") || direct_expr_child_count(value.nodes) != 1 || base_type_name_text(result_name) != "Result" || llvm_type_for_repr_in_program(program, result_name) != ret {
        false
    } else {
        match direct_expr_child_at(value.nodes, 0) {
            Some(_) => true,
            None => false,
        }
    }
}

fn result_match_node_can_emit_return(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], node: IrExprNode, ret: String, locals: BackendLocals) -> Bool {
    if !result_match_arms_are_ok_err(node.match_arms) {
        false
    } else {
        match expr_node_child_at(nodes, node, 0) {
            Some(scrutinee) => if is_call_expr_kind(scrutinee.kind) && is_fs_string_result_intrinsic_name(scrutinee.name) && scrutinee.direct_child_count == 1 {
                match expr_node_child_at(nodes, scrutinee, 0) {
                    Some(path_child) => if string_call_child_can_emit(program, function_value, nodes, path_child, locals) {
                        match result_match_node_body_node_for_variant(nodes, node, "Ok") {
                            Some(ok_body) => match result_match_node_body_node_for_variant(nodes, node, "Err") {
                                Some(err_body) => if true {
                                    let ok_payload_name = result_match_node_payload_name(node, "Ok");
                                    let ok_base_locals = clone_backend_locals(locals);
                                    let ok_locals = if ok_payload_name == "" {
                                        ok_base_locals
                                    } else {
                                        backend_locals_push(ok_base_locals, backend_local(ok_payload_name, "String", "%aic.String", llvm_local(concat2(llvm_node_prefix(node.node), ".ok.str"), ".2")))
                                    };
                                    let err_payload_name = result_match_node_payload_name(node, "Err");
                                    let err_base_locals = clone_backend_locals(locals);
                                    let err_locals = if err_payload_name == "" {
                                        err_base_locals
                                    } else {
                                        backend_locals_push(err_base_locals, backend_local(err_payload_name, "FsError", known_no_payload_enum_llvm_type("FsError"), fs_error_value_name(llvm_node_prefix(node.node))))
                                    };
                                    return_node_can_emit_with_locals(program, function_value, nodes, ok_body, ret, ok_locals) && return_node_can_emit_with_locals(program, function_value, nodes, err_body, ret, err_locals)
                                } else { false },
                                None => false,
                            },
                            None => false,
                        }
                    } else {
                        false
                    },
                    None => false,
                }
            } else {
                false
            },
            None => false,
        }
    }
}

fn result_match_expr_can_emit_return(program: IrProgram, value: IrExpr, function_value: IrFunctionDef, ret: String, locals: BackendLocals) -> Bool {
    if base_type_name_text(function_result_type_name(program, function_value)) != "Result" || llvm_type_for_id(program, function_value.return_type) != ret || !result_match_arms_are_ok_err(value.match_arms) {
        false
    } else {
        match direct_expr_child_at(value.nodes, 0) {
            Some(scrutinee) => if is_call_expr_kind(scrutinee.kind) && is_fs_string_result_intrinsic_name(scrutinee.name) && scrutinee.direct_child_count == 1 {
                match expr_node_child_at(value.nodes, scrutinee, 0) {
                    Some(path_child) => if string_call_child_can_emit(program, function_value, value.nodes, path_child, locals) {
                        match result_match_expr_body_node_for_variant(value, "Ok") {
                            Some(ok_body) => match result_match_expr_body_node_for_variant(value, "Err") {
                                Some(err_body) => if true {
                                    let ok_payload_name = result_match_expr_payload_name(value, "Ok");
                                    let ok_base_locals = clone_backend_locals(locals);
                                    let ok_locals = if ok_payload_name == "" {
                                        ok_base_locals
                                    } else {
                                        backend_locals_push(ok_base_locals, backend_local(ok_payload_name, "String", "%aic.String", llvm_local(concat2(llvm_expr_prefix(value.node), ".ok.str"), ".2")))
                                    };
                                    let err_payload_name = result_match_expr_payload_name(value, "Err");
                                    let err_base_locals = clone_backend_locals(locals);
                                    let err_locals = if err_payload_name == "" {
                                        err_base_locals
                                    } else {
                                        backend_locals_push(err_base_locals, backend_local(err_payload_name, "FsError", known_no_payload_enum_llvm_type("FsError"), fs_error_value_name(llvm_expr_prefix(value.node))))
                                    };
                                    return_node_can_emit_with_locals(program, function_value, value.nodes, ok_body, ret, ok_locals) && return_node_can_emit_with_locals(program, function_value, value.nodes, err_body, ret, err_locals)
                                } else { false },
                                None => false,
                            },
                            None => false,
                        }
                    } else {
                        false
                    },
                    None => false,
                }
            } else {
                false
            },
            None => false,
        }
    }
}

fn option_vec_get_match_node_type_name(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], node: IrExprNode, locals: BackendLocals) -> String {
    if !option_match_arms_are_some_none(node.match_arms) || node.direct_child_count < 3 {
        ""
    } else {
        match expr_node_child_at(nodes, node, 0) {
            Some(scrutinee) => if is_vec_get_intrinsic_name(scrutinee.name) && vec_get_node_can_emit(program, function_value, nodes, scrutinee, locals) {
                let option_name = vec_get_node_type_name(program, function_value, nodes, scrutinee, locals);
                let payload_type_name = generic_arg_at(option_name, 0);
                let payload_ty = llvm_payload_slot_type(program, payload_type_name);
                if base_type_name_text(option_name) != "Option" || payload_ty == "" {
                    ""
                } else {
                    match result_match_node_body_node_for_variant(nodes, node, "Some") {
                        Some(some_body) => match result_match_node_body_node_for_variant(nodes, node, "None") {
                            Some(none_body) => if true {
                                let payload_locals = push_option_payload_local(program, clone_backend_locals(locals), option_match_payload_name_from_node(node), payload_type_name, vec_get_loaded_name(llvm_node_prefix(scrutinee.node)));
                                let some_type = branch_value_node_type_name_with_locals(program, function_value, nodes, some_body, payload_locals);
                                let none_type = branch_value_node_type_name_with_locals(program, function_value, nodes, none_body, locals);
                                if some_type != "" && some_type == none_type { some_type } else { "" }
                            } else { "" },
                            None => "",
                        },
                        None => "",
                    }
                }
            } else {
                ""
            },
            None => "",
        }
    }
}

fn option_vec_get_match_expr_type_name(program: IrProgram, value: IrExpr, function_value: IrFunctionDef, locals: BackendLocals) -> String {
    if !option_match_arms_are_some_none(value.match_arms) || value.direct_child_count < 3 {
        ""
    } else {
        match direct_expr_child_at(value.nodes, 0) {
            Some(scrutinee) => if is_vec_get_intrinsic_name(scrutinee.name) && vec_get_node_can_emit(program, function_value, value.nodes, scrutinee, locals) {
                let option_name = vec_get_node_type_name(program, function_value, value.nodes, scrutinee, locals);
                let payload_type_name = generic_arg_at(option_name, 0);
                let payload_ty = llvm_payload_slot_type(program, payload_type_name);
                if base_type_name_text(option_name) != "Option" || payload_ty == "" {
                    ""
                } else {
                    match result_match_expr_body_node_for_variant(value, "Some") {
                        Some(some_body) => match result_match_expr_body_node_for_variant(value, "None") {
                            Some(none_body) => if true {
                                let payload_locals = push_option_payload_local(program, clone_backend_locals(locals), option_match_payload_name_from_expr(value), payload_type_name, vec_get_loaded_name(llvm_node_prefix(scrutinee.node)));
                                let some_type = branch_value_node_type_name_with_locals(program, function_value, value.nodes, some_body, payload_locals);
                                let none_type = branch_value_node_type_name_with_locals(program, function_value, value.nodes, none_body, locals);
                                if some_type != "" && some_type == none_type { some_type } else { "" }
                            } else { "" },
                            None => "",
                        },
                        None => "",
                    }
                }
            } else {
                ""
            },
            None => "",
        }
    }
}

fn option_vec_get_match_node_llvm_type(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], node: IrExprNode, locals: BackendLocals) -> String {
    llvm_type_for_repr_in_program(program, option_vec_get_match_node_type_name(program, function_value, nodes, node, locals))
}

fn option_vec_get_match_expr_llvm_type(program: IrProgram, value: IrExpr, function_value: IrFunctionDef, locals: BackendLocals) -> String {
    llvm_type_for_repr_in_program(program, option_vec_get_match_expr_type_name(program, value, function_value, locals))
}

fn option_vec_get_match_node_can_emit_value(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], node: IrExprNode, locals: BackendLocals) -> Bool {
    let expected = option_vec_get_match_node_llvm_type(program, function_value, nodes, node, locals);
    if expected == "" || expected == "void" || !option_match_arms_are_some_none(node.match_arms) || node.direct_child_count < 3 {
        false
    } else {
        match expr_node_child_at(nodes, node, 0) {
            Some(scrutinee) => if is_vec_get_intrinsic_name(scrutinee.name) && vec_get_node_can_emit(program, function_value, nodes, scrutinee, locals) {
                let option_name = vec_get_node_type_name(program, function_value, nodes, scrutinee, locals);
                let payload_type_name = generic_arg_at(option_name, 0);
                let payload_ty = llvm_payload_slot_type(program, payload_type_name);
                if base_type_name_text(option_name) != "Option" || payload_ty == "" {
                    false
                } else {
                    match result_match_node_body_node_for_variant(nodes, node, "Some") {
                        Some(some_body) => match result_match_node_body_node_for_variant(nodes, node, "None") {
                            Some(none_body) => if true {
                                let payload_locals = push_option_payload_local(program, clone_backend_locals(locals), option_match_payload_name_from_node(node), payload_type_name, vec_get_loaded_name(llvm_node_prefix(scrutinee.node)));
                                branch_value_node_can_emit_with_locals(program, function_value, nodes, some_body, expected, payload_locals)
                                    && branch_value_node_can_emit_with_locals(program, function_value, nodes, none_body, expected, locals)
                            } else { false },
                            None => false,
                        },
                        None => false,
                    }
                }
            } else {
                false
            },
            None => false,
        }
    }
}

fn option_vec_get_match_expr_can_emit_value(program: IrProgram, value: IrExpr, function_value: IrFunctionDef, locals: BackendLocals) -> Bool {
    let expected = option_vec_get_match_expr_llvm_type(program, value, function_value, locals);
    if expected == "" || expected == "void" || !option_match_arms_are_some_none(value.match_arms) || value.direct_child_count < 3 {
