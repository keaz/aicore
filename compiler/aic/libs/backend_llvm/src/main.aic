module compiler.backend_llvm;

import compiler.source;
import compiler.diagnostics;
import compiler.ir;
import std.option;
import std.string;
import std.vec;

pub enum BackendArtifactKind {
    LlvmIrArtifact,
    NativeObjectArtifact,
    StaticLibraryArtifact,
    ExecutableArtifact,
}

pub enum BackendNativeLinkKind {
    NativeLibraryLink,
    NativeFrameworkLink,
    NativeObjectLink,
    NativeSearchPathLink,
}

pub struct BackendNativeLink {
    pub name: String,
    pub kind: BackendNativeLinkKind,
    pub path: String,
    pub static_link: Bool,
    pub span: SourceSpan,
}

pub struct BackendOptions {
    pub artifact_name: String,
    pub target_triple: String,
    pub artifact_kind: BackendArtifactKind,
    pub require_entry: Bool,
    pub native_links: Vec[BackendNativeLink],
}

pub struct BackendSymbol {
    pub source_name: String,
    pub llvm_name: String,
    pub kind: String,
    pub span: SourceSpan,
}

pub struct BackendArtifact {
    pub format: String,
    pub schema_version: Int,
    pub artifact_name: String,
    pub file_name: String,
    pub artifact_kind: BackendArtifactKind,
    pub target_triple: String,
    pub llvm_ir: String,
    pub symbols: Vec[BackendSymbol],
    pub features: Vec[String],
    pub native_links: Vec[BackendNativeLink],
    pub digest: String,
    pub diagnostics: Vec[Diagnostic],
}

pub fn backend_native_link(name: String, kind: BackendNativeLinkKind, path: String, static_link: Bool, span_value: SourceSpan) -> BackendNativeLink {
    BackendNativeLink {
        name: name,
        kind: kind,
        path: path,
        static_link: static_link,
        span: span_value,
    }
}

pub fn backend_options(artifact_name: String, target_triple: String, artifact_kind: BackendArtifactKind, require_entry: Bool, native_links: Vec[BackendNativeLink]) -> BackendOptions {
    BackendOptions {
        artifact_name: artifact_name,
        target_triple: target_triple,
        artifact_kind: artifact_kind,
        require_entry: require_entry,
        native_links: native_links,
    }
}

fn backend_artifact_kind_name(value: BackendArtifactKind) -> String {
    match value {
        LlvmIrArtifact => "llvm-ir",
        NativeObjectArtifact => "object",
        StaticLibraryArtifact => "static-library",
        ExecutableArtifact => "executable",
    }
}

fn backend_native_link_kind_name(value: BackendNativeLinkKind) -> String {
    match value {
        NativeLibraryLink => "library",
        NativeFrameworkLink => "framework",
        NativeObjectLink => "object",
        NativeSearchPathLink => "search-path",
    }
}

fn backend_artifact_extension(value: BackendArtifactKind) -> String {
    match value {
        LlvmIrArtifact => ".ll",
        NativeObjectArtifact => ".o",
        StaticLibraryArtifact => ".a",
        ExecutableArtifact => "",
    }
}

fn backend_error(code: String, span_value: SourceSpan, message: String, help: String) -> Diagnostic {
    with_help(error(diagnostic_code(code), span_value, message), help)
}

fn push_backend_error(values: Vec[Diagnostic], code: String, span_value: SourceSpan, message: String, help: String) -> Vec[Diagnostic] {
    vec.push(values, backend_error(code, span_value, message, help))
}

fn validate_backend_ir_input(program: IrProgram) -> Vec[Diagnostic] {
    let mut diagnostics: Vec[Diagnostic] = vec.new_vec();
    if program.schema_version != current_ir_schema_version() {
        diagnostics = push_backend_error(diagnostics, "E5010", program.span, "backend emission requires schema_version 1 IR", "migrate older IR or reject future schema versions before backend lowering");
    } else {
        ()
    };
    if vec.vec_len(program.items) > 0 && vec.vec_len(program.source_map) == 0 {
        diagnostics = push_backend_error(diagnostics, "E5011", program.span, "backend emission requires source-map metadata for item-bearing programs", "preserve lowering source_map entries so backend diagnostics can locate generated nodes");
    } else {
        ()
    };
    let mut symbol_index = 0;
    while symbol_index < vec.vec_len(program.symbols) {
        match vec.get(program.symbols, symbol_index) {
            Some(symbol_value) => if symbol_value.name == "" {
                diagnostics = push_backend_error(diagnostics, "E5013", symbol_value.span, "backend emission requires named IR symbols", "retain symbol names during IR lowering");
            } else {
                ()
            },
            None => (),
        };
        symbol_index = symbol_index + 1;
    };
    let mut type_index = 0;
    while type_index < vec.vec_len(program.types) {
        match vec.get(program.types, type_index) {
            Some(type_value) => if type_value.name == "" {
                diagnostics = push_backend_error(diagnostics, "E5013", type_value.span, "backend emission requires named IR types", "retain canonical type repr metadata during IR lowering");
            } else {
                ()
            },
            None => (),
        };
        type_index = type_index + 1;
    };
    let mut source_index = 0;
    while source_index < vec.vec_len(program.source_map) {
        match vec.get(program.source_map, source_index) {
            Some(entry) => if entry.kind == "" || entry.name == "" {
                diagnostics = push_backend_error(diagnostics, "E5013", entry.span, "backend emission requires named source-map entries", "preserve source-map kind/name fields during IR lowering");
            } else {
                ()
            },
            None => (),
        };
        source_index = source_index + 1;
    };
    diagnostics
}

pub fn default_backend_options(name: String) -> BackendOptions {
    backend_options(name, "", LlvmIrArtifact(), true, vec.new_vec())
}

fn concat2(left: String, right: String) -> String {
    let mut parts: Vec[String] = vec.new_vec();
    parts = vec.push(parts, left);
    parts = vec.push(parts, right);
    string.join(parts, "")
}

fn concat3(first: String, second: String, third: String) -> String {
    let mut parts: Vec[String] = vec.new_vec();
    parts = vec.push(parts, first);
    parts = vec.push(parts, second);
    parts = vec.push(parts, third);
    string.join(parts, "")
}

pub fn backend_mangle_symbol(name: String) -> String {
    let mut out = string.replace(name, "::", "_");
    out = string.replace(out, ".", "_");
    out = string.replace(out, "[", "_");
    out = string.replace(out, "]", "");
    out = string.replace(out, ",", "_");
    out = string.replace(out, " ", "_");
    out = string.replace(out, "-", "_");
    out = string.replace(out, "(", "_");
    out = string.replace(out, ")", "");
    if out == "main" {
        "main"
    } else {
        concat2("aic_", out)
    }
}

pub fn backend_artifact_file_name(options: BackendOptions) -> String {
    let base = if options.artifact_name == "" {
        "aic_selfhost"
    } else {
        backend_mangle_symbol(options.artifact_name)
    };
    if match options.artifact_kind { StaticLibraryArtifact => true, _ => false } {
        concat3("lib", base, backend_artifact_extension(options.artifact_kind))
    } else {
        concat2(base, backend_artifact_extension(options.artifact_kind))
    }
}

fn backend_symbol(source_name: String, llvm_name: String, kind: String, span_value: SourceSpan) -> BackendSymbol {
    BackendSymbol {
        source_name: source_name,
        llvm_name: llvm_name,
        kind: kind,
        span: span_value,
    }
}

fn type_name_for_id(types: Vec[IrTypeDef], id: IrTypeId) -> String {
    let mut index = 0;
    let mut out = "<?>";
    while index < vec.vec_len(types) {
        match vec.get(types, index) {
            Some(value) => if value.id.value == id.value {
                out = value.name;
                index = vec.vec_len(types);
            } else {
                ()
            },
            None => (),
        };
        index = index + 1;
    };
    out
}

fn llvm_type_for_repr(repr: String) -> String {
    if repr == "Int" || repr == "Int64" || repr == "UInt" || repr == "usize" || repr == "isize" {
        "i64"
    } else if repr == "Int32" || repr == "UInt32" || repr == "ProcExitStatus" {
        "i32"
    } else if repr == "Int16" || repr == "UInt16" {
        "i16"
    } else if repr == "Int8" || repr == "UInt8" {
        "i8"
    } else if repr == "Bool" {
        "i1"
    } else if repr == "String" {
        "%aic.String"
    } else if repr == "()" {
        "void"
    } else {
        ""
    }
}

fn llvm_type_for_id(types: Vec[IrTypeDef], id: IrTypeId) -> String {
    llvm_type_for_repr(type_name_for_id(types, id))
}

fn is_llvm_primitive_type(repr: String) -> Bool {
    llvm_type_for_repr(repr) != ""
}

fn is_supported_backend_expr_kind(value: IrExprKind) -> Bool {
    match value {
        IrIntExpr => true,
        IrFloatExpr => true,
        IrBoolExpr => true,
        IrStringExpr => true,
        IrCharExpr => true,
        IrTemplateExpr => false,
        IrUnitExpr => true,
        IrNameExpr => true,
        IrCallExpr => true,
        IrClosureExpr => true,
        IrIfExpr => true,
        IrWhileExpr => true,
        IrForExpr => false,
        IrLoopExpr => true,
        IrBreakExpr => true,
        IrContinueExpr => true,
        IrMatchExpr => true,
        IrBinaryExpr => true,
        IrUnaryExpr => true,
        IrBorrowExpr => true,
        IrAwaitExpr => true,
        IrTryExpr => true,
        IrStructLiteralExpr => true,
        IrTupleExpr => true,
        IrFieldAccessExpr => true,
        IrBlockExpr => true,
        IrUnsafeBlockExpr => false,
    }
}

fn is_string_expr_kind(value: IrExprKind) -> Bool {
    match value {
        IrStringExpr => true,
        _ => false,
    }
}

fn is_call_expr_kind(value: IrExprKind) -> Bool {
    match value {
        IrCallExpr => true,
        _ => false,
    }
}

fn is_block_expr_kind(value: IrExprKind) -> Bool {
    match value {
        IrBlockExpr => true,
        _ => false,
    }
}

fn is_io_print_intrinsic_name(name: String) -> Bool {
    name == "print_str" || name == "eprint_str"
}

fn is_decimal_digit(value: String) -> Bool {
    value == "0" || value == "1" || value == "2" || value == "3" || value == "4" || value == "5" || value == "6" || value == "7" || value == "8" || value == "9"
}

fn is_decimal_integer_text(value: String) -> Bool {
    if value == "" {
        false
    } else {
        let mut index = 0;
        let mut ok = true;
        while ok && index < string.len(value) {
            let part = string.substring(value, index, index + 1);
            if index == 0 && part == "-" {
                ok = string.len(value) > 1;
            } else if !is_decimal_digit(part) {
                ok = false;
            } else {
                ()
            };
            index = index + 1;
        };
        ok
    }
}

fn function_has_param_named(function_value: IrFunctionDef, name: String) -> Bool {
    let mut index = 0;
    let mut found = false;
    while !found && index < vec.vec_len(function_value.params) {
        match vec.get(function_value.params, index) {
            Some(param) => if param.name == name {
                found = true;
            } else {
                ()
            },
            None => (),
        };
        index = index + 1;
    };
    found
}

fn function_param_llvm_type(program: IrProgram, function_value: IrFunctionDef, name: String) -> String {
    let mut index = 0;
    let mut out = "";
    while out == "" && index < vec.vec_len(function_value.params) {
        match vec.get(function_value.params, index) {
            Some(param) => if param.name == name {
                out = llvm_type_for_id(program.types, param.type_id);
            } else {
                ()
            },
            None => (),
        };
        index = index + 1;
    };
    out
}

fn function_param_type_name(program: IrProgram, function_value: IrFunctionDef, name: String) -> String {
    let mut index = 0;
    let mut out = "";
    while out == "" && index < vec.vec_len(function_value.params) {
        match vec.get(function_value.params, index) {
            Some(param) => if param.name == name {
                out = type_name_for_id(program.types, param.type_id);
            } else {
                ()
            },
            None => (),
        };
        index = index + 1;
    };
    out
}

fn llvm_int_bits(value: String) -> Int {
    if value == "i8" {
        8
    } else if value == "i16" {
        16
    } else if value == "i32" {
        32
    } else if value == "i64" {
        64
    } else {
        0
    }
}

fn type_name_is_signed_integer(value: String) -> Bool {
    value == "Int" || value == "Int8" || value == "Int16" || value == "Int32" || value == "Int64" || value == "Int128" || value == "isize" || value == "ProcExitStatus"
}

fn llvm_integer_extension_op(source_type_name: String, source_llvm: String, target_llvm: String) -> String {
    let source_bits = llvm_int_bits(source_llvm);
    let target_bits = llvm_int_bits(target_llvm);
    if source_bits > 0 && target_bits > source_bits {
        if type_name_is_signed_integer(source_type_name) {
            "sext"
        } else {
            "zext"
        }
    } else {
        ""
    }
}

fn function_param_return_cast_op(program: IrProgram, function_value: IrFunctionDef, name: String, ret: String) -> String {
    let source_llvm = function_param_llvm_type(program, function_value, name);
    if source_llvm == ret {
        ""
    } else {
        llvm_integer_extension_op(function_param_type_name(program, function_value, name), source_llvm, ret)
    }
}

fn return_name_can_emit(program: IrProgram, function_value: IrFunctionDef, name: String, ret: String) -> Bool {
    let source_llvm = function_param_llvm_type(program, function_value, name);
    source_llvm == ret || function_param_return_cast_op(program, function_value, name, ret) != ""
}

fn direct_expr_child_at(nodes: Vec[IrExprNode], child_index: Int) -> Option[IrExprNode] {
    let mut index = 0;
    let mut seen = 0;
    let mut out: Option[IrExprNode] = None();
    while index < vec.vec_len(nodes) {
        match vec.get(nodes, index) {
            Some(node) => if node.depth == 1 {
                if seen == child_index {
                    out = Some(node);
                    index = vec.vec_len(nodes);
                } else {
                    seen = seen + 1;
                };
                ()
            } else {
                ()
            },
            None => (),
        };
        index = index + 1;
    };
    out
}

fn direct_expr_child_count(nodes: Vec[IrExprNode]) -> Int {
    let mut index = 0;
    let mut count = 0;
    while index < vec.vec_len(nodes) {
        match vec.get(nodes, index) {
            Some(node) => if node.depth == 1 {
                count = count + 1;
            } else {
                ()
            },
            None => (),
        };
        index = index + 1;
    };
    count
}

fn simple_node_llvm_value(node: IrExprNode, function_value: IrFunctionDef) -> String {
    match node.kind {
        IrIntExpr => node.text,
        IrBoolExpr => if node.text == "true" { "1" } else { "0" },
        IrNameExpr => if function_has_param_named(function_value, node.text) {
            concat2("%", backend_mangle_symbol(node.text))
        } else {
            ""
        },
        _ => "",
    }
}

fn simple_node_llvm_type(program: IrProgram, node: IrExprNode, function_value: IrFunctionDef) -> String {
    match node.kind {
        IrIntExpr => "i64",
        IrBoolExpr => "i1",
        IrNameExpr => function_param_llvm_type(program, function_value, node.text),
        _ => "",
    }
}

fn simple_node_can_emit(node: IrExprNode, function_value: IrFunctionDef) -> Bool {
    match node.kind {
        IrIntExpr => is_decimal_integer_text(node.text),
        IrBoolExpr => node.text == "true" || node.text == "false",
        IrNameExpr => function_has_param_named(function_value, node.text),
        _ => false,
    }
}

fn simple_expr_can_emit(value: IrExpr, function_value: IrFunctionDef) -> Bool {
    match value.kind {
        IrIntExpr => is_decimal_integer_text(value.text),
        IrBoolExpr => value.text == "true" || value.text == "false",
        IrUnitExpr => true,
        IrNameExpr => function_has_param_named(function_value, value.text),
        _ => false,
    }
}

fn expr_node_index(nodes: Vec[IrExprNode], target: IrNodeId) -> Int {
    let mut index = 0;
    let mut out = -1;
    while out < 0 && index < vec.vec_len(nodes) {
        match vec.get(nodes, index) {
            Some(node) => if node.node.value == target.value {
                out = index;
            } else {
                ()
            },
            None => (),
        };
        index = index + 1;
    };
    out
}

fn expr_node_child_at(nodes: Vec[IrExprNode], parent: IrExprNode, child_index: Int) -> Option[IrExprNode] {
    let parent_index = expr_node_index(nodes, parent.node);
    let mut index = parent_index + 1;
    let mut seen = 0;
    let mut out: Option[IrExprNode] = None();
    while parent_index >= 0 && index < vec.vec_len(nodes) {
        match vec.get(nodes, index) {
            Some(node) => if node.depth <= parent.depth {
                index = vec.vec_len(nodes);
            } else if node.depth == parent.depth + 1 {
                if seen == child_index {
                    out = Some(node);
                    index = vec.vec_len(nodes);
                } else {
                    seen = seen + 1;
                };
                ()
            } else {
                ()
            },
            None => (),
        };
        index = index + 1;
    };
    out
}

fn string_replace_node_can_emit(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], node: IrExprNode) -> Bool {
    if node.name != "string.replace" || node.direct_child_count != 3 {
        false
    } else {
        let mut index = 0;
        let mut ok = true;
        while ok && index < 3 {
            match expr_node_child_at(nodes, node, index) {
                Some(child) => if string_call_child_can_emit(program, function_value, nodes, child) {
                    ()
                } else {
                    ok = false;
                },
                None => if true {
                    ok = false;
                    ()
                } else { () },
            };
            index = index + 1;
        };
        ok
    }
}

fn string_call_child_can_emit(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], node: IrExprNode) -> Bool {
    match node.kind {
        IrStringExpr => true,
        IrNameExpr => function_param_llvm_type(program, function_value, node.text) == "%aic.String",
        IrCallExpr => if node.name == "string.replace" {
            string_replace_node_can_emit(program, function_value, nodes, node)
        } else {
            string_direct_call_node_can_emit(program, function_value, nodes, node)
        },
        _ => false,
    }
}

fn call_child_node_can_emit(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], callee_name: String, param_index: Int, node: IrExprNode) -> Bool {
    let expected = call_target_param_type(program, callee_name, param_index);
    if expected == "%aic.String" {
        string_call_child_can_emit(program, function_value, nodes, node)
    } else if simple_node_can_emit(node, function_value) {
        let actual = simple_node_llvm_type(program, node, function_value);
        expected != "" && actual != "" && expected == actual
    } else {
        false
    }
}

fn string_direct_call_node_can_emit(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], node: IrExprNode) -> Bool {
    if node.name == "" || string.contains(node.name, ".") || !call_target_exists(program, node.name) {
        false
    } else if call_target_return_type(program, node.name) != "%aic.String" {
        false
    } else if node.direct_child_count != call_target_param_count(program, node.name) {
        false
    } else {
        let mut index = 0;
        let mut ok = true;
        while ok && index < node.direct_child_count {
            match expr_node_child_at(nodes, node, index) {
                Some(child) => if call_child_node_can_emit(program, function_value, nodes, node.name, index, child) {
                    ()
                } else {
                    ok = false;
                },
                None => if true {
                    ok = false;
                    ()
                } else { () },
            };
            index = index + 1;
        };
        ok
    }
}

fn string_replace_expr_can_emit(program: IrProgram, value: IrExpr, function_value: IrFunctionDef) -> Bool {
    if value.name != "string.replace" || direct_expr_child_count(value.nodes) != 3 {
        false
    } else {
        let mut index = 0;
        let mut ok = true;
        while ok && index < 3 {
            match direct_expr_child_at(value.nodes, index) {
                Some(node) => if string_call_child_can_emit(program, function_value, value.nodes, node) {
                    ()
                } else {
                    ok = false;
                },
                None => if true {
                    ok = false;
                    ()
                } else { () },
            };
            index = index + 1;
        };
        ok
    }
}

fn call_target_return_type(program: IrProgram, callee_name: String) -> String {
    let mut index = 0;
    let mut out = "";
    while out == "" && index < vec.vec_len(program.items) {
        match vec.get(program.items, index) {
            Some(item) => match item {
                IrFunctionItemValue(function_value) => if function_value.name == callee_name {
                    out = llvm_type_for_id(program.types, function_value.return_type);
                } else {
                    ()
                },
                _ => (),
            },
            None => (),
        };
        index = index + 1;
    };
    out
}

fn call_target_param_type(program: IrProgram, callee_name: String, param_index: Int) -> String {
    let mut item_index = 0;
    let mut out = "";
    while out == "" && item_index < vec.vec_len(program.items) {
        match vec.get(program.items, item_index) {
            Some(item) => match item {
                IrFunctionItemValue(function_value) => if function_value.name == callee_name {
                    match vec.get(function_value.params, param_index) {
                        Some(param) => if true {
                            out = llvm_type_for_id(program.types, param.type_id);
                            ()
                        } else { () },
                        None => (),
                    }
                } else {
                    ()
                },
                _ => (),
            },
            None => (),
        };
        item_index = item_index + 1;
    };
    out
}

fn call_target_param_count(program: IrProgram, callee_name: String) -> Int {
    let mut item_index = 0;
    let mut out = 0;
    let mut found = false;
    while !found && item_index < vec.vec_len(program.items) {
        match vec.get(program.items, item_index) {
            Some(item) => match item {
                IrFunctionItemValue(function_value) => if function_value.name == callee_name {
                    out = vec.vec_len(function_value.params);
                    found = true;
                } else {
                    ()
                },
                _ => (),
            },
            None => (),
        };
        item_index = item_index + 1;
    };
    out
}

fn call_target_exists(program: IrProgram, callee_name: String) -> Bool {
    call_target_return_type(program, callee_name) != ""
}

fn call_expr_can_emit(program: IrProgram, value: IrExpr, function_value: IrFunctionDef) -> Bool {
    if is_io_print_intrinsic_name(value.name) {
        direct_expr_child_count(value.nodes) == 1 && match direct_expr_child_at(value.nodes, 0) {
            Some(child) => string_call_child_can_emit(program, function_value, value.nodes, child),
            None => false,
        }
    } else if string_replace_expr_can_emit(program, value, function_value) {
        true
    } else if value.name == "" || string.contains(value.name, ".") || !call_target_exists(program, value.name) {
        false
    } else if direct_expr_child_count(value.nodes) != call_target_param_count(program, value.name) {
        false
    } else {
        let mut index = 0;
        let mut ok = true;
        while ok && index < direct_expr_child_count(value.nodes) {
            match direct_expr_child_at(value.nodes, index) {
                Some(node) => if call_child_node_can_emit(program, function_value, value.nodes, value.name, index, node) {
                    ()
                } else {
                    ok = false;
                },
                None => if true {
                    ok = false;
                    ()
                } else { () },
            };
            index = index + 1;
        };
        ok
    }
}

fn binary_expr_can_emit(value: IrExpr, function_value: IrFunctionDef) -> Bool {
    if value.op == "+" || value.op == "-" || value.op == "*" {
        match direct_expr_child_at(value.nodes, 0) {
            Some(left) => match direct_expr_child_at(value.nodes, 1) {
                Some(right) => simple_node_can_emit(left, function_value) && simple_node_can_emit(right, function_value),
                None => false,
            },
            None => false,
        }
    } else {
        false
    }
}

fn binary_compare_op_can_emit(op: String) -> Bool {
    op == "==" || op == "!=" || op == "<" || op == ">" || op == "<=" || op == ">="
}

fn compare_predicate(op: String) -> String {
    if op == "==" {
        "eq"
    } else if op == "!=" {
        "ne"
    } else if op == "<" {
        "slt"
    } else if op == ">" {
        "sgt"
    } else if op == "<=" {
        "sle"
    } else if op == ">=" {
        "sge"
    } else {
        ""
    }
}

fn string_compare_predicate(op: String) -> String {
    if op == "==" {
        "eq"
    } else if op == "!=" {
        "ne"
    } else {
        ""
    }
}

fn bool_node_can_emit(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], node: IrExprNode) -> Bool {
    match node.kind {
        IrBoolExpr => node.text == "true" || node.text == "false",
        IrNameExpr => function_param_llvm_type(program, function_value, node.text) == "i1",
        IrBinaryExpr => if binary_compare_op_can_emit(node.op) {
            match expr_node_child_at(nodes, node, 0) {
                Some(left) => match expr_node_child_at(nodes, node, 1) {
                    Some(right) => if string_call_child_can_emit(program, function_value, nodes, left) && string_call_child_can_emit(program, function_value, nodes, right) {
                        node.op == "==" || node.op == "!="
                    } else if simple_node_can_emit(left, function_value) && simple_node_can_emit(right, function_value) {
                        let left_type = simple_node_llvm_type(program, left, function_value);
                        let right_type = simple_node_llvm_type(program, right, function_value);
                        left_type != "" && left_type == right_type
                    } else {
                        false
                    },
                    None => false,
                },
                None => false,
            }
        } else {
            false
        },
        _ => false,
    }
}

fn block_tail_node_can_emit(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], block_node: IrExprNode, ret: String) -> Bool {
    if !is_block_expr_kind(block_node.kind) || block_node.direct_child_count != 1 {
        false
    } else {
        match expr_node_child_at(nodes, block_node, 0) {
            Some(child) => return_node_can_emit(program, function_value, nodes, child, ret),
            None => false,
        }
    }
}

fn branch_node_can_emit(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], branch_node: IrExprNode, ret: String) -> Bool {
    if is_block_expr_kind(branch_node.kind) {
        block_tail_node_can_emit(program, function_value, nodes, branch_node, ret)
    } else {
        return_node_can_emit(program, function_value, nodes, branch_node, ret)
    }
}

fn if_node_can_emit(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], node: IrExprNode, ret: String) -> Bool {
    if node.direct_child_count != 3 {
        false
    } else {
        match expr_node_child_at(nodes, node, 0) {
            Some(condition) => match expr_node_child_at(nodes, node, 1) {
                Some(then_block) => match expr_node_child_at(nodes, node, 2) {
                    Some(else_block) => bool_node_can_emit(program, function_value, nodes, condition)
                        && branch_node_can_emit(program, function_value, nodes, then_block, ret)
                        && branch_node_can_emit(program, function_value, nodes, else_block, ret),
                    None => false,
                },
                None => false,
            },
            None => false,
        }
    }
}

fn return_node_can_emit(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], node: IrExprNode, ret: String) -> Bool {
    match node.kind {
        IrIntExpr => ret == "i64" && is_decimal_integer_text(node.text),
        IrBoolExpr => ret == "i1" && (node.text == "true" || node.text == "false"),
        IrStringExpr => ret == "%aic.String",
        IrUnitExpr => ret == "void",
        IrNameExpr => return_name_can_emit(program, function_value, node.text, ret),
        IrCallExpr => if node.name == "string.replace" {
            ret == "%aic.String" && string_replace_node_can_emit(program, function_value, nodes, node)
        } else {
            call_target_return_type(program, node.name) == ret && string_direct_call_node_can_emit(program, function_value, nodes, node)
        },
        IrIfExpr => if_node_can_emit(program, function_value, nodes, node, ret),
        _ => false,
    }
}

fn if_expr_can_emit(program: IrProgram, value: IrExpr, function_value: IrFunctionDef) -> Bool {
    let ret = llvm_type_for_id(program.types, function_value.return_type);
    if value.direct_child_count != 3 {
        false
    } else {
        match direct_expr_child_at(value.nodes, 0) {
            Some(condition) => match direct_expr_child_at(value.nodes, 1) {
                Some(then_block) => match direct_expr_child_at(value.nodes, 2) {
                    Some(else_block) => bool_node_can_emit(program, function_value, value.nodes, condition)
                        && branch_node_can_emit(program, function_value, value.nodes, then_block, ret)
                        && branch_node_can_emit(program, function_value, value.nodes, else_block, ret),
                    None => false,
                },
                None => false,
            },
            None => false,
        }
    }
}

fn static_match_body(value: IrExpr) -> String {
    let matched = match direct_expr_child_at(value.nodes, 0) {
        Some(node) => node.text,
        None => "",
    };
    let mut index = 0;
    let mut out = "";
    while out == "" && index < vec.vec_len(value.match_arms) {
        match vec.get(value.match_arms, index) {
            Some(arm) => if arm.pattern_text == matched || arm.pattern_text == "_" {
                out = arm.body_text;
            } else {
                ()
            },
            None => (),
        };
        index = index + 1;
    };
    out
}

fn match_expr_can_emit(value: IrExpr) -> Bool {
    let selected = static_match_body(value);
    let mut arms_ok = vec.vec_len(value.match_arms) > 0 && selected != "";
    let mut index = 0;
    while arms_ok && index < vec.vec_len(value.match_arms) {
        match vec.get(value.match_arms, index) {
            Some(arm) => if is_decimal_integer_text(arm.body_text) || arm.body_text == "true" || arm.body_text == "false" {
                ()
            } else {
                arms_ok = false;
            },
            None => (),
        };
        index = index + 1;
    };
    arms_ok
}

fn match_has_arm(value: IrExpr, pattern: String, body: String) -> Bool {
    let mut index = 0;
    let mut found = false;
    while !found && index < vec.vec_len(value.match_arms) {
        match vec.get(value.match_arms, index) {
            Some(arm) => if arm.pattern_text == pattern && arm.body_text == body {
                found = true;
            } else {
                ()
            },
            None => (),
        };
        index = index + 1;
    };
    found
}

fn env_arg_or_empty_expr_can_emit(program: IrProgram, value: IrExpr, function_value: IrFunctionDef) -> Bool {
    let is_match = match value.kind {
        IrMatchExpr => true,
        _ => false,
    };
    if !is_match || llvm_type_for_id(program.types, function_value.return_type) != "%aic.String" {
        false
    } else if !match_has_arm(value, "Some(value)", "value") || !match_has_arm(value, "None", "\"\"") {
        false
    } else {
        match direct_expr_child_at(value.nodes, 0) {
            Some(call_node) => if is_call_expr_kind(call_node.kind) && call_node.name == "arg_at" && call_node.direct_child_count == 1 {
                match expr_node_child_at(value.nodes, call_node, 0) {
                    Some(index_node) => simple_node_can_emit(index_node, function_value) && simple_node_llvm_type(program, index_node, function_value) == "i64",
                    None => false,
                }
            } else {
                false
            },
            None => false,
        }
    }
}

fn statement_expr_can_emit_as_noop(value: IrExpr) -> Bool {
    match value.kind {
        IrUnitExpr => true,
        IrWhileExpr => string.starts_with(value.text, "while false"),
        IrLoopExpr => false,
        IrForExpr => false,
        IrBreakExpr => false,
        IrContinueExpr => false,
        _ => false,
    }
}

fn statement_can_emit_as_noop(statement: IrStatement) -> Bool {
    match statement.kind {
        IrLetStatement => match statement.expr {
            Some(expr) => match expr.kind {
                IrIntExpr => is_decimal_integer_text(expr.text),
                IrBoolExpr => expr.text == "true" || expr.text == "false",
                IrUnitExpr => true,
                IrClosureExpr => true,
                IrStructLiteralExpr => true,
                IrTupleExpr => true,
                _ => false,
            },
            None => true,
        },
        IrExprStatement => match statement.expr {
            Some(expr) => statement_expr_can_emit_as_noop(expr),
            None => true,
        },
        IrAssertStatement => false,
        IrAssignStatement => false,
        IrReturnStatement => false,
    }
}

fn return_expr_can_emit(program: IrProgram, value: IrExpr, function_value: IrFunctionDef) -> Bool {
    match value.kind {
        IrIntExpr => is_decimal_integer_text(value.text),
        IrBoolExpr => value.text == "true" || value.text == "false",
        IrStringExpr => llvm_type_for_id(program.types, function_value.return_type) == "%aic.String",
        IrUnitExpr => true,
        IrNameExpr => return_name_can_emit(program, function_value, value.text, llvm_type_for_id(program.types, function_value.return_type)),
        IrBinaryExpr => binary_expr_can_emit(value, function_value),
        IrCallExpr => call_expr_can_emit(program, value, function_value),
        IrIfExpr => if_expr_can_emit(program, value, function_value),
        IrMatchExpr => match_expr_can_emit(value) || env_arg_or_empty_expr_can_emit(program, value, function_value),
        _ => false,
    }
}

fn block_can_emit(program: IrProgram, block: IrBlock, function_value: IrFunctionDef) -> Bool {
    let mut index = 0;
    let mut ok = true;
    while ok && index < vec.vec_len(block.statements) {
        match vec.get(block.statements, index) {
            Some(statement) => if statement_can_emit_as_noop(statement) {
                ()
            } else {
                ok = false;
            },
            None => (),
        };
        index = index + 1;
    };
    if ok {
        match block.tail_expr {
            Some(expr) => return_expr_can_emit(program, expr, function_value),
            None => llvm_type_for_id(program.types, function_value.return_type) == "void",
        }
    } else {
        false
    }
}

fn append_expr_diagnostics(out: Vec[Diagnostic], expr: IrExpr, max_errors: Int) -> Vec[Diagnostic] {
    let mut diagnostics = out;
    if vec.vec_len(diagnostics) < max_errors && !is_supported_backend_expr_kind(expr.kind) {
        diagnostics = push_backend_error(diagnostics, "E5101", expr.span, "self-host backend has no lowering hook for this expression kind", "add a backend lowering case before emitting LLVM for this IR node");
    } else {
        ()
    };
    let mut index = 0;
    while index < vec.vec_len(expr.nodes) {
        match vec.get(expr.nodes, index) {
            Some(node) => if vec.vec_len(diagnostics) < max_errors && !is_supported_backend_expr_kind(node.kind) {
                diagnostics = push_backend_error(diagnostics, "E5101", node.span, "self-host backend has no lowering hook for this nested expression kind", "extend backend lowering coverage for this expression node");
            } else {
                ()
            },
            None => (),
        };
        index = index + 1;
    };
    diagnostics
}

fn append_optional_expr_diagnostics(out: Vec[Diagnostic], expr: Option[IrExpr], max_errors: Int) -> Vec[Diagnostic] {
    match expr {
        Some(value) => append_expr_diagnostics(out, value, max_errors),
        None => out,
    }
}

fn append_block_diagnostics(out: Vec[Diagnostic], block: IrBlock, max_errors: Int) -> Vec[Diagnostic] {
    let mut diagnostics = out;
    let mut index = 0;
    while index < vec.vec_len(block.statements) {
        match vec.get(block.statements, index) {
            Some(statement) => if true {
                diagnostics = append_optional_expr_diagnostics(diagnostics, statement.expr, max_errors);
                ()
            } else {
                ()
            },
            None => (),
        };
        index = index + 1;
    };
    append_optional_expr_diagnostics(diagnostics, block.tail_expr, max_errors)
}

fn append_backend_block_emission_diagnostics(out: Vec[Diagnostic], program: IrProgram, function_value: IrFunctionDef, max_errors: Int) -> Vec[Diagnostic] {
    let mut diagnostics = out;
    let mut index = 0;
    while index < vec.vec_len(function_value.body.statements) {
        match vec.get(function_value.body.statements, index) {
            Some(statement) => if vec.vec_len(diagnostics) < max_errors && !statement_can_emit_as_noop(statement) {
                diagnostics = push_backend_error(diagnostics, "E5101", statement.span, "self-host backend cannot emit this executable statement yet", "restrict backend-covered executable functions to side-effect-free literal lets and while false guards, or add statement lowering");
            } else {
                ()
            },
            None => (),
        };
        index = index + 1;
    };
    match function_value.body.tail_expr {
        Some(expr) => if vec.vec_len(diagnostics) < max_errors && !return_expr_can_emit(program, expr, function_value) {
            diagnostics = push_backend_error(diagnostics, "E5101", expr.span, "self-host backend cannot emit this function return expression yet", "add expression lowering for this IR shape before emitting a backend artifact");
        } else {
            ()
        },
        None => if vec.vec_len(diagnostics) < max_errors && llvm_type_for_id(program.types, function_value.return_type) != "void" {
            diagnostics = push_backend_error(diagnostics, "E5101", function_value.body.span, "self-host backend requires a return expression for non-void functions", "add a tail expression or lower explicit return statements");
        } else {
            ()
        },
    };
    diagnostics
}

fn append_function_diagnostics(out: Vec[Diagnostic], program: IrProgram, function_value: IrFunctionDef, max_errors: Int) -> Vec[Diagnostic] {
    let mut diagnostics = out;
    if function_value.is_extern && function_value.extern_abi != "" && function_value.extern_abi != "C" {
        diagnostics = push_backend_error(diagnostics, "E5102", function_value.span, "self-host backend only supports extern C ABI metadata", "use extern \"C\" or keep this declaration out of the backend-covered corpus");
    } else {
        ()
    };
    let ret = llvm_type_for_id(program.types, function_value.return_type);
    if ret == "" {
        diagnostics = push_backend_error(diagnostics, "E5102", function_value.span, "self-host backend cannot lower this function return type to LLVM", "restrict backend-covered functions to primitive return values until aggregate return lowering is implemented");
    } else {
        ()
    };
    let mut param_index = 0;
    while param_index < vec.vec_len(function_value.params) {
        match vec.get(function_value.params, param_index) {
            Some(param) => if llvm_type_for_id(program.types, param.type_id) == "" {
                diagnostics = push_backend_error(diagnostics, "E5102", param.span, "self-host backend cannot lower this parameter type to LLVM", "use primitive parameters for backend-covered executable functions");
            } else {
                ()
            },
            None => (),
        };
        param_index = param_index + 1;
    };
    diagnostics = append_optional_expr_diagnostics(diagnostics, function_value.requires_expr, max_errors);
    diagnostics = append_optional_expr_diagnostics(diagnostics, function_value.ensures_expr, max_errors);
    diagnostics = append_block_diagnostics(diagnostics, function_value.body, max_errors);
    append_backend_block_emission_diagnostics(diagnostics, program, function_value, max_errors)
}

fn append_link_diagnostics(out: Vec[Diagnostic], links: Vec[BackendNativeLink]) -> Vec[Diagnostic] {
    let mut diagnostics = out;
    let mut index = 0;
    while index < vec.vec_len(links) {
        match vec.get(links, index) {
            Some(link) => if link.name == "" {
                diagnostics = push_backend_error(diagnostics, "E5103", link.span, "native link metadata requires a non-empty name", "preserve package manifest native-link names before backend emission");
            } else if link.path == "" && match link.kind { NativeObjectLink => true, NativeSearchPathLink => true, _ => false } {
                diagnostics = push_backend_error(diagnostics, "E5103", link.span, "native object/search-path link metadata requires a path", "preserve package manifest native-link paths before backend emission");
            } else {
                ()
            },
            None => (),
        };
        index = index + 1;
    };
    diagnostics
}

fn program_has_entry(program: IrProgram) -> Bool {
    let mut index = 0;
    let mut found = false;
    while !found && index < vec.vec_len(program.items) {
        match vec.get(program.items, index) {
            Some(item) => match item {
                IrFunctionItemValue(function_value) => if function_value.runtime_visible && function_value.name == "main" {
                    found = true;
                } else {
                    ()
                },
                _ => (),
            },
            None => (),
        };
        index = index + 1;
    };
    found
}

pub fn validate_backend_program(program: IrProgram, options: BackendOptions, max_errors: Int) -> Vec[Diagnostic] {
    let mut diagnostics = validate_backend_ir_input(program);
    if options.artifact_name == "" {
        diagnostics = push_backend_error(diagnostics, "E5104", program.span, "backend artifact name must not be empty", "choose a deterministic artifact name before backend emission");
    } else {
        ()
    };
    if options.require_entry && !program_has_entry(program) {
        diagnostics = push_backend_error(diagnostics, "E5104", program.span, "backend executable artifact requires a runtime-visible main function", "lower a checked program with a main function or emit a library artifact");
    } else {
        ()
    };
    match options.artifact_kind {
        LlvmIrArtifact => (),
        NativeObjectArtifact => if true {
            diagnostics = push_backend_error(diagnostics, "E5105", program.span, "self-host backend emits LLVM IR text artifacts in this package", "materialize object files through the driver after LLVM IR emission");
            ()
        } else { () },
        StaticLibraryArtifact => if true {
            diagnostics = push_backend_error(diagnostics, "E5105", program.span, "self-host backend emits LLVM IR text artifacts in this package", "archive object files through the driver after LLVM IR emission");
            ()
        } else { () },
        ExecutableArtifact => if true {
            diagnostics = push_backend_error(diagnostics, "E5105", program.span, "self-host backend emits LLVM IR text artifacts in this package", "link executables through the driver after LLVM IR emission");
            ()
        } else { () },
    };
    diagnostics = append_link_diagnostics(diagnostics, options.native_links);
    let mut type_index = 0;
    while type_index < vec.vec_len(program.types) {
        match vec.get(program.types, type_index) {
            Some(type_value) => match type_value.kind {
                IrUnknownType => if true {
                    diagnostics = push_backend_error(diagnostics, "E5102", type_value.span, "self-host backend cannot lower unknown IR types", "complete type metadata before backend emission");
                    ()
                } else { () },
                _ => (),
            },
            None => (),
        };
        type_index = type_index + 1;
    };
    let mut item_index = 0;
    while item_index < vec.vec_len(program.items) {
        match vec.get(program.items, item_index) {
            Some(item) => match item {
                IrFunctionItemValue(function_value) => if function_value.runtime_visible {
                    diagnostics = append_function_diagnostics(diagnostics, program, function_value, max_errors);
                } else {
                    ()
                },
                IrTraitItemValue(_) => (),
                IrImplItemValue(_) => (),
                IrConstItemValue(const_value) => if true {
                    diagnostics = append_optional_expr_diagnostics(diagnostics, const_value.initializer, max_errors);
                    ()
                } else { () },
                IrStructItemValue(_) => (),
                IrEnumItemValue(_) => (),
                IrTypeAliasItemValue(_) => (),
            },
            None => (),
        };
        item_index = item_index + 1;
    };
    diagnostics
}

fn has_struct_item(program: IrProgram) -> Bool {
    let mut index = 0;
    let mut found = false;
    while !found && index < vec.vec_len(program.items) {
        match vec.get(program.items, index) {
            Some(item) => match item {
                IrStructItemValue(_) => if true { found = true; () } else { () },
                _ => (),
            },
            None => (),
        };
        index = index + 1;
    };
    found
}

fn has_enum_item(program: IrProgram) -> Bool {
    let mut index = 0;
    let mut found = false;
    while !found && index < vec.vec_len(program.items) {
        match vec.get(program.items, index) {
            Some(item) => match item {
                IrEnumItemValue(_) => if true { found = true; () } else { () },
                _ => (),
            },
            None => (),
        };
        index = index + 1;
    };
    found
}

fn has_trait_or_impl_item(program: IrProgram) -> Bool {
    let mut index = 0;
    let mut found = false;
    while !found && index < vec.vec_len(program.items) {
        match vec.get(program.items, index) {
            Some(item) => match item {
                IrTraitItemValue(_) => if true { found = true; () } else { () },
                IrImplItemValue(_) => if true { found = true; () } else { () },
                _ => (),
            },
            None => (),
        };
        index = index + 1;
    };
    found
}

fn has_alias_or_const_item(program: IrProgram) -> Bool {
    let mut index = 0;
    let mut found = false;
    while !found && index < vec.vec_len(program.items) {
        match vec.get(program.items, index) {
            Some(item) => match item {
                IrTypeAliasItemValue(_) => if true { found = true; () } else { () },
                IrConstItemValue(_) => if true { found = true; () } else { () },
                _ => (),
            },
            None => (),
        };
        index = index + 1;
    };
    found
}

fn has_tuple_type(program: IrProgram) -> Bool {
    let mut index = 0;
    let mut found = false;
    while !found && index < vec.vec_len(program.types) {
        match vec.get(program.types, index) {
            Some(type_value) => match type_value.kind {
                IrTupleType(_) => if true { found = true; () } else { () },
                _ => (),
            },
            None => (),
        };
        index = index + 1;
    };
    found
}

fn has_function_instantiation(program: IrProgram) -> Bool {
    vec.vec_len(program.generic_instantiations) > 0
}

fn has_generic_item(program: IrProgram) -> Bool {
    let mut index = 0;
    let mut found = false;
    while !found && index < vec.vec_len(program.items) {
        match vec.get(program.items, index) {
            Some(item) => match item {
                IrFunctionItemValue(function_value) => if vec.vec_len(function_value.generics) > 0 { found = true; } else { () },
                IrStructItemValue(struct_value) => if vec.vec_len(struct_value.generics) > 0 { found = true; } else { () },
                IrEnumItemValue(enum_value) => if vec.vec_len(enum_value.generics) > 0 { found = true; } else { () },
                IrTraitItemValue(trait_value) => if vec.vec_len(trait_value.generics) > 0 { found = true; } else { () },
                IrImplItemValue(impl_value) => if vec.vec_len(impl_value.generics) > 0 { found = true; } else { () },
                IrTypeAliasItemValue(alias_value) => if vec.vec_len(alias_value.generics) > 0 { found = true; } else { () },
                IrConstItemValue(_) => (),
            },
            None => (),
        };
        index = index + 1;
    };
    found
}

fn has_async_function(program: IrProgram) -> Bool {
    let mut index = 0;
    let mut found = false;
    while !found && index < vec.vec_len(program.items) {
        match vec.get(program.items, index) {
            Some(item) => match item {
                IrFunctionItemValue(function_value) => if function_value.is_async { found = true; } else { () },
                _ => (),
            },
            None => (),
        };
        index = index + 1;
    };
    found
}

fn has_expr_kind(program: IrProgram, kind_name: String) -> Bool {
    string.contains(ir_program_to_json(program), concat3("\"kind\":\"", kind_name, "\""))
}

pub fn backend_program_features(program: IrProgram, options: BackendOptions) -> Vec[String] {
    let mut features: Vec[String] = vec.new_vec();
    features = vec.push(features, "primitive-lowering");
    features = vec.push(features, "function-lowering");
    if has_struct_item(program) { features = vec.push(features, "struct-lowering"); } else { () };
    if has_enum_item(program) { features = vec.push(features, "enum-lowering"); } else { () };
    if has_tuple_type(program) || has_expr_kind(program, "tuple") { features = vec.push(features, "tuple-lowering"); } else { () };
    if has_generic_item(program) { features = vec.push(features, "generic-definition-metadata"); } else { () };
    if has_function_instantiation(program) { features = vec.push(features, "generic-monomorph-metadata"); } else { () };
    if has_expr_kind(program, "closure") { features = vec.push(features, "closure-lowering"); } else { () };
    if has_async_function(program) || has_expr_kind(program, "await") { features = vec.push(features, "async-future-lowering"); } else { () };
    if has_trait_or_impl_item(program) { features = vec.push(features, "trait-dispatch-metadata"); } else { () };
    if string.contains(ir_program_to_json(program), "Handle") { features = vec.push(features, "resource-handle-metadata"); } else { () };
    if has_alias_or_const_item(program) { features = vec.push(features, "const-global-metadata"); } else { () };
    if vec.vec_len(options.native_links) > 0 { features = vec.push(features, "native-link-metadata"); } else { () };
    features
}

fn llvm_param_list(program: IrProgram, params: Vec[IrParam]) -> String {
    let mut parts: Vec[String] = vec.new_vec();
    let mut index = 0;
    while index < vec.vec_len(params) {
        match vec.get(params, index) {
            Some(param) => if true {
                if index > 0 { parts = vec.push(parts, ", "); } else { () };
                parts = vec.push(parts, llvm_type_for_id(program.types, param.type_id));
                parts = vec.push(parts, " %");
                parts = vec.push(parts, backend_mangle_symbol(param.name));
                ()
            } else {
                ()
            },
            None => (),
        };
        index = index + 1;
    };
    string.join(parts, "")
}

fn binary_llvm_op(op: String) -> String {
    if op == "+" {
        "add"
    } else if op == "-" {
        "sub"
    } else if op == "*" {
        "mul"
    } else {
        ""
    }
}

fn emit_call_arg_values(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], callee_name: String) -> String {
    let mut parts: Vec[String] = vec.new_vec();
    let mut index = 0;
    while index < direct_expr_child_count(nodes) {
        match direct_expr_child_at(nodes, index) {
            Some(node) => if call_target_param_type(program, callee_name, index) == "%aic.String" {
                parts = vec.push(parts, emit_string_node_value(program, function_value, nodes, node));
            } else {
                ()
            },
            None => (),
        };
        index = index + 1;
    };
    string.join(parts, "")
}

fn call_arg_node_value_name(program: IrProgram, function_value: IrFunctionDef, node: IrExprNode, expected: String) -> String {
    if expected == "%aic.String" {
        string_node_value_name(node)
    } else {
        simple_node_llvm_value(node, function_value)
    }
}

fn emit_call_args(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], callee_name: String) -> String {
    let mut parts: Vec[String] = vec.new_vec();
    let mut index = 0;
    while index < direct_expr_child_count(nodes) {
        match direct_expr_child_at(nodes, index) {
            Some(node) => if true {
                let expected = call_target_param_type(program, callee_name, index);
                if index > 0 {
                    parts = vec.push(parts, ", ");
                } else {
                    ()
                };
                parts = vec.push(parts, expected);
                parts = vec.push(parts, " ");
                parts = vec.push(parts, call_arg_node_value_name(program, function_value, node, expected));
                ()
            } else {
                ()
            },
            None => (),
        };
        index = index + 1;
    };
    string.join(parts, "")
}

fn emit_node_call_args(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], node: IrExprNode) -> String {
    let mut parts: Vec[String] = vec.new_vec();
    let mut index = 0;
    while index < node.direct_child_count {
        match expr_node_child_at(nodes, node, index) {
            Some(child) => if true {
                let expected = call_target_param_type(program, node.name, index);
                if index > 0 {
                    parts = vec.push(parts, ", ");
                } else {
                    ()
                };
                parts = vec.push(parts, expected);
                parts = vec.push(parts, " ");
                parts = vec.push(parts, call_arg_node_value_name(program, function_value, child, expected));
                ()
            } else {
                ()
            },
            None => (),
        };
        index = index + 1;
    };
    string.join(parts, "")
}

fn llvm_string_global_name(function_name: String) -> String {
    concat2("@.aic.str.", backend_mangle_symbol(function_name))
}

fn llvm_string_node_global_name(function_name: String, node: IrNodeId) -> String {
    concat3(llvm_string_global_name(function_name), ".", string.int_to_string(node.value))
}

fn string_literal_payload(value: String) -> String {
    if string.len(value) >= 2 && string.starts_with(value, "\"") && string.ends_with(value, "\"") {
        string.substring(value, 1, string.len(value) - 1)
    } else {
        value
    }
}

fn llvm_escape_string_data(value: String) -> String {
    let mut parts: Vec[String] = vec.new_vec();
    let mut index = 0;
    while index < string.len(value) {
        let ch = string.substring(value, index, index + 1);
        if ch == "\n" {
            parts = vec.push(parts, "\\0A");
        } else if ch == "\t" {
            parts = vec.push(parts, "\\09");
        } else if ch == "\"" {
            parts = vec.push(parts, "\\22");
        } else if ch == "\\" {
            parts = vec.push(parts, "\\5C");
        } else {
            parts = vec.push(parts, ch);
        };
        index = index + 1;
    };
    string.join(parts, "")
}

fn emit_named_string_literal_global(global_name: String, value: String) -> String {
    let payload = string_literal_payload(value);
    let mut parts: Vec[String] = vec.new_vec();
    parts = vec.push(parts, global_name);
    parts = vec.push(parts, " = private unnamed_addr constant [");
    parts = vec.push(parts, string.int_to_string(string.len(payload)));
    parts = vec.push(parts, " x i8] c\"");
    parts = vec.push(parts, llvm_escape_string_data(payload));
    parts = vec.push(parts, "\"\n");
    string.join(parts, "")
}

fn emit_string_literal_global(function_value: IrFunctionDef, value: String) -> String {
    emit_named_string_literal_global(llvm_string_global_name(function_value.name), value)
}

fn emit_string_node_globals_for_expr(function_value: IrFunctionDef, expr: IrExpr) -> String {
    let mut parts: Vec[String] = vec.new_vec();
    let mut index = 0;
    while index < vec.vec_len(expr.nodes) {
        match vec.get(expr.nodes, index) {
            Some(node) => if is_string_expr_kind(node.kind) {
                parts = vec.push(parts, emit_named_string_literal_global(llvm_string_node_global_name(function_value.name, node.node), node.text));
            } else {
                ()
            },
            None => (),
        };
        index = index + 1;
    };
    string.join(parts, "")
}

fn emit_string_globals_for_function(function_value: IrFunctionDef) -> String {
    match function_value.body.tail_expr {
        Some(expr) => match expr.kind {
            IrStringExpr => concat2(emit_string_literal_global(function_value, expr.text), emit_string_node_globals_for_expr(function_value, expr)),
            _ => emit_string_node_globals_for_expr(function_value, expr),
        },
        None => "",
    }
}

fn emit_string_globals(program: IrProgram) -> String {
    let mut parts: Vec[String] = vec.new_vec();
    let mut index = 0;
    while index < vec.vec_len(program.items) {
        match vec.get(program.items, index) {
            Some(item) => match item {
                IrFunctionItemValue(function_value) => if function_value.runtime_visible {
                    parts = vec.push(parts, emit_string_globals_for_function(function_value));
                } else {
                    ()
                },
                _ => (),
            },
            None => (),
        };
        index = index + 1;
    };
    string.join(parts, "")
}

fn program_uses_string_type(program: IrProgram) -> Bool {
    let mut index = 0;
    let mut found = false;
    while !found && index < vec.vec_len(program.types) {
        match vec.get(program.types, index) {
            Some(type_value) => if type_value.name == "String" {
                found = true;
            } else {
                ()
            },
            None => (),
        };
        index = index + 1;
    };
    found
}

fn expr_uses_string_replace(expr: IrExpr) -> Bool {
    let mut found = is_call_expr_kind(expr.kind) && expr.name == "string.replace";
    let mut index = 0;
    while !found && index < vec.vec_len(expr.nodes) {
        match vec.get(expr.nodes, index) {
            Some(node) => if is_call_expr_kind(node.kind) && node.name == "string.replace" {
                found = true;
            } else {
                ()
            },
            None => (),
        };
        index = index + 1;
    };
    found
}

fn expr_uses_io_print(expr: IrExpr) -> Bool {
    let mut found = is_call_expr_kind(expr.kind) && is_io_print_intrinsic_name(expr.name);
    let mut index = 0;
    while !found && index < vec.vec_len(expr.nodes) {
        match vec.get(expr.nodes, index) {
            Some(node) => if is_call_expr_kind(node.kind) && is_io_print_intrinsic_name(node.name) {
                found = true;
            } else {
                ()
            },
            None => (),
        };
        index = index + 1;
    };
    found
}

fn expr_uses_env_arg_at(expr: IrExpr) -> Bool {
    let mut found = is_call_expr_kind(expr.kind) && expr.name == "arg_at";
    let mut index = 0;
    while !found && index < vec.vec_len(expr.nodes) {
        match vec.get(expr.nodes, index) {
            Some(node) => if is_call_expr_kind(node.kind) && node.name == "arg_at" {
                found = true;
            } else {
                ()
            },
            None => (),
        };
        index = index + 1;
    };
    found
}

fn program_uses_string_replace(program: IrProgram) -> Bool {
    let mut index = 0;
    let mut found = false;
    while !found && index < vec.vec_len(program.items) {
        match vec.get(program.items, index) {
            Some(item) => match item {
                IrFunctionItemValue(function_value) => match function_value.body.tail_expr {
                    Some(expr) => if expr_uses_string_replace(expr) {
                        found = true;
                    } else {
                        ()
                    },
                    None => (),
                },
                _ => (),
            },
            None => (),
        };
        index = index + 1;
    };
    found
}

fn program_uses_io_print(program: IrProgram) -> Bool {
    let mut index = 0;
    let mut found = false;
    while !found && index < vec.vec_len(program.items) {
        match vec.get(program.items, index) {
            Some(item) => match item {
                IrFunctionItemValue(function_value) => match function_value.body.tail_expr {
                    Some(expr) => if expr_uses_io_print(expr) {
                        found = true;
                    } else {
                        ()
                    },
                    None => (),
                },
                _ => (),
            },
            None => (),
        };
        index = index + 1;
    };
    found
}

fn program_uses_env_arg_at(program: IrProgram) -> Bool {
    let mut index = 0;
    let mut found = false;
    while !found && index < vec.vec_len(program.items) {
        match vec.get(program.items, index) {
            Some(item) => match item {
                IrFunctionItemValue(function_value) => match function_value.body.tail_expr {
                    Some(expr) => if expr_uses_env_arg_at(expr) {
                        found = true;
                    } else {
                        ()
                    },
                    None => (),
                },
                _ => (),
            },
            None => (),
        };
        index = index + 1;
    };
    found
}

fn emit_runtime_declarations(program: IrProgram) -> String {
    let mut parts: Vec[String] = vec.new_vec();
    if program_uses_string_type(program) {
        parts = vec.push(parts, "declare i64 @aic_rt_string_compare(i8*, i64, i64, i8*, i64, i64)\n");
    } else {
        ()
    };
    if program_uses_string_replace(program) {
        parts = vec.push(parts, "declare void @aic_rt_string_replace(i8*, i64, i64, i8*, i64, i64, i8*, i64, i64, i8**, i64*)\n");
    } else {
        ()
    };
    if program_uses_io_print(program) {
        parts = vec.push(parts, "declare void @aic_rt_print_str(i8*, i64, i64)\n");
        parts = vec.push(parts, "declare void @aic_rt_eprint_str(i8*, i64, i64)\n");
    } else {
        ()
    };
    if program_uses_env_arg_at(program) {
        parts = vec.push(parts, "declare i64 @aic_rt_env_arg_at(i64, i8**, i64*)\n");
    } else {
        ()
    };
    string.join(parts, "")
}

fn emit_type_declarations(program: IrProgram) -> String {
    if program_uses_string_type(program) {
        "%aic.String = type { i8*, i64, i64 }\n"
    } else {
        ""
    }
}

fn llvm_expr_prefix(node: IrNodeId) -> String {
    concat2("expr.", string.int_to_string(node.value))
}

fn llvm_node_prefix(node: IrNodeId) -> String {
    concat2("node.", string.int_to_string(node.value))
}

fn llvm_local(prefix: String, suffix: String) -> String {
    concat3("%", prefix, suffix)
}

fn llvm_expr_value_local(expr: IrExpr) -> String {
    llvm_local(llvm_expr_prefix(expr.node), ".value")
}

fn llvm_node_value_local(node: IrExprNode) -> String {
    llvm_local(llvm_node_prefix(node.node), ".value")
}

fn emit_string_literal_value(global_name: String, literal_text: String, prefix: String) -> String {
    let payload = string_literal_payload(literal_text);
    let mut parts: Vec[String] = vec.new_vec();
    parts = vec.push(parts, "  ");
    parts = vec.push(parts, llvm_local(prefix, ".ptr"));
    parts = vec.push(parts, " = getelementptr inbounds [");
    parts = vec.push(parts, string.int_to_string(string.len(payload)));
    parts = vec.push(parts, " x i8], [");
    parts = vec.push(parts, string.int_to_string(string.len(payload)));
    parts = vec.push(parts, " x i8]* ");
    parts = vec.push(parts, global_name);
    parts = vec.push(parts, ", i64 0, i64 0\n  ");
    parts = vec.push(parts, llvm_local(prefix, ".0"));
    parts = vec.push(parts, " = insertvalue %aic.String undef, i8* ");
    parts = vec.push(parts, llvm_local(prefix, ".ptr"));
    parts = vec.push(parts, ", 0\n  ");
    parts = vec.push(parts, llvm_local(prefix, ".1"));
    parts = vec.push(parts, " = insertvalue %aic.String ");
    parts = vec.push(parts, llvm_local(prefix, ".0"));
    parts = vec.push(parts, ", i64 ");
    parts = vec.push(parts, string.int_to_string(string.len(payload)));
    parts = vec.push(parts, ", 1\n  ");
    parts = vec.push(parts, llvm_local(prefix, ".value"));
    parts = vec.push(parts, " = insertvalue %aic.String ");
    parts = vec.push(parts, llvm_local(prefix, ".1"));
    parts = vec.push(parts, ", i64 ");
    parts = vec.push(parts, string.int_to_string(string.len(payload)));
    parts = vec.push(parts, ", 2\n");
    string.join(parts, "")
}

fn emit_string_extracts(value_name: String, prefix: String) -> String {
    let mut parts: Vec[String] = vec.new_vec();
    parts = vec.push(parts, "  ");
    parts = vec.push(parts, llvm_local(prefix, ".ptr"));
    parts = vec.push(parts, " = extractvalue %aic.String ");
    parts = vec.push(parts, value_name);
    parts = vec.push(parts, ", 0\n  ");
    parts = vec.push(parts, llvm_local(prefix, ".len"));
    parts = vec.push(parts, " = extractvalue %aic.String ");
    parts = vec.push(parts, value_name);
    parts = vec.push(parts, ", 1\n  ");
    parts = vec.push(parts, llvm_local(prefix, ".cap"));
    parts = vec.push(parts, " = extractvalue %aic.String ");
    parts = vec.push(parts, value_name);
    parts = vec.push(parts, ", 2\n");
    string.join(parts, "")
}

fn emit_string_replace_call(prefix: String, first_value: String, second_value: String, third_value: String) -> String {
    let first_prefix = concat2(prefix, ".arg0");
    let second_prefix = concat2(prefix, ".arg1");
    let third_prefix = concat2(prefix, ".arg2");
    let mut parts: Vec[String] = vec.new_vec();
    parts = vec.push(parts, emit_string_extracts(first_value, first_prefix));
    parts = vec.push(parts, emit_string_extracts(second_value, second_prefix));
    parts = vec.push(parts, emit_string_extracts(third_value, third_prefix));
    parts = vec.push(parts, "  ");
    parts = vec.push(parts, llvm_local(prefix, ".out.ptr"));
    parts = vec.push(parts, " = alloca i8*\n  ");
    parts = vec.push(parts, llvm_local(prefix, ".out.len"));
    parts = vec.push(parts, " = alloca i64\n  call void @aic_rt_string_replace(i8* ");
    parts = vec.push(parts, llvm_local(first_prefix, ".ptr"));
    parts = vec.push(parts, ", i64 ");
    parts = vec.push(parts, llvm_local(first_prefix, ".len"));
    parts = vec.push(parts, ", i64 ");
    parts = vec.push(parts, llvm_local(first_prefix, ".cap"));
    parts = vec.push(parts, ", i8* ");
    parts = vec.push(parts, llvm_local(second_prefix, ".ptr"));
    parts = vec.push(parts, ", i64 ");
    parts = vec.push(parts, llvm_local(second_prefix, ".len"));
    parts = vec.push(parts, ", i64 ");
    parts = vec.push(parts, llvm_local(second_prefix, ".cap"));
    parts = vec.push(parts, ", i8* ");
    parts = vec.push(parts, llvm_local(third_prefix, ".ptr"));
    parts = vec.push(parts, ", i64 ");
    parts = vec.push(parts, llvm_local(third_prefix, ".len"));
    parts = vec.push(parts, ", i64 ");
    parts = vec.push(parts, llvm_local(third_prefix, ".cap"));
    parts = vec.push(parts, ", i8** ");
    parts = vec.push(parts, llvm_local(prefix, ".out.ptr"));
    parts = vec.push(parts, ", i64* ");
    parts = vec.push(parts, llvm_local(prefix, ".out.len"));
    parts = vec.push(parts, ")\n  ");
    parts = vec.push(parts, llvm_local(prefix, ".ret.ptr"));
    parts = vec.push(parts, " = load i8*, i8** ");
    parts = vec.push(parts, llvm_local(prefix, ".out.ptr"));
    parts = vec.push(parts, "\n  ");
    parts = vec.push(parts, llvm_local(prefix, ".ret.len"));
    parts = vec.push(parts, " = load i64, i64* ");
    parts = vec.push(parts, llvm_local(prefix, ".out.len"));
    parts = vec.push(parts, "\n  ");
    parts = vec.push(parts, llvm_local(prefix, ".0"));
    parts = vec.push(parts, " = insertvalue %aic.String undef, i8* ");
    parts = vec.push(parts, llvm_local(prefix, ".ret.ptr"));
    parts = vec.push(parts, ", 0\n  ");
    parts = vec.push(parts, llvm_local(prefix, ".1"));
    parts = vec.push(parts, " = insertvalue %aic.String ");
    parts = vec.push(parts, llvm_local(prefix, ".0"));
    parts = vec.push(parts, ", i64 ");
    parts = vec.push(parts, llvm_local(prefix, ".ret.len"));
    parts = vec.push(parts, ", 1\n  ");
    parts = vec.push(parts, llvm_local(prefix, ".value"));
    parts = vec.push(parts, " = insertvalue %aic.String ");
    parts = vec.push(parts, llvm_local(prefix, ".1"));
    parts = vec.push(parts, ", i64 ");
    parts = vec.push(parts, llvm_local(prefix, ".ret.len"));
    parts = vec.push(parts, ", 2\n");
    string.join(parts, "")
}

fn string_node_value_name(node: IrExprNode) -> String {
    match node.kind {
        IrNameExpr => concat2("%", backend_mangle_symbol(node.text)),
        _ => llvm_node_value_local(node),
    }
}

fn emit_string_node_value(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], node: IrExprNode) -> String {
    match node.kind {
        IrStringExpr => emit_string_literal_value(llvm_string_node_global_name(function_value.name, node.node), node.text, llvm_node_prefix(node.node)),
        IrNameExpr => "",
        IrCallExpr => if node.name == "string.replace" {
            emit_string_replace_node_value(program, function_value, nodes, node)
        } else {
            emit_string_direct_call_node_value(program, function_value, nodes, node)
        },
        _ => "",
    }
}

fn emit_string_replace_node_value(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], node: IrExprNode) -> String {
    let mut parts: Vec[String] = vec.new_vec();
    let first = match expr_node_child_at(nodes, node, 0) {
        Some(child) => if true {
            parts = vec.push(parts, emit_string_node_value(program, function_value, nodes, child));
            string_node_value_name(child)
        } else { "" },
        None => "",
    };
    let second = match expr_node_child_at(nodes, node, 1) {
        Some(child) => if true {
            parts = vec.push(parts, emit_string_node_value(program, function_value, nodes, child));
            string_node_value_name(child)
        } else { "" },
        None => "",
    };
    let third = match expr_node_child_at(nodes, node, 2) {
        Some(child) => if true {
            parts = vec.push(parts, emit_string_node_value(program, function_value, nodes, child));
            string_node_value_name(child)
        } else { "" },
        None => "",
    };
    parts = vec.push(parts, emit_string_replace_call(llvm_node_prefix(node.node), first, second, third));
    string.join(parts, "")
}

fn emit_string_direct_call_node_value(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], node: IrExprNode) -> String {
    let mut parts: Vec[String] = vec.new_vec();
    let mut index = 0;
    while index < node.direct_child_count {
        match expr_node_child_at(nodes, node, index) {
            Some(child) => if call_target_param_type(program, node.name, index) == "%aic.String" {
                parts = vec.push(parts, emit_string_node_value(program, function_value, nodes, child));
            } else {
                ()
            },
            None => (),
        };
        index = index + 1;
    };
    parts = vec.push(parts, "  ");
    parts = vec.push(parts, llvm_node_value_local(node));
    parts = vec.push(parts, " = call %aic.String @");
    parts = vec.push(parts, backend_mangle_symbol(node.name));
    parts = vec.push(parts, "(");
    parts = vec.push(parts, emit_node_call_args(program, function_value, nodes, node));
    parts = vec.push(parts, ")\n");
    string.join(parts, "")
}

fn emit_string_replace_expr_value(program: IrProgram, function_value: IrFunctionDef, expr: IrExpr) -> String {
    let mut parts: Vec[String] = vec.new_vec();
    let first = match direct_expr_child_at(expr.nodes, 0) {
        Some(child) => if true {
            parts = vec.push(parts, emit_string_node_value(program, function_value, expr.nodes, child));
            string_node_value_name(child)
        } else { "" },
        None => "",
    };
    let second = match direct_expr_child_at(expr.nodes, 1) {
        Some(child) => if true {
            parts = vec.push(parts, emit_string_node_value(program, function_value, expr.nodes, child));
            string_node_value_name(child)
        } else { "" },
        None => "",
    };
    let third = match direct_expr_child_at(expr.nodes, 2) {
        Some(child) => if true {
            parts = vec.push(parts, emit_string_node_value(program, function_value, expr.nodes, child));
            string_node_value_name(child)
        } else { "" },
        None => "",
    };
    parts = vec.push(parts, emit_string_replace_call(llvm_expr_prefix(expr.node), first, second, third));
    string.join(parts, "")
}

fn emit_string_direct_call_expr_value(program: IrProgram, function_value: IrFunctionDef, expr: IrExpr) -> String {
    let mut parts: Vec[String] = vec.new_vec();
    parts = vec.push(parts, emit_call_arg_values(program, function_value, expr.nodes, expr.name));
    parts = vec.push(parts, "  ");
    parts = vec.push(parts, llvm_expr_value_local(expr));
    parts = vec.push(parts, " = call %aic.String @");
    parts = vec.push(parts, backend_mangle_symbol(expr.name));
    parts = vec.push(parts, "(");
    parts = vec.push(parts, emit_call_args(program, function_value, expr.nodes, expr.name));
    parts = vec.push(parts, ")\n");
    string.join(parts, "")
}

fn bool_node_value_name(node: IrExprNode) -> String {
    match node.kind {
        IrBoolExpr => if node.text == "true" { "1" } else { "0" },
        IrNameExpr => concat2("%", backend_mangle_symbol(node.text)),
        _ => llvm_node_value_local(node),
    }
}

fn emit_bool_node_value(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], node: IrExprNode) -> String {
    match node.kind {
        IrBoolExpr => "",
        IrNameExpr => "",
        IrBinaryExpr => emit_compare_node_value(program, function_value, nodes, node),
        _ => "",
    }
}

fn emit_compare_node_value(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], node: IrExprNode) -> String {
    match expr_node_child_at(nodes, node, 0) {
        Some(left) => match expr_node_child_at(nodes, node, 1) {
            Some(right) => if string_call_child_can_emit(program, function_value, nodes, left) && string_call_child_can_emit(program, function_value, nodes, right) {
                emit_string_compare_node_value(program, function_value, nodes, node, left, right)
            } else {
                emit_primitive_compare_node_value(program, function_value, node, left, right)
            },
            None => "",
        },
        None => "",
    }
}

fn emit_primitive_compare_node_value(program: IrProgram, function_value: IrFunctionDef, node: IrExprNode, left: IrExprNode, right: IrExprNode) -> String {
    let ty = simple_node_llvm_type(program, left, function_value);
    let mut parts: Vec[String] = vec.new_vec();
    parts = vec.push(parts, "  ");
    parts = vec.push(parts, llvm_node_value_local(node));
    parts = vec.push(parts, " = icmp ");
    parts = vec.push(parts, compare_predicate(node.op));
    parts = vec.push(parts, " ");
    parts = vec.push(parts, ty);
    parts = vec.push(parts, " ");
    parts = vec.push(parts, simple_node_llvm_value(left, function_value));
    parts = vec.push(parts, ", ");
    parts = vec.push(parts, simple_node_llvm_value(right, function_value));
    parts = vec.push(parts, "\n");
    string.join(parts, "")
}

fn emit_string_compare_node_value(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], node: IrExprNode, left: IrExprNode, right: IrExprNode) -> String {
    let left_name = string_node_value_name(left);
    let right_name = string_node_value_name(right);
    let mut parts: Vec[String] = vec.new_vec();
    parts = vec.push(parts, emit_string_node_value(program, function_value, nodes, left));
    parts = vec.push(parts, emit_string_node_value(program, function_value, nodes, right));
    parts = vec.push(parts, emit_string_extracts(left_name, concat2(llvm_node_prefix(node.node), ".lhs")));
    parts = vec.push(parts, emit_string_extracts(right_name, concat2(llvm_node_prefix(node.node), ".rhs")));
    parts = vec.push(parts, "  ");
    parts = vec.push(parts, llvm_local(llvm_node_prefix(node.node), ".raw"));
    parts = vec.push(parts, " = call i64 @aic_rt_string_compare(i8* ");
    parts = vec.push(parts, llvm_local(concat2(llvm_node_prefix(node.node), ".lhs"), ".ptr"));
    parts = vec.push(parts, ", i64 ");
    parts = vec.push(parts, llvm_local(concat2(llvm_node_prefix(node.node), ".lhs"), ".len"));
    parts = vec.push(parts, ", i64 ");
    parts = vec.push(parts, llvm_local(concat2(llvm_node_prefix(node.node), ".lhs"), ".cap"));
    parts = vec.push(parts, ", i8* ");
    parts = vec.push(parts, llvm_local(concat2(llvm_node_prefix(node.node), ".rhs"), ".ptr"));
    parts = vec.push(parts, ", i64 ");
    parts = vec.push(parts, llvm_local(concat2(llvm_node_prefix(node.node), ".rhs"), ".len"));
    parts = vec.push(parts, ", i64 ");
    parts = vec.push(parts, llvm_local(concat2(llvm_node_prefix(node.node), ".rhs"), ".cap"));
    parts = vec.push(parts, ")\n  ");
    parts = vec.push(parts, llvm_node_value_local(node));
    parts = vec.push(parts, " = icmp ");
    parts = vec.push(parts, string_compare_predicate(node.op));
    parts = vec.push(parts, " i64 ");
    parts = vec.push(parts, llvm_local(llvm_node_prefix(node.node), ".raw"));
    parts = vec.push(parts, ", 0\n");
    string.join(parts, "")
}

fn emit_return_name_value(program: IrProgram, function_value: IrFunctionDef, name: String, ret: String, prefix: String) -> String {
    let source_llvm = function_param_llvm_type(program, function_value, name);
    let source_value = concat2("%", backend_mangle_symbol(name));
    let cast_op = function_param_return_cast_op(program, function_value, name, ret);
    let mut parts: Vec[String] = vec.new_vec();
    if cast_op == "" {
        parts = vec.push(parts, "  ret ");
        parts = vec.push(parts, ret);
        parts = vec.push(parts, " ");
        parts = vec.push(parts, source_value);
        parts = vec.push(parts, "\n");
    } else {
        parts = vec.push(parts, "  ");
        parts = vec.push(parts, llvm_local(prefix, ".cast"));
        parts = vec.push(parts, " = ");
        parts = vec.push(parts, cast_op);
        parts = vec.push(parts, " ");
        parts = vec.push(parts, source_llvm);
        parts = vec.push(parts, " ");
        parts = vec.push(parts, source_value);
        parts = vec.push(parts, " to ");
        parts = vec.push(parts, ret);
        parts = vec.push(parts, "\n  ret ");
        parts = vec.push(parts, ret);
        parts = vec.push(parts, " ");
        parts = vec.push(parts, llvm_local(prefix, ".cast"));
        parts = vec.push(parts, "\n");
    };
    string.join(parts, "")
}

fn emit_return_node(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], node: IrExprNode, ret: String) -> String {
    let mut parts: Vec[String] = vec.new_vec();
    match node.kind {
        IrIntExpr => if true {
            parts = vec.push(parts, "  ret ");
            parts = vec.push(parts, ret);
            parts = vec.push(parts, " ");
            parts = vec.push(parts, node.text);
            parts = vec.push(parts, "\n");
            ()
        } else { () },
        IrBoolExpr => if true {
            parts = vec.push(parts, "  ret ");
            parts = vec.push(parts, ret);
            parts = vec.push(parts, " ");
            parts = vec.push(parts, if node.text == "true" { "1" } else { "0" });
            parts = vec.push(parts, "\n");
            ()
        } else { () },
        IrStringExpr => if true {
            parts = vec.push(parts, emit_string_literal_value(llvm_string_node_global_name(function_value.name, node.node), node.text, llvm_node_prefix(node.node)));
            parts = vec.push(parts, "  ret ");
            parts = vec.push(parts, ret);
            parts = vec.push(parts, " ");
            parts = vec.push(parts, llvm_node_value_local(node));
            parts = vec.push(parts, "\n");
            ()
        } else { () },
        IrNameExpr => if true {
            parts = vec.push(parts, emit_return_name_value(program, function_value, node.text, ret, llvm_node_prefix(node.node)));
            ()
        } else { () },
        IrCallExpr => if true {
            parts = vec.push(parts, emit_string_node_value(program, function_value, nodes, node));
            parts = vec.push(parts, "  ret ");
            parts = vec.push(parts, ret);
            parts = vec.push(parts, " ");
            parts = vec.push(parts, string_node_value_name(node));
            parts = vec.push(parts, "\n");
            ()
        } else { () },
        IrIfExpr => if true {
            parts = vec.push(parts, emit_if_node_return(program, function_value, nodes, node, ret));
            ()
        } else { () },
        _ => (),
    };
    string.join(parts, "")
}

fn emit_block_tail_return(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], block_node: IrExprNode, ret: String) -> String {
    match expr_node_child_at(nodes, block_node, 0) {
        Some(child) => emit_return_node(program, function_value, nodes, child, ret),
        None => "",
    }
}

fn emit_branch_return(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], branch_node: IrExprNode, ret: String) -> String {
    if is_block_expr_kind(branch_node.kind) {
        emit_block_tail_return(program, function_value, nodes, branch_node, ret)
    } else {
        emit_return_node(program, function_value, nodes, branch_node, ret)
    }
}

fn emit_if_node_return(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], node: IrExprNode, ret: String) -> String {
    match expr_node_child_at(nodes, node, 0) {
        Some(condition) => match expr_node_child_at(nodes, node, 1) {
            Some(then_block) => match expr_node_child_at(nodes, node, 2) {
                Some(else_block) => if true {
                    let then_label = concat2("if.then.", string.int_to_string(node.node.value));
                    let else_label = concat2("if.else.", string.int_to_string(node.node.value));
                    let mut parts: Vec[String] = vec.new_vec();
                    parts = vec.push(parts, emit_bool_node_value(program, function_value, nodes, condition));
                    parts = vec.push(parts, "  br i1 ");
                    parts = vec.push(parts, bool_node_value_name(condition));
                    parts = vec.push(parts, ", label %");
                    parts = vec.push(parts, then_label);
                    parts = vec.push(parts, ", label %");
                    parts = vec.push(parts, else_label);
                    parts = vec.push(parts, "\n");
                    parts = vec.push(parts, then_label);
                    parts = vec.push(parts, ":\n");
                    parts = vec.push(parts, emit_branch_return(program, function_value, nodes, then_block, ret));
                    parts = vec.push(parts, else_label);
                    parts = vec.push(parts, ":\n");
                    parts = vec.push(parts, emit_branch_return(program, function_value, nodes, else_block, ret));
                    string.join(parts, "")
                } else { "" },
                None => "",
            },
            None => "",
        },
        None => "",
    }
}

fn emit_if_expr_return(program: IrProgram, function_value: IrFunctionDef, expr: IrExpr, ret: String) -> String {
    match direct_expr_child_at(expr.nodes, 0) {
        Some(condition) => match direct_expr_child_at(expr.nodes, 1) {
            Some(then_block) => match direct_expr_child_at(expr.nodes, 2) {
                Some(else_block) => if true {
                    let then_label = concat2("if.then.", string.int_to_string(expr.node.value));
                    let else_label = concat2("if.else.", string.int_to_string(expr.node.value));
                    let mut parts: Vec[String] = vec.new_vec();
                    parts = vec.push(parts, emit_bool_node_value(program, function_value, expr.nodes, condition));
                    parts = vec.push(parts, "  br i1 ");
                    parts = vec.push(parts, bool_node_value_name(condition));
                    parts = vec.push(parts, ", label %");
                    parts = vec.push(parts, then_label);
                    parts = vec.push(parts, ", label %");
                    parts = vec.push(parts, else_label);
                    parts = vec.push(parts, "\n");
                    parts = vec.push(parts, then_label);
                    parts = vec.push(parts, ":\n");
                    parts = vec.push(parts, emit_branch_return(program, function_value, expr.nodes, then_block, ret));
                    parts = vec.push(parts, else_label);
                    parts = vec.push(parts, ":\n");
                    parts = vec.push(parts, emit_branch_return(program, function_value, expr.nodes, else_block, ret));
                    string.join(parts, "")
                } else { "" },
                None => "",
            },
            None => "",
        },
        None => "",
    }
}

fn io_print_runtime_name(name: String) -> String {
    if name == "eprint_str" {
        "@aic_rt_eprint_str"
    } else {
        "@aic_rt_print_str"
    }
}

fn emit_io_print_expr_return(program: IrProgram, function_value: IrFunctionDef, expr: IrExpr) -> String {
    match direct_expr_child_at(expr.nodes, 0) {
        Some(child) => if true {
            let arg_name = string_node_value_name(child);
            let prefix = llvm_expr_prefix(expr.node);
            let mut parts: Vec[String] = vec.new_vec();
            parts = vec.push(parts, emit_string_node_value(program, function_value, expr.nodes, child));
            parts = vec.push(parts, emit_string_extracts(arg_name, prefix));
            parts = vec.push(parts, "  call void ");
            parts = vec.push(parts, io_print_runtime_name(expr.name));
            parts = vec.push(parts, "(i8* ");
            parts = vec.push(parts, llvm_local(prefix, ".ptr"));
            parts = vec.push(parts, ", i64 ");
            parts = vec.push(parts, llvm_local(prefix, ".len"));
            parts = vec.push(parts, ", i64 ");
            parts = vec.push(parts, llvm_local(prefix, ".cap"));
            parts = vec.push(parts, ")\n  ret void\n");
            string.join(parts, "")
        } else { "" },
        None => "",
    }
}

fn emit_empty_string_return(prefix: String) -> String {
    let mut parts: Vec[String] = vec.new_vec();
    parts = vec.push(parts, "  ");
    parts = vec.push(parts, llvm_local(prefix, ".empty.0"));
    parts = vec.push(parts, " = insertvalue %aic.String undef, i8* null, 0\n  ");
    parts = vec.push(parts, llvm_local(prefix, ".empty.1"));
    parts = vec.push(parts, " = insertvalue %aic.String ");
    parts = vec.push(parts, llvm_local(prefix, ".empty.0"));
    parts = vec.push(parts, ", i64 0, 1\n  ");
    parts = vec.push(parts, llvm_local(prefix, ".empty.value"));
    parts = vec.push(parts, " = insertvalue %aic.String ");
    parts = vec.push(parts, llvm_local(prefix, ".empty.1"));
    parts = vec.push(parts, ", i64 0, 2\n  ret %aic.String ");
    parts = vec.push(parts, llvm_local(prefix, ".empty.value"));
    parts = vec.push(parts, "\n");
    string.join(parts, "")
}

fn emit_env_arg_or_empty_return(program: IrProgram, function_value: IrFunctionDef, expr: IrExpr) -> String {
    match direct_expr_child_at(expr.nodes, 0) {
        Some(call_node) => match expr_node_child_at(expr.nodes, call_node, 0) {
            Some(index_node) => if true {
                let prefix = llvm_expr_prefix(expr.node);
                let some_label = concat2("match.some.", string.int_to_string(expr.node.value));
                let none_label = concat2("match.none.", string.int_to_string(expr.node.value));
                let mut parts: Vec[String] = vec.new_vec();
                parts = vec.push(parts, "  ");
                parts = vec.push(parts, llvm_local(prefix, ".arg.ptr"));
                parts = vec.push(parts, " = alloca i8*\n  ");
                parts = vec.push(parts, llvm_local(prefix, ".arg.len"));
                parts = vec.push(parts, " = alloca i64\n  ");
                parts = vec.push(parts, llvm_local(prefix, ".arg.ok"));
                parts = vec.push(parts, " = call i64 @aic_rt_env_arg_at(i64 ");
                parts = vec.push(parts, simple_node_llvm_value(index_node, function_value));
                parts = vec.push(parts, ", i8** ");
                parts = vec.push(parts, llvm_local(prefix, ".arg.ptr"));
                parts = vec.push(parts, ", i64* ");
                parts = vec.push(parts, llvm_local(prefix, ".arg.len"));
                parts = vec.push(parts, ")\n  ");
                parts = vec.push(parts, llvm_local(prefix, ".arg.present"));
                parts = vec.push(parts, " = icmp ne i64 ");
                parts = vec.push(parts, llvm_local(prefix, ".arg.ok"));
                parts = vec.push(parts, ", 0\n  br i1 ");
                parts = vec.push(parts, llvm_local(prefix, ".arg.present"));
                parts = vec.push(parts, ", label %");
                parts = vec.push(parts, some_label);
                parts = vec.push(parts, ", label %");
                parts = vec.push(parts, none_label);
                parts = vec.push(parts, "\n");
                parts = vec.push(parts, some_label);
                parts = vec.push(parts, ":\n  ");
                parts = vec.push(parts, llvm_local(prefix, ".some.ptr"));
                parts = vec.push(parts, " = load i8*, i8** ");
                parts = vec.push(parts, llvm_local(prefix, ".arg.ptr"));
                parts = vec.push(parts, "\n  ");
                parts = vec.push(parts, llvm_local(prefix, ".some.len"));
                parts = vec.push(parts, " = load i64, i64* ");
                parts = vec.push(parts, llvm_local(prefix, ".arg.len"));
                parts = vec.push(parts, "\n  ");
                parts = vec.push(parts, llvm_local(prefix, ".some.0"));
                parts = vec.push(parts, " = insertvalue %aic.String undef, i8* ");
                parts = vec.push(parts, llvm_local(prefix, ".some.ptr"));
                parts = vec.push(parts, ", 0\n  ");
                parts = vec.push(parts, llvm_local(prefix, ".some.1"));
                parts = vec.push(parts, " = insertvalue %aic.String ");
                parts = vec.push(parts, llvm_local(prefix, ".some.0"));
                parts = vec.push(parts, ", i64 ");
                parts = vec.push(parts, llvm_local(prefix, ".some.len"));
                parts = vec.push(parts, ", 1\n  ");
                parts = vec.push(parts, llvm_local(prefix, ".some.value"));
                parts = vec.push(parts, " = insertvalue %aic.String ");
                parts = vec.push(parts, llvm_local(prefix, ".some.1"));
                parts = vec.push(parts, ", i64 ");
                parts = vec.push(parts, llvm_local(prefix, ".some.len"));
                parts = vec.push(parts, ", 2\n  ret %aic.String ");
                parts = vec.push(parts, llvm_local(prefix, ".some.value"));
                parts = vec.push(parts, "\n");
                parts = vec.push(parts, none_label);
                parts = vec.push(parts, ":\n");
                parts = vec.push(parts, emit_empty_string_return(prefix));
                string.join(parts, "")
            } else { "" },
            None => "",
        },
        None => "",
    }
}

fn emit_return_expr(program: IrProgram, function_value: IrFunctionDef, expr: IrExpr, ret: String) -> String {
    let mut parts: Vec[String] = vec.new_vec();
    match expr.kind {
        IrIntExpr => if true {
            parts = vec.push(parts, "  ret ");
            parts = vec.push(parts, ret);
            parts = vec.push(parts, " ");
            parts = vec.push(parts, expr.text);
            parts = vec.push(parts, "\n");
            ()
        } else { () },
        IrBoolExpr => if true {
            parts = vec.push(parts, "  ret ");
            parts = vec.push(parts, ret);
            parts = vec.push(parts, " ");
            parts = vec.push(parts, if expr.text == "true" { "1" } else { "0" });
            parts = vec.push(parts, "\n");
            ()
        } else { () },
        IrStringExpr => if true {
            let payload = string_literal_payload(expr.text);
            parts = vec.push(parts, "  %str.ptr = getelementptr inbounds [");
            parts = vec.push(parts, string.int_to_string(string.len(payload)));
            parts = vec.push(parts, " x i8], [");
            parts = vec.push(parts, string.int_to_string(string.len(payload)));
            parts = vec.push(parts, " x i8]* ");
            parts = vec.push(parts, llvm_string_global_name(function_value.name));
            parts = vec.push(parts, ", i64 0, i64 0\n");
            parts = vec.push(parts, "  %str.0 = insertvalue %aic.String undef, i8* %str.ptr, 0\n");
            parts = vec.push(parts, "  %str.1 = insertvalue %aic.String %str.0, i64 ");
            parts = vec.push(parts, string.int_to_string(string.len(payload)));
            parts = vec.push(parts, ", 1\n");
            parts = vec.push(parts, "  %str.2 = insertvalue %aic.String %str.1, i64 ");
            parts = vec.push(parts, string.int_to_string(string.len(payload)));
            parts = vec.push(parts, ", 2\n");
            parts = vec.push(parts, "  ret ");
            parts = vec.push(parts, ret);
            parts = vec.push(parts, " %str.2\n");
            ()
        } else { () },
        IrUnitExpr => if true {
            parts = vec.push(parts, "  ret void\n");
            ()
        } else { () },
        IrNameExpr => if true {
            parts = vec.push(parts, emit_return_name_value(program, function_value, expr.text, ret, llvm_expr_prefix(expr.node)));
            ()
        } else { () },
        IrBinaryExpr => if true {
            match direct_expr_child_at(expr.nodes, 0) {
                Some(left) => match direct_expr_child_at(expr.nodes, 1) {
                    Some(right) => if true {
                        parts = vec.push(parts, "  %ret = ");
                        parts = vec.push(parts, binary_llvm_op(expr.op));
                        parts = vec.push(parts, " ");
                        parts = vec.push(parts, ret);
                        parts = vec.push(parts, " ");
                        parts = vec.push(parts, simple_node_llvm_value(left, function_value));
                        parts = vec.push(parts, ", ");
                        parts = vec.push(parts, simple_node_llvm_value(right, function_value));
                        parts = vec.push(parts, "\n  ret ");
                        parts = vec.push(parts, ret);
                        parts = vec.push(parts, " %ret\n");
                        ()
                    } else { () },
                    None => (),
                },
                None => (),
            };
            ()
        } else { () },
        IrCallExpr => if true {
            if is_io_print_intrinsic_name(expr.name) {
                parts = vec.push(parts, emit_io_print_expr_return(program, function_value, expr));
            } else if expr.name == "string.replace" {
                parts = vec.push(parts, emit_string_replace_expr_value(program, function_value, expr));
                parts = vec.push(parts, "  ret ");
                parts = vec.push(parts, ret);
                parts = vec.push(parts, " ");
                parts = vec.push(parts, llvm_expr_value_local(expr));
                parts = vec.push(parts, "\n");
            } else {
                let call_ret = call_target_return_type(program, expr.name);
                if call_ret == "%aic.String" {
                    parts = vec.push(parts, emit_string_direct_call_expr_value(program, function_value, expr));
                    parts = vec.push(parts, "  ret ");
                    parts = vec.push(parts, ret);
                    parts = vec.push(parts, " ");
                    parts = vec.push(parts, llvm_expr_value_local(expr));
                    parts = vec.push(parts, "\n");
                } else {
                    parts = vec.push(parts, emit_call_arg_values(program, function_value, expr.nodes, expr.name));
                    parts = vec.push(parts, "  %ret = call ");
                    parts = vec.push(parts, call_ret);
                    parts = vec.push(parts, " @");
                    parts = vec.push(parts, backend_mangle_symbol(expr.name));
                    parts = vec.push(parts, "(");
                    parts = vec.push(parts, emit_call_args(program, function_value, expr.nodes, expr.name));
                    parts = vec.push(parts, ")\n  ret ");
                    parts = vec.push(parts, ret);
                    parts = vec.push(parts, " %ret\n");
                };
            };
            ()
        } else { () },
        IrIfExpr => if true {
            parts = vec.push(parts, emit_if_expr_return(program, function_value, expr, ret));
            ()
        } else { () },
        IrMatchExpr => if true {
            if env_arg_or_empty_expr_can_emit(program, expr, function_value) {
                parts = vec.push(parts, emit_env_arg_or_empty_return(program, function_value, expr));
            } else {
                let selected = static_match_body(expr);
                parts = vec.push(parts, "  ret ");
                parts = vec.push(parts, ret);
                parts = vec.push(parts, " ");
                if selected == "true" {
                    parts = vec.push(parts, "1");
                } else if selected == "false" {
                    parts = vec.push(parts, "0");
                } else {
                    parts = vec.push(parts, selected);
                };
                parts = vec.push(parts, "\n");
            };
            ()
        } else { () },
        _ => (),
    };
    string.join(parts, "")
}

fn emit_function_llvm(program: IrProgram, function_value: IrFunctionDef) -> String {
    let ret = llvm_type_for_id(program.types, function_value.return_type);
    let name = backend_mangle_symbol(function_value.name);
    let params = llvm_param_list(program, function_value.params);
    let mut parts: Vec[String] = vec.new_vec();
    parts = vec.push(parts, "define ");
    parts = vec.push(parts, ret);
    parts = vec.push(parts, " @");
    parts = vec.push(parts, name);
    parts = vec.push(parts, "(");
    parts = vec.push(parts, params);
    parts = vec.push(parts, ") {\nentry:\n");
    match function_value.body.tail_expr {
        Some(expr) => if true {
            parts = vec.push(parts, emit_return_expr(program, function_value, expr, ret));
            ()
        } else { () },
        None => if ret == "void" {
            parts = vec.push(parts, "  ret void\n");
        } else {
            ()
        },
    };
    parts = vec.push(parts, "}\n");
    string.join(parts, "")
}

fn collect_backend_symbols(program: IrProgram) -> Vec[BackendSymbol] {
    let mut symbols: Vec[BackendSymbol] = vec.new_vec();
    let mut index = 0;
    while index < vec.vec_len(program.items) {
        match vec.get(program.items, index) {
            Some(item) => match item {
                IrFunctionItemValue(function_value) => if function_value.runtime_visible {
                    symbols = vec.push(symbols, backend_symbol(function_value.name, backend_mangle_symbol(function_value.name), "function", function_value.span));
                } else {
                    ()
                },
                IrStructItemValue(struct_value) => if true {
                    symbols = vec.push(symbols, backend_symbol(struct_value.name, backend_mangle_symbol(struct_value.name), "struct", struct_value.span));
                    ()
                } else { () },
                IrEnumItemValue(enum_value) => if true {
                    symbols = vec.push(symbols, backend_symbol(enum_value.name, backend_mangle_symbol(enum_value.name), "enum", enum_value.span));
                    ()
                } else { () },
                IrTraitItemValue(trait_value) => if true {
                    symbols = vec.push(symbols, backend_symbol(trait_value.name, backend_mangle_symbol(trait_value.name), "trait", trait_value.span));
                    ()
                } else { () },
                IrImplItemValue(impl_value) => if true {
                    symbols = vec.push(symbols, backend_symbol(impl_value.head_text, backend_mangle_symbol(impl_value.head_text), "impl", impl_value.span));
                    ()
                } else { () },
                IrTypeAliasItemValue(alias_value) => if true {
                    symbols = vec.push(symbols, backend_symbol(alias_value.name, backend_mangle_symbol(alias_value.name), "type_alias", alias_value.span));
                    ()
                } else { () },
                IrConstItemValue(const_value) => if true {
                    symbols = vec.push(symbols, backend_symbol(const_value.name, backend_mangle_symbol(const_value.name), "const", const_value.span));
                    ()
                } else { () },
            },
            None => (),
        };
        index = index + 1;
    };
    symbols
}

fn emit_item_metadata(program: IrProgram) -> String {
    let mut parts: Vec[String] = vec.new_vec();
    let mut index = 0;
    while index < vec.vec_len(program.items) {
        match vec.get(program.items, index) {
            Some(item) => match item {
                IrStructItemValue(value) => if true {
                    parts = vec.push(parts, "; struct ");
                    parts = vec.push(parts, value.name);
                    parts = vec.push(parts, " fields=");
                    parts = vec.push(parts, string.int_to_string(vec.vec_len(value.fields)));
                    parts = vec.push(parts, "\n");
                    ()
                } else { () },
                IrEnumItemValue(value) => if true {
                    parts = vec.push(parts, "; enum ");
                    parts = vec.push(parts, value.name);
                    parts = vec.push(parts, " variants=");
                    parts = vec.push(parts, string.int_to_string(vec.vec_len(value.variants)));
                    parts = vec.push(parts, "\n");
                    ()
                } else { () },
                IrTraitItemValue(value) => if true {
                    parts = vec.push(parts, "; trait ");
                    parts = vec.push(parts, value.name);
                    parts = vec.push(parts, " methods=");
                    parts = vec.push(parts, string.int_to_string(vec.vec_len(value.methods)));
                    parts = vec.push(parts, "\n");
                    ()
                } else { () },
                IrImplItemValue(value) => if true {
                    parts = vec.push(parts, "; impl ");
                    parts = vec.push(parts, value.head_text);
                    parts = vec.push(parts, " methods=");
                    parts = vec.push(parts, string.int_to_string(vec.vec_len(value.methods)));
                    parts = vec.push(parts, "\n");
                    ()
                } else { () },
                IrTypeAliasItemValue(value) => if true {
                    parts = vec.push(parts, "; type_alias ");
                    parts = vec.push(parts, value.name);
                    parts = vec.push(parts, "\n");
                    ()
                } else { () },
                IrConstItemValue(value) => if true {
                    parts = vec.push(parts, "@");
                    parts = vec.push(parts, backend_mangle_symbol(value.name));
                    parts = vec.push(parts, " = internal constant i64 0\n");
                    ()
                } else { () },
                IrFunctionItemValue(_) => (),
            },
            None => (),
        };
        index = index + 1;
    };
    string.join(parts, "")
}

fn emit_functions_llvm(program: IrProgram) -> String {
    let mut parts: Vec[String] = vec.new_vec();
    let mut index = 0;
    while index < vec.vec_len(program.items) {
        match vec.get(program.items, index) {
            Some(item) => match item {
                IrFunctionItemValue(function_value) => if function_value.runtime_visible {
                    parts = vec.push(parts, emit_function_llvm(program, function_value));
                    parts = vec.push(parts, "\n");
                } else {
                    ()
                },
                _ => (),
            },
            None => (),
        };
        index = index + 1;
    };
    string.join(parts, "")
}

fn native_links_summary(links: Vec[BackendNativeLink]) -> String {
    let mut parts: Vec[String] = vec.new_vec();
    let mut index = 0;
    while index < vec.vec_len(links) {
        match vec.get(links, index) {
            Some(link) => if true {
                parts = vec.push(parts, "; native_link ");
                parts = vec.push(parts, backend_native_link_kind_name(link.kind));
                parts = vec.push(parts, " ");
                parts = vec.push(parts, link.name);
                if link.path != "" {
                    parts = vec.push(parts, " path=");
                    parts = vec.push(parts, link.path);
                } else {
                    ()
                };
                if link.static_link {
                    parts = vec.push(parts, " static=true");
                } else {
                    ()
                };
                parts = vec.push(parts, "\n");
                ()
            } else {
                ()
            },
            None => (),
        };
        index = index + 1;
    };
    string.join(parts, "")
}

pub fn emit_llvm_text(program: IrProgram, options: BackendOptions) -> String {
    let mut parts: Vec[String] = vec.new_vec();
    parts = vec.push(parts, "; AICore self-host LLVM IR (deterministic)\n");
    parts = vec.push(parts, "; format=aicore-selfhost-backend-llvm-v1\n");
    parts = vec.push(parts, "; module=");
    parts = vec.push(parts, program.module_path);
    parts = vec.push(parts, "\n");
    parts = vec.push(parts, "; artifact=");
    parts = vec.push(parts, backend_artifact_file_name(options));
    parts = vec.push(parts, "\n");
    if options.target_triple == "" {
        parts = vec.push(parts, "; target=native\n\n");
    } else {
        parts = vec.push(parts, "target triple = \"");
        parts = vec.push(parts, options.target_triple);
        parts = vec.push(parts, "\"\n\n");
    };
    parts = vec.push(parts, native_links_summary(options.native_links));
    parts = vec.push(parts, emit_type_declarations(program));
    parts = vec.push(parts, emit_runtime_declarations(program));
    parts = vec.push(parts, emit_string_globals(program));
    parts = vec.push(parts, emit_item_metadata(program));
    parts = vec.push(parts, "\n");
    parts = vec.push(parts, emit_functions_llvm(program));
    string.join(parts, "")
}

pub fn backend_artifact_digest(program: IrProgram, options: BackendOptions, llvm_text: String) -> String {
    let mut parts: Vec[String] = vec.new_vec();
    parts = vec.push(parts, "backend-v1;module=");
    parts = vec.push(parts, program.module_path);
    parts = vec.push(parts, ";artifact=");
    parts = vec.push(parts, backend_artifact_file_name(options));
    parts = vec.push(parts, ";kind=");
    parts = vec.push(parts, backend_artifact_kind_name(options.artifact_kind));
    parts = vec.push(parts, ";items=");
    parts = vec.push(parts, string.int_to_string(vec.vec_len(program.items)));
    parts = vec.push(parts, ";symbols=");
    parts = vec.push(parts, string.int_to_string(vec.vec_len(program.symbols)));
    parts = vec.push(parts, ";features=");
    parts = vec.push(parts, string.join(backend_program_features(program, options), ","));
    parts = vec.push(parts, ";bytes=");
    parts = vec.push(parts, string.int_to_string(string.len(llvm_text)));
    string.join(parts, "")
}

pub fn emit_backend_artifact(program: IrProgram, options: BackendOptions, max_errors: Int) -> BackendArtifact {
    let diagnostics = validate_backend_program(program, options, max_errors);
    let llvm_text = if vec.vec_len(diagnostics) == 0 {
        emit_llvm_text(program, options)
    } else {
        ""
    };
    BackendArtifact {
        format: "aicore-selfhost-backend-llvm-v1",
        schema_version: 1,
        artifact_name: options.artifact_name,
        file_name: backend_artifact_file_name(options),
        artifact_kind: options.artifact_kind,
        target_triple: options.target_triple,
        llvm_ir: llvm_text,
        symbols: collect_backend_symbols(program),
        features: backend_program_features(program, options),
        native_links: options.native_links,
        digest: backend_artifact_digest(program, options, llvm_text),
        diagnostics: diagnostics,
    }
}

pub fn backend_artifact_ok(value: BackendArtifact) -> Bool {
    vec.vec_len(value.diagnostics) == 0 && value.llvm_ir != ""
}

pub fn backend_diagnostic_count(value: BackendArtifact) -> Int {
    vec.vec_len(value.diagnostics)
}

pub fn backend_has_diagnostic_code(value: BackendArtifact, code: String) -> Bool {
    let mut index = 0;
    let mut found = false;
    while !found && index < vec.vec_len(value.diagnostics) {
        match vec.get(value.diagnostics, index) {
            Some(diagnostic_value) => if diagnostic_value.code.value == code {
                found = true;
            } else {
                ()
            },
            None => (),
        };
        index = index + 1;
    };
    found
}
