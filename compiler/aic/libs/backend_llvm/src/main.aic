module compiler.backend_llvm;

import compiler.source;
import compiler.diagnostics;
import compiler.ir;
import std.option;
import std.string;
import std.vec;

pub enum BackendArtifactKind {
    LlvmIrArtifact,
    NativeObjectArtifact,
    StaticLibraryArtifact,
    ExecutableArtifact,
}

pub enum BackendNativeLinkKind {
    NativeLibraryLink,
    NativeFrameworkLink,
    NativeObjectLink,
    NativeSearchPathLink,
}

pub struct BackendNativeLink {
    pub name: String,
    pub kind: BackendNativeLinkKind,
    pub path: String,
    pub static_link: Bool,
    pub span: SourceSpan,
}

pub struct BackendOptions {
    pub artifact_name: String,
    pub target_triple: String,
    pub artifact_kind: BackendArtifactKind,
    pub require_entry: Bool,
    pub native_links: Vec[BackendNativeLink],
}

pub struct BackendSymbol {
    pub source_name: String,
    pub llvm_name: String,
    pub kind: String,
    pub span: SourceSpan,
}

struct BackendLocal {
    name: String,
    type_name: String,
    llvm_type: String,
    value_name: String,
}

struct BackendLocalCheck {
    ok: Bool,
    locals: Vec[BackendLocal],
}

struct BackendStatementEmission {
    text: String,
    locals: Vec[BackendLocal],
}

pub struct BackendArtifact {
    pub format: String,
    pub schema_version: Int,
    pub artifact_name: String,
    pub file_name: String,
    pub artifact_kind: BackendArtifactKind,
    pub target_triple: String,
    pub llvm_ir: String,
    pub symbols: Vec[BackendSymbol],
    pub features: Vec[String],
    pub native_links: Vec[BackendNativeLink],
    pub digest: String,
    pub diagnostics: Vec[Diagnostic],
}

pub fn backend_native_link(name: String, kind: BackendNativeLinkKind, path: String, static_link: Bool, span_value: SourceSpan) -> BackendNativeLink {
    BackendNativeLink {
        name: name,
        kind: kind,
        path: path,
        static_link: static_link,
        span: span_value,
    }
}

pub fn backend_options(artifact_name: String, target_triple: String, artifact_kind: BackendArtifactKind, require_entry: Bool, native_links: Vec[BackendNativeLink]) -> BackendOptions {
    BackendOptions {
        artifact_name: artifact_name,
        target_triple: target_triple,
        artifact_kind: artifact_kind,
        require_entry: require_entry,
        native_links: native_links,
    }
}

fn backend_artifact_kind_name(value: BackendArtifactKind) -> String {
    match value {
        LlvmIrArtifact => "llvm-ir",
        NativeObjectArtifact => "object",
        StaticLibraryArtifact => "static-library",
        ExecutableArtifact => "executable",
    }
}

fn backend_native_link_kind_name(value: BackendNativeLinkKind) -> String {
    match value {
        NativeLibraryLink => "library",
        NativeFrameworkLink => "framework",
        NativeObjectLink => "object",
        NativeSearchPathLink => "search-path",
    }
}

fn backend_artifact_extension(value: BackendArtifactKind) -> String {
    match value {
        LlvmIrArtifact => ".ll",
        NativeObjectArtifact => ".o",
        StaticLibraryArtifact => ".a",
        ExecutableArtifact => "",
    }
}

fn backend_error(code: String, span_value: SourceSpan, message: String, help: String) -> Diagnostic {
    with_help(error(diagnostic_code(code), span_value, message), help)
}

fn push_backend_error(values: Vec[Diagnostic], code: String, span_value: SourceSpan, message: String, help: String) -> Vec[Diagnostic] {
    vec.push(values, backend_error(code, span_value, message, help))
}

fn validate_backend_ir_input(program: IrProgram) -> Vec[Diagnostic] {
    let mut diagnostics: Vec[Diagnostic] = vec.new_vec();
    if program.schema_version != current_ir_schema_version() {
        diagnostics = push_backend_error(diagnostics, "E5010", program.span, "backend emission requires schema_version 1 IR", "migrate older IR or reject future schema versions before backend lowering");
    } else {
        ()
    };
    if vec.vec_len(program.items) > 0 && vec.vec_len(program.source_map) == 0 {
        diagnostics = push_backend_error(diagnostics, "E5011", program.span, "backend emission requires source-map metadata for item-bearing programs", "preserve lowering source_map entries so backend diagnostics can locate generated nodes");
    } else {
        ()
    };
    let mut symbol_index = 0;
    while symbol_index < vec.vec_len(program.symbols) {
        match vec.get(program.symbols, symbol_index) {
            Some(symbol_value) => if symbol_value.name == "" {
                diagnostics = push_backend_error(diagnostics, "E5013", symbol_value.span, "backend emission requires named IR symbols", "retain symbol names during IR lowering");
            } else {
                ()
            },
            None => (),
        };
        symbol_index = symbol_index + 1;
    };
    let mut type_index = 0;
    while type_index < vec.vec_len(program.types) {
        match vec.get(program.types, type_index) {
            Some(type_value) => if type_value.name == "" {
                diagnostics = push_backend_error(diagnostics, "E5013", type_value.span, "backend emission requires named IR types", "retain canonical type repr metadata during IR lowering");
            } else {
                ()
            },
            None => (),
        };
        type_index = type_index + 1;
    };
    let mut source_index = 0;
    while source_index < vec.vec_len(program.source_map) {
        match vec.get(program.source_map, source_index) {
            Some(entry) => if entry.kind == "" || entry.name == "" {
                diagnostics = push_backend_error(diagnostics, "E5013", entry.span, "backend emission requires named source-map entries", "preserve source-map kind/name fields during IR lowering");
            } else {
                ()
            },
            None => (),
        };
        source_index = source_index + 1;
    };
    diagnostics
}

pub fn default_backend_options(name: String) -> BackendOptions {
    backend_options(name, "", LlvmIrArtifact(), true, vec.new_vec())
}

fn concat2(left: String, right: String) -> String {
    let mut parts: Vec[String] = vec.new_vec();
    parts = vec.push(parts, left);
    parts = vec.push(parts, right);
    string.join(parts, "")
}

fn concat3(first: String, second: String, third: String) -> String {
    let mut parts: Vec[String] = vec.new_vec();
    parts = vec.push(parts, first);
    parts = vec.push(parts, second);
    parts = vec.push(parts, third);
    string.join(parts, "")
}

pub fn backend_mangle_symbol(name: String) -> String {
    let mut out = string.replace(name, "::", "_");
    out = string.replace(out, ".", "_");
    out = string.replace(out, "[", "_");
    out = string.replace(out, "]", "");
    out = string.replace(out, ",", "_");
    out = string.replace(out, " ", "_");
    out = string.replace(out, "-", "_");
    out = string.replace(out, "(", "_");
    out = string.replace(out, ")", "");
    if out == "main" {
        "main"
    } else {
        concat2("aic_", out)
    }
}

pub fn backend_artifact_file_name(options: BackendOptions) -> String {
    let base = if options.artifact_name == "" {
        "aic_selfhost"
    } else {
        backend_mangle_symbol(options.artifact_name)
    };
    if match options.artifact_kind { StaticLibraryArtifact => true, _ => false } {
        concat3("lib", base, backend_artifact_extension(options.artifact_kind))
    } else {
        concat2(base, backend_artifact_extension(options.artifact_kind))
    }
}

fn backend_symbol(source_name: String, llvm_name: String, kind: String, span_value: SourceSpan) -> BackendSymbol {
    BackendSymbol {
        source_name: source_name,
        llvm_name: llvm_name,
        kind: kind,
        span: span_value,
    }
}

fn backend_local(name: String, type_name: String, llvm_type: String, value_name: String) -> BackendLocal {
    BackendLocal {
        name: name,
        type_name: type_name,
        llvm_type: llvm_type,
        value_name: value_name,
    }
}

fn backend_local_check(ok: Bool, locals: Vec[BackendLocal]) -> BackendLocalCheck {
    BackendLocalCheck {
        ok: ok,
        locals: locals,
    }
}

fn backend_statement_emission(text: String, locals: Vec[BackendLocal]) -> BackendStatementEmission {
    BackendStatementEmission {
        text: text,
        locals: locals,
    }
}

fn type_name_for_id(types: Vec[IrTypeDef], id: IrTypeId) -> String {
    let mut index = 0;
    let mut out = "<?>";
    while index < vec.vec_len(types) {
        match vec.get(types, index) {
            Some(value) => if value.id.value == id.value {
                out = value.name;
                index = vec.vec_len(types);
            } else {
                ()
            },
            None => (),
        };
        index = index + 1;
    };
    out
}

fn llvm_type_for_repr(repr: String) -> String {
    if repr == "Int" || repr == "Int64" || repr == "UInt" || repr == "usize" || repr == "isize" {
        "i64"
    } else if repr == "Int32" || repr == "UInt32" || repr == "ProcExitStatus" {
        "i32"
    } else if repr == "Int16" || repr == "UInt16" {
        "i16"
    } else if repr == "Int8" || repr == "UInt8" {
        "i8"
    } else if repr == "Bool" {
        "i1"
    } else if repr == "String" {
        "%aic.String"
    } else if repr == "()" {
        "void"
    } else {
        ""
    }
}

fn base_type_name_text(value: String) -> String {
    let mut index = 0;
    let mut out = value;
    while index < string.len(value) {
        if string.substring(value, index, index + 1) == "[" {
            out = string.trim(string.substring(value, 0, index));
            index = string.len(value);
        } else {
            ()
        };
        index = index + 1;
    };
    out
}

fn generic_arg_at(value: String, target: Int) -> String {
    let mut bracket = -1;
    let mut index = 0;
    while bracket < 0 && index < string.len(value) {
        if string.substring(value, index, index + 1) == "[" {
            bracket = index;
        } else {
            ()
        };
        index = index + 1;
    };
    let mut out = "";
    if bracket >= 0 {
        let mut depth = 0;
        let mut seen = 0;
        let mut start = bracket + 1;
        index = bracket + 1;
        while out == "" && index < string.len(value) {
            let ch = string.substring(value, index, index + 1);
            if ch == "[" {
                depth = depth + 1;
            } else if ch == "]" {
                if depth == 0 {
                    if seen == target {
                        out = string.trim(string.substring(value, start, index));
                    } else {
                        ()
                    };
                    index = string.len(value);
                } else {
                    depth = depth - 1;
                }
            } else if ch == "," && depth == 0 {
                if seen == target {
                    out = string.trim(string.substring(value, start, index));
                    index = string.len(value);
                } else {
                    seen = seen + 1;
                    start = index + 1;
                }
            } else {
                ()
            };
            index = index + 1;
        }
    } else {
        ()
    };
    out
}

fn llvm_no_payload_enum_type(variant_count: Int) -> String {
    let mut parts: Vec[String] = vec.new_vec();
    parts = vec.push(parts, "{ i32");
    let mut index = 0;
    while index < variant_count {
        parts = vec.push(parts, ", i8");
        index = index + 1;
    };
    parts = vec.push(parts, " }");
    string.join(parts, "")
}

fn known_no_payload_enum_llvm_type(name: String) -> String {
    if name == "FsError" {
        llvm_no_payload_enum_type(7)
    } else if name == "ProcError" {
        llvm_no_payload_enum_type(5)
    } else if name == "IoError" {
        llvm_no_payload_enum_type(3)
    } else if name == "Writer" {
        llvm_no_payload_enum_type(2)
    } else {
        ""
    }
}

fn llvm_payload_slot_type(program: IrProgram, repr: String) -> String {
    let ty = llvm_type_for_repr_in_program(program, repr);
    if ty == "void" {
        "i8"
    } else {
        ty
    }
}

fn llvm_result_type(program: IrProgram, repr: String) -> String {
    let ok = generic_arg_at(repr, 0);
    let err = generic_arg_at(repr, 1);
    let ok_ty = llvm_payload_slot_type(program, ok);
    let err_ty = llvm_payload_slot_type(program, err);
    if ok_ty == "" || err_ty == "" {
        ""
    } else {
        concat3(concat3("{ i32, ", ok_ty, ", "), err_ty, " }")
    }
}

fn llvm_option_type(program: IrProgram, repr: String) -> String {
    let some = generic_arg_at(repr, 0);
    let some_ty = llvm_payload_slot_type(program, some);
    if some_ty == "" {
        ""
    } else {
        concat3("{ i32, ", some_ty, ", i8 }")
    }
}

fn known_struct_llvm_type(program: IrProgram, name: String) -> String {
    if name == "SourceId" {
        "{ i64 }"
    } else if name == "DriverSource" {
        "{ %aic.String, %aic.String, { i64 } }"
    } else if name == "DriverCommandResult" {
        "{ i64, %aic.String, %aic.String, %aic.String, %aic.String, { i64, i64, i64 } }"
    } else if name == "ProcOutput" {
        "{ i32, %aic.String, %aic.String }"
    } else if name == "SourceLoadState" {
        "{ { i64, i64, i64 }, i64 }"
    } else {
        ""
    }
}

fn known_struct_field_llvm_type_by_index(name: String, field_index: Int) -> String {
    if name == "SourceId" {
        if field_index == 0 { "i64" } else { "" }
    } else if name == "DriverSource" {
        if field_index == 0 {
            "%aic.String"
        } else if field_index == 1 {
            "%aic.String"
        } else if field_index == 2 {
            "{ i64 }"
        } else {
            ""
        }
    } else if name == "DriverCommandResult" {
        if field_index == 0 {
            "i64"
        } else if field_index == 1 {
            "%aic.String"
        } else if field_index == 2 {
            "%aic.String"
        } else if field_index == 3 {
            "%aic.String"
        } else if field_index == 4 {
            "%aic.String"
        } else if field_index == 5 {
            "{ i64, i64, i64 }"
        } else {
            ""
        }
    } else if name == "ProcOutput" {
        if field_index == 0 {
            "i32"
        } else if field_index == 1 {
            "%aic.String"
        } else if field_index == 2 {
            "%aic.String"
        } else {
            ""
        }
    } else if name == "SourceLoadState" {
        if field_index == 0 {
            "{ i64, i64, i64 }"
        } else if field_index == 1 {
            "i64"
        } else {
            ""
        }
    } else {
        ""
    }
}

fn struct_item_field_llvm_type_by_index(program: IrProgram, name: String, field_index: Int) -> String {
    let mut item_index = 0;
    let mut out = "";
    while out == "" && item_index < vec.vec_len(program.items) {
        match vec.get(program.items, item_index) {
            Some(item) => match item {
                IrStructItemValue(struct_value) => if struct_value.name == name {
                    match vec.get(struct_value.fields, field_index) {
                        Some(field) => if true {
                            out = llvm_type_for_id(program, field.type_id);
                            ()
                        } else { () },
                        None => (),
                    }
                } else {
                    ()
                },
                _ => (),
            },
            None => (),
        };
        item_index = item_index + 1;
    };
    out
}

fn struct_field_llvm_type_by_index(program: IrProgram, name: String, field_index: Int) -> String {
    let known = known_struct_field_llvm_type_by_index(name, field_index);
    if known != "" {
        known
    } else {
        struct_item_field_llvm_type_by_index(program, name, field_index)
    }
}

fn struct_item_llvm_type(program: IrProgram, name: String) -> String {
    let mut item_index = 0;
    let mut out = "";
    while out == "" && item_index < vec.vec_len(program.items) {
        match vec.get(program.items, item_index) {
            Some(item) => match item {
                IrStructItemValue(struct_value) => if struct_value.name == name {
                    let mut parts: Vec[String] = vec.new_vec();
                    parts = vec.push(parts, "{ ");
                    let mut field_index = 0;
                    let mut ok = true;
                    while ok && field_index < vec.vec_len(struct_value.fields) {
                        match vec.get(struct_value.fields, field_index) {
                            Some(field) => if true {
                                let field_ty = llvm_type_for_id(program, field.type_id);
                                if field_ty == "" {
                                    ok = false;
                                } else {
                                    if field_index > 0 {
                                        parts = vec.push(parts, ", ");
                                    } else {
                                        ()
                                    };
                                    parts = vec.push(parts, field_ty);
                                };
                                ()
                            } else { () },
                            None => (),
                        };
                        field_index = field_index + 1;
                    };
                    if ok {
                        parts = vec.push(parts, " }");
                        out = string.join(parts, "");
                    } else {
                        ()
                    }
                } else {
                    ()
                },
                _ => (),
            },
            None => (),
        };
        item_index = item_index + 1;
    };
    out
}

fn enum_item_llvm_type(program: IrProgram, name: String) -> String {
    let mut item_index = 0;
    let mut out = "";
    while out == "" && item_index < vec.vec_len(program.items) {
        match vec.get(program.items, item_index) {
            Some(item) => match item {
                IrEnumItemValue(enum_value) => if enum_value.name == name {
                    let mut parts: Vec[String] = vec.new_vec();
                    parts = vec.push(parts, "{ i32");
                    let mut variant_index = 0;
                    let mut ok = true;
                    while ok && variant_index < vec.vec_len(enum_value.variants) {
                        match vec.get(enum_value.variants, variant_index) {
                            Some(variant) => if true {
                                let slot_ty = match variant.payload_type {
                                    Some(type_id_value) => llvm_payload_slot_type(program, type_name_for_id(program.types, type_id_value)),
                                    None => "i8",
                                };
                                if slot_ty == "" {
                                    ok = false;
                                } else {
                                    parts = vec.push(parts, ", ");
                                    parts = vec.push(parts, slot_ty);
                                };
                                ()
                            } else { () },
                            None => (),
                        };
                        variant_index = variant_index + 1;
                    };
                    if ok {
                        parts = vec.push(parts, " }");
                        out = string.join(parts, "");
                    } else {
                        ()
                    }
                } else {
                    ()
                },
                _ => (),
            },
            None => (),
        };
        item_index = item_index + 1;
    };
    out
}

fn llvm_type_for_repr_in_program(program: IrProgram, repr: String) -> String {
    let primitive = llvm_type_for_repr(repr);
    if primitive != "" {
        primitive
    } else {
        let base = base_type_name_text(repr);
        if base == "Vec" {
            "{ i64, i64, i64 }"
        } else if base == "Result" {
            llvm_result_type(program, repr)
        } else if base == "Option" {
            llvm_option_type(program, repr)
        } else {
            let known_struct = known_struct_llvm_type(program, base);
            if known_struct != "" {
                known_struct
            } else {
                let known_enum = known_no_payload_enum_llvm_type(base);
                if known_enum != "" {
                    known_enum
                } else {
                    let struct_ty = struct_item_llvm_type(program, base);
                    if struct_ty != "" {
                        struct_ty
                    } else {
                        enum_item_llvm_type(program, base)
                    }
                }
            }
        }
    }
}

fn llvm_type_for_id(program: IrProgram, id: IrTypeId) -> String {
    llvm_type_for_repr_in_program(program, type_name_for_id(program.types, id))
}

fn is_llvm_primitive_type(repr: String) -> Bool {
    llvm_type_for_repr(repr) != ""
}

fn is_supported_backend_expr_kind(value: IrExprKind) -> Bool {
    match value {
        IrIntExpr => true,
        IrFloatExpr => true,
        IrBoolExpr => true,
        IrStringExpr => true,
        IrCharExpr => true,
        IrTemplateExpr => false,
        IrUnitExpr => true,
        IrNameExpr => true,
        IrCallExpr => true,
        IrClosureExpr => true,
        IrIfExpr => true,
        IrWhileExpr => true,
        IrForExpr => false,
        IrLoopExpr => true,
        IrBreakExpr => true,
        IrContinueExpr => true,
        IrMatchExpr => true,
        IrBinaryExpr => true,
        IrUnaryExpr => true,
        IrBorrowExpr => true,
        IrAwaitExpr => true,
        IrTryExpr => true,
        IrStructLiteralExpr => true,
        IrTupleExpr => true,
        IrFieldAccessExpr => true,
        IrBlockExpr => true,
        IrUnsafeBlockExpr => false,
    }
}

fn is_string_expr_kind(value: IrExprKind) -> Bool {
    match value {
        IrStringExpr => true,
        _ => false,
    }
}

fn is_call_expr_kind(value: IrExprKind) -> Bool {
    match value {
        IrCallExpr => true,
        _ => false,
    }
}

fn is_block_expr_kind(value: IrExprKind) -> Bool {
    match value {
        IrBlockExpr => true,
        _ => false,
    }
}

fn is_io_print_intrinsic_name(name: String) -> Bool {
    name == "print_str" || name == "eprint_str"
}

fn is_fs_string_result_intrinsic_name(name: String) -> Bool {
    name == "read_text" || name == "temp_file"
}

fn is_fs_bool_result_intrinsic_name(name: String) -> Bool {
    name == "write_text" || name == "delete"
}

fn is_fs_intrinsic_name(name: String) -> Bool {
    is_fs_string_result_intrinsic_name(name) || is_fs_bool_result_intrinsic_name(name)
}

fn is_decimal_digit(value: String) -> Bool {
    value == "0" || value == "1" || value == "2" || value == "3" || value == "4" || value == "5" || value == "6" || value == "7" || value == "8" || value == "9"
}

fn is_decimal_integer_text(value: String) -> Bool {
    if value == "" {
        false
    } else {
        let mut index = 0;
        let mut ok = true;
        while ok && index < string.len(value) {
            let part = string.substring(value, index, index + 1);
            if index == 0 && part == "-" {
                ok = string.len(value) > 1;
            } else if !is_decimal_digit(part) {
                ok = false;
            } else {
                ()
            };
            index = index + 1;
        };
        ok
    }
}

fn function_has_param_named(function_value: IrFunctionDef, name: String) -> Bool {
    let mut index = 0;
    let mut found = false;
    while !found && index < vec.vec_len(function_value.params) {
        match vec.get(function_value.params, index) {
            Some(param) => if param.name == name {
                found = true;
            } else {
                ()
            },
            None => (),
        };
        index = index + 1;
    };
    found
}

fn function_param_llvm_type(program: IrProgram, function_value: IrFunctionDef, name: String) -> String {
    let mut index = 0;
    let mut out = "";
    while out == "" && index < vec.vec_len(function_value.params) {
        match vec.get(function_value.params, index) {
            Some(param) => if param.name == name {
                out = llvm_type_for_id(program, param.type_id);
            } else {
                ()
            },
            None => (),
        };
        index = index + 1;
    };
    out
}

fn function_param_type_name(program: IrProgram, function_value: IrFunctionDef, name: String) -> String {
    let mut index = 0;
    let mut out = "";
    while out == "" && index < vec.vec_len(function_value.params) {
        match vec.get(function_value.params, index) {
            Some(param) => if param.name == name {
                out = type_name_for_id(program.types, param.type_id);
            } else {
                ()
            },
            None => (),
        };
        index = index + 1;
    };
    out
}

fn backend_local_named(locals: Vec[BackendLocal], name: String) -> Option[BackendLocal] {
    let mut index = vec.vec_len(locals) - 1;
    let mut out: Option[BackendLocal] = None();
    let mut done = vec.vec_len(locals) == 0;
    while !done {
        match vec.get(locals, index) {
            Some(value) => if value.name == name {
                out = Some(value);
                done = true;
            } else if index == 0 {
                done = true;
            } else {
                index = index - 1;
            },
            None => if index == 0 {
                done = true;
            } else {
                index = index - 1;
            },
        }
    };
    out
}

fn value_name_for_name(function_value: IrFunctionDef, locals: Vec[BackendLocal], name: String) -> String {
    match backend_local_named(locals, name) {
        Some(local_value) => local_value.value_name,
        None => value_name_for_param(function_value, name),
    }
}

fn type_name_for_name(program: IrProgram, function_value: IrFunctionDef, locals: Vec[BackendLocal], name: String) -> String {
    match backend_local_named(locals, name) {
        Some(local_value) => local_value.type_name,
        None => function_param_type_name(program, function_value, name),
    }
}

fn llvm_type_for_name(program: IrProgram, function_value: IrFunctionDef, locals: Vec[BackendLocal], name: String) -> String {
    match backend_local_named(locals, name) {
        Some(local_value) => local_value.llvm_type,
        None => function_param_llvm_type(program, function_value, name),
    }
}

fn name_is_value_available(function_value: IrFunctionDef, locals: Vec[BackendLocal], name: String) -> Bool {
    value_name_for_name(function_value, locals, name) != ""
}

fn value_name_for_param(function_value: IrFunctionDef, name: String) -> String {
    if function_has_param_named(function_value, name) {
        concat2("%", backend_mangle_symbol(name))
    } else {
        ""
    }
}

fn known_struct_field_index_by_name(name: String, field_name: String) -> Int {
    if name == "SourceId" {
        if field_name == "value" { 0 } else { -1 }
    } else if name == "DriverSource" {
        if field_name == "path" {
            0
        } else if field_name == "text" {
            1
        } else if field_name == "source" {
            2
        } else {
            -1
        }
    } else if name == "DriverCommandResult" {
        if field_name == "exit_code" {
            0
        } else if field_name == "stdout" {
            1
        } else if field_name == "stderr" {
            2
        } else if field_name == "artifact_path" {
            3
        } else if field_name == "artifact_text" {
            4
        } else if field_name == "diagnostics" {
            5
        } else {
            -1
        }
    } else if name == "ProcOutput" {
        if field_name == "status" {
            0
        } else if field_name == "stdout" {
            1
        } else if field_name == "stderr" {
            2
        } else {
            -1
        }
    } else if name == "SourceLoadState" {
        if field_name == "sources" {
            0
        } else if field_name == "next_source" {
            1
        } else {
            -1
        }
    } else {
        -1
    }
}

fn struct_item_field_index_by_name(program: IrProgram, name: String, field_name: String) -> Int {
    let mut item_index = 0;
    let mut out = -1;
    while out < 0 && item_index < vec.vec_len(program.items) {
        match vec.get(program.items, item_index) {
            Some(item) => match item {
                IrStructItemValue(struct_value) => if struct_value.name == name {
                    let mut field_index = 0;
                    while out < 0 && field_index < vec.vec_len(struct_value.fields) {
                        match vec.get(struct_value.fields, field_index) {
                            Some(field) => if field.name == field_name {
                                out = field_index;
                            } else {
                                ()
                            },
                            None => (),
                        };
                        field_index = field_index + 1;
                    };
                    ()
                } else {
                    ()
                },
                _ => (),
            },
            None => (),
        };
        item_index = item_index + 1;
    };
    out
}

fn struct_field_index_by_name(program: IrProgram, name: String, field_name: String) -> Int {
    let known = known_struct_field_index_by_name(name, field_name);
    if known >= 0 {
        known
    } else {
        struct_item_field_index_by_name(program, name, field_name)
    }
}

fn field_access_name_from_text(value: String) -> String {
    let mut index = 0;
    let mut start = 0;
    while index < string.len(value) {
        if string.substring(value, index, index + 1) == "." {
            start = index + 1;
        } else {
            ()
        };
        index = index + 1;
    };
    string.substring(value, start, string.len(value))
}

fn field_access_field_name(node: IrExprNode) -> String {
    if node.name != "" {
        node.name
    } else {
        field_access_name_from_text(node.text)
    }
}

fn field_access_base_node(nodes: Vec[IrExprNode], node: IrExprNode) -> Option[IrExprNode] {
    expr_node_child_at(nodes, node, 0)
}

fn field_access_base_type_name(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], node: IrExprNode, locals: Vec[BackendLocal]) -> String {
    match field_access_base_node(nodes, node) {
        Some(base) => match base.kind {
            IrNameExpr => type_name_for_name(program, function_value, locals, base.text),
            _ => "",
        },
        None => "",
    }
}

fn field_access_node_llvm_type(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], node: IrExprNode, locals: Vec[BackendLocal]) -> String {
    let base_type = field_access_base_type_name(program, function_value, nodes, node, locals);
    let field_index = struct_field_index_by_name(program, base_type, field_access_field_name(node));
    if base_type == "" || field_index < 0 {
        ""
    } else {
        struct_field_llvm_type_by_index(program, base_type, field_index)
    }
}

fn field_access_node_can_emit(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], node: IrExprNode, locals: Vec[BackendLocal], expected: String) -> Bool {
    field_access_node_llvm_type(program, function_value, nodes, node, locals) == expected
}

fn field_access_base_value_name(function_value: IrFunctionDef, nodes: Vec[IrExprNode], node: IrExprNode, locals: Vec[BackendLocal]) -> String {
    match field_access_base_node(nodes, node) {
        Some(base) => match base.kind {
            IrNameExpr => value_name_for_name(function_value, locals, base.text),
            _ => "",
        },
        None => "",
    }
}

fn emit_field_access_node_value(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], node: IrExprNode, locals: Vec[BackendLocal]) -> String {
    let base_type = field_access_base_type_name(program, function_value, nodes, node, locals);
    let field_index = struct_field_index_by_name(program, base_type, field_access_field_name(node));
    let field_ty = if field_index >= 0 {
        struct_field_llvm_type_by_index(program, base_type, field_index)
    } else {
        ""
    };
    let base_value = field_access_base_value_name(function_value, nodes, node, locals);
    if base_type == "" || field_ty == "" || base_value == "" || field_index < 0 {
        ""
    } else {
        let mut parts: Vec[String] = vec.new_vec();
        parts = vec.push(parts, "  ");
        parts = vec.push(parts, llvm_node_value_local(node));
        parts = vec.push(parts, " = extractvalue ");
        parts = vec.push(parts, llvm_type_for_repr_in_program(program, base_type));
        parts = vec.push(parts, " ");
        parts = vec.push(parts, base_value);
        parts = vec.push(parts, ", ");
        parts = vec.push(parts, string.int_to_string(field_index));
        parts = vec.push(parts, "\n");
        string.join(parts, "")
    }
}

fn llvm_int_bits(value: String) -> Int {
    if value == "i8" {
        8
    } else if value == "i16" {
        16
    } else if value == "i32" {
        32
    } else if value == "i64" {
        64
    } else {
        0
    }
}

fn type_name_is_signed_integer(value: String) -> Bool {
    value == "Int" || value == "Int8" || value == "Int16" || value == "Int32" || value == "Int64" || value == "Int128" || value == "isize" || value == "ProcExitStatus"
}

fn llvm_integer_extension_op(source_type_name: String, source_llvm: String, target_llvm: String) -> String {
    let source_bits = llvm_int_bits(source_llvm);
    let target_bits = llvm_int_bits(target_llvm);
    if source_bits > 0 && target_bits > source_bits {
        if type_name_is_signed_integer(source_type_name) {
            "sext"
        } else {
            "zext"
        }
    } else {
        ""
    }
}

fn function_param_return_cast_op(program: IrProgram, function_value: IrFunctionDef, name: String, ret: String) -> String {
    let source_llvm = function_param_llvm_type(program, function_value, name);
    if source_llvm == ret {
        ""
    } else {
        llvm_integer_extension_op(function_param_type_name(program, function_value, name), source_llvm, ret)
    }
}

fn return_name_can_emit_with_locals(program: IrProgram, function_value: IrFunctionDef, locals: Vec[BackendLocal], name: String, ret: String) -> Bool {
    let source_llvm = llvm_type_for_name(program, function_value, locals, name);
    source_llvm == ret || function_param_return_cast_op(program, function_value, name, ret) != ""
}

fn return_name_can_emit(program: IrProgram, function_value: IrFunctionDef, name: String, ret: String) -> Bool {
    return_name_can_emit_with_locals(program, function_value, vec.new_vec(), name, ret)
}

fn direct_expr_child_at(nodes: Vec[IrExprNode], child_index: Int) -> Option[IrExprNode] {
    let mut index = 0;
    let mut seen = 0;
    let mut out: Option[IrExprNode] = None();
    while index < vec.vec_len(nodes) {
        match vec.get(nodes, index) {
            Some(node) => if node.depth == 1 {
                if seen == child_index {
                    out = Some(node);
                    index = vec.vec_len(nodes);
                } else {
                    seen = seen + 1;
                };
                ()
            } else {
                ()
            },
            None => (),
        };
        index = index + 1;
    };
    out
}

fn direct_expr_child_count(nodes: Vec[IrExprNode]) -> Int {
    let mut index = 0;
    let mut count = 0;
    while index < vec.vec_len(nodes) {
        match vec.get(nodes, index) {
            Some(node) => if node.depth == 1 {
                count = count + 1;
            } else {
                ()
            },
            None => (),
        };
        index = index + 1;
    };
    count
}

fn simple_node_llvm_value_with_locals(node: IrExprNode, function_value: IrFunctionDef, locals: Vec[BackendLocal]) -> String {
    match node.kind {
        IrIntExpr => node.text,
        IrBoolExpr => if node.text == "true" { "1" } else { "0" },
        IrNameExpr => value_name_for_name(function_value, locals, node.text),
        _ => "",
    }
}

fn simple_node_llvm_value(node: IrExprNode, function_value: IrFunctionDef) -> String {
    simple_node_llvm_value_with_locals(node, function_value, vec.new_vec())
}

fn simple_node_llvm_type_with_locals(program: IrProgram, node: IrExprNode, function_value: IrFunctionDef, locals: Vec[BackendLocal]) -> String {
    match node.kind {
        IrIntExpr => "i64",
        IrBoolExpr => "i1",
        IrNameExpr => llvm_type_for_name(program, function_value, locals, node.text),
        _ => "",
    }
}

fn simple_node_llvm_type(program: IrProgram, node: IrExprNode, function_value: IrFunctionDef) -> String {
    simple_node_llvm_type_with_locals(program, node, function_value, vec.new_vec())
}

fn simple_node_can_emit_with_locals(node: IrExprNode, function_value: IrFunctionDef, locals: Vec[BackendLocal]) -> Bool {
    match node.kind {
        IrIntExpr => is_decimal_integer_text(node.text),
        IrBoolExpr => node.text == "true" || node.text == "false",
        IrNameExpr => name_is_value_available(function_value, locals, node.text),
        _ => false,
    }
}

fn simple_node_can_emit(node: IrExprNode, function_value: IrFunctionDef) -> Bool {
    simple_node_can_emit_with_locals(node, function_value, vec.new_vec())
}

fn simple_expr_can_emit(value: IrExpr, function_value: IrFunctionDef) -> Bool {
    match value.kind {
        IrIntExpr => is_decimal_integer_text(value.text),
        IrBoolExpr => value.text == "true" || value.text == "false",
        IrUnitExpr => true,
        IrNameExpr => function_has_param_named(function_value, value.text),
        _ => false,
    }
}

fn value_node_llvm_type(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], node: IrExprNode, locals: Vec[BackendLocal]) -> String {
    match node.kind {
        IrIntExpr => "i64",
        IrBoolExpr => "i1",
        IrStringExpr => "%aic.String",
        IrNameExpr => llvm_type_for_name(program, function_value, locals, node.text),
        IrFieldAccessExpr => field_access_node_llvm_type(program, function_value, nodes, node, locals),
        IrCallExpr => call_target_return_type(program, node.name),
        IrStructLiteralExpr => llvm_type_for_repr_in_program(program, node.name),
        _ => "",
    }
}

fn value_node_can_emit(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], node: IrExprNode, locals: Vec[BackendLocal]) -> Bool {
    match node.kind {
        IrIntExpr => is_decimal_integer_text(node.text),
        IrBoolExpr => node.text == "true" || node.text == "false",
        IrStringExpr => true,
        IrNameExpr => name_is_value_available(function_value, locals, node.text),
        IrFieldAccessExpr => field_access_node_llvm_type(program, function_value, nodes, node, locals) != "",
        IrCallExpr => if node.name == "string.replace" {
            string_replace_node_can_emit(program, function_value, nodes, node, locals)
        } else {
            direct_call_node_can_emit(program, function_value, nodes, node, locals)
        },
        IrStructLiteralExpr => struct_literal_node_can_emit(program, function_value, nodes, node, locals, value_node_llvm_type(program, function_value, nodes, node, locals)),
        _ => false,
    }
}

fn value_expr_llvm_type(program: IrProgram, value: IrExpr, function_value: IrFunctionDef, locals: Vec[BackendLocal]) -> String {
    match value.kind {
        IrIntExpr => "i64",
        IrBoolExpr => "i1",
        IrStringExpr => "%aic.String",
        IrUnitExpr => "void",
        IrNameExpr => llvm_type_for_name(program, function_value, locals, value.text),
        IrCallExpr => call_target_return_type(program, value.name),
        IrIfExpr => llvm_type_for_id(program, function_value.return_type),
        IrStructLiteralExpr => llvm_type_for_repr_in_program(program, value.name),
        _ => "",
    }
}

fn expr_value_name(program: IrProgram, function_value: IrFunctionDef, value: IrExpr, locals: Vec[BackendLocal]) -> String {
    match value.kind {
        IrIntExpr => value.text,
        IrBoolExpr => if value.text == "true" { "1" } else { "0" },
        IrStringExpr => llvm_expr_value_local(value),
        IrNameExpr => value_name_for_name(function_value, locals, value.text),
        IrCallExpr => llvm_expr_value_local(value),
        IrStructLiteralExpr => struct_literal_value_name(llvm_expr_prefix(value.node), direct_expr_child_count(value.nodes), value_expr_llvm_type(program, value, function_value, locals)),
        _ => "",
    }
}

fn value_expr_can_emit(program: IrProgram, value: IrExpr, function_value: IrFunctionDef, locals: Vec[BackendLocal]) -> Bool {
    match value.kind {
        IrIntExpr => is_decimal_integer_text(value.text),
        IrBoolExpr => value.text == "true" || value.text == "false",
        IrStringExpr => true,
        IrUnitExpr => true,
        IrNameExpr => name_is_value_available(function_value, locals, value.text),
        IrBinaryExpr => binary_expr_can_emit_with_locals(value, function_value, locals),
        IrCallExpr => call_expr_can_emit_with_locals(program, value, function_value, locals),
        IrIfExpr => if_expr_can_emit_with_locals(program, value, function_value, locals),
        IrStructLiteralExpr => struct_literal_expr_can_emit(program, value, function_value, locals, value_expr_llvm_type(program, value, function_value, locals)),
        _ => false,
    }
}

fn expr_node_index(nodes: Vec[IrExprNode], target: IrNodeId) -> Int {
    let mut index = 0;
    let mut out = -1;
    while out < 0 && index < vec.vec_len(nodes) {
        match vec.get(nodes, index) {
            Some(node) => if node.node.value == target.value {
                out = index;
            } else {
                ()
            },
            None => (),
        };
        index = index + 1;
    };
    out
}

fn expr_node_child_at(nodes: Vec[IrExprNode], parent: IrExprNode, child_index: Int) -> Option[IrExprNode] {
    let parent_index = expr_node_index(nodes, parent.node);
    let mut index = parent_index + 1;
    let mut seen = 0;
    let mut out: Option[IrExprNode] = None();
    while parent_index >= 0 && index < vec.vec_len(nodes) {
        match vec.get(nodes, index) {
            Some(node) => if node.depth <= parent.depth {
                index = vec.vec_len(nodes);
            } else if node.depth == parent.depth + 1 {
                if seen == child_index {
                    out = Some(node);
                    index = vec.vec_len(nodes);
                } else {
                    seen = seen + 1;
                };
                ()
            } else {
                ()
            },
            None => (),
        };
        index = index + 1;
    };
    out
}

fn string_replace_node_can_emit(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], node: IrExprNode, locals: Vec[BackendLocal]) -> Bool {
    if node.name != "string.replace" || node.direct_child_count != 3 {
        false
    } else {
        let mut index = 0;
        let mut ok = true;
        while ok && index < 3 {
            match expr_node_child_at(nodes, node, index) {
                Some(child) => if string_call_child_can_emit(program, function_value, nodes, child, locals) {
                    ()
                } else {
                    ok = false;
                },
                None => if true {
                    ok = false;
                    ()
                } else { () },
            };
            index = index + 1;
        };
        ok
    }
}

fn string_call_child_can_emit(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], node: IrExprNode, locals: Vec[BackendLocal]) -> Bool {
    match node.kind {
        IrStringExpr => true,
        IrNameExpr => llvm_type_for_name(program, function_value, locals, node.text) == "%aic.String",
        IrFieldAccessExpr => field_access_node_can_emit(program, function_value, nodes, node, locals, "%aic.String"),
        IrCallExpr => if node.name == "string.replace" {
            string_replace_node_can_emit(program, function_value, nodes, node, locals)
        } else {
            string_direct_call_node_can_emit(program, function_value, nodes, node, locals)
        },
        _ => false,
    }
}

fn call_child_node_can_emit(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], callee_name: String, param_index: Int, node: IrExprNode, locals: Vec[BackendLocal]) -> Bool {
    let expected = call_target_param_type(program, callee_name, param_index);
    if expected == "%aic.String" {
        string_call_child_can_emit(program, function_value, nodes, node, locals)
    } else if simple_node_can_emit_with_locals(node, function_value, locals) {
        let actual = simple_node_llvm_type_with_locals(program, node, function_value, locals);
        expected != "" && actual != "" && expected == actual
    } else {
        match node.kind {
            IrFieldAccessExpr => field_access_node_can_emit(program, function_value, nodes, node, locals, expected),
            IrCallExpr => call_target_return_type(program, node.name) == expected && direct_call_node_can_emit(program, function_value, nodes, node, locals),
            _ => false,
        }
    }
}

fn direct_call_node_can_emit(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], node: IrExprNode, locals: Vec[BackendLocal]) -> Bool {
    if node.name == "" || string.contains(node.name, ".") || !call_target_exists(program, node.name) {
        false
    } else if node.direct_child_count != call_target_param_count(program, node.name) {
        false
    } else {
        let mut index = 0;
        let mut ok = true;
        while ok && index < node.direct_child_count {
            match expr_node_child_at(nodes, node, index) {
                Some(child) => if call_child_node_can_emit(program, function_value, nodes, node.name, index, child, locals) {
                    ()
                } else {
                    ok = false;
                },
                None => if true {
                    ok = false;
                    ()
                } else { () },
            };
            index = index + 1;
        };
        ok
    }
}

fn string_direct_call_node_can_emit(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], node: IrExprNode, locals: Vec[BackendLocal]) -> Bool {
    call_target_return_type(program, node.name) == "%aic.String" && direct_call_node_can_emit(program, function_value, nodes, node, locals)
}

fn string_replace_expr_can_emit(program: IrProgram, value: IrExpr, function_value: IrFunctionDef, locals: Vec[BackendLocal]) -> Bool {
    if value.name != "string.replace" || direct_expr_child_count(value.nodes) != 3 {
        false
    } else {
        let mut index = 0;
        let mut ok = true;
        while ok && index < 3 {
            match direct_expr_child_at(value.nodes, index) {
                Some(node) => if string_call_child_can_emit(program, function_value, value.nodes, node, locals) {
                    ()
                } else {
                    ok = false;
                },
                None => if true {
                    ok = false;
                    ()
                } else { () },
            };
            index = index + 1;
        };
        ok
    }
}

fn call_target_return_type(program: IrProgram, callee_name: String) -> String {
    let mut index = 0;
    let mut out = "";
    while out == "" && index < vec.vec_len(program.items) {
        match vec.get(program.items, index) {
            Some(item) => match item {
                IrFunctionItemValue(function_value) => if function_value.name == callee_name {
                    out = llvm_type_for_id(program, function_value.return_type);
                } else {
                    ()
                },
                _ => (),
            },
            None => (),
        };
        index = index + 1;
    };
    out
}

fn call_target_return_type_name(program: IrProgram, callee_name: String) -> String {
    let mut index = 0;
    let mut out = "";
    while out == "" && index < vec.vec_len(program.items) {
        match vec.get(program.items, index) {
            Some(item) => match item {
                IrFunctionItemValue(function_value) => if function_value.name == callee_name {
                    out = type_name_for_id(program.types, function_value.return_type);
                } else {
                    ()
                },
                _ => (),
            },
            None => (),
        };
        index = index + 1;
    };
    out
}

fn call_target_param_type(program: IrProgram, callee_name: String, param_index: Int) -> String {
    let mut item_index = 0;
    let mut out = "";
    while out == "" && item_index < vec.vec_len(program.items) {
        match vec.get(program.items, item_index) {
            Some(item) => match item {
                IrFunctionItemValue(function_value) => if function_value.name == callee_name {
                    match vec.get(function_value.params, param_index) {
                        Some(param) => if true {
                            out = llvm_type_for_id(program, param.type_id);
                            ()
                        } else { () },
                        None => (),
                    }
                } else {
                    ()
                },
                _ => (),
            },
            None => (),
        };
        item_index = item_index + 1;
    };
    out
}

fn call_target_param_count(program: IrProgram, callee_name: String) -> Int {
    let mut item_index = 0;
    let mut out = 0;
    let mut found = false;
    while !found && item_index < vec.vec_len(program.items) {
        match vec.get(program.items, item_index) {
            Some(item) => match item {
                IrFunctionItemValue(function_value) => if function_value.name == callee_name {
                    out = vec.vec_len(function_value.params);
                    found = true;
                } else {
                    ()
                },
                _ => (),
            },
            None => (),
        };
        item_index = item_index + 1;
    };
    out
}

fn call_target_exists(program: IrProgram, callee_name: String) -> Bool {
    call_target_return_type(program, callee_name) != ""
}

fn call_expr_can_emit_with_locals(program: IrProgram, value: IrExpr, function_value: IrFunctionDef, locals: Vec[BackendLocal]) -> Bool {
    if is_io_print_intrinsic_name(value.name) {
        direct_expr_child_count(value.nodes) == 1 && match direct_expr_child_at(value.nodes, 0) {
            Some(child) => string_call_child_can_emit(program, function_value, value.nodes, child, locals),
            None => false,
        }
    } else if is_fs_string_result_intrinsic_name(value.name) {
        direct_expr_child_count(value.nodes) == 1 && match direct_expr_child_at(value.nodes, 0) {
            Some(child) => string_call_child_can_emit(program, function_value, value.nodes, child, locals),
            None => false,
        }
    } else if is_fs_bool_result_intrinsic_name(value.name) {
        if value.name == "write_text" {
            direct_expr_child_count(value.nodes) == 2 && match direct_expr_child_at(value.nodes, 0) {
                Some(path_child) => match direct_expr_child_at(value.nodes, 1) {
                    Some(content_child) => string_call_child_can_emit(program, function_value, value.nodes, path_child, locals) && string_call_child_can_emit(program, function_value, value.nodes, content_child, locals),
                    None => false,
                },
                None => false,
            }
        } else {
            direct_expr_child_count(value.nodes) == 1 && match direct_expr_child_at(value.nodes, 0) {
                Some(child) => string_call_child_can_emit(program, function_value, value.nodes, child, locals),
                None => false,
            }
        }
    } else if string_replace_expr_can_emit(program, value, function_value, locals) {
        true
    } else if value.name == "" || string.contains(value.name, ".") || !call_target_exists(program, value.name) {
        false
    } else if direct_expr_child_count(value.nodes) != call_target_param_count(program, value.name) {
        false
    } else {
        let mut index = 0;
        let mut ok = true;
        while ok && index < direct_expr_child_count(value.nodes) {
            match direct_expr_child_at(value.nodes, index) {
                Some(node) => if call_child_node_can_emit(program, function_value, value.nodes, value.name, index, node, locals) {
                    ()
                } else {
                    ok = false;
                },
                None => if true {
                    ok = false;
                    ()
                } else { () },
            };
            index = index + 1;
        };
        ok
    }
}

fn call_expr_can_emit(program: IrProgram, value: IrExpr, function_value: IrFunctionDef) -> Bool {
    call_expr_can_emit_with_locals(program, value, function_value, vec.new_vec())
}

fn binary_expr_can_emit_with_locals(value: IrExpr, function_value: IrFunctionDef, locals: Vec[BackendLocal]) -> Bool {
    if value.op == "+" || value.op == "-" || value.op == "*" {
        match direct_expr_child_at(value.nodes, 0) {
            Some(left) => match direct_expr_child_at(value.nodes, 1) {
                Some(right) => simple_node_can_emit_with_locals(left, function_value, locals) && simple_node_can_emit_with_locals(right, function_value, locals),
                None => false,
            },
            None => false,
        }
    } else {
        false
    }
}

fn binary_expr_can_emit(value: IrExpr, function_value: IrFunctionDef) -> Bool {
    binary_expr_can_emit_with_locals(value, function_value, vec.new_vec())
}

fn binary_compare_op_can_emit(op: String) -> Bool {
    op == "==" || op == "!=" || op == "<" || op == ">" || op == "<=" || op == ">="
}

fn compare_predicate(op: String) -> String {
    if op == "==" {
        "eq"
    } else if op == "!=" {
        "ne"
    } else if op == "<" {
        "slt"
    } else if op == ">" {
        "sgt"
    } else if op == "<=" {
        "sle"
    } else if op == ">=" {
        "sge"
    } else {
        ""
    }
}

fn string_compare_predicate(op: String) -> String {
    if op == "==" {
        "eq"
    } else if op == "!=" {
        "ne"
    } else {
        ""
    }
}

fn bool_node_can_emit_with_locals(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], node: IrExprNode, locals: Vec[BackendLocal]) -> Bool {
    match node.kind {
        IrBoolExpr => node.text == "true" || node.text == "false",
        IrNameExpr => llvm_type_for_name(program, function_value, locals, node.text) == "i1",
        IrBinaryExpr => if binary_compare_op_can_emit(node.op) {
            match expr_node_child_at(nodes, node, 0) {
                Some(left) => match expr_node_child_at(nodes, node, 1) {
                    Some(right) => if string_call_child_can_emit(program, function_value, nodes, left, locals) && string_call_child_can_emit(program, function_value, nodes, right, locals) {
                        node.op == "==" || node.op == "!="
                    } else if value_node_can_emit(program, function_value, nodes, left, locals) && value_node_can_emit(program, function_value, nodes, right, locals) {
                        let left_type = value_node_llvm_type(program, function_value, nodes, left, locals);
                        let right_type = value_node_llvm_type(program, function_value, nodes, right, locals);
                        left_type != "" && left_type == right_type
                    } else {
                        false
                    },
                    None => false,
                },
                None => false,
            }
        } else {
            false
        },
        _ => false,
    }
}

fn bool_node_can_emit(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], node: IrExprNode) -> Bool {
    bool_node_can_emit_with_locals(program, function_value, nodes, node, vec.new_vec())
}

fn block_tail_node_can_emit_with_locals(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], block_node: IrExprNode, ret: String, locals: Vec[BackendLocal]) -> Bool {
    if !is_block_expr_kind(block_node.kind) {
        false
    } else {
        block_node_can_emit_return(program, function_value, nodes, block_node, ret, locals)
    }
}

fn branch_node_can_emit_with_locals(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], branch_node: IrExprNode, ret: String, locals: Vec[BackendLocal]) -> Bool {
    if is_block_expr_kind(branch_node.kind) {
        block_tail_node_can_emit_with_locals(program, function_value, nodes, branch_node, ret, locals)
    } else {
        return_node_can_emit_with_locals(program, function_value, nodes, branch_node, ret, locals)
    }
}

fn branch_node_can_emit(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], branch_node: IrExprNode, ret: String) -> Bool {
    branch_node_can_emit_with_locals(program, function_value, nodes, branch_node, ret, vec.new_vec())
}

fn if_node_can_emit_with_locals(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], node: IrExprNode, ret: String, locals: Vec[BackendLocal]) -> Bool {
    if node.direct_child_count != 3 {
        false
    } else {
        match expr_node_child_at(nodes, node, 0) {
            Some(condition) => match expr_node_child_at(nodes, node, 1) {
                Some(then_block) => match expr_node_child_at(nodes, node, 2) {
                    Some(else_block) => bool_node_can_emit_with_locals(program, function_value, nodes, condition, locals)
                        && branch_node_can_emit_with_locals(program, function_value, nodes, then_block, ret, locals)
                        && branch_node_can_emit_with_locals(program, function_value, nodes, else_block, ret, locals),
                    None => false,
                },
                None => false,
            },
            None => false,
        }
    }
}

fn if_node_can_emit(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], node: IrExprNode, ret: String) -> Bool {
    if_node_can_emit_with_locals(program, function_value, nodes, node, ret, vec.new_vec())
}

fn struct_literal_child_can_emit(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], child: IrExprNode, locals: Vec[BackendLocal], expected: String) -> Bool {
    if expected == "%aic.String" {
        string_call_child_can_emit(program, function_value, nodes, child, locals)
    } else if value_node_can_emit(program, function_value, nodes, child, locals) {
        value_node_llvm_type(program, function_value, nodes, child, locals) == expected
    } else {
        false
    }
}

fn struct_literal_node_can_emit(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], node: IrExprNode, locals: Vec[BackendLocal], ret: String) -> Bool {
    let struct_ty = llvm_type_for_repr_in_program(program, node.name);
    if node.name == "" || struct_ty == "" || struct_ty != ret {
        false
    } else {
        let mut index = 0;
        let mut ok = true;
        while ok && index < node.direct_child_count {
            match expr_node_child_at(nodes, node, index) {
                Some(child) => if true {
                    let field_ty = struct_field_llvm_type_by_index(program, node.name, index);
                    if field_ty != "" && struct_literal_child_can_emit(program, function_value, nodes, child, locals, field_ty) {
                        ()
                    } else {
                        ok = false;
                    };
                    ()
                } else { () },
                None => if true {
                    ok = false;
                    ()
                } else { () },
            };
            index = index + 1;
        };
        ok
    }
}

fn struct_literal_expr_can_emit(program: IrProgram, value: IrExpr, function_value: IrFunctionDef, locals: Vec[BackendLocal], ret: String) -> Bool {
    let struct_ty = llvm_type_for_repr_in_program(program, value.name);
    if value.name == "" || struct_ty == "" || struct_ty != ret {
        false
    } else {
        let mut index = 0;
        let mut ok = true;
        while ok && index < direct_expr_child_count(value.nodes) {
            match direct_expr_child_at(value.nodes, index) {
                Some(child) => if true {
                    let field_ty = struct_field_llvm_type_by_index(program, value.name, index);
                    if field_ty != "" && struct_literal_child_can_emit(program, function_value, value.nodes, child, locals, field_ty) {
                        ()
                    } else {
                        ok = false;
                    };
                    ()
                } else { () },
                None => if true {
                    ok = false;
                    ()
                } else { () },
            };
            index = index + 1;
        };
        ok
    }
}

fn return_node_can_emit_with_locals(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], node: IrExprNode, ret: String, locals: Vec[BackendLocal]) -> Bool {
    match node.kind {
        IrIntExpr => ret == "i64" && is_decimal_integer_text(node.text),
        IrBoolExpr => ret == "i1" && (node.text == "true" || node.text == "false"),
        IrStringExpr => ret == "%aic.String",
        IrUnitExpr => ret == "void",
        IrNameExpr => return_name_can_emit_with_locals(program, function_value, locals, node.text, ret),
        IrFieldAccessExpr => field_access_node_can_emit(program, function_value, nodes, node, locals, ret),
        IrCallExpr => if node.name == "string.replace" {
            ret == "%aic.String" && string_replace_node_can_emit(program, function_value, nodes, node, locals)
        } else {
            call_target_return_type(program, node.name) == ret && direct_call_node_can_emit(program, function_value, nodes, node, locals)
        },
        IrIfExpr => if_node_can_emit_with_locals(program, function_value, nodes, node, ret, locals),
        IrStructLiteralExpr => struct_literal_node_can_emit(program, function_value, nodes, node, locals, ret),
        _ => false,
    }
}

fn return_node_can_emit(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], node: IrExprNode, ret: String) -> Bool {
    return_node_can_emit_with_locals(program, function_value, nodes, node, ret, vec.new_vec())
}

fn if_expr_can_emit_with_locals(program: IrProgram, value: IrExpr, function_value: IrFunctionDef, locals: Vec[BackendLocal]) -> Bool {
    let ret = llvm_type_for_id(program, function_value.return_type);
    if value.direct_child_count != 3 {
        false
    } else {
        match direct_expr_child_at(value.nodes, 0) {
            Some(condition) => match direct_expr_child_at(value.nodes, 1) {
                Some(then_block) => match direct_expr_child_at(value.nodes, 2) {
                    Some(else_block) => bool_node_can_emit_with_locals(program, function_value, value.nodes, condition, locals)
                        && branch_node_can_emit_with_locals(program, function_value, value.nodes, then_block, ret, locals)
                        && branch_node_can_emit_with_locals(program, function_value, value.nodes, else_block, ret, locals),
                    None => false,
                },
                None => false,
            },
            None => false,
        }
    }
}

fn if_expr_can_emit(program: IrProgram, value: IrExpr, function_value: IrFunctionDef) -> Bool {
    if_expr_can_emit_with_locals(program, value, function_value, vec.new_vec())
}

fn static_match_body(value: IrExpr) -> String {
    let matched = match direct_expr_child_at(value.nodes, 0) {
        Some(node) => node.text,
        None => "",
    };
    let mut index = 0;
    let mut out = "";
    while out == "" && index < vec.vec_len(value.match_arms) {
        match vec.get(value.match_arms, index) {
            Some(arm) => if arm.pattern_text == matched || arm.pattern_text == "_" {
                out = arm.body_text;
            } else {
                ()
            },
            None => (),
        };
        index = index + 1;
    };
    out
}

fn match_expr_can_emit(value: IrExpr) -> Bool {
    let selected = static_match_body(value);
    let mut arms_ok = vec.vec_len(value.match_arms) > 0 && selected != "";
    let mut index = 0;
    while arms_ok && index < vec.vec_len(value.match_arms) {
        match vec.get(value.match_arms, index) {
            Some(arm) => if is_decimal_integer_text(arm.body_text) || arm.body_text == "true" || arm.body_text == "false" {
                ()
            } else {
                arms_ok = false;
            },
            None => (),
        };
        index = index + 1;
    };
    arms_ok
}

fn match_has_arm(value: IrExpr, pattern: String, body: String) -> Bool {
    let mut index = 0;
    let mut found = false;
    while !found && index < vec.vec_len(value.match_arms) {
        match vec.get(value.match_arms, index) {
            Some(arm) => if arm.pattern_text == pattern && arm.body_text == body {
                found = true;
            } else {
                ()
            },
            None => (),
        };
        index = index + 1;
    };
    found
}

fn block_child_is_let(node: IrExprNode) -> Bool {
    string.starts_with(node.role, "let:")
}

fn block_child_is_tail(node: IrExprNode) -> Bool {
    node.role == "tail"
}

fn block_let_name_from_role(role: String) -> String {
    let mut index = 4;
    let mut out = "";
    let mut done = !string.starts_with(role, "let:");
    while !done && index < string.len(role) {
        let part = string.substring(role, index, index + 1);
        if part == ":" {
            done = true;
        } else {
            out = concat2(out, part);
            index = index + 1;
        }
    };
    out
}

fn node_value_name(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], node: IrExprNode, locals: Vec[BackendLocal]) -> String {
    match node.kind {
        IrIntExpr => node.text,
        IrBoolExpr => if node.text == "true" { "1" } else { "0" },
        IrStringExpr => string_node_value_name(node),
        IrNameExpr => value_name_for_name(function_value, locals, node.text),
        IrFieldAccessExpr => llvm_node_value_local(node),
        IrCallExpr => llvm_node_value_local(node),
        IrStructLiteralExpr => struct_literal_value_name(llvm_node_prefix(node.node), node.direct_child_count, value_node_llvm_type(program, function_value, nodes, node, locals)),
        _ => "",
    }
}

fn backend_local_for_node(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], node: IrExprNode, locals: Vec[BackendLocal], name: String) -> BackendLocal {
    let type_name = match node.kind {
        IrNameExpr => type_name_for_name(program, function_value, locals, node.text),
        IrCallExpr => call_target_return_type_name(program, node.name),
        IrStringExpr => "String",
        IrIntExpr => "Int",
        IrBoolExpr => "Bool",
        IrFieldAccessExpr => if true {
            let llvm = field_access_node_llvm_type(program, function_value, nodes, node, locals);
            if llvm == "%aic.String" {
                "String"
            } else if llvm == "i1" {
                "Bool"
            } else {
                "Int"
            }
        } else { "" },
        _ => "",
    };
    backend_local(name, type_name, value_node_llvm_type(program, function_value, nodes, node, locals), node_value_name(program, function_value, nodes, node, locals))
}

fn let_node_can_emit(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], node: IrExprNode, locals: Vec[BackendLocal]) -> Bool {
    block_let_name_from_role(node.role) != "" && value_node_can_emit(program, function_value, nodes, node, locals)
}

fn push_node_local(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], node: IrExprNode, locals: Vec[BackendLocal]) -> Vec[BackendLocal] {
    let name = block_let_name_from_role(node.role);
    if name == "" {
        locals
    } else {
        vec.push(locals, backend_local_for_node(program, function_value, nodes, node, locals, name))
    }
}

fn node_is_unit_or_false_loop(node: IrExprNode) -> Bool {
    match node.kind {
        IrUnitExpr => true,
        _ => string.starts_with(node.text, "while false"),
    }
}

fn block_node_local_check(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], block_node: IrExprNode, ret: String, locals: Vec[BackendLocal]) -> BackendLocalCheck {
    let mut out = locals;
    let mut ok = true;
    let mut index = 0;
    let mut saw_tail = false;
    while ok && index < block_node.direct_child_count {
        match expr_node_child_at(nodes, block_node, index) {
            Some(child) => if block_child_is_let(child) {
                if let_node_can_emit(program, function_value, nodes, child, out) {
                    out = push_node_local(program, function_value, nodes, child, out);
                } else {
                    ok = false;
                };
                ()
            } else if block_child_is_tail(child) {
                saw_tail = true;
                if return_node_can_emit_with_locals(program, function_value, nodes, child, ret, out) {
                    ()
                } else {
                    ok = false;
                };
                ()
            } else if node_is_unit_or_false_loop(child) {
                ()
            } else {
                ok = false;
            },
            None => if true {
                ok = false;
                ()
            } else { () },
        };
        index = index + 1;
    };
    backend_local_check(ok && saw_tail, out)
}

fn block_node_can_emit_return(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], block_node: IrExprNode, ret: String, locals: Vec[BackendLocal]) -> Bool {
    block_node_local_check(program, function_value, nodes, block_node, ret, locals).ok
}

fn env_arg_or_empty_expr_can_emit(program: IrProgram, value: IrExpr, function_value: IrFunctionDef) -> Bool {
    let is_match = match value.kind {
        IrMatchExpr => true,
        _ => false,
    };
    if !is_match || llvm_type_for_id(program, function_value.return_type) != "%aic.String" {
        false
    } else if !match_has_arm(value, "Some(value)", "value") || !match_has_arm(value, "None", "\"\"") {
        false
    } else {
        match direct_expr_child_at(value.nodes, 0) {
            Some(call_node) => if is_call_expr_kind(call_node.kind) && call_node.name == "arg_at" && call_node.direct_child_count == 1 {
                match expr_node_child_at(value.nodes, call_node, 0) {
                    Some(index_node) => simple_node_can_emit(index_node, function_value) && simple_node_llvm_type(program, index_node, function_value) == "i64",
                    None => false,
                }
            } else {
                false
            },
            None => false,
        }
    }
}

fn statement_expr_can_emit_as_noop(value: IrExpr) -> Bool {
    match value.kind {
        IrUnitExpr => true,
        IrWhileExpr => string.starts_with(value.text, "while false"),
        IrLoopExpr => false,
        IrForExpr => false,
        IrBreakExpr => false,
        IrContinueExpr => false,
        _ => false,
    }
}

fn statement_can_emit_as_noop(statement: IrStatement) -> Bool {
    match statement.kind {
        IrLetStatement => match statement.expr {
            Some(expr) => match expr.kind {
                IrIntExpr => is_decimal_integer_text(expr.text),
                IrBoolExpr => expr.text == "true" || expr.text == "false",
                IrUnitExpr => true,
                IrClosureExpr => true,
                IrStructLiteralExpr => true,
                IrTupleExpr => true,
                _ => false,
            },
            None => true,
        },
        IrExprStatement => match statement.expr {
            Some(expr) => statement_expr_can_emit_as_noop(expr),
            None => true,
        },
        IrAssertStatement => false,
        IrAssignStatement => false,
        IrReturnStatement => false,
    }
}

fn expr_statement_can_emit_with_locals(program: IrProgram, function_value: IrFunctionDef, expr: IrExpr, locals: Vec[BackendLocal]) -> Bool {
    match expr.kind {
        IrCallExpr => if call_target_return_type(program, expr.name) == "void" {
            call_expr_can_emit_with_locals(program, expr, function_value, locals)
        } else {
            false
        },
        _ => statement_expr_can_emit_as_noop(expr),
    }
}

fn expr_statement_can_emit(program: IrProgram, function_value: IrFunctionDef, expr: IrExpr) -> Bool {
    expr_statement_can_emit_with_locals(program, function_value, expr, vec.new_vec())
}

fn let_statement_value_can_emit(program: IrProgram, function_value: IrFunctionDef, statement: IrStatement, locals: Vec[BackendLocal]) -> Bool {
    match statement.expr {
        Some(expr) => value_expr_can_emit(program, expr, function_value, locals),
        None => true,
    }
}

fn local_for_expr(program: IrProgram, function_value: IrFunctionDef, expr: IrExpr, locals: Vec[BackendLocal], name: String) -> BackendLocal {
    let type_name = match expr.kind {
        IrNameExpr => type_name_for_name(program, function_value, locals, expr.text),
        IrCallExpr => call_target_return_type_name(program, expr.name),
        IrStringExpr => "String",
        IrIntExpr => "Int",
        IrBoolExpr => "Bool",
        _ => "",
    };
    backend_local(name, type_name, value_expr_llvm_type(program, expr, function_value, locals), expr_value_name(program, function_value, expr, locals))
}

fn statement_check_with_locals(program: IrProgram, function_value: IrFunctionDef, statement: IrStatement, locals: Vec[BackendLocal]) -> BackendLocalCheck {
    if statement_can_emit_as_noop(statement) {
        backend_local_check(true, locals)
    } else {
        match statement.kind {
            IrLetStatement => if statement.name != "" && let_statement_value_can_emit(program, function_value, statement, locals) {
                match statement.expr {
                    Some(expr) => backend_local_check(true, vec.push(locals, local_for_expr(program, function_value, expr, locals, statement.name))),
                    None => backend_local_check(true, locals),
                }
            } else {
                backend_local_check(false, locals)
            },
            IrExprStatement => match statement.expr {
                Some(expr) => backend_local_check(expr_statement_can_emit_with_locals(program, function_value, expr, locals), locals),
                None => backend_local_check(true, locals),
            },
            _ => backend_local_check(false, locals),
        }
    }
}

fn statement_can_emit_with_locals(program: IrProgram, function_value: IrFunctionDef, statement: IrStatement, locals: Vec[BackendLocal]) -> Bool {
    statement_check_with_locals(program, function_value, statement, locals).ok
}

fn statement_can_emit(program: IrProgram, function_value: IrFunctionDef, statement: IrStatement) -> Bool {
    if statement_can_emit_as_noop(statement) {
        true
    } else {
        match statement.kind {
            IrExprStatement => match statement.expr {
                Some(expr) => expr_statement_can_emit(program, function_value, expr),
                None => true,
            },
            IrLetStatement => let_statement_value_can_emit(program, function_value, statement, vec.new_vec()),
            _ => false,
        }
    }
}

fn return_expr_can_emit_with_locals(program: IrProgram, value: IrExpr, function_value: IrFunctionDef, locals: Vec[BackendLocal]) -> Bool {
    match value.kind {
        IrIntExpr => is_decimal_integer_text(value.text),
        IrBoolExpr => value.text == "true" || value.text == "false",
        IrStringExpr => llvm_type_for_id(program, function_value.return_type) == "%aic.String",
        IrUnitExpr => true,
        IrNameExpr => return_name_can_emit_with_locals(program, function_value, locals, value.text, llvm_type_for_id(program, function_value.return_type)),
        IrBinaryExpr => binary_expr_can_emit_with_locals(value, function_value, locals),
        IrCallExpr => call_expr_can_emit_with_locals(program, value, function_value, locals),
        IrIfExpr => if_expr_can_emit_with_locals(program, value, function_value, locals),
        IrMatchExpr => match_expr_can_emit(value) || env_arg_or_empty_expr_can_emit(program, value, function_value),
        IrStructLiteralExpr => struct_literal_expr_can_emit(program, value, function_value, locals, llvm_type_for_id(program, function_value.return_type)),
        _ => false,
    }
}

fn return_expr_can_emit(program: IrProgram, value: IrExpr, function_value: IrFunctionDef) -> Bool {
    return_expr_can_emit_with_locals(program, value, function_value, vec.new_vec())
}

fn block_can_emit(program: IrProgram, block: IrBlock, function_value: IrFunctionDef) -> Bool {
    let mut index = 0;
    let mut ok = true;
    let mut locals: Vec[BackendLocal] = vec.new_vec();
    while ok && index < vec.vec_len(block.statements) {
        match vec.get(block.statements, index) {
            Some(statement) => if true {
                let checked = statement_check_with_locals(program, function_value, statement, locals);
                ok = checked.ok;
                locals = checked.locals;
            } else {
                ()
            },
            None => (),
        };
        index = index + 1;
    };
    if ok {
        match block.tail_expr {
            Some(expr) => return_expr_can_emit_with_locals(program, expr, function_value, locals),
            None => llvm_type_for_id(program, function_value.return_type) == "void",
        }
    } else {
        false
    }
}

fn append_expr_diagnostics(out: Vec[Diagnostic], expr: IrExpr, max_errors: Int) -> Vec[Diagnostic] {
    let mut diagnostics = out;
    if vec.vec_len(diagnostics) < max_errors && !is_supported_backend_expr_kind(expr.kind) {
        diagnostics = push_backend_error(diagnostics, "E5101", expr.span, "self-host backend has no lowering hook for this expression kind", "add a backend lowering case before emitting LLVM for this IR node");
    } else {
        ()
    };
    let mut index = 0;
    while index < vec.vec_len(expr.nodes) {
        match vec.get(expr.nodes, index) {
            Some(node) => if vec.vec_len(diagnostics) < max_errors && !is_supported_backend_expr_kind(node.kind) {
                diagnostics = push_backend_error(diagnostics, "E5101", node.span, "self-host backend has no lowering hook for this nested expression kind", "extend backend lowering coverage for this expression node");
            } else {
                ()
            },
            None => (),
        };
        index = index + 1;
    };
    diagnostics
}

fn append_optional_expr_diagnostics(out: Vec[Diagnostic], expr: Option[IrExpr], max_errors: Int) -> Vec[Diagnostic] {
    match expr {
        Some(value) => append_expr_diagnostics(out, value, max_errors),
        None => out,
    }
}

fn append_block_diagnostics(out: Vec[Diagnostic], block: IrBlock, max_errors: Int) -> Vec[Diagnostic] {
    let mut diagnostics = out;
    let mut index = 0;
    while index < vec.vec_len(block.statements) {
        match vec.get(block.statements, index) {
            Some(statement) => if true {
                diagnostics = append_optional_expr_diagnostics(diagnostics, statement.expr, max_errors);
                ()
            } else {
                ()
            },
            None => (),
        };
        index = index + 1;
    };
    append_optional_expr_diagnostics(diagnostics, block.tail_expr, max_errors)
}

fn append_backend_block_emission_diagnostics(out: Vec[Diagnostic], program: IrProgram, function_value: IrFunctionDef, max_errors: Int) -> Vec[Diagnostic] {
    let mut diagnostics = out;
    let mut index = 0;
    let mut locals: Vec[BackendLocal] = vec.new_vec();
    let mut statements_ok = true;
    while index < vec.vec_len(function_value.body.statements) {
        match vec.get(function_value.body.statements, index) {
            Some(statement) => if statements_ok && vec.vec_len(diagnostics) < max_errors {
                let checked = statement_check_with_locals(program, function_value, statement, locals);
                if checked.ok {
                    locals = checked.locals;
                } else {
                    statements_ok = false;
                    diagnostics = push_backend_error(diagnostics, "E5101", statement.span, "self-host backend cannot emit this executable statement yet", "restrict backend-covered executable functions to side-effect-free literal lets and while false guards, or add statement lowering");
                };
                ()
            } else {
                ()
            },
            None => (),
        };
        index = index + 1;
    };
    match function_value.body.tail_expr {
        Some(expr) => if statements_ok && vec.vec_len(diagnostics) < max_errors && !return_expr_can_emit_with_locals(program, expr, function_value, locals) {
            diagnostics = push_backend_error(diagnostics, "E5101", expr.span, "self-host backend cannot emit this function return expression yet", "add expression lowering for this IR shape before emitting a backend artifact");
        } else {
            ()
        },
        None => if vec.vec_len(diagnostics) < max_errors && llvm_type_for_id(program, function_value.return_type) != "void" {
            diagnostics = push_backend_error(diagnostics, "E5101", function_value.body.span, "self-host backend requires a return expression for non-void functions", "add a tail expression or lower explicit return statements");
        } else {
            ()
        },
    };
    diagnostics
}

fn append_function_diagnostics(out: Vec[Diagnostic], program: IrProgram, function_value: IrFunctionDef, max_errors: Int) -> Vec[Diagnostic] {
    let mut diagnostics = out;
    if function_value.is_extern && function_value.extern_abi != "" && function_value.extern_abi != "C" {
        diagnostics = push_backend_error(diagnostics, "E5102", function_value.span, "self-host backend only supports extern C ABI metadata", "use extern \"C\" or keep this declaration out of the backend-covered corpus");
    } else {
        ()
    };
    let ret = llvm_type_for_id(program, function_value.return_type);
    if ret == "" {
        diagnostics = push_backend_error(diagnostics, "E5102", function_value.span, "self-host backend cannot lower this function return type to LLVM", "restrict backend-covered functions to primitive return values until aggregate return lowering is implemented");
    } else {
        ()
    };
    let mut param_index = 0;
    while param_index < vec.vec_len(function_value.params) {
        match vec.get(function_value.params, param_index) {
            Some(param) => if llvm_type_for_id(program, param.type_id) == "" {
                diagnostics = push_backend_error(diagnostics, "E5102", param.span, "self-host backend cannot lower this parameter type to LLVM", "use primitive parameters for backend-covered executable functions");
            } else {
                ()
            },
            None => (),
        };
        param_index = param_index + 1;
    };
    diagnostics = append_optional_expr_diagnostics(diagnostics, function_value.requires_expr, max_errors);
    diagnostics = append_optional_expr_diagnostics(diagnostics, function_value.ensures_expr, max_errors);
    diagnostics = append_block_diagnostics(diagnostics, function_value.body, max_errors);
    append_backend_block_emission_diagnostics(diagnostics, program, function_value, max_errors)
}

fn append_link_diagnostics(out: Vec[Diagnostic], links: Vec[BackendNativeLink]) -> Vec[Diagnostic] {
    let mut diagnostics = out;
    let mut index = 0;
    while index < vec.vec_len(links) {
        match vec.get(links, index) {
            Some(link) => if link.name == "" {
                diagnostics = push_backend_error(diagnostics, "E5103", link.span, "native link metadata requires a non-empty name", "preserve package manifest native-link names before backend emission");
            } else if link.path == "" && match link.kind { NativeObjectLink => true, NativeSearchPathLink => true, _ => false } {
                diagnostics = push_backend_error(diagnostics, "E5103", link.span, "native object/search-path link metadata requires a path", "preserve package manifest native-link paths before backend emission");
            } else {
                ()
            },
            None => (),
        };
        index = index + 1;
    };
    diagnostics
}

fn program_has_entry(program: IrProgram) -> Bool {
    let mut index = 0;
    let mut found = false;
    while !found && index < vec.vec_len(program.items) {
        match vec.get(program.items, index) {
            Some(item) => match item {
                IrFunctionItemValue(function_value) => if function_value.runtime_visible && function_value.name == "main" {
                    found = true;
                } else {
                    ()
                },
                _ => (),
            },
            None => (),
        };
        index = index + 1;
    };
    found
}

pub fn validate_backend_program(program: IrProgram, options: BackendOptions, max_errors: Int) -> Vec[Diagnostic] {
    let mut diagnostics = validate_backend_ir_input(program);
    if options.artifact_name == "" {
        diagnostics = push_backend_error(diagnostics, "E5104", program.span, "backend artifact name must not be empty", "choose a deterministic artifact name before backend emission");
    } else {
        ()
    };
    if options.require_entry && !program_has_entry(program) {
        diagnostics = push_backend_error(diagnostics, "E5104", program.span, "backend executable artifact requires a runtime-visible main function", "lower a checked program with a main function or emit a library artifact");
    } else {
        ()
    };
    match options.artifact_kind {
        LlvmIrArtifact => (),
        NativeObjectArtifact => if true {
            diagnostics = push_backend_error(diagnostics, "E5105", program.span, "self-host backend emits LLVM IR text artifacts in this package", "materialize object files through the driver after LLVM IR emission");
            ()
        } else { () },
        StaticLibraryArtifact => if true {
            diagnostics = push_backend_error(diagnostics, "E5105", program.span, "self-host backend emits LLVM IR text artifacts in this package", "archive object files through the driver after LLVM IR emission");
            ()
        } else { () },
        ExecutableArtifact => if true {
            diagnostics = push_backend_error(diagnostics, "E5105", program.span, "self-host backend emits LLVM IR text artifacts in this package", "link executables through the driver after LLVM IR emission");
            ()
        } else { () },
    };
    diagnostics = append_link_diagnostics(diagnostics, options.native_links);
    let mut type_index = 0;
    while type_index < vec.vec_len(program.types) {
        match vec.get(program.types, type_index) {
            Some(type_value) => match type_value.kind {
                IrUnknownType => if true {
                    diagnostics = push_backend_error(diagnostics, "E5102", type_value.span, "self-host backend cannot lower unknown IR types", "complete type metadata before backend emission");
                    ()
                } else { () },
                _ => (),
            },
            None => (),
        };
        type_index = type_index + 1;
    };
    let mut item_index = 0;
    while item_index < vec.vec_len(program.items) {
        match vec.get(program.items, item_index) {
            Some(item) => match item {
                IrFunctionItemValue(function_value) => if function_value.runtime_visible {
                    diagnostics = append_function_diagnostics(diagnostics, program, function_value, max_errors);
                } else {
                    ()
                },
                IrTraitItemValue(_) => (),
                IrImplItemValue(_) => (),
                IrConstItemValue(const_value) => if true {
                    diagnostics = append_optional_expr_diagnostics(diagnostics, const_value.initializer, max_errors);
                    ()
                } else { () },
                IrStructItemValue(_) => (),
                IrEnumItemValue(_) => (),
                IrTypeAliasItemValue(_) => (),
            },
            None => (),
        };
        item_index = item_index + 1;
    };
    diagnostics
}

fn has_struct_item(program: IrProgram) -> Bool {
    let mut index = 0;
    let mut found = false;
    while !found && index < vec.vec_len(program.items) {
        match vec.get(program.items, index) {
            Some(item) => match item {
                IrStructItemValue(_) => if true { found = true; () } else { () },
                _ => (),
            },
            None => (),
        };
        index = index + 1;
    };
    found
}

fn has_enum_item(program: IrProgram) -> Bool {
    let mut index = 0;
    let mut found = false;
    while !found && index < vec.vec_len(program.items) {
        match vec.get(program.items, index) {
            Some(item) => match item {
                IrEnumItemValue(_) => if true { found = true; () } else { () },
                _ => (),
            },
            None => (),
        };
        index = index + 1;
    };
    found
}

fn has_trait_or_impl_item(program: IrProgram) -> Bool {
    let mut index = 0;
    let mut found = false;
    while !found && index < vec.vec_len(program.items) {
        match vec.get(program.items, index) {
            Some(item) => match item {
                IrTraitItemValue(_) => if true { found = true; () } else { () },
                IrImplItemValue(_) => if true { found = true; () } else { () },
                _ => (),
            },
            None => (),
        };
        index = index + 1;
    };
    found
}

fn has_alias_or_const_item(program: IrProgram) -> Bool {
    let mut index = 0;
    let mut found = false;
    while !found && index < vec.vec_len(program.items) {
        match vec.get(program.items, index) {
            Some(item) => match item {
                IrTypeAliasItemValue(_) => if true { found = true; () } else { () },
                IrConstItemValue(_) => if true { found = true; () } else { () },
                _ => (),
            },
            None => (),
        };
        index = index + 1;
    };
    found
}

fn has_tuple_type(program: IrProgram) -> Bool {
    let mut index = 0;
    let mut found = false;
    while !found && index < vec.vec_len(program.types) {
        match vec.get(program.types, index) {
            Some(type_value) => match type_value.kind {
                IrTupleType(_) => if true { found = true; () } else { () },
                _ => (),
            },
            None => (),
        };
        index = index + 1;
    };
    found
}

fn has_function_instantiation(program: IrProgram) -> Bool {
    vec.vec_len(program.generic_instantiations) > 0
}

fn has_generic_item(program: IrProgram) -> Bool {
    let mut index = 0;
    let mut found = false;
    while !found && index < vec.vec_len(program.items) {
        match vec.get(program.items, index) {
            Some(item) => match item {
                IrFunctionItemValue(function_value) => if vec.vec_len(function_value.generics) > 0 { found = true; } else { () },
                IrStructItemValue(struct_value) => if vec.vec_len(struct_value.generics) > 0 { found = true; } else { () },
                IrEnumItemValue(enum_value) => if vec.vec_len(enum_value.generics) > 0 { found = true; } else { () },
                IrTraitItemValue(trait_value) => if vec.vec_len(trait_value.generics) > 0 { found = true; } else { () },
                IrImplItemValue(impl_value) => if vec.vec_len(impl_value.generics) > 0 { found = true; } else { () },
                IrTypeAliasItemValue(alias_value) => if vec.vec_len(alias_value.generics) > 0 { found = true; } else { () },
                IrConstItemValue(_) => (),
            },
            None => (),
        };
        index = index + 1;
    };
    found
}

fn has_async_function(program: IrProgram) -> Bool {
    let mut index = 0;
    let mut found = false;
    while !found && index < vec.vec_len(program.items) {
        match vec.get(program.items, index) {
            Some(item) => match item {
                IrFunctionItemValue(function_value) => if function_value.is_async { found = true; } else { () },
                _ => (),
            },
            None => (),
        };
        index = index + 1;
    };
    found
}

fn has_expr_kind(program: IrProgram, kind_name: String) -> Bool {
    string.contains(ir_program_to_json(program), concat3("\"kind\":\"", kind_name, "\""))
}

pub fn backend_program_features(program: IrProgram, options: BackendOptions) -> Vec[String] {
    let mut features: Vec[String] = vec.new_vec();
    features = vec.push(features, "primitive-lowering");
    features = vec.push(features, "function-lowering");
    if has_struct_item(program) { features = vec.push(features, "struct-lowering"); } else { () };
    if has_enum_item(program) { features = vec.push(features, "enum-lowering"); } else { () };
    if has_tuple_type(program) || has_expr_kind(program, "tuple") { features = vec.push(features, "tuple-lowering"); } else { () };
    if has_generic_item(program) { features = vec.push(features, "generic-definition-metadata"); } else { () };
    if has_function_instantiation(program) { features = vec.push(features, "generic-monomorph-metadata"); } else { () };
    if has_expr_kind(program, "closure") { features = vec.push(features, "closure-lowering"); } else { () };
    if has_async_function(program) || has_expr_kind(program, "await") { features = vec.push(features, "async-future-lowering"); } else { () };
    if has_trait_or_impl_item(program) { features = vec.push(features, "trait-dispatch-metadata"); } else { () };
    if string.contains(ir_program_to_json(program), "Handle") { features = vec.push(features, "resource-handle-metadata"); } else { () };
    if has_alias_or_const_item(program) { features = vec.push(features, "const-global-metadata"); } else { () };
    if vec.vec_len(options.native_links) > 0 { features = vec.push(features, "native-link-metadata"); } else { () };
    features
}

fn llvm_param_list(program: IrProgram, params: Vec[IrParam]) -> String {
    let mut parts: Vec[String] = vec.new_vec();
    let mut index = 0;
    while index < vec.vec_len(params) {
        match vec.get(params, index) {
            Some(param) => if true {
                if index > 0 { parts = vec.push(parts, ", "); } else { () };
                parts = vec.push(parts, llvm_type_for_id(program, param.type_id));
                parts = vec.push(parts, " %");
                parts = vec.push(parts, backend_mangle_symbol(param.name));
                ()
            } else {
                ()
            },
            None => (),
        };
        index = index + 1;
    };
    string.join(parts, "")
}

fn binary_llvm_op(op: String) -> String {
    if op == "+" {
        "add"
    } else if op == "-" {
        "sub"
    } else if op == "*" {
        "mul"
    } else {
        ""
    }
}

fn emit_call_arg_values(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], callee_name: String, locals: Vec[BackendLocal]) -> String {
    let mut parts: Vec[String] = vec.new_vec();
    let mut index = 0;
    while index < direct_expr_child_count(nodes) {
        match direct_expr_child_at(nodes, index) {
            Some(node) => if true {
                parts = vec.push(parts, emit_value_node(program, function_value, nodes, node, locals));
                ()
            } else {
                ()
            },
            None => (),
        };
        index = index + 1;
    };
    string.join(parts, "")
}

fn emit_node_call_arg_values(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], node: IrExprNode, locals: Vec[BackendLocal]) -> String {
    let mut parts: Vec[String] = vec.new_vec();
    let mut index = 0;
    while index < node.direct_child_count {
        match expr_node_child_at(nodes, node, index) {
            Some(child) => if true {
                parts = vec.push(parts, emit_value_node(program, function_value, nodes, child, locals));
                ()
            } else {
                ()
            },
            None => (),
        };
        index = index + 1;
    };
    string.join(parts, "")
}

fn call_arg_node_value_name(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], node: IrExprNode, locals: Vec[BackendLocal], expected: String) -> String {
    if expected == "%aic.String" {
        string_node_value_name_with_locals(function_value, locals, node)
    } else {
        node_value_name(program, function_value, nodes, node, locals)
    }
}

fn emit_call_args(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], callee_name: String, locals: Vec[BackendLocal]) -> String {
    let mut parts: Vec[String] = vec.new_vec();
    let mut index = 0;
    while index < direct_expr_child_count(nodes) {
        match direct_expr_child_at(nodes, index) {
            Some(node) => if true {
                let expected = call_target_param_type(program, callee_name, index);
                if index > 0 {
                    parts = vec.push(parts, ", ");
                } else {
                    ()
                };
                parts = vec.push(parts, expected);
                parts = vec.push(parts, " ");
                parts = vec.push(parts, call_arg_node_value_name(program, function_value, nodes, node, locals, expected));
                ()
            } else {
                ()
            },
            None => (),
        };
        index = index + 1;
    };
    string.join(parts, "")
}

fn emit_node_call_args(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], node: IrExprNode, locals: Vec[BackendLocal]) -> String {
    let mut parts: Vec[String] = vec.new_vec();
    let mut index = 0;
    while index < node.direct_child_count {
        match expr_node_child_at(nodes, node, index) {
            Some(child) => if true {
                let expected = call_target_param_type(program, node.name, index);
                if index > 0 {
                    parts = vec.push(parts, ", ");
                } else {
                    ()
                };
                parts = vec.push(parts, expected);
                parts = vec.push(parts, " ");
                parts = vec.push(parts, call_arg_node_value_name(program, function_value, nodes, child, locals, expected));
                ()
            } else {
                ()
            },
            None => (),
        };
        index = index + 1;
    };
    string.join(parts, "")
}

fn llvm_string_global_name(function_name: String) -> String {
    concat2("@.aic.str.", backend_mangle_symbol(function_name))
}

fn llvm_string_node_global_name(function_name: String, node: IrNodeId) -> String {
    concat3(llvm_string_global_name(function_name), ".", string.int_to_string(node.value))
}

fn string_literal_payload(value: String) -> String {
    if string.len(value) >= 2 && string.starts_with(value, "\"") && string.ends_with(value, "\"") {
        string.substring(value, 1, string.len(value) - 1)
    } else {
        value
    }
}

fn llvm_escape_string_data(value: String) -> String {
    let mut parts: Vec[String] = vec.new_vec();
    let mut index = 0;
    while index < string.len(value) {
        let ch = string.substring(value, index, index + 1);
        if ch == "\n" {
            parts = vec.push(parts, "\\0A");
        } else if ch == "\t" {
            parts = vec.push(parts, "\\09");
        } else if ch == "\"" {
            parts = vec.push(parts, "\\22");
        } else if ch == "\\" {
            parts = vec.push(parts, "\\5C");
        } else {
            parts = vec.push(parts, ch);
        };
        index = index + 1;
    };
    string.join(parts, "")
}

fn emit_named_string_literal_global(global_name: String, value: String) -> String {
    let payload = string_literal_payload(value);
    let mut parts: Vec[String] = vec.new_vec();
    parts = vec.push(parts, global_name);
    parts = vec.push(parts, " = private unnamed_addr constant [");
    parts = vec.push(parts, string.int_to_string(string.len(payload)));
    parts = vec.push(parts, " x i8] c\"");
    parts = vec.push(parts, llvm_escape_string_data(payload));
    parts = vec.push(parts, "\"\n");
    string.join(parts, "")
}

fn emit_string_literal_global(function_value: IrFunctionDef, value: String) -> String {
    emit_named_string_literal_global(llvm_string_global_name(function_value.name), value)
}

fn emit_string_node_globals_for_expr(function_value: IrFunctionDef, expr: IrExpr) -> String {
    let mut parts: Vec[String] = vec.new_vec();
    let mut index = 0;
    while index < vec.vec_len(expr.nodes) {
        match vec.get(expr.nodes, index) {
            Some(node) => if is_string_expr_kind(node.kind) {
                parts = vec.push(parts, emit_named_string_literal_global(llvm_string_node_global_name(function_value.name, node.node), node.text));
            } else {
                ()
            },
            None => (),
        };
        index = index + 1;
    };
    string.join(parts, "")
}

fn emit_string_globals_for_function(function_value: IrFunctionDef) -> String {
    match function_value.body.tail_expr {
        Some(expr) => match expr.kind {
            IrStringExpr => concat2(emit_string_literal_global(function_value, expr.text), emit_string_node_globals_for_expr(function_value, expr)),
            _ => emit_string_node_globals_for_expr(function_value, expr),
        },
        None => "",
    }
}

fn emit_string_globals(program: IrProgram) -> String {
    let mut parts: Vec[String] = vec.new_vec();
    let mut index = 0;
    while index < vec.vec_len(program.items) {
        match vec.get(program.items, index) {
            Some(item) => match item {
                IrFunctionItemValue(function_value) => if function_value.runtime_visible {
                    parts = vec.push(parts, emit_string_globals_for_function(function_value));
                } else {
                    ()
                },
                _ => (),
            },
            None => (),
        };
        index = index + 1;
    };
    string.join(parts, "")
}

fn program_uses_string_type(program: IrProgram) -> Bool {
    let mut index = 0;
    let mut found = false;
    while !found && index < vec.vec_len(program.types) {
        match vec.get(program.types, index) {
            Some(type_value) => if type_value.name == "String" {
                found = true;
            } else {
                ()
            },
            None => (),
        };
        index = index + 1;
    };
    found
}

fn expr_uses_string_replace(expr: IrExpr) -> Bool {
    let mut found = is_call_expr_kind(expr.kind) && expr.name == "string.replace";
    let mut index = 0;
    while !found && index < vec.vec_len(expr.nodes) {
        match vec.get(expr.nodes, index) {
            Some(node) => if is_call_expr_kind(node.kind) && node.name == "string.replace" {
                found = true;
            } else {
                ()
            },
            None => (),
        };
        index = index + 1;
    };
    found
}

fn expr_uses_io_print(expr: IrExpr) -> Bool {
    let mut found = is_call_expr_kind(expr.kind) && is_io_print_intrinsic_name(expr.name);
    let mut index = 0;
    while !found && index < vec.vec_len(expr.nodes) {
        match vec.get(expr.nodes, index) {
            Some(node) => if is_call_expr_kind(node.kind) && is_io_print_intrinsic_name(node.name) {
                found = true;
            } else {
                ()
            },
            None => (),
        };
        index = index + 1;
    };
    found
}

fn expr_uses_env_arg_at(expr: IrExpr) -> Bool {
    let mut found = is_call_expr_kind(expr.kind) && expr.name == "arg_at";
    let mut index = 0;
    while !found && index < vec.vec_len(expr.nodes) {
        match vec.get(expr.nodes, index) {
            Some(node) => if is_call_expr_kind(node.kind) && node.name == "arg_at" {
                found = true;
            } else {
                ()
            },
            None => (),
        };
        index = index + 1;
    };
    found
}

fn expr_uses_call_named(expr: IrExpr, name: String) -> Bool {
    let mut found = is_call_expr_kind(expr.kind) && expr.name == name;
    let mut index = 0;
    while !found && index < vec.vec_len(expr.nodes) {
        match vec.get(expr.nodes, index) {
            Some(node) => if is_call_expr_kind(node.kind) && node.name == name {
                found = true;
            } else {
                ()
            },
            None => (),
        };
        index = index + 1;
    };
    found
}

fn statement_uses_call_named(statement: IrStatement, name: String) -> Bool {
    match statement.expr {
        Some(expr) => expr_uses_call_named(expr, name),
        None => false,
    }
}

fn block_uses_call_named(block: IrBlock, name: String) -> Bool {
    let mut found = false;
    let mut index = 0;
    while !found && index < vec.vec_len(block.statements) {
        match vec.get(block.statements, index) {
            Some(statement) => if statement_uses_call_named(statement, name) {
                found = true;
            } else {
                ()
            },
            None => (),
        };
        index = index + 1;
    };
    if found {
        true
    } else {
        match block.tail_expr {
            Some(expr) => expr_uses_call_named(expr, name),
            None => false,
        }
    }
}

fn program_uses_call_named(program: IrProgram, name: String) -> Bool {
    let mut index = 0;
    let mut found = false;
    while !found && index < vec.vec_len(program.items) {
        match vec.get(program.items, index) {
            Some(item) => match item {
                IrFunctionItemValue(function_value) => if block_uses_call_named(function_value.body, name) {
                    found = true;
                } else {
                    ()
                },
                _ => (),
            },
            None => (),
        };
        index = index + 1;
    };
    found
}

fn program_uses_string_replace(program: IrProgram) -> Bool {
    let mut index = 0;
    let mut found = false;
    while !found && index < vec.vec_len(program.items) {
        match vec.get(program.items, index) {
            Some(item) => match item {
                IrFunctionItemValue(function_value) => match function_value.body.tail_expr {
                    Some(expr) => if expr_uses_string_replace(expr) {
                        found = true;
                    } else {
                        ()
                    },
                    None => (),
                },
                _ => (),
            },
            None => (),
        };
        index = index + 1;
    };
    found
}

fn program_uses_io_print(program: IrProgram) -> Bool {
    let mut index = 0;
    let mut found = false;
    while !found && index < vec.vec_len(program.items) {
        match vec.get(program.items, index) {
            Some(item) => match item {
                IrFunctionItemValue(function_value) => match function_value.body.tail_expr {
                    Some(expr) => if expr_uses_io_print(expr) {
                        found = true;
                    } else {
                        ()
                    },
                    None => (),
                },
                _ => (),
            },
            None => (),
        };
        index = index + 1;
