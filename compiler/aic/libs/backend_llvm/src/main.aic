fn result_bool_match_node_can_emit_return(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], node: IrExprNode, ret: String, locals: BackendLocals) -> Bool {
    if ret != "i64" || !result_match_arms_are_ok_err(node.match_arms) {
        false
    } else {
        match expr_node_child_at(nodes, node, 0) {
            Some(scrutinee) => if is_call_expr_kind(scrutinee.kind) && is_fs_bool_result_intrinsic_name(scrutinee.name) {
                let args_ok = if scrutinee.name == "write_text" {
                    scrutinee.direct_child_count == 2 && match expr_node_child_at(nodes, scrutinee, 0) {
                        Some(path_child) => match expr_node_child_at(nodes, scrutinee, 1) {
                            Some(content_child) => string_call_child_can_emit(program, function_value, nodes, path_child, locals) && string_call_child_can_emit(program, function_value, nodes, content_child, locals),
                            None => false,
                        },
                        None => false,
                    }
                } else {
                    scrutinee.direct_child_count == 1 && match expr_node_child_at(nodes, scrutinee, 0) {
                        Some(path_child) => string_call_child_can_emit(program, function_value, nodes, path_child, locals),
                        None => false,
                    }
                };
                if args_ok {
                    match result_match_node_body_node_for_variant(nodes, node, "Ok") {
                        Some(ok_body) => match result_match_node_body_node_for_variant(nodes, node, "Err") {
                            Some(err_body) => branch_node_can_emit_with_locals(program, function_value, nodes, ok_body, ret, locals) && branch_node_can_emit_with_locals(program, function_value, nodes, err_body, ret, locals),
                            None => false,
                        },
                        None => false,
                    }
                } else {
                    false
                }
            } else {
                false
            },
            None => false,
        }
    }
}

fn result_bool_match_expr_can_emit_return(program: IrProgram, value: IrExpr, function_value: IrFunctionDef, ret: String, locals: BackendLocals) -> Bool {
    if ret != "i64" || !result_match_arms_are_ok_err(value.match_arms) {
        false
    } else {
        match direct_expr_child_at(value.nodes, 0) {
            Some(scrutinee) => if is_call_expr_kind(scrutinee.kind) && is_fs_bool_result_intrinsic_name(scrutinee.name) {
