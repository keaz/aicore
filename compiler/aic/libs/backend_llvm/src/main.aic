}

fn known_call_return_type_name(callee_name: String) -> String {
    if callee_name == "driver_join_path" || callee_name == "driver_manifest_main_path" || callee_name == "compiler_source_path_for_import" || callee_name == "source_path_for_input" || callee_name == "concat2" || callee_name == "concat3" || callee_name == "concat4" || callee_name == "concat5" || callee_name == "shell_quote" {
        "String"
    } else if callee_name == "string.len" {
        "Int"
    } else if is_string_join_intrinsic_name(callee_name) {
        "String"
    } else if is_string_split_intrinsic_name(callee_name) {
        "Vec[String]"
    } else if is_string_trim_intrinsic_name(callee_name) {
        "String"
    } else if is_string_char_at_intrinsic_name(callee_name) {
        "Option[String]"
    } else if is_string_int_to_string_intrinsic_name(callee_name) {
        "String"
    } else if is_vec_len_intrinsic_name(callee_name) {
        "Int"
    } else if is_string_slice_intrinsic_name(callee_name) {
        "String"
    } else if callee_name == "source_id" {
        "SourceId"
    } else if callee_name == "driver_source" {
        "DriverSource"
    } else if callee_name == "driver_sources_with_synthetic_imports_for_all" {
        "Vec[DriverSource]"
    } else if callee_name == "driver_check_sources" || callee_name == "driver_ir_json_sources" || callee_name == "driver_build_sources" || callee_name == "driver_build_sources_with_imported_units" || callee_name == "driver_unsupported_command" || callee_name == "missing_arg" {
        "DriverCommandResult"
    } else if callee_name == "driver_has_source_path" {
        "Bool"
    } else if callee_name == "proc.run" {
        "Result[ProcOutput, ProcError]"
    } else {
        ""
    }
}

fn known_call_return_type(program: IrProgram, callee_name: String) -> String {
    llvm_type_for_repr_in_program(program, known_call_return_type_name(callee_name))
}

fn known_call_param_count(callee_name: String) -> Int {
    if callee_name == "driver_manifest_main_path" || callee_name == "source_id" || callee_name == "source_path_for_input" || callee_name == "shell_quote" || callee_name == "string.len" || is_string_trim_intrinsic_name(callee_name) || is_string_int_to_string_intrinsic_name(callee_name) {
        1
    } else if is_string_join_intrinsic_name(callee_name) || is_string_split_intrinsic_name(callee_name) || is_string_char_at_intrinsic_name(callee_name) {
        2
    } else if is_string_slice_intrinsic_name(callee_name) {
        3
    } else if callee_name == "proc.run" {
        1
    } else if callee_name == "driver_join_path" || callee_name == "driver_has_source_path" || callee_name == "driver_sources_with_synthetic_imports_for_all" || callee_name == "driver_check_sources" || callee_name == "driver_ir_json_sources" || callee_name == "driver_unsupported_command" || callee_name == "missing_arg" || callee_name == "concat2" {
        2
    } else if callee_name == "driver_source" || callee_name == "driver_build_sources" || callee_name == "driver_build_sources_with_imported_units" || callee_name == "concat3" {
        3
    } else if callee_name == "concat4" {
        4
    } else if callee_name == "concat5" {
        5
    } else {
        0
    }
}

fn known_call_param_type(program: IrProgram, callee_name: String, param_index: Int) -> String {
    if callee_name == "string.len" {
        "%aic.String"
    } else if is_string_join_intrinsic_name(callee_name) {
        if param_index == 0 { llvm_type_for_repr_in_program(program, "Vec[String]") } else { "%aic.String" }
    } else if is_string_split_intrinsic_name(callee_name) {
        "%aic.String"
    } else if is_string_trim_intrinsic_name(callee_name) {
        "%aic.String"
    } else if is_string_char_at_intrinsic_name(callee_name) {
        if param_index == 0 { "%aic.String" } else { "i64" }
    } else if is_string_int_to_string_intrinsic_name(callee_name) {
        "i64"
    } else if is_string_slice_intrinsic_name(callee_name) {
        if param_index == 0 { "%aic.String" } else { "i64" }
    } else if callee_name == "source_id" {
        "i64"
    } else if callee_name == "driver_source" {
        if param_index == 2 { llvm_type_for_repr_in_program(program, "SourceId") } else { "%aic.String" }
    } else if callee_name == "driver_has_source_path" {
        if param_index == 0 { llvm_type_for_repr_in_program(program, "Vec[DriverSource]") } else { "%aic.String" }
    } else if callee_name == "driver_sources_with_synthetic_imports_for_all" || callee_name == "driver_check_sources" || callee_name == "driver_ir_json_sources" {
        if param_index == 0 { llvm_type_for_repr_in_program(program, "Vec[DriverSource]") } else { "i64" }
    } else if callee_name == "driver_build_sources" || callee_name == "driver_build_sources_with_imported_units" {
        if param_index == 0 {
            llvm_type_for_repr_in_program(program, "Vec[DriverSource]")
        } else if param_index == 1 {
            "%aic.String"
        } else {
            "i64"
        }
    } else if callee_name == "driver_unsupported_command" {
        if param_index == 0 { "%aic.String" } else { "i64" }
    } else if callee_name == "missing_arg" {
        "%aic.String"
    } else if callee_name == "proc.run" {
        "%aic.String"
    } else {
        "%aic.String"
    }
}

fn call_expr_can_emit_with_locals(program: IrProgram, value: IrExpr, function_value: IrFunctionDef, locals: BackendLocals) -> Bool {
    if is_string_bool_intrinsic_name(value.name) {
        string_bool_expr_can_emit(program, value, function_value, locals)
    } else if is_io_print_intrinsic_name(value.name) {
        direct_expr_child_count(value.nodes) == 1 && match direct_expr_child_at(value.nodes, 0) {
            Some(child) => string_call_child_can_emit(program, function_value, value.nodes, child, locals),
            None => false,
        }
    } else if is_fs_string_result_intrinsic_name(value.name) {
        direct_expr_child_count(value.nodes) == 1 && match direct_expr_child_at(value.nodes, 0) {
            Some(child) => string_call_child_can_emit(program, function_value, value.nodes, child, locals),
            None => false,
        }
    } else if is_fs_bool_result_intrinsic_name(value.name) {
        if value.name == "write_text" {
            direct_expr_child_count(value.nodes) == 2 && match direct_expr_child_at(value.nodes, 0) {
                Some(path_child) => match direct_expr_child_at(value.nodes, 1) {
                    Some(content_child) => string_call_child_can_emit(program, function_value, value.nodes, path_child, locals) && string_call_child_can_emit(program, function_value, value.nodes, content_child, locals),
                    None => false,
                },
                None => false,
            }
        } else {
            direct_expr_child_count(value.nodes) == 1 && match direct_expr_child_at(value.nodes, 0) {
                Some(child) => string_call_child_can_emit(program, function_value, value.nodes, child, locals),
                None => false,
            }
        }
    } else if is_proc_result_intrinsic_name(value.name) {
        direct_expr_child_count(value.nodes) == 1 && match direct_expr_child_at(value.nodes, 0) {
            Some(child) => string_call_child_can_emit(program, function_value, value.nodes, child, locals),
            None => false,
        }
    } else if string_replace_expr_can_emit(program, value, function_value, locals) {
        true
    } else if string_join_expr_can_emit(program, value, function_value, locals) {
        true
    } else if value.name == "vec.new_vec" {
        vec_new_vec_expr_can_emit(program, value)
    } else if value.name == "vec.push" {
        vec_push_expr_can_emit(program, value, function_value, locals)
    } else if is_vec_get_intrinsic_name(value.name) {
        vec_get_expr_can_emit(program, value, function_value, locals)
    } else if value.name != "" && llvm_type_for_repr_in_program(program, optional_type_name_for_id(program.types, value.type_id)) != "" && call_expr_children_can_emit_without_signature(program, value, function_value, locals) {
        true
    } else if value.name == "" {
        false
    } else {
        let target: Option[IrFunctionDef] = call_target_function(program, value.name);
        if call_target_return_type_resolved(program, value.name, target) == "" {
            false
        } else if direct_expr_child_count(value.nodes) != call_target_param_count_resolved(value.name, target) {
            false
        } else {
            let mut index = 0;
            let mut ok = true;
            while ok && index < direct_expr_child_count(value.nodes) {
                match direct_expr_child_at(value.nodes, index) {
                    Some(node) => if call_child_node_can_emit_expected(program, function_value, value.nodes, call_target_param_type_resolved(program, value.name, target, index), call_target_param_type_name_resolved(program, target, index), node, locals) {
                        ()
                    } else {
                        ok = false;
                    },
                    None => if true {
                        ok = false;
                        ()
                    } else { () },
                };
                index = index + 1;
            };
            ok
        }
    }
}

fn call_expr_can_emit(program: IrProgram, value: IrExpr, function_value: IrFunctionDef) -> Bool {
    call_expr_can_emit_with_locals(program, value, function_value, backend_empty_locals())
}

fn binary_arithmetic_op_can_emit(op: String) -> Bool {
    op == "+" || op == "-" || op == "*" || op == "Add" || op == "Sub" || op == "Mul"
}

fn binary_logical_op_can_emit(op: String) -> Bool {
    op == "||" || op == "&&" || op == "Or" || op == "And"
}

fn is_llvm_integer_type(value: String) -> Bool {
    value == "i8" || value == "i16" || value == "i32" || value == "i64"
}

fn binary_node_llvm_type(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], node: IrExprNode, locals: BackendLocals) -> String {
    if binary_logical_op_can_emit(node.op) || binary_compare_op_can_emit(node.op) {
        "i1"
    } else if binary_arithmetic_op_can_emit(node.op) {
        match expr_node_child_at(nodes, node, 0) {
            Some(left) => value_node_llvm_type(program, function_value, nodes, left, locals),
            None => "",
        }
    } else {
        ""
    }
}

fn binary_node_can_emit_with_locals(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], node: IrExprNode, locals: BackendLocals) -> Bool {
    if binary_arithmetic_op_can_emit(node.op) {
        match expr_node_child_at(nodes, node, 0) {
            Some(left) => match expr_node_child_at(nodes, node, 1) {
                Some(right) => if value_node_can_emit(program, function_value, nodes, left, locals) && value_node_can_emit(program, function_value, nodes, right, locals) {
                    let left_type = value_node_llvm_type(program, function_value, nodes, left, locals);
                    let right_type = value_node_llvm_type(program, function_value, nodes, right, locals);
                    left_type == right_type && is_llvm_integer_type(left_type)
                } else {
                    false
                },
                None => false,
            },
            None => false,
        }
    } else if binary_logical_op_can_emit(node.op) {
        match expr_node_child_at(nodes, node, 0) {
            Some(left) => match expr_node_child_at(nodes, node, 1) {
                Some(right) => bool_node_can_emit_with_locals(program, function_value, nodes, left, locals) && bool_node_can_emit_with_locals(program, function_value, nodes, right, locals),
                None => false,
            },
            None => false,
        }
    } else if binary_compare_op_can_emit(node.op) {
        match expr_node_child_at(nodes, node, 0) {
            Some(left) => match expr_node_child_at(nodes, node, 1) {
                Some(right) => if string_call_child_can_emit(program, function_value, nodes, left, locals) && string_call_child_can_emit(program, function_value, nodes, right, locals) {
                    node.op == "==" || node.op == "!=" || node.op == "Eq" || node.op == "Ne"
                } else if value_node_can_emit(program, function_value, nodes, left, locals) && value_node_can_emit(program, function_value, nodes, right, locals) {
                    let left_type = value_node_llvm_type(program, function_value, nodes, left, locals);
                    let right_type = value_node_llvm_type(program, function_value, nodes, right, locals);
                    let right_is_int_literal = match right.kind {
                        IrIntExpr => is_decimal_integer_text(literal_text_or_name(right.text, right.name)),
                        _ => false,
                    };
                    left_type != "" && (left_type == right_type || (is_llvm_integer_type(left_type) && right_is_int_literal))
                } else {
                    false
                },
                None => false,
            },
            None => false,
        }
    } else {
        false
    }
}

fn binary_expr_llvm_type(program: IrProgram, value: IrExpr, function_value: IrFunctionDef, locals: BackendLocals) -> String {
    if binary_logical_op_can_emit(value.op) || binary_compare_op_can_emit(value.op) {
        "i1"
    } else if binary_arithmetic_op_can_emit(value.op) {
        match direct_expr_child_at(value.nodes, 0) {
            Some(left) => value_node_llvm_type(program, function_value, value.nodes, left, locals),
            None => "",
        }
    } else {
        ""
    }
}

fn binary_expr_can_emit_with_locals(program: IrProgram, value: IrExpr, function_value: IrFunctionDef, locals: BackendLocals) -> Bool {
    if binary_arithmetic_op_can_emit(value.op) {
        match direct_expr_child_at(value.nodes, 0) {
            Some(left) => match direct_expr_child_at(value.nodes, 1) {
                Some(right) => if value_node_can_emit(program, function_value, value.nodes, left, locals) && value_node_can_emit(program, function_value, value.nodes, right, locals) {
                    let left_type = value_node_llvm_type(program, function_value, value.nodes, left, locals);
                    let right_type = value_node_llvm_type(program, function_value, value.nodes, right, locals);
                    left_type == right_type && is_llvm_integer_type(left_type)
                } else {
                    false
                },
                None => false,
            },
            None => false,
        }
    } else if binary_logical_op_can_emit(value.op) {
        match direct_expr_child_at(value.nodes, 0) {
            Some(left) => match direct_expr_child_at(value.nodes, 1) {
                Some(right) => bool_node_can_emit_with_locals(program, function_value, value.nodes, left, locals) && bool_node_can_emit_with_locals(program, function_value, value.nodes, right, locals),
                None => false,
            },
            None => false,
        }
    } else if binary_compare_op_can_emit(value.op) {
        match direct_expr_child_at(value.nodes, 0) {
            Some(left) => match direct_expr_child_at(value.nodes, 1) {
                Some(right) => if string_call_child_can_emit(program, function_value, value.nodes, left, locals) && string_call_child_can_emit(program, function_value, value.nodes, right, locals) {
                    value.op == "==" || value.op == "!=" || value.op == "Eq" || value.op == "Ne"
                } else if value_node_can_emit(program, function_value, value.nodes, left, locals) && value_node_can_emit(program, function_value, value.nodes, right, locals) {
                    let left_type = value_node_llvm_type(program, function_value, value.nodes, left, locals);
                    let right_type = value_node_llvm_type(program, function_value, value.nodes, right, locals);
                    let right_is_int_literal = match right.kind {
                        IrIntExpr => is_decimal_integer_text(literal_text_or_name(right.text, right.name)),
                        _ => false,
                    };
                    left_type != "" && (left_type == right_type || (is_llvm_integer_type(left_type) && right_is_int_literal))
                } else {
                    false
                },
                None => false,
            },
            None => false,
        }
    } else {
        false
    }
}

fn binary_expr_can_emit(value: IrExpr, function_value: IrFunctionDef) -> Bool {
    if binary_arithmetic_op_can_emit(value.op) {
        match direct_expr_child_at(value.nodes, 0) {
            Some(left) => match direct_expr_child_at(value.nodes, 1) {
                Some(right) => simple_node_can_emit_with_locals(left, function_value, backend_empty_locals()) && simple_node_can_emit_with_locals(right, function_value, backend_empty_locals()),
                None => false,
            },
            None => false,
        }
    } else {
        false
    }
}

fn binary_compare_op_can_emit(op: String) -> Bool {
    op == "==" || op == "!=" || op == "<" || op == ">" || op == "<=" || op == ">=" || op == "Eq" || op == "Ne" || op == "Lt" || op == "Gt" || op == "Le" || op == "Ge"
}

fn compare_predicate(op: String) -> String {
    if op == "==" || op == "Eq" {
        "eq"
    } else if op == "!=" || op == "Ne" {
        "ne"
    } else if op == "<" || op == "Lt" {
        "slt"
    } else if op == ">" || op == "Gt" {
        "sgt"
    } else if op == "<=" || op == "Le" {
        "sle"
    } else if op == ">=" || op == "Ge" {
        "sge"
    } else {
        ""
    }
}

fn string_compare_predicate(op: String) -> String {
    if op == "==" || op == "Eq" {
        "eq"
    } else if op == "!=" || op == "Ne" {
        "ne"
    } else {
        ""
    }
}

fn bool_node_can_emit_with_locals(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], node: IrExprNode, locals: BackendLocals) -> Bool {
    match node.kind {
        IrBoolExpr => literal_text_or_name(node.text, node.name) == "true" || literal_text_or_name(node.text, node.name) == "false",
        IrNameExpr => llvm_type_for_name(program, function_value, locals, node.text) == "i1",
        IrFieldAccessExpr => field_access_node_can_emit(program, function_value, nodes, node, locals, "i1"),
        IrCallExpr => if is_string_bool_intrinsic_name(node.name) {
            string_bool_node_can_emit(program, function_value, nodes, node, locals)
        } else {
            call_node_return_type_matches(program, node, "i1") && direct_call_node_can_emit(program, function_value, nodes, node, locals)
        },
        IrUnaryExpr => node.op == "!" && match expr_node_child_at(nodes, node, 0) {
            Some(child) => bool_node_can_emit_with_locals(program, function_value, nodes, child, locals),
            None => false,
        },
        IrBinaryExpr => if binary_logical_op_can_emit(node.op) {
            match expr_node_child_at(nodes, node, 0) {
                Some(left) => match expr_node_child_at(nodes, node, 1) {
                    Some(right) => bool_node_can_emit_with_locals(program, function_value, nodes, left, locals) && bool_node_can_emit_with_locals(program, function_value, nodes, right, locals),
                    None => false,
                },
                None => false,
            }
        } else if binary_compare_op_can_emit(node.op) {
            match expr_node_child_at(nodes, node, 0) {
                Some(left) => match expr_node_child_at(nodes, node, 1) {
                    Some(right) => if string_call_child_can_emit(program, function_value, nodes, left, locals) && string_call_child_can_emit(program, function_value, nodes, right, locals) {
                        node.op == "==" || node.op == "!=" || node.op == "Eq" || node.op == "Ne"
                    } else if value_node_can_emit(program, function_value, nodes, left, locals) && value_node_can_emit(program, function_value, nodes, right, locals) {
                        let left_type = value_node_llvm_type(program, function_value, nodes, left, locals);
                        let right_type = value_node_llvm_type(program, function_value, nodes, right, locals);
                        let right_is_int_literal = match right.kind {
                            IrIntExpr => is_decimal_integer_text(literal_text_or_name(right.text, right.name)),
                            _ => false,
                        };
                        left_type != "" && (left_type == right_type || (is_llvm_integer_type(left_type) && right_is_int_literal))
                    } else {
                        false
                    },
                    None => false,
                },
                None => false,
            }
        } else {
            false
        },
        IrIfExpr => if_node_value_llvm_type(program, function_value, nodes, node, locals) == "i1"
            && if_node_value_can_emit_with_locals(program, function_value, nodes, node, locals),
        IrMatchExpr => if option_vec_get_match_node_type_name(program, function_value, nodes, node, locals) != "" {
            option_vec_get_match_node_llvm_type(program, function_value, nodes, node, locals) == "i1"
                && option_vec_get_match_node_can_emit_value(program, function_value, nodes, node, locals)
        } else if option_match_node_type_name(program, function_value, nodes, node, locals) != "" {
            option_match_node_llvm_type(program, function_value, nodes, node, locals) == "i1"
                && option_match_node_can_emit_value(program, function_value, nodes, node, locals)
        } else {
            enum_bool_match_node_can_emit(program, function_value, nodes, node, locals)
        },
        _ => false,
    }
}

fn bool_node_can_emit(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], node: IrExprNode) -> Bool {
    bool_node_can_emit_with_locals(program, function_value, nodes, node, backend_param_locals(program, function_value))
}

fn block_tail_node_can_emit_with_locals(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], block_node: IrExprNode, ret: String, locals: BackendLocals) -> Bool {
    if !is_block_expr_kind(block_node.kind) {
        false
    } else {
        block_node_can_emit_return(program, function_value, nodes, block_node, ret, locals)
    }
}

fn branch_node_can_emit_with_locals(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], branch_node: IrExprNode, ret: String, locals: BackendLocals) -> Bool {
    if is_block_expr_kind(branch_node.kind) {
        block_tail_node_can_emit_with_locals(program, function_value, nodes, branch_node, ret, locals)
    } else {
        return_node_can_emit_with_locals(program, function_value, nodes, branch_node, ret, locals)
    }
}

fn branch_node_can_emit(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], branch_node: IrExprNode, ret: String) -> Bool {
    branch_node_can_emit_with_locals(program, function_value, nodes, branch_node, ret, backend_empty_locals())
}

fn branch_value_node_can_emit_with_locals(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], branch_node: IrExprNode, expected: String, locals: BackendLocals) -> Bool {
    branch_value_node_can_emit_with_expected_type(program, function_value, nodes, branch_node, expected, branch_expected_type_name(program, function_value, expected), locals)
}

fn branch_value_node_can_emit_with_expected_type(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], branch_node: IrExprNode, expected: String, expected_type_name: String, locals: BackendLocals) -> Bool {
    if expected == "" || expected == "void" {
        false
    } else if is_block_expr_kind(branch_node.kind) {
        let mut index = 0;
        let mut ok = true;
        let mut done = false;
        let mut out_locals = clone_backend_locals(locals);
        while ok && !done && index < branch_node.direct_child_count {
            match expr_node_child_at(nodes, branch_node, index) {
                Some(child) => if block_child_is_let(child) {
                    if let_node_can_emit(program, function_value, nodes, child, out_locals) {
                        out_locals = push_node_local(program, function_value, nodes, child, out_locals);
                    } else {
                        ok = false;
                    };
                    ()
                } else if block_child_is_assign(child) {
                    ok = assign_node_can_emit(program, function_value, nodes, child, out_locals, block_assign_target_from_role(child.role));
                    ()
                } else if block_child_is_expr(child) {
                    ok = expr_node_statement_can_emit_with_locals(program, function_value, nodes, child, out_locals);
                    ()
                } else if block_child_is_tail(child) {
                    ok = branch_value_node_can_emit_with_expected_type(program, function_value, nodes, child, expected, expected_type_name, out_locals);
                    done = true;
                    ()
                } else {
                    ok = false;
                    ()
                },
                None => if true {
                    ok = false;
                    ()
                } else { () },
            };
            index = index + 1;
        };
        ok && done
    } else {
        expected_vec_new_vec_node_can_emit(branch_node, expected)
            || expected_enum_constructor_node_can_emit(program, function_value, nodes, branch_node, locals, expected_type_name) && llvm_type_for_repr_in_program(program, expected_type_name) == expected
            || node_is_match_expr(branch_node) && direct_option_match_node_can_emit_expected_path(nodes, branch_node) && option_match_node_can_emit_value_expected(program, function_value, nodes, branch_node, locals, expected, expected_type_name)
            || node_is_if_expr(branch_node) && if_node_value_can_emit_with_expected_type(program, function_value, nodes, branch_node, locals, expected, expected_type_name)
            || value_node_can_emit(program, function_value, nodes, branch_node, locals) && value_node_llvm_type(program, function_value, nodes, branch_node, locals) == expected
    }
}

fn if_node_can_emit_with_locals(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], node: IrExprNode, ret: String, locals: BackendLocals) -> Bool {
    if node.direct_child_count != 3 {
        false
    } else {
        match expr_node_child_at(nodes, node, 0) {
            Some(condition) => match expr_node_child_at(nodes, node, 1) {
                Some(then_block) => match expr_node_child_at(nodes, node, 2) {
                    Some(else_block) => if bool_node_can_emit_with_locals(program, function_value, nodes, condition, locals)
                        && branch_node_can_emit_with_locals(program, function_value, nodes, then_block, ret, locals)
                        && branch_node_can_emit_with_locals(program, function_value, nodes, else_block, ret, locals) {
                        true
                    } else {
                        base_type_name_text(function_result_type_name(program, function_value)) == "Result" && bool_node_can_emit_with_locals(program, function_value, nodes, condition, locals)
                    },
                    None => false,
                },
                None => false,
            },
            None => false,
        }
    }
}

fn if_node_can_emit(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], node: IrExprNode, ret: String) -> Bool {
    if_node_can_emit_with_locals(program, function_value, nodes, node, ret, backend_empty_locals())
}

fn struct_literal_child_can_emit(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], child: IrExprNode, locals: BackendLocals, expected: String, expected_type_name: String) -> Bool {
    if expected == "%aic.String" {
        string_call_child_can_emit(program, function_value, nodes, child, locals)
    } else if expected_vec_new_vec_node_can_emit(child, expected) {
        true
    } else if expected_enum_constructor_node_can_emit(program, function_value, nodes, child, locals, expected_type_name) {
        true
    } else if node_is_if_expr(child) {
        if_node_value_can_emit_with_expected_type(program, function_value, nodes, child, locals, expected, expected_type_name)
    } else if node_is_match_expr(child) && direct_option_match_node_can_emit_expected_path(nodes, child) {
        option_match_node_can_emit_value_expected(program, function_value, nodes, child, locals, expected, expected_type_name)
    } else if value_node_can_emit(program, function_value, nodes, child, locals) {
        value_node_llvm_type(program, function_value, nodes, child, locals) == expected
    } else {
        false
    }
}

fn struct_literal_node_can_emit(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], node: IrExprNode, locals: BackendLocals, ret: String) -> Bool {
    let struct_ty = llvm_type_for_repr_in_program(program, node.name);
    if node.name == "" || struct_ty == "" || struct_ty != ret {
        false
    } else {
        let mut index = 0;
        let mut ok = true;
        while ok && index < node.direct_child_count {
            match expr_node_child_at(nodes, node, index) {
                Some(child) => if true {
                    let field_ty = struct_field_llvm_type_by_index(program, node.name, index);
                    let field_type_name = struct_field_type_name_by_index(program, node.name, index);
                    if field_ty != "" && struct_literal_child_can_emit(program, function_value, nodes, child, locals, field_ty, field_type_name) {
                        ()
                    } else {
                        ok = false;
                    };
                    ()
                } else { () },
                None => if true {
                    ok = false;
                    ()
                } else { () },
            };
            index = index + 1;
        };
        ok
    }
}

fn struct_literal_expr_can_emit(program: IrProgram, value: IrExpr, function_value: IrFunctionDef, locals: BackendLocals, ret: String) -> Bool {
    let struct_ty = llvm_type_for_repr_in_program(program, value.name);
    if value.name == "" || struct_ty == "" || struct_ty != ret {
        false
    } else {
        let mut index = 0;
        let mut ok = true;
        while ok && index < direct_expr_child_count(value.nodes) {
            match direct_expr_child_at(value.nodes, index) {
                Some(child) => if true {
                    let field_ty = struct_field_llvm_type_by_index(program, value.name, index);
                    let field_type_name = struct_field_type_name_by_index(program, value.name, index);
                    if field_ty != "" && struct_literal_child_can_emit(program, function_value, value.nodes, child, locals, field_ty, field_type_name) {
                        ()
                    } else {
                        ok = false;
                    };
                    ()
                } else { () },
                None => if true {
                    ok = false;
                    ()
                } else { () },
            };
            index = index + 1;
        };
        ok
    }
}

fn return_node_can_emit_with_locals(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], node: IrExprNode, ret: String, locals: BackendLocals) -> Bool {
    match node.kind {
        IrIntExpr => ret == "i64" && is_decimal_integer_text(literal_text_or_name(node.text, node.name)),
        IrBoolExpr => ret == "i1" && (literal_text_or_name(node.text, node.name) == "true" || literal_text_or_name(node.text, node.name) == "false"),
        IrStringExpr => ret == "%aic.String",
        IrUnitExpr => ret == "void",
        IrNameExpr => return_name_can_emit_with_locals(program, function_value, locals, node.text, ret),
        IrFieldAccessExpr => field_access_node_can_emit(program, function_value, nodes, node, locals, ret),
        IrBinaryExpr => value_node_llvm_type(program, function_value, nodes, node, locals) == ret && binary_node_can_emit_with_locals(program, function_value, nodes, node, locals),
        IrUnaryExpr => if node.op == "!" {
            ret == "i1" && bool_node_can_emit_with_locals(program, function_value, nodes, node, locals)
        } else if node.op == "-" {
            ret == "i64" && value_node_can_emit(program, function_value, nodes, node, locals)
        } else {
            false
        },
        IrCallExpr => if is_string_bool_intrinsic_name(node.name) {
            ret == "i1" && string_bool_node_can_emit(program, function_value, nodes, node, locals)
        } else if node.name == "string.replace" {
            ret == "%aic.String" && string_replace_node_can_emit(program, function_value, nodes, node, locals)
        } else if is_string_join_intrinsic_name(node.name) {
            ret == "%aic.String" && string_join_node_can_emit(program, function_value, nodes, node, locals)
        } else if is_string_split_intrinsic_name(node.name) {
            ret == llvm_type_for_repr_in_program(program, "Vec[String]") && string_split_node_can_emit(program, function_value, nodes, node, locals)
        } else if is_string_trim_intrinsic_name(node.name) {
            ret == "%aic.String" && string_trim_node_can_emit(program, function_value, nodes, node, locals)
        } else if is_string_char_at_intrinsic_name(node.name) {
            ret == llvm_type_for_repr_in_program(program, "Option[String]") && string_char_at_node_can_emit(program, function_value, nodes, node, locals)
        } else if is_string_int_to_string_intrinsic_name(node.name) {
            ret == "%aic.String" && string_int_to_string_node_can_emit(program, function_value, nodes, node, locals)
        } else if is_string_len_intrinsic_name(node.name) {
            ret == "i64" && string_len_node_can_emit(program, function_value, nodes, node, locals)
        } else if is_vec_len_intrinsic_name(node.name) {
            ret == "i64" && vec_len_node_can_emit(program, function_value, nodes, node, locals)
        } else if is_string_slice_intrinsic_name(node.name) {
            ret == "%aic.String" && string_slice_node_can_emit(program, function_value, nodes, node, locals)
        } else if node.name == "vec.new_vec" {
            expected_vec_new_vec_node_can_emit(node, ret)
        } else if node.name == "vec.push" {
            vec_push_node_llvm_type(program, function_value, nodes, node, locals) == ret && vec_push_node_can_emit(program, function_value, nodes, node, locals)
        } else if is_vec_get_intrinsic_name(node.name) {
            vec_get_node_llvm_type(program, function_value, nodes, node, locals) == ret && vec_get_node_can_emit(program, function_value, nodes, node, locals)
        } else if expected_enum_constructor_node_can_emit(program, function_value, nodes, node, locals, function_result_type_name(program, function_value)) {
            llvm_type_for_repr_in_program(program, function_result_type_name(program, function_value)) == ret
        } else if node.name == "Ok" || node.name == "Err" {
            result_constructor_node_can_emit(program, function_value, nodes, node, ret, locals)
        } else if is_io_print_intrinsic_name(node.name) {
            ret == "void" && direct_call_node_can_emit(program, function_value, nodes, node, locals)
        } else if is_fs_string_result_intrinsic_name(node.name) {
            ret == llvm_type_for_repr_in_program(program, "Result[String, FsError]") && direct_call_node_can_emit(program, function_value, nodes, node, locals)
        } else if is_fs_bool_result_intrinsic_name(node.name) {
            ret == llvm_type_for_repr_in_program(program, "Result[Bool, FsError]") && direct_call_node_can_emit(program, function_value, nodes, node, locals)
        } else if is_proc_result_intrinsic_name(node.name) {
            ret == llvm_type_for_repr_in_program(program, "Result[ProcOutput, ProcError]") && direct_call_node_can_emit(program, function_value, nodes, node, locals)
        } else {
            let call_ret = call_target_return_type(program, node.name);
            if call_ret != "" {
                call_ret == ret && direct_call_node_can_emit(program, function_value, nodes, node, locals)
            } else if enum_variant_constructor_llvm_type(program, node.name) == ret {
                enum_variant_constructor_node_can_emit(program, function_value, nodes, node, locals)
            } else {
                false
            }
        },
        IrIfExpr => if_node_can_emit_with_locals(program, function_value, nodes, node, ret, locals),
        IrLoopExpr => loop_node_can_emit_value_with_type(program, function_value, nodes, node, locals, ret, loop_node_value_type_name(program, function_value, nodes, node, locals)),
        IrMatchExpr => if direct_result_match_node_can_emit_result_return(program, function_value, nodes, node, ret, locals) {
            true
        } else if result_match_node_can_emit_return(program, function_value, nodes, node, ret, locals) {
            true
        } else if option_vec_get_match_node_can_emit_return(program, function_value, nodes, node, ret, locals) {
            true
        } else if option_match_node_can_emit_return(program, function_value, nodes, node, ret, locals) {
            true
        } else if result_bool_match_node_can_emit_return(program, function_value, nodes, node, ret, locals) {
            true
        } else if fs_string_match_node_can_emit_int_return(program, function_value, nodes, node, ret, locals) {
            true
        } else if proc_run_match_node_can_emit_int_return(program, function_value, nodes, node, ret, locals) {
            true
        } else if direct_result_match_node_can_emit_return(program, function_value, nodes, node, ret, locals) {
            true
        } else if ret == "%aic.String" && result_string_match_node_can_emit(program, function_value, nodes, node, locals) {
            true
        } else if enum_bool_match_node_can_emit_return(program, function_value, nodes, node, ret, locals) {
            true
        } else {
            ret == "i1" && enum_bool_match_node_can_emit(program, function_value, nodes, node, locals)
        },
        IrStructLiteralExpr => struct_literal_node_can_emit(program, function_value, nodes, node, locals, ret),
        _ => false,
    }
}

fn return_node_can_emit(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], node: IrExprNode, ret: String) -> Bool {
    return_node_can_emit_with_locals(program, function_value, nodes, node, ret, backend_param_locals(program, function_value))
}

fn if_expr_can_emit_with_locals(program: IrProgram, value: IrExpr, function_value: IrFunctionDef, locals: BackendLocals) -> Bool {
    let ret = llvm_type_for_id(program, function_value.return_type);
    if value.direct_child_count != 3 {
        false
    } else {
        match direct_expr_child_at(value.nodes, 0) {
            Some(condition) => match direct_expr_child_at(value.nodes, 1) {
                Some(then_block) => match direct_expr_child_at(value.nodes, 2) {
                    Some(else_block) => if bool_node_can_emit_with_locals(program, function_value, value.nodes, condition, locals)
                        && branch_node_can_emit_with_locals(program, function_value, value.nodes, then_block, ret, locals)
                        && branch_node_can_emit_with_locals(program, function_value, value.nodes, else_block, ret, locals) {
                        true
                    } else {
                        base_type_name_text(function_result_type_name(program, function_value)) == "Result" && bool_node_can_emit_with_locals(program, function_value, value.nodes, condition, locals)
                    },
                    None => false,
                },
                None => false,
            },
            None => false,
        }
    }
}

fn if_expr_can_emit(program: IrProgram, value: IrExpr, function_value: IrFunctionDef) -> Bool {
    if_expr_can_emit_with_locals(program, value, function_value, backend_empty_locals())
}

fn if_expr_value_can_emit_with_locals(program: IrProgram, value: IrExpr, function_value: IrFunctionDef, locals: BackendLocals) -> Bool {
