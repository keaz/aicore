fn emit_enum_match_check_prefix(prefix: String, index: Int) -> String {
    concat2(prefix, concat2(".check.", string.int_to_string(index)))
}

fn emit_enum_match_arm_prefix(prefix: String, index: Int) -> String {
    concat2(prefix, concat2(".arm.", string.int_to_string(index)))
}

