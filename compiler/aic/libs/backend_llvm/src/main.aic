}

fn if_node_value_can_emit_with_expected(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], node: IrExprNode, locals: BackendLocals, expected: String) -> Bool {
    if_node_value_can_emit_with_expected_type(program, function_value, nodes, node, locals, expected, branch_expected_type_name(program, function_value, expected))
}

fn if_node_value_can_emit_with_expected_type(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], node: IrExprNode, locals: BackendLocals, expected: String, expected_type_name: String) -> Bool {
    if node.direct_child_count != 3 || expected == "" || expected == "void" {
        false
    } else {
        match expr_node_child_at(nodes, node, 0) {
            Some(condition) => match expr_node_child_at(nodes, node, 1) {
                Some(then_block) => match expr_node_child_at(nodes, node, 2) {
                    Some(else_block) => bool_node_can_emit_with_locals(program, function_value, nodes, condition, locals)
                        && branch_value_node_can_emit_with_expected_type(program, function_value, nodes, then_block, expected, expected_type_name, locals)
                        && branch_value_node_can_emit_with_expected_type(program, function_value, nodes, else_block, expected, expected_type_name, locals),
                    None => false,
                },
                None => false,
            },
            None => false,
        }
    }
}

fn static_match_body(value: IrExpr) -> String {
    let matched = match direct_expr_child_at(value.nodes, 0) {
        Some(node) => node.text,
        None => "",
    };
    let mut index = 0;
    let mut out = "";
    while out == "" && index < vec.vec_len(value.match_arms) {
        match vec.get(value.match_arms, index) {
            Some(arm) => if arm.pattern_text == matched || arm.pattern_text == "_" {
                out = arm.body_text;
            } else {
                ()
            },
            None => (),
        };
        index = index + 1;
    };
    out
}

fn match_expr_can_emit(value: IrExpr) -> Bool {
    let selected = static_match_body(value);
    let mut arms_ok = vec.vec_len(value.match_arms) > 0 && selected != "";
    let mut index = 0;
    while arms_ok && index < vec.vec_len(value.match_arms) {
        match vec.get(value.match_arms, index) {
            Some(arm) => if is_decimal_integer_text(arm.body_text) || arm.body_text == "true" || arm.body_text == "false" {
                ()
            } else {
                arms_ok = false;
            },
            None => (),
        };
        index = index + 1;
    };
    arms_ok
}

fn bool_literal_text_can_emit(value: String) -> Bool {
    value == "true" || value == "false"
}

fn bool_literal_llvm_value(value: String) -> String {
    if value == "true" { "1" } else { "0" }
}

fn enum_bool_match_arm_can_emit(program: IrProgram, parent_name: String, arm: IrMatchArm) -> Bool {
    bool_literal_text_can_emit(arm.body_text)
        && (arm.pattern_text == "_" || base_type_name_text(enum_variant_parent_name(program, match_arm_variant_text(arm.pattern_text))) == base_type_name_text(parent_name))
}

fn enum_bool_match_expr_can_emit(program: IrProgram, value: IrExpr, function_value: IrFunctionDef, locals: BackendLocals) -> Bool {
    if value.direct_child_count < 1 || vec.vec_len(value.match_arms) == 0 {
        false
    } else {
        match direct_expr_child_at(value.nodes, 0) {
            Some(scrutinee) => if value_node_can_emit(program, function_value, value.nodes, scrutinee, locals) {
                let parent_name = node_type_name(program, function_value, value.nodes, scrutinee, locals);
                if !enum_parent_is_known(program, parent_name) || value_node_llvm_type(program, function_value, value.nodes, scrutinee, locals) != llvm_type_for_repr_in_program(program, parent_name) {
                    false
                } else {
                    let mut index = 0;
                    let mut ok = true;
                    while ok && index < vec.vec_len(value.match_arms) {
                        match vec.get(value.match_arms, index) {
                            Some(arm) => if enum_bool_match_arm_can_emit(program, parent_name, arm) {
                                ()
                            } else {
                                ok = false;
                            },
                            None => if true {
                                ok = false;
                                ()
                            } else { () },
                        };
                        index = index + 1;
                    };
                    ok
                }
            } else {
                false
            },
            None => false,
        }
    }
}

fn enum_bool_match_node_can_emit(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], node: IrExprNode, locals: BackendLocals) -> Bool {
    if node.direct_child_count < 1 || vec.vec_len(node.match_arms) == 0 {
        false
    } else {
        match expr_node_child_at(nodes, node, 0) {
            Some(scrutinee) => if value_node_can_emit(program, function_value, nodes, scrutinee, locals) {
                let parent_name = node_type_name(program, function_value, nodes, scrutinee, locals);
                if !enum_parent_is_known(program, parent_name) || value_node_llvm_type(program, function_value, nodes, scrutinee, locals) != llvm_type_for_repr_in_program(program, parent_name) {
                    false
                } else {
                    let mut index = 0;
                    let mut ok = true;
                    while ok && index < vec.vec_len(node.match_arms) {
                        match vec.get(node.match_arms, index) {
                            Some(arm) => if enum_bool_match_arm_can_emit(program, parent_name, arm) {
                                ()
                            } else {
                                ok = false;
                            },
                            None => if true {
                                ok = false;
                                ()
                            } else { () },
                        };
                        index = index + 1;
                    };
                    ok
                }
            } else {
                false
            },
            None => false,
        }
    }
}

fn enum_match_expr_type_name(program: IrProgram, value: IrExpr, function_value: IrFunctionDef, locals: BackendLocals) -> String {
    let explicit = optional_type_name_for_id(program.types, value.type_id);
    if explicit != "" {
        explicit
    } else if value.direct_child_count < 1 + vec.vec_len(value.match_arms) || vec.vec_len(value.match_arms) == 0 {
        ""
    } else {
        match direct_expr_child_at(value.nodes, 0) {
            Some(scrutinee) => if true {
                let parent_name = node_type_name(program, function_value, value.nodes, scrutinee, locals);
                if !enum_parent_is_known(program, parent_name) || value_node_llvm_type(program, function_value, value.nodes, scrutinee, locals) != llvm_type_for_repr_in_program(program, parent_name) {
                    ""
                } else {
                    let mut index = 0;
                    let mut out = "";
                    let mut ok = true;
                    while ok && index < vec.vec_len(value.match_arms) {
                        match vec.get(value.match_arms, index) {
                            Some(arm) => match direct_expr_child_at(value.nodes, index + 1) {
                                Some(body) => if enum_match_arm_pattern_can_emit_return(program, parent_name, arm) {
                                    let arm_locals = enum_match_arm_locals(program, parent_name, arm, locals, enum_match_arm_payload_value_name(llvm_expr_prefix(value.node), index));
                                    let body_type = branch_value_node_type_name_with_locals(program, function_value, value.nodes, body, arm_locals);
                                    if body_type == "" {
                                        ok = false;
                                    } else if out == "" {
                                        out = body_type;
                                    } else if out == body_type {
                                        ()
                                    } else {
                                        ok = false;
                                    };
                                    ()
                                } else {
                                    ok = false;
                                },
                                None => if true {
                                    ok = false;
                                    ()
                                } else { () },
                            },
                            None => if true {
                                ok = false;
                                ()
                            } else { () },
                        };
                        index = index + 1;
                    };
                    if ok { out } else { "" }
                }
            } else { "" },
            None => "",
        }
    }
}

fn enum_match_node_type_name(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], node: IrExprNode, locals: BackendLocals) -> String {
    let explicit = optional_type_name_for_id(program.types, node.type_id);
    if explicit != "" {
        explicit
    } else if node.direct_child_count < 1 + vec.vec_len(node.match_arms) || vec.vec_len(node.match_arms) == 0 {
        ""
    } else {
        match expr_node_child_at(nodes, node, 0) {
            Some(scrutinee) => if true {
                let parent_name = node_type_name(program, function_value, nodes, scrutinee, locals);
                if !enum_parent_is_known(program, parent_name) || value_node_llvm_type(program, function_value, nodes, scrutinee, locals) != llvm_type_for_repr_in_program(program, parent_name) {
                    ""
                } else {
                    let mut index = 0;
                    let mut out = "";
                    let mut ok = true;
                    while ok && index < vec.vec_len(node.match_arms) {
                        match vec.get(node.match_arms, index) {
                            Some(arm) => match expr_node_child_at(nodes, node, index + 1) {
                                Some(body) => if enum_match_arm_pattern_can_emit_return(program, parent_name, arm) {
                                    let arm_locals = enum_match_arm_locals(program, parent_name, arm, locals, enum_match_arm_payload_value_name(llvm_node_prefix(node.node), index));
                                    let body_type = branch_value_node_type_name_with_locals(program, function_value, nodes, body, arm_locals);
                                    if body_type == "" {
                                        ok = false;
                                    } else if out == "" {
                                        out = body_type;
                                    } else if out == body_type {
                                        ()
                                    } else {
                                        ok = false;
                                    };
                                    ()
                                } else {
                                    ok = false;
                                },
                                None => if true {
                                    ok = false;
                                    ()
                                } else { () },
                            },
                            None => if true {
                                ok = false;
                                ()
                            } else { () },
                        };
                        index = index + 1;
                    };
                    if ok { out } else { "" }
                }
            } else { "" },
            None => "",
        }
    }
}

fn enum_match_expr_llvm_type(program: IrProgram, value: IrExpr, function_value: IrFunctionDef, locals: BackendLocals) -> String {
    llvm_type_for_repr_in_program(program, enum_match_expr_type_name(program, value, function_value, locals))
}

fn enum_match_node_llvm_type(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], node: IrExprNode, locals: BackendLocals) -> String {
    llvm_type_for_repr_in_program(program, enum_match_node_type_name(program, function_value, nodes, node, locals))
}

