    if base_type_name_text(expected_type_name) == "Option" {
        emit_expected_option_constructor_expr_value(program, function_value, value, locals, expected, expected_type_name)
    } else if base_type_name_text(expected_type_name) == "Result" {
        emit_expected_result_constructor_expr_value(program, function_value, value, locals, expected, expected_type_name)
    } else {
        ""
    }
}

fn struct_literal_child_value_name(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], child: IrExprNode, locals: BackendLocals, expected: String, expected_type_name: String) -> String {
    if expected == "%aic.String" {
        string_node_value_name_with_locals(function_value, locals, child)
    } else if expected_vec_new_vec_node_can_emit(child, expected) {
        llvm_node_value_local(child)
    } else if expected_enum_constructor_node_can_emit(program, function_value, nodes, child, locals, expected_type_name) {
        expected_enum_constructor_node_value_name(child)
    } else if node_is_if_expr(child) || node_is_match_expr(child) {
        llvm_node_value_local(child)
    } else {
        node_value_name(program, function_value, nodes, child, locals)
    }
}

fn emit_struct_literal_child_value(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], child: IrExprNode, locals: BackendLocals, expected: String, expected_type_name: String) -> String {
    if expected == "%aic.String" {
        emit_string_node_value(program, function_value, nodes, child, locals)
    } else if expected_vec_new_vec_node_can_emit(child, expected) {
        emit_empty_vec_value(llvm_node_prefix(child.node), expected)
    } else if expected_enum_constructor_node_can_emit(program, function_value, nodes, child, locals, expected_type_name) {
        emit_expected_enum_constructor_node_value(program, function_value, nodes, child, locals, expected, expected_type_name)
    } else if node_is_if_expr(child) {
        emit_if_node_value_with_expected_type(program, function_value, nodes, child, locals, expected, expected_type_name)
    } else if node_is_match_expr(child) && direct_option_match_node_can_emit_expected_path(nodes, child) {
        emit_option_match_node_value_expected(program, function_value, nodes, child, locals, expected, expected_type_name)
    } else {
        emit_value_node(program, function_value, nodes, child, locals)
    }
}

fn emit_struct_literal_node_value(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], node: IrExprNode, locals: BackendLocals, ret: String) -> String {
    let prefix = llvm_node_prefix(node.node);
    let mut parts: Vec[String] = vec.new_vec();
    let mut index = 0;
    while index < node.direct_child_count {
        match expr_node_child_at(nodes, node, index) {
                Some(child) => if true {
                    let field_ty = struct_field_llvm_type_by_index(program, node.name, index);
                    let field_type_name = struct_field_type_name_by_index(program, node.name, index);
                    let previous = if index == 0 {
                        "undef"
                    } else {
                        struct_literal_field_local(prefix, index - 1)
                    };
                parts = vec.push(parts, emit_struct_literal_child_value(program, function_value, nodes, child, locals, field_ty, field_type_name));
                parts = vec.push(parts, "  ");
                parts = vec.push(parts, struct_literal_field_local(prefix, index));
                parts = vec.push(parts, " = insertvalue ");
                parts = vec.push(parts, ret);
                parts = vec.push(parts, " ");
                parts = vec.push(parts, previous);
                parts = vec.push(parts, ", ");
                parts = vec.push(parts, field_ty);
                parts = vec.push(parts, " ");
                parts = vec.push(parts, struct_literal_child_value_name(program, function_value, nodes, child, locals, field_ty, field_type_name));
                parts = vec.push(parts, ", ");
                parts = vec.push(parts, string.int_to_string(index));
                parts = vec.push(parts, "\n");
                ()
            } else { () },
            None => (),
        };
        index = index + 1;
    };
    string.join(parts, "")
}

fn emit_struct_literal_expr_value(program: IrProgram, function_value: IrFunctionDef, expr: IrExpr, locals: BackendLocals, ret: String) -> String {
    let prefix = llvm_expr_prefix(expr.node);
    let mut parts: Vec[String] = vec.new_vec();
    let mut index = 0;
    while index < direct_expr_child_count(expr.nodes) {
        match direct_expr_child_at(expr.nodes, index) {
                Some(child) => if true {
                    let field_ty = struct_field_llvm_type_by_index(program, expr.name, index);
                    let field_type_name = struct_field_type_name_by_index(program, expr.name, index);
                    let previous = if index == 0 {
                        "undef"
                    } else {
                        struct_literal_field_local(prefix, index - 1)
                    };
                parts = vec.push(parts, emit_struct_literal_child_value(program, function_value, expr.nodes, child, locals, field_ty, field_type_name));
                parts = vec.push(parts, "  ");
                parts = vec.push(parts, struct_literal_field_local(prefix, index));
                parts = vec.push(parts, " = insertvalue ");
                parts = vec.push(parts, ret);
                parts = vec.push(parts, " ");
                parts = vec.push(parts, previous);
                parts = vec.push(parts, ", ");
                parts = vec.push(parts, field_ty);
                parts = vec.push(parts, " ");
                parts = vec.push(parts, struct_literal_child_value_name(program, function_value, expr.nodes, child, locals, field_ty, field_type_name));
                parts = vec.push(parts, ", ");
                parts = vec.push(parts, string.int_to_string(index));
                parts = vec.push(parts, "\n");
                ()
            } else { () },
            None => (),
        };
        index = index + 1;
    };
    string.join(parts, "")
}

fn emit_void_call_expr_statement(program: IrProgram, function_value: IrFunctionDef, expr: IrExpr, locals: BackendLocals) -> String {
    let mut parts: Vec[String] = vec.new_vec();
    parts = vec.push(parts, emit_call_arg_values(program, function_value, expr.nodes, expr.name, locals));
    parts = vec.push(parts, "  call void @");
    parts = vec.push(parts, backend_mangle_symbol(expr.name));
    parts = vec.push(parts, "(");
    parts = vec.push(parts, emit_call_args(program, function_value, expr.nodes, expr.name, locals));
    parts = vec.push(parts, ")\n");
    string.join(parts, "")
}

fn emit_void_call_node_statement(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], node: IrExprNode, locals: BackendLocals) -> String {
    let mut parts: Vec[String] = vec.new_vec();
    parts = vec.push(parts, emit_node_call_arg_values(program, function_value, nodes, node, locals));
    parts = vec.push(parts, "  call void @");
    parts = vec.push(parts, backend_mangle_symbol(node.name));
    parts = vec.push(parts, "(");
    parts = vec.push(parts, emit_node_call_args(program, function_value, nodes, node, locals));
    parts = vec.push(parts, ")\n");
    string.join(parts, "")
}

fn emit_discard_fs_bool_node_statement(program: IrProgram, function_value: IrFunctionDef, nodes: Vec[IrExprNode], node: IrExprNode, locals: BackendLocals) -> String {
    match expr_node_child_at(nodes, node, 0) {
        Some(path_child) => if true {
            let prefix = llvm_node_prefix(node.node);
            let path_name = string_node_value_name_with_locals(function_value, locals, path_child);
            let path_prefix = concat2(prefix, ".path");
            let mut parts: Vec[String] = vec.new_vec();
            parts = vec.push(parts, emit_string_node_value(program, function_value, nodes, path_child, locals));
            parts = vec.push(parts, emit_string_extracts(path_name, path_prefix));
            if node.name == "write_text" {
                match expr_node_child_at(nodes, node, 1) {
                    Some(content_child) => if true {
                        let content_name = string_node_value_name_with_locals(function_value, locals, content_child);
                        let content_prefix = concat2(prefix, ".content");
                        parts = vec.push(parts, emit_string_node_value(program, function_value, nodes, content_child, locals));
                        parts = vec.push(parts, emit_string_extracts(content_name, content_prefix));
                        parts = vec.push(parts, "  ");
                        parts = vec.push(parts, llvm_local(prefix, ".discard.rc"));
                        parts = vec.push(parts, " = call i64 ");
                        parts = vec.push(parts, fs_bool_runtime_name(node.name));
                        parts = vec.push(parts, "(i8* ");
                        parts = vec.push(parts, llvm_local(path_prefix, ".ptr"));
                        parts = vec.push(parts, ", i64 ");
                        parts = vec.push(parts, llvm_local(path_prefix, ".len"));
                        parts = vec.push(parts, ", i64 ");
                        parts = vec.push(parts, llvm_local(path_prefix, ".cap"));
                        parts = vec.push(parts, ", i8* ");
                        parts = vec.push(parts, llvm_local(content_prefix, ".ptr"));
                        parts = vec.push(parts, ", i64 ");
                        parts = vec.push(parts, llvm_local(content_prefix, ".len"));
                        parts = vec.push(parts, ", i64 ");
                        parts = vec.push(parts, llvm_local(content_prefix, ".cap"));
                        parts = vec.push(parts, ")\n");
                        ()
                    } else { () },
                    None => (),
                };
            } else {
                parts = vec.push(parts, "  ");
                parts = vec.push(parts, llvm_local(prefix, ".discard.rc"));
                parts = vec.push(parts, " = call i64 ");
                parts = vec.push(parts, fs_bool_runtime_name(node.name));
                parts = vec.push(parts, "(i8* ");
                parts = vec.push(parts, llvm_local(path_prefix, ".ptr"));
                parts = vec.push(parts, ", i64 ");
                parts = vec.push(parts, llvm_local(path_prefix, ".len"));
                parts = vec.push(parts, ", i64 ");
                parts = vec.push(parts, llvm_local(path_prefix, ".cap"));
                parts = vec.push(parts, ")\n");
            };
            string.join(parts, "")
        } else { "" },
        None => "",
    }
}

