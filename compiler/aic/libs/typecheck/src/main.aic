fn field_name_exists(names: Vec[String], name: String) -> Bool {
    let mut found = false;
    let mut index = 0;
    while !found && index < vec.vec_len(names) {
        match vec.get(names, index) {
            Some(existing) => if existing == name {
                found = true;
            } else {
                ()
            },
            None => (),
        };
        index = index + 1;
    };
    found
}

fn struct_field_type(item: AstStructDecl, receiver_type: String, name: String) -> String {
    let struct_args = generic_arg_texts(receiver_type);
    let mut map = empty_generic_map();
    let mut gen_index = 0;
    while gen_index < vec.vec_len(item.generic_params.params) {
        match vec.get(item.generic_params.params, gen_index) {
            Some(param) => match vec.get(struct_args, gen_index) {
                Some(value) => if true {
                    map = add_or_update_generic(map, param.name.value, value);
                    ()
                } else {
                    ()
                },
                None => (),
            },
            None => (),
        };
        gen_index = gen_index + 1;
    };
    let mut out = "<unknown>";
    let mut found = false;
    let mut index = 0;
    while !found && index < vec.vec_len(item.fields) {
        match vec.get(item.fields, index) {
            Some(field) => if field.name.value == name {
                out = instantiate_type_text(type_text(field.type_ref), map);
                found = true;
            } else {
                ()
            },
            None => (),
        };
        index = index + 1;
    };
    out
}

fn has_trait_impl(semantics: SemanticOutput, trait_name: String, type_name_value: String) -> Bool {
    let mut found = false;
    let mut index = 0;
    while !found && index < vec.vec_len(semantics.impls) {
        match vec.get(semantics.impls, index) {
            Some(item) => if item.trait_name == trait_name && item.target_type == type_name_value && !item.conflicting {
                found = true;
            } else {
                ()
            },
            None => (),
        };
        index = index + 1;
    };
    found
}

fn generic_param_bound_count(params: AstGenericParamList, generic_name: String) -> Int {
    let mut out = 0;
    let mut found = false;
    let mut index = 0;
    while !found && index < vec.vec_len(params.params) {
        match vec.get(params.params, index) {
            Some(param) => if param.name.value == generic_name {
                out = vec.vec_len(param.bounds);
                found = true;
            } else {
                ()
            },
            None => (),
        };
        index = index + 1;
    };
    out
}

fn check_generic_bounds(env: TypecheckEnv, params: AstGenericParamList, semantics: SemanticOutput, max_errors: Int, span_value: SourceSpan) -> TypecheckEnv {
    let mut out = env;
    let mut index = 0;
    while index < vec.vec_len(params.params) {
        match vec.get(params.params, index) {
            Some(param) => match generic_value(out.generic_map, param.name.value) {
                Some(actual) => if true {
                    let mut bound_index = 0;
                    while bound_index < vec.vec_len(param.bounds) {
                        match vec.get(param.bounds, bound_index) {
                            Some(bound) => if has_trait_impl(semantics, bound.value, actual) {
                                ()
                            } else {
                                let mut parts: Vec[String] = vec.new_vec();
                                parts = vec.push(parts, "type '");
                                parts = vec.push(parts, actual);
                                parts = vec.push(parts, "' does not satisfy trait bound '");
                                parts = vec.push(parts, bound.value);
                                parts = vec.push(parts, "'");
                                out = env_error(out, max_errors, "E1258", span_value, string.join(parts, ""), "add a matching trait impl or choose a type that satisfies the bound");
                            },
                            None => (),
                        };
                        bound_index = bound_index + 1;
                    };
                    ()
                } else {
                    ()
                },
                None => (),
            },
            None => (),
        };
        index = index + 1;
    };
    out
}

fn infer_expr(expr: AstExpr, env: TypecheckEnv, units: Vec[ResolveUnit], resolver: ResolverOutput, semantics: SemanticOutput, max_errors: Int, expected: String) -> ExprCheck {
    match expr.kind {
        AstIntExpr => infer_int_literal(expr, env, max_errors, expected),
        AstFloatExpr => infer_float_literal(expr, env, expected),
        AstBoolExpr => expr_check(env, "Bool"),
        AstStringExpr => expr_check(env, "String"),
        AstTemplateExpr => expr_check(env, "String"),
        AstCharExpr => expr_check(env, "Char"),
        AstUnitExpr => expr_check(env, "()"),
        AstNameExpr => infer_name_expr(expr, env, units, resolver, max_errors),
        AstCallExpr => infer_call_expr(expr, env, units, resolver, semantics, max_errors, expected),
        AstStructLiteralExpr => infer_struct_literal(expr, env, units, resolver, semantics, max_errors),
        AstFieldAccessExpr => infer_field_access(expr, env, units, resolver, semantics, max_errors),
        AstBinaryExpr => infer_binary_expr(expr, env, units, resolver, semantics, max_errors),
        AstUnaryExpr => infer_unary_expr(expr, env, units, resolver, semantics, max_errors),
        AstTupleExpr => expr_check(infer_all_children(expr, env, units, resolver, semantics, max_errors).env, "Tuple"),
        AstBlockExpr => expr_check(env, "()"),
        AstIfExpr => infer_if_expr(expr, env, units, resolver, semantics, max_errors, expected),
        AstWhileExpr => infer_while_expr(expr, env, units, resolver, semantics, max_errors),
        AstForExpr => infer_for_expr(expr, env, units, resolver, semantics, max_errors),
        AstLoopExpr => expr_check(env, "()"),
        AstBreakExpr => infer_break_expr(expr, env, units, resolver, semantics, max_errors),
        AstContinueExpr => if env.in_loop {
            expr_check(env, "()")
        } else {
            expr_check(env_error(env, max_errors, "E1276", expr.span, "continue outside loop", "move continue into a loop body"), "()")
        },
        AstMatchExpr => infer_match_expr(expr, env, units, resolver, semantics, max_errors, expected),
        AstBorrowExpr => infer_first_child_or_unknown(expr, env, units, resolver, semantics, max_errors),
        AstAwaitExpr => infer_first_child_or_unknown(expr, env, units, resolver, semantics, max_errors),
        AstTryExpr => infer_try_expr(expr, env, units, resolver, semantics, max_errors),
        AstClosureExpr => expr_check(env, "Fn"),
    }
}

fn infer_all_children(expr: AstExpr, env: TypecheckEnv, units: Vec[ResolveUnit], resolver: ResolverOutput, semantics: SemanticOutput, max_errors: Int) -> ExprCheck {
    let mut out_env = env;
    let mut index = 0;
    while index < expr.direct_child_count {
        match direct_expr_at(expr, index) {
            Some(child_expr) => if true {
                let checked = infer_expr(child_expr, out_env, units, resolver, semantics, max_errors, "<unknown>");
                out_env = checked.env;
                ()
            } else {
                ()
            },
            None => (),
        };
        index = index + 1;
    };
    expr_check(out_env, "<unknown>")
}

fn infer_first_child_or_unknown(expr: AstExpr, env: TypecheckEnv, units: Vec[ResolveUnit], resolver: ResolverOutput, semantics: SemanticOutput, max_errors: Int) -> ExprCheck {
    match direct_expr_at(expr, 0) {
        Some(child_expr) => infer_expr(child_expr, env, units, resolver, semantics, max_errors, "<unknown>"),
        None => expr_check(env, "<unknown>"),
    }
}

fn infer_int_literal(expr: AstExpr, env: TypecheckEnv, max_errors: Int, expected: String) -> ExprCheck {
    let out_type = if is_integer_type(expected) { expected } else { "Int" };
    let out_env = if literal_exceeds_small_width(expr.name, out_type) {
        let mut parts: Vec[String] = vec.new_vec();
        parts = vec.push(parts, "integer literal '");
        parts = vec.push(parts, expr.name);
        parts = vec.push(parts, "' is outside the range of '");
        parts = vec.push(parts, out_type);
        parts = vec.push(parts, "'");
        env_error(env, max_errors, "E1204", expr.span, string.join(parts, ""), "choose a wider integer type or reduce the literal value")
    } else {
        env
    };
    expr_check(out_env, out_type)
}

fn literal_exceeds_small_width(literal: String, ty: String) -> Bool {
    if ty == "Int8" || ty == "UInt8" {
        string.len(literal) > 3
    } else if ty == "Int16" || ty == "UInt16" {
        string.len(literal) > 5
    } else {
        false
    }
}

fn infer_float_literal(expr: AstExpr, env: TypecheckEnv, expected: String) -> ExprCheck {
    if is_float_type(expected) {
        expr_check(env, expected)
    } else {
        expr_check(env, "Float64")
    }
}

fn infer_name_expr(expr: AstExpr, env: TypecheckEnv, units: Vec[ResolveUnit], resolver: ResolverOutput, max_errors: Int) -> ExprCheck {
    match find_binding(env.bindings, expr.name) {
        Some(binding) => expr_check(env, binding.type_text),
        None => match lookup_value_symbol(units, resolver, env.module_path, expr.name, ResolverConstSymbol(), ResolverValueNamespace()) {
            Some(symbol) => expr_check(env, symbol.type_name),
            None => match lookup_value_symbol(units, resolver, env.module_path, expr.name, ResolverFunctionSymbol(), ResolverValueNamespace()) {
                Some(symbol) => expr_check(env, symbol.type_name),
                None => match lookup_value_symbol(units, resolver, env.module_path, expr.name, ResolverVariantSymbol(), ResolverMemberNamespace()) {
                    Some(symbol) => expr_check(env, symbol.type_name),
                    None => if expr.name == "None" {
                        expr_check(env, "Option")
                    } else {
                        let mut parts: Vec[String] = vec.new_vec();
                        parts = vec.push(parts, "unknown symbol '");
                        parts = vec.push(parts, expr.name);
                        parts = vec.push(parts, "'");
                        expr_check(env_error(env, max_errors, "E1208", expr.span, string.join(parts, ""), "declare or import the symbol before use"), "<unknown>")
                    },
                },
            },
        },
    }
}

fn infer_call_expr(expr: AstExpr, env: TypecheckEnv, units: Vec[ResolveUnit], resolver: ResolverOutput, semantics: SemanticOutput, max_errors: Int, expected: String) -> ExprCheck {
    if expr.name == "Some" {
        infer_builtin_variant(expr, env, units, resolver, semantics, max_errors, expected, "Option", "Some", 1)
    } else if expr.name == "None" {
        infer_builtin_variant(expr, env, units, resolver, semantics, max_errors, expected, "Option", "None", 0)
    } else if expr.name == "Ok" {
        infer_builtin_variant(expr, env, units, resolver, semantics, max_errors, expected, "Result", "Ok", 1)
    } else if expr.name == "Err" {
        infer_builtin_variant(expr, env, units, resolver, semantics, max_errors, expected, "Result", "Err", 1)
    } else if string.contains(expr.name, ".") {
        infer_member_call(expr, env, units, resolver, semantics, max_errors)
    } else {
        match lookup_value_symbol(units, resolver, env.module_path, expr.name, ResolverFunctionSymbol(), ResolverValueNamespace()) {
            Some(symbol) => match find_function_signature(units, symbol.module_path, symbol.name) {
                Some(signature) => check_function_call(expr, env, units, resolver, semantics, max_errors, signature, symbol.module_path, symbol.name),
                None => expr_check(env, symbol.type_name),
            },
            None => match lookup_value_symbol(units, resolver, env.module_path, expr.name, ResolverVariantSymbol(), ResolverMemberNamespace()) {
                Some(symbol) => check_declared_variant_call(expr, env, units, resolver, semantics, max_errors, symbol),
                None => infer_name_expr(simple_expr(AstNameExpr(), "", expr.name, expr.span, expr.name), env, units, resolver, max_errors),
            },
        }
    }
}

fn infer_builtin_variant(expr: AstExpr, env: TypecheckEnv, units: Vec[ResolveUnit], resolver: ResolverOutput, semantics: SemanticOutput, max_errors: Int, expected: String, type_name_value: String, variant_name: String, expected_args: Int) -> ExprCheck {
    let mut out_env = env;
    if call_arg_count(expr) != expected_args {
        let mut parts: Vec[String] = vec.new_vec();
        parts = vec.push(parts, "variant '");
        parts = vec.push(parts, variant_name);
        parts = vec.push(parts, "' expects a different argument count");
        out_env = env_error(out_env, max_errors, "E1215", expr.span, string.join(parts, ""), "adjust the number of variant arguments");
    } else {
        let mut index = 0;
        while index < call_arg_count(expr) {
            match call_arg_expr(expr, index) {
                Some(arg_expr) => if true {
                    let checked = infer_expr(arg_expr, out_env, units, resolver, semantics, max_errors, "<unknown>");
                    out_env = checked.env;
                    ()
                } else {
                    ()
                },
                None => (),
            };
            index = index + 1;
        };
    };
    if expected != "<unknown>" && string.starts_with(expected, type_name_value) {
        expr_check(out_env, expected)
    } else {
        expr_check(out_env, type_name_value)
    }
}

fn check_function_call(expr: AstExpr, env: TypecheckEnv, units: Vec[ResolveUnit], resolver: ResolverOutput, semantics: SemanticOutput, max_errors: Int, signature: AstFunctionSignature, module_path: String, symbol_name: String) -> ExprCheck {
    let requester_module = env.module_path;
    let mut out_env = env;
    let arg_count = call_arg_count(expr);
    if arg_count != vec.vec_len(signature.params) {
        let mut parts: Vec[String] = vec.new_vec();
        parts = vec.push(parts, "function '");
        parts = vec.push(parts, symbol_name);
        parts = vec.push(parts, "' expects a different argument count");
        out_env = env_error(out_env, max_errors, "E1214", expr.span, string.join(parts, ""), "adjust the number of call arguments");
    } else {
        let mut generic_map_value = empty_generic_map();
        let mut index = 0;
        while index < arg_count {
            match call_arg_node(expr, index) {
                Some(arg_node) => match call_arg_expr(expr, index) {
                    Some(arg_expr) => match vec.get(signature.params, index) {
                    Some(param) => if true {
                        let expected_type = type_text(param.type_ref);
                        let checked = infer_expr(arg_expr, out_env, units, resolver, semantics, max_errors, expected_type);
                        out_env = checked.env;
                        if is_generic_param(signature.generic_params, expected_type) {
                            match generic_value(generic_map_value, expected_type) {
                                Some(existing) => if types_compatible(units, requester_module, existing, checked.type_text) {
                                    ()
                                } else {
                                    let mut parts: Vec[String] = vec.new_vec();
                                    parts = vec.push(parts, "generic argument mismatch for '");
                                    parts = vec.push(parts, expected_type);
                                    parts = vec.push(parts, "': expected '");
                                    parts = vec.push(parts, existing);
                                    parts = vec.push(parts, "', found '");
                                    parts = vec.push(parts, checked.type_text);
                                    parts = vec.push(parts, "'");
                                    out_env = env_error(out_env, max_errors, "E1214", arg_node.span, string.join(parts, ""), "pass values with the same inferred generic type");
                                },
                                None => if true {
                                    generic_map_value = add_or_update_generic(generic_map_value, expected_type, checked.type_text);
                                    ()
                                } else {
                                    ()
                                },
                            };
                        } else if types_compatible(units, requester_module, instantiate_type_text(expected_type, generic_map_value), checked.type_text) {
                            ()
                        } else {
                            let mut parts: Vec[String] = vec.new_vec();
                            parts = vec.push(parts, "argument type mismatch for call to '");
                            parts = vec.push(parts, symbol_name);
                            parts = vec.push(parts, "': expected '");
                            parts = vec.push(parts, instantiate_type_text(expected_type, generic_map_value));
                            parts = vec.push(parts, "', found '");
                            parts = vec.push(parts, checked.type_text);
                            parts = vec.push(parts, "'");
                            out_env = env_error(out_env, max_errors, "E1214", arg_node.span, string.join(parts, ""), "change the argument type or function signature");
                        };
                        let named_arg = role_tail(arg_node.role, "arg:");
                        if named_arg != "" && named_arg != param.name.value {
                            let mut named_parts: Vec[String] = vec.new_vec();
                            named_parts = vec.push(named_parts, "unknown named argument '");
                            named_parts = vec.push(named_parts, named_arg);
                            named_parts = vec.push(named_parts, "' for function '");
                            named_parts = vec.push(named_parts, symbol_name);
                            named_parts = vec.push(named_parts, "'");
                            out_env = env_error(out_env, max_errors, "E1213", arg_node.span, string.join(named_parts, ""), "use a parameter name declared by the function signature");
                        } else {
                            ()
                        };
                        ()
                    } else {
                        ()
                    },
                    None => (),
                    },
                    None => (),
                },
                None => (),
            };
            index = index + 1;
        };
        out_env = typecheck_env(out_env.module_path, out_env.function_name, out_env.return_type, out_env.bindings, generic_map_value, out_env.diagnostics, out_env.instantiations, out_env.in_loop);
        out_env = check_generic_bounds(out_env, signature.generic_params, semantics, max_errors, expr.span);
        if vec.vec_len(generic_map_value.names) > 0 {
            out_env = append_instantiation(out_env, typecheck_instantiation(module_path, symbol_name, "function", generic_map_value.values, expr.span));
        } else {
            ()
        };
    };
    let return_text = instantiate_type_text(type_text(signature.return_type), out_env.generic_map);
    expr_check(out_env, return_text)
}

fn is_generic_param(params: AstGenericParamList, name: String) -> Bool {
    let mut found = false;
    let mut index = 0;
    while !found && index < vec.vec_len(params.params) {
        match vec.get(params.params, index) {
            Some(param) => if param.name.value == name {
                found = true;
            } else {
                ()
            },
            None => (),
        };
        index = index + 1;
    };
    found
}

fn check_declared_variant_call(expr: AstExpr, env: TypecheckEnv, units: Vec[ResolveUnit], resolver: ResolverOutput, semantics: SemanticOutput, max_errors: Int, symbol: ResolvedSymbol) -> ExprCheck {
    match find_enum_variant(units, symbol.name) {
        Some(variant) => if true {
            let expected_args = match variant.payload_type { Some(_) => 1, None => 0 };
            let requester_module = env.module_path;
            let mut out_env = env;
            if call_arg_count(expr) != expected_args {
                out_env = env_error(out_env, max_errors, "E1215", expr.span, "variant argument count mismatch", "adjust the variant constructor arguments");
            } else {
                match variant.payload_type {
                    Some(payload_type) => match call_arg_node(expr, 0) {
                        Some(arg_node) => match call_arg_expr(expr, 0) {
                            Some(arg_expr) => if true {
                            let checked = infer_expr(arg_expr, out_env, units, resolver, semantics, max_errors, type_text(payload_type));
                            out_env = checked.env;
                            if types_compatible(units, requester_module, type_text(payload_type), checked.type_text) {
                                ()
                            } else {
                                out_env = env_error(out_env, max_errors, "E1216", arg_node.span, "variant payload type mismatch", "pass a payload with the declared variant type");
                            };
                            ()
                        } else {
                            ()
                        },
                            None => (),
                        },
                        None => (),
                    },
                    None => (),
                };
            };
            expr_check(out_env, enum_name_for_variant(units, symbol.name))
        } else {
            expr_check(env, symbol.type_name)
        },
        None => expr_check(env, symbol.type_name),
    }
}

fn infer_member_call(expr: AstExpr, env: TypecheckEnv, units: Vec[ResolveUnit], resolver: ResolverOutput, semantics: SemanticOutput, max_errors: Int) -> ExprCheck {
    let receiver_name = path_prefix(expr.name);
    let method_name = path_tail(expr.name);
    let receiver_type = match find_binding(env.bindings, receiver_name) {
        Some(binding) => binding.type_text,
        None => "<unknown>",
    };
    match find_member_symbol(resolver.symbols, receiver_type, method_name, ResolverMethodSymbol()) {
        Some(symbol) => expr_check(env, symbol.type_name),
        None => if receiver_type == "<unknown>" {
            expr_check(env, "<unknown>")
        } else {
            let mut out_type = "<unknown>";
            let mut found = false;
            let mut index = 0;
            while !found && index < vec.vec_len(resolver.symbols) {
                match vec.get(resolver.symbols, index) {
                    Some(symbol) => if same_symbol_kind(symbol.kind, ResolverMethodSymbol()) && symbol.name == method_name {
                        out_type = symbol.type_name;
                        found = true;
                    } else {
                        ()
                    },
                    None => (),
                };
                index = index + 1;
            };
            if found {
                expr_check(env, out_type)
            } else {
                let mut parts: Vec[String] = vec.new_vec();
                parts = vec.push(parts, "unknown method '");
                parts = vec.push(parts, method_name);
                parts = vec.push(parts, "' for type '");
                parts = vec.push(parts, receiver_type);
                parts = vec.push(parts, "'");
                expr_check(env_error(env, max_errors, "E1228", expr.span, string.join(parts, ""), "declare an impl method for the receiver type"), "<unknown>")
            }
        },
    }
}

fn infer_struct_literal(expr: AstExpr, env: TypecheckEnv, units: Vec[ResolveUnit], resolver: ResolverOutput, semantics: SemanticOutput, max_errors: Int) -> ExprCheck {
    match find_struct_decl(units, expr.name) {
        Some(struct_item) => if true {
            let requester_module = env.module_path;
            let mut out_env = env;
            let mut seen: Vec[String] = vec.new_vec();
            let mut index = 0;
            while index < field_value_count(expr) {
                match struct_field_node(expr, index) {
                    Some(node) => match struct_field_expr(expr, index) {
                        Some(field_expr) => if true {
                        let field_name = role_tail(node.role, "field:");
                        if field_name_exists(seen, field_name) {
                            out_env = env_error(out_env, max_errors, "E1254", node.span, "duplicate field in struct literal", "remove the duplicate field initializer");
                        } else {
                            seen = vec.push(seen, field_name);
                        };
                        let expected_type = struct_field_type(struct_item, struct_item.name.value, field_name);
                        if expected_type == "<unknown>" {
                            let mut parts: Vec[String] = vec.new_vec();
                            parts = vec.push(parts, "unknown field '");
                            parts = vec.push(parts, field_name);
                            parts = vec.push(parts, "' for struct '");
                            parts = vec.push(parts, struct_item.name.value);
                            parts = vec.push(parts, "'");
                            out_env = env_error(out_env, max_errors, "E1228", node.span, string.join(parts, ""), "use a field declared by the struct");
                        } else {
                            let checked = infer_expr(field_expr, out_env, units, resolver, semantics, max_errors, expected_type);
                            out_env = checked.env;
                            if types_compatible(units, requester_module, expected_type, checked.type_text) {
                                ()
                            } else {
                                out_env = env_error(out_env, max_errors, "E1204", node.span, "struct field initializer type mismatch", "change the initializer to match the field type");
                            };
                        };
                        ()
                    } else {
                        ()
                    },
                        None => (),
                    },
                    None => (),
                };
                index = index + 1;
            };
            expr_check(out_env, expr.name)
        } else {
            expr_check(env, expr.name)
        },
        None => expr_check(env_error(env, max_errors, "E1208", expr.span, "unknown struct literal type", "declare the struct before constructing it"), "<unknown>"),
    }
}

fn infer_field_access(expr: AstExpr, env: TypecheckEnv, units: Vec[ResolveUnit], resolver: ResolverOutput, semantics: SemanticOutput, max_errors: Int) -> ExprCheck {
    match direct_expr_at(expr, 0) {
        Some(base_expr) => if true {
            let checked = infer_expr(base_expr, env, units, resolver, semantics, max_errors, "<unknown>");
            let base_type = checked.type_text;
            match find_struct_decl(units, nominal_type_name(base_type)) {
                Some(struct_item) => if true {
                    let field_type = struct_field_type(struct_item, base_type, expr.name);
                    if field_type == "<unknown>" {
                        let mut parts: Vec[String] = vec.new_vec();
                        parts = vec.push(parts, "unknown field '");
                        parts = vec.push(parts, expr.name);
                        parts = vec.push(parts, "' for type '");
                        parts = vec.push(parts, base_type);
                        parts = vec.push(parts, "'");
                        expr_check(env_error(checked.env, max_errors, "E1228", expr.span, string.join(parts, ""), "use a field declared by the receiver type"), "<unknown>")
                    } else {
                        expr_check(checked.env, field_type)
                    }
                } else {
                    expr_check(checked.env, "<unknown>")
                },
                None => expr_check(checked.env, "<unknown>"),
            }
        } else {
            expr_check(env, "<unknown>")
        },
        None => expr_check(env, "<unknown>"),
    }
}

fn infer_binary_expr(expr: AstExpr, env: TypecheckEnv, units: Vec[ResolveUnit], resolver: ResolverOutput, semantics: SemanticOutput, max_errors: Int) -> ExprCheck {
    let requester_module = env.module_path;
    let left = match direct_expr_at(expr, 0) { Some(child_expr) => child_expr, None => simple_expr(AstUnitExpr(), "", "", expr.span, "()") };
    let right = match direct_expr_at(expr, 1) { Some(child_expr) => child_expr, None => simple_expr(AstUnitExpr(), "", "", expr.span, "()") };
    let left_checked = infer_expr(left, env, units, resolver, semantics, max_errors, "<unknown>");
    let right_checked = infer_expr(right, left_checked.env, units, resolver, semantics, max_errors, left_checked.type_text);
    let left_type = left_checked.type_text;
    let right_type = right_checked.type_text;
    let left_canonical = canonical_type_text(units, requester_module, left_type);
    let right_canonical = canonical_type_text(units, requester_module, right_type);
    if expr.op == "&&" || expr.op == "||" {
        let out_env = if left_type == "Bool" && right_type == "Bool" {
            right_checked.env
        } else {
            env_error(right_checked.env, max_errors, "E1204", expr.span, "logical operators require Bool operands", "convert both operands to Bool")
        };
        expr_check(out_env, "Bool")
    } else if expr.op == "==" || expr.op == "!=" {
        let out_env = if types_compatible(units, requester_module, left_type, right_type) {
            right_checked.env
        } else {
            env_error(right_checked.env, max_errors, "E1231", expr.span, "equality operands must have matching types", "compare values of the same type")
        };
        expr_check(out_env, "Bool")
    } else if is_ordering_op(expr.op) {
        if types_compatible(units, requester_module, left_type, right_type) && (is_integer_type(left_canonical) || is_float_type(left_canonical) || left_canonical == "Char") && (is_integer_type(right_canonical) || is_float_type(right_canonical) || right_canonical == "Char") {
            expr_check(right_checked.env, "Bool")
        } else {
            expr_check(env_error(right_checked.env, max_errors, "E1232", expr.span, "comparison operators require matching integer, float, or Char operands", "use matching comparable operand types"), "Bool")
        }
    } else if is_arithmetic_op(expr.op) {
        if types_compatible(units, requester_module, left_type, right_type) && (is_integer_type(left_canonical) || is_float_type(left_canonical)) && (is_integer_type(right_canonical) || is_float_type(right_canonical)) {
            expr_check(right_checked.env, left_type)
        } else {
            expr_check(env_error(right_checked.env, max_errors, "E1230", expr.span, "arithmetic operators require matching numeric operand types", "use matching integer or float operand types"), left_type)
        }
    } else {
        expr_check(right_checked.env, left_type)
    }
}

fn is_ordering_op(op: String) -> Bool {
    op == "<" || op == "<=" || op == ">" || op == ">="
}

fn is_arithmetic_op(op: String) -> Bool {
    op == "+" || op == "-" || op == "*" || op == "/" || op == "%" || op == "&" || op == "|" || op == "^" || op == "<<" || op == ">>" || op == ">>>"
}

fn infer_unary_expr(expr: AstExpr, env: TypecheckEnv, units: Vec[ResolveUnit], resolver: ResolverOutput, semantics: SemanticOutput, max_errors: Int) -> ExprCheck {
    let checked = infer_first_child_or_unknown(expr, env, units, resolver, semantics, max_errors);
    if expr.op == "!" && checked.type_text != "Bool" {
        expr_check(env_error(checked.env, max_errors, "E1204", expr.span, "logical not requires Bool operand", "use a Bool expression"), "Bool")
    } else if expr.op == "-" && !is_integer_type(checked.type_text) && !is_float_type(checked.type_text) {
        expr_check(env_error(checked.env, max_errors, "E1204", expr.span, "numeric negation requires numeric operand", "use an integer or float expression"), checked.type_text)
    } else {
        checked
    }
}

fn infer_if_expr(expr: AstExpr, env: TypecheckEnv, units: Vec[ResolveUnit], resolver: ResolverOutput, semantics: SemanticOutput, max_errors: Int, expected: String) -> ExprCheck {
    let cond = match direct_expr_at(expr, 0) { Some(child_expr) => child_expr, None => simple_expr(AstBoolExpr(), "", "true", expr.span, "true") };
    let cond_checked = infer_expr(cond, env, units, resolver, semantics, max_errors, "Bool");
    let mut out_env = if cond_checked.type_text == "Bool" {
        cond_checked.env
    } else {
        env_error(cond_checked.env, max_errors, "E1204", expr.span, "if condition must be Bool", "use a Bool expression as the condition")
    };
    match direct_expr_at(expr, 1) {
        Some(else_expr) => if true {
            let checked_else = infer_expr(else_expr, out_env, units, resolver, semantics, max_errors, expected);
            out_env = checked_else.env;
            expr_check(out_env, checked_else.type_text)
        } else {
            expr_check(out_env, "()")
        },
        None => expr_check(out_env, "()"),
    }
}

fn infer_while_expr(expr: AstExpr, env: TypecheckEnv, units: Vec[ResolveUnit], resolver: ResolverOutput, semantics: SemanticOutput, max_errors: Int) -> ExprCheck {
    match direct_expr_at(expr, 0) {
        Some(cond_expr) => if true {
            let checked = infer_expr(cond_expr, env, units, resolver, semantics, max_errors, "Bool");
            if checked.type_text == "Bool" {
                expr_check(checked.env, "()")
            } else {
                expr_check(env_error(checked.env, max_errors, "E1273", cond_expr.span, "while condition must be Bool", "use a Bool expression as the loop condition"), "()")
            }
        } else {
            expr_check(env, "()")
        },
        None => expr_check(env, "()"),
    }
}

fn infer_for_expr(expr: AstExpr, env: TypecheckEnv, units: Vec[ResolveUnit], resolver: ResolverOutput, semantics: SemanticOutput, max_errors: Int) -> ExprCheck {
    let module_path = env.module_path;
    let function_name = env.function_name;
    let checked = infer_first_child_or_unknown(expr, env, units, resolver, semantics, max_errors);
    let loop_binding = typecheck_binding(module_path, function_name, expr.name, "Int", true, TypecheckLocalValue(), expr.span);
    expr_check(append_binding(checked.env, loop_binding), "()")
}

fn infer_break_expr(expr: AstExpr, env: TypecheckEnv, units: Vec[ResolveUnit], resolver: ResolverOutput, semantics: SemanticOutput, max_errors: Int) -> ExprCheck {
    if !env.in_loop {
        expr_check(env_error(env, max_errors, "E1275", expr.span, "break outside loop", "move break into a loop body"), "()")
    } else {
        infer_first_child_or_unknown(expr, env, units, resolver, semantics, max_errors)
    }
}

fn infer_try_expr(expr: AstExpr, env: TypecheckEnv, units: Vec[ResolveUnit], resolver: ResolverOutput, semantics: SemanticOutput, max_errors: Int) -> ExprCheck {
    let checked = infer_first_child_or_unknown(expr, env, units, resolver, semantics, max_errors);
    let ty = checked.type_text;
    if string.starts_with(ty, "Result[") {
        let args = generic_arg_texts(ty);
        match vec.get(args, 0) {
            Some(ok_type) => expr_check(checked.env, ok_type),
            None => expr_check(checked.env, "<unknown>"),
        }
    } else {
        expr_check(checked.env, "<unknown>")
    }
}

fn infer_match_expr(expr: AstExpr, env: TypecheckEnv, units: Vec[ResolveUnit], resolver: ResolverOutput, semantics: SemanticOutput, max_errors: Int, expected: String) -> ExprCheck {
    let requester_module = env.module_path;
    let scrutinee_expr = match direct_expr_at(expr, 0) { Some(child_expr) => child_expr, None => simple_expr(AstUnitExpr(), "", "", expr.span, "()") };
    let scrutinee = infer_expr(scrutinee_expr, env, units, resolver, semantics, max_errors, "<unknown>");
    let mut out_env = scrutinee.env;
    let mut child_index = 1;
    let mut result_type = expected;
    let mut arm_index = 0;
    while arm_index < vec.vec_len(expr.match_arms) {
        match vec.get(expr.match_arms, arm_index) {
            Some(arm) => if true {
                if arm.guard_text != "" {
                    let mut guard_checked = false;
                    match direct_expr_node_at(expr, child_index) {
                        Some(guard_node) => match direct_expr_at(expr, child_index) {
                            Some(guard_expr) => if true {
                                let guard_check = infer_expr(guard_expr, out_env, units, resolver, semantics, max_errors, "Bool");
                                out_env = guard_check.env;
                                guard_checked = true;
                                if guard_check.type_text == "Bool" {
                                    ()
                                } else {
                                    out_env = env_error(out_env, max_errors, "E1270", guard_node.span, "match guard must be Bool", "use a Bool expression as the guard");
                                };
                                ()
                            } else {
                                ()
                            },
                            None => (),
                        },
                        None => (),
                    };
                    if guard_checked {
                        ()
                    } else {
                        out_env = env_error(out_env, max_errors, "E1270", arm.span, "match guard must be Bool", "use a Bool expression as the guard");
                    };
                    child_index = child_index + 1;
                } else {
                    ()
                };
                match direct_expr_node_at(expr, child_index) {
                    Some(body_node) => match direct_expr_at(expr, child_index) {
                        Some(body_expr) => if true {
                            let body_expected = if result_type == "<unknown>" { expected } else { result_type };
                            let body_check = infer_expr(body_expr, out_env, units, resolver, semantics, max_errors, body_expected);
                            out_env = body_check.env;
                            if result_type == "<unknown>" {
                                result_type = body_check.type_text;
                            } else if types_compatible(units, requester_module, result_type, body_check.type_text) {
                                ()
                            } else {
                                out_env = env_error(out_env, max_errors, "E1204", body_node.span, "match arm body type mismatch", "make all match arms produce the same type");
                            };
                            ()
                        } else {
                            ()
                        },
                        None => (),
                    },
                    None => (),
                };
                child_index = child_index + 1;
                ()
            } else {
                ()
            },
            None => (),
        };
        arm_index = arm_index + 1;
    };
    out_env = check_match_exhaustiveness(expr, out_env, scrutinee.type_text, max_errors);
    expr_check(out_env, result_type)
}

fn check_match_exhaustiveness(expr: AstExpr, env: TypecheckEnv, scrutinee_type: String, max_errors: Int) -> TypecheckEnv {
    let mut out = env;
    if scrutinee_type == "Bool" {
        let mut has_true = false;
        let mut has_false = false;
        let mut has_wildcard = false;
        let mut index = 0;
        while index < vec.vec_len(expr.match_arms) {
            match vec.get(expr.match_arms, index) {
                Some(arm) => if arm.guard_text == "" {
                    if string.contains(arm.pattern_text, "_") {
                        has_wildcard = true;
                    } else if string.contains(arm.pattern_text, "true") {
                        has_true = true;
                    } else if string.contains(arm.pattern_text, "false") {
                        has_false = true;
                    } else {
                        ()
                    }
                } else {
                    ()
                },
                None => (),
            };
            index = index + 1;
        };
        if has_wildcard || (has_true && has_false) {
            out
        } else {
            env_error(out, max_errors, "E1246", expr.span, "non-exhaustive Bool match", "cover both true and false without guarded-only arms")
        }
    } else if string.starts_with(scrutinee_type, "Option") {
        let has_some = match_has_pattern(expr, "Some");
        let has_none = match_has_pattern(expr, "None");
        if has_some && has_none {
            out
        } else {
            env_error(out, max_errors, "E1246", expr.span, "non-exhaustive Option match", "cover Some and None variants")
        }
    } else if string.starts_with(scrutinee_type, "Result") {
        let has_ok = match_has_pattern(expr, "Ok");
        let has_err = match_has_pattern(expr, "Err");
        if has_ok && has_err {
            out
        } else {
            env_error(out, max_errors, "E1248", expr.span, "non-exhaustive Result match", "cover Ok and Err variants")
        }
    } else {
        out
    }
}

fn match_has_pattern(expr: AstExpr, pattern_name: String) -> Bool {
    let mut found = false;
    let mut index = 0;
    while !found && index < vec.vec_len(expr.match_arms) {
        match vec.get(expr.match_arms, index) {
            Some(arm) => if arm.guard_text == "" && string.contains(arm.pattern_text, pattern_name) {
                found = true;
            } else {
                ()
            },
            None => (),
        };
        index = index + 1;
    };
    found
}

fn check_expected_type(env: TypecheckEnv, units: Vec[ResolveUnit], module_path: String, span_value: SourceSpan, context: String, expected: String, found: String, max_errors: Int) -> TypecheckEnv {
    if types_compatible(units, module_path, expected, found) {
        env
    } else {
        let mut parts: Vec[String] = vec.new_vec();
        parts = vec.push(parts, context);
        parts = vec.push(parts, " type mismatch: expected '");
        parts = vec.push(parts, expected);
        parts = vec.push(parts, "', found '");
        parts = vec.push(parts, found);
        parts = vec.push(parts, "'");
        env_error(env, max_errors, "E1204", span_value, string.join(parts, ""), "change the expression or declared type so they match")
    }
}

fn check_statement(statement: AstStatement, env: TypecheckEnv, units: Vec[ResolveUnit], resolver: ResolverOutput, semantics: SemanticOutput, max_errors: Int) -> TypecheckEnv {
    let module_path = env.module_path;
    let function_name = env.function_name;
    let return_type = env.return_type;
    match statement.kind {
        AstLetStatement => match statement.expr {
            Some(expr) => if true {
                let expected = match statement.type_ref { Some(ty) => type_text(ty), None => "<unknown>" };
                let checked = infer_expr(expr, env, units, resolver, semantics, max_errors, expected);
                let mut out_env = checked.env;
                let final_type = if expected == "<unknown>" { checked.type_text } else { expected };
                if expected != "<unknown>" {
                    out_env = check_expected_type(out_env, units, module_path, statement.span, "let binding", expected, checked.type_text, max_errors);
                } else {
                    ()
                };
                out_env = append_binding(out_env, typecheck_binding(module_path, function_name, statement.name, final_type, statement.mutable, TypecheckLocalValue(), statement.span));
                out_env
            } else {
                env
            },
            None => env,
        },
        AstAssignStatement => match statement.expr {
            Some(expr) => match find_binding(env.bindings, statement.target) {
                Some(binding) => if binding.mutable {
                    let checked = infer_expr(expr, env, units, resolver, semantics, max_errors, binding.type_text);
                    check_expected_type(checked.env, units, module_path, statement.span, "assignment", binding.type_text, checked.type_text, max_errors)
                } else {
                    env_error(env, max_errors, "E1266", statement.span, "cannot assign to immutable binding", "declare the binding with `let mut` before assigning")
                },
                None => env_error(env, max_errors, "E1208", statement.span, "unknown assignment target", "assign only to a declared local binding"),
            },
            None => env,
        },
        AstReturnStatement => match statement.expr {
            Some(expr) => if true {
                let checked = infer_expr(expr, env, units, resolver, semantics, max_errors, return_type);
                check_expected_type(checked.env, units, module_path, statement.span, "return", return_type, checked.type_text, max_errors)
            } else {
                env
            },
            None => check_expected_type(env, units, module_path, statement.span, "return", return_type, "()", max_errors),
        },
        AstExprStatement => match statement.expr {
            Some(expr) => infer_expr(expr, env, units, resolver, semantics, max_errors, "<unknown>").env,
            None => env,
        },
    }
}

fn check_block(block: AstBlock, env: TypecheckEnv, units: Vec[ResolveUnit], resolver: ResolverOutput, semantics: SemanticOutput, max_errors: Int) -> TypecheckEnv {
    let module_path = env.module_path;
    let return_type = env.return_type;
    let mut out_env = env;
    let mut index = 0;
    while index < vec.vec_len(block.statements) {
        match vec.get(block.statements, index) {
            Some(statement) => if true {
                out_env = check_statement(statement, out_env, units, resolver, semantics, max_errors);
                ()
            } else {
                ()
            },
            None => (),
        };
        index = index + 1;
    };
    match block.tail_expr {
        Some(expr) => if true {
            let checked = infer_expr(expr, out_env, units, resolver, semantics, max_errors, return_type);
            out_env = check_expected_type(checked.env, units, module_path, expr.span, "function return", return_type, checked.type_text, max_errors);
            ()
        } else {
            ()
        },
        None => (),
    };
    out_env
}

fn initial_env_for_signature(module_path: String, signature: AstFunctionSignature, diagnostics: Vec[Diagnostic]) -> TypecheckEnv {
    let mut bindings: Vec[TypecheckBinding] = vec.new_vec();
    let mut index = 0;
    while index < vec.vec_len(signature.params) {
        match vec.get(signature.params, index) {
            Some(param) => if true {
                bindings = vec.push(bindings, typecheck_binding(module_path, signature.name.value, param.name.value, type_text(param.type_ref), true, TypecheckLocalValue(), param.span));
                ()
            } else {
                ()
            },
            None => (),
        };
        index = index + 1;
    };
    typecheck_env(module_path, signature.name.value, type_text(signature.return_type), bindings, empty_generic_map(), diagnostics, vec.new_vec(), false)
}

fn check_function_item(function_item: AstFunctionDecl, module_path: String, units: Vec[ResolveUnit], resolver: ResolverOutput, semantics: SemanticOutput, output: TypecheckOutput, max_errors: Int) -> TypecheckOutput {
    let env = initial_env_for_signature(module_path, function_item.signature, output.diagnostics);
    let checked = check_block(function_item.body, env, units, resolver, semantics, max_errors);
    let mut out = typecheck_output(output.entry_module, output.functions, output.bindings, output.instantiations, checked.diagnostics);
    out = append_function(out, typecheck_function(module_path, function_item.signature.name.value, type_text(function_item.signature.return_type), vec.vec_len(function_item.signature.params), true, function_item.span));
    out = append_bindings(out, checked.bindings);
    append_instantiations(out, checked.instantiations)
}

fn check_impl_method(method: AstImplMethod, module_path: String, units: Vec[ResolveUnit], resolver: ResolverOutput, semantics: SemanticOutput, output: TypecheckOutput, max_errors: Int) -> TypecheckOutput {
    let env = initial_env_for_signature(module_path, method.signature, output.diagnostics);
    let checked = check_block(method.body, env, units, resolver, semantics, max_errors);
    let mut out = typecheck_output(output.entry_module, output.functions, output.bindings, output.instantiations, checked.diagnostics);
    out = append_function(out, typecheck_function(module_path, method.signature.name.value, type_text(method.signature.return_type), vec.vec_len(method.signature.params), true, method.span));
    out = append_bindings(out, checked.bindings);
    append_instantiations(out, checked.instantiations)
}

fn check_const_item(const_item: AstConstDecl, module_path: String, units: Vec[ResolveUnit], resolver: ResolverOutput, semantics: SemanticOutput, output: TypecheckOutput, max_errors: Int) -> TypecheckOutput {
    match const_item.initializer_expr {
        Some(expr) => if true {
            let env = typecheck_env(module_path, const_item.name.value, type_text(const_item.type_ref), vec.new_vec(), empty_generic_map(), output.diagnostics, vec.new_vec(), false);
            let checked = infer_expr(expr, env, units, resolver, semantics, max_errors, type_text(const_item.type_ref));
            let checked_env = check_expected_type(checked.env, units, module_path, const_item.span, "const initializer", type_text(const_item.type_ref), checked.type_text, max_errors);
            typecheck_output(output.entry_module, output.functions, output.bindings, output.instantiations, checked_env.diagnostics)
        } else {
            output
        },
        None => output,
    }
}

fn check_struct_defaults(struct_item: AstStructDecl, module_path: String, units: Vec[ResolveUnit], resolver: ResolverOutput, semantics: SemanticOutput, output: TypecheckOutput, max_errors: Int) -> TypecheckOutput {
    let mut out = output;
    let mut index = 0;
    while index < vec.vec_len(struct_item.fields) {
        match vec.get(struct_item.fields, index) {
            Some(field) => match field.default_expr {
                Some(expr) => if true {
                    let env = typecheck_env(module_path, struct_item.name.value, type_text(field.type_ref), vec.new_vec(), empty_generic_map(), out.diagnostics, vec.new_vec(), false);
                    let checked = infer_expr(expr, env, units, resolver, semantics, max_errors, type_text(field.type_ref));
                    let checked_env = check_expected_type(checked.env, units, module_path, field.span, "field default", type_text(field.type_ref), checked.type_text, max_errors);
                    out = typecheck_output(out.entry_module, out.functions, out.bindings, out.instantiations, checked_env.diagnostics);
                    ()
                } else {
                    ()
                },
                None => (),
            },
            None => (),
        };
        index = index + 1;
    };
    out
}

fn check_item(item: AstProgramItem, module_path: String, units: Vec[ResolveUnit], resolver: ResolverOutput, semantics: SemanticOutput, output: TypecheckOutput, max_errors: Int) -> TypecheckOutput {
    match item.function_item {
        Some(function_item) => check_function_item(function_item, module_path, units, resolver, semantics, output, max_errors),
        None => match item.const_item {
            Some(const_item) => check_const_item(const_item, module_path, units, resolver, semantics, output, max_errors),
            None => match item.struct_item {
                Some(struct_item) => check_struct_defaults(struct_item, module_path, units, resolver, semantics, output, max_errors),
                None => match item.impl_item {
                    Some(impl_item) => if true {
                        let mut out = output;
                        let mut index = 0;
                        while index < vec.vec_len(impl_item.methods) {
                            match vec.get(impl_item.methods, index) {
                                Some(method) => if true {
                                    out = check_impl_method(method, module_path, units, resolver, semantics, out, max_errors);
                                    ()
                                } else {
                                    ()
                                },
                                None => (),
                            };
                            index = index + 1;
                        };
                        out
                    } else {
                        output
                    },
                    None => output,
                },
            },
        },
    }
}

fn effect_or_capability_names(text: String) -> Vec[String] {
    if text == "" {
        vec.new_vec()
    } else {
        string.split(text, ",")
    }
}

fn known_effect(name: String) -> Bool {
    name == "io" || name == "fs" || name == "net" || name == "time" || name == "rand" || name == "env" || name == "proc" || name == "concurrency"
}

fn known_capability(name: String) -> Bool {
    known_effect(name)
}

fn append_effect_declaration_diagnostics(diagnostics: Vec[Diagnostic], names: Vec[String], span_value: SourceSpan, max_errors: Int) -> Vec[Diagnostic] {
    let mut out = diagnostics;
    let mut seen: Vec[String] = vec.new_vec();
    let mut index = 0;
    while index < vec.vec_len(names) {
        match vec.get(names, index) {
            Some(name) => if !known_effect(name) {
                let mut parts: Vec[String] = vec.new_vec();
                parts = vec.push(parts, "unknown effect '");
                parts = vec.push(parts, name);
                parts = vec.push(parts, "'");
                out = append_diagnostic_if_room(out, max_errors, with_help(error(diagnostic_code("E2003"), span_value, string.join(parts, "")), "known effects: io, fs, net, time, rand, env, proc, concurrency"));
                ()
            } else if string_vec_contains(seen, name) {
                let mut parts: Vec[String] = vec.new_vec();
                parts = vec.push(parts, "duplicate effect '");
                parts = vec.push(parts, name);
                parts = vec.push(parts, "' in signature");
                out = append_diagnostic_if_room(out, max_errors, error(diagnostic_code("E2004"), span_value, string.join(parts, "")));
                ()
            } else {
                seen = vec.push(seen, name);
                ()
            },
            None => (),
        };
        index = index + 1;
    };
    out
}

fn append_capability_declaration_diagnostics(diagnostics: Vec[Diagnostic], names: Vec[String], span_value: SourceSpan, max_errors: Int) -> Vec[Diagnostic] {
    let mut out = diagnostics;
    let mut seen: Vec[String] = vec.new_vec();
    let mut index = 0;
    while index < vec.vec_len(names) {
        match vec.get(names, index) {
            Some(name) => if !known_capability(name) {
                let mut parts: Vec[String] = vec.new_vec();
                parts = vec.push(parts, "unknown capability '");
                parts = vec.push(parts, name);
                parts = vec.push(parts, "'");
                out = append_diagnostic_if_room(out, max_errors, with_help(error(diagnostic_code("E2007"), span_value, string.join(parts, "")), "known capabilities: io, fs, net, time, rand, env, proc, concurrency"));
                ()
            } else if string_vec_contains(seen, name) {
                let mut parts: Vec[String] = vec.new_vec();
                parts = vec.push(parts, "duplicate capability '");
                parts = vec.push(parts, name);
                parts = vec.push(parts, "' in signature");
                out = append_diagnostic_if_room(out, max_errors, error(diagnostic_code("E2008"), span_value, string.join(parts, "")));
                ()
            } else {
                seen = vec.push(seen, name);
                ()
            },
            None => (),
        };
        index = index + 1;
    };
    out
}

fn function_effect_key(module_path: String, name: String) -> String {
    if module_path == "" || module_path == "<root>" {
        name
    } else {
        let mut parts: Vec[String] = vec.new_vec();
        parts = vec.push(parts, module_path);
        parts = vec.push(parts, "::");
        parts = vec.push(parts, name);
        string.join(parts, "")
    }
}

fn effect_entry_key(entry: EffectFunctionEntry) -> String {
    function_effect_key(entry.module_path, entry.name)
}

fn effect_call_callee_key(edge: EffectCallEdge) -> String {
    function_effect_key(edge.callee_module, edge.callee_name)
}

fn find_effect_entry(entries: Vec[EffectFunctionEntry], module_path: String, name: String) -> Option[EffectFunctionEntry] {
    let mut out: Option[EffectFunctionEntry] = None();
    let mut found = false;
    let mut index = 0;
    while !found && index < vec.vec_len(entries) {
        match vec.get(entries, index) {
            Some(entry) => if entry.module_path == module_path && entry.name == name {
                out = Some(entry);
                found = true;
            } else {
                ()
            },
            None => (),
        };
        index = index + 1;
    };
    out
}

fn find_effect_entry_by_key(entries: Vec[EffectFunctionEntry], key: String) -> Option[EffectFunctionEntry] {
    let mut out: Option[EffectFunctionEntry] = None();
    let mut found = false;
    let mut index = 0;
    while !found && index < vec.vec_len(entries) {
        match vec.get(entries, index) {
            Some(entry) => if effect_entry_key(entry) == key {
                out = Some(entry);
                found = true;
            } else {
                ()
            },
            None => (),
        };
        index = index + 1;
    };
    out
}

fn find_effect_entry_by_name(entries: Vec[EffectFunctionEntry], name: String) -> Option[EffectFunctionEntry] {
    let mut out: Option[EffectFunctionEntry] = None();
    let mut found = false;
    let mut index = 0;
    while !found && index < vec.vec_len(entries) {
        match vec.get(entries, index) {
            Some(entry) => if entry.name == name {
                out = Some(entry);
                found = true;
            } else {
                ()
            },
            None => (),
        };
        index = index + 1;
    };
    out
}

fn replace_effect_entry(entries: Vec[EffectFunctionEntry], updated: EffectFunctionEntry) -> Vec[EffectFunctionEntry] {
    let mut out: Vec[EffectFunctionEntry] = vec.new_vec();
    let mut index = 0;
    while index < vec.vec_len(entries) {
        match vec.get(entries, index) {
            Some(entry) => if effect_entry_key(entry) == effect_entry_key(updated) {
                out = vec.push(out, updated);
                ()
            } else {
                out = vec.push(out, entry);
                ()
            },
            None => (),
        };
        index = index + 1;
    };
    out
}

fn append_signature_effect_entry(entries: Vec[EffectFunctionEntry], module_path: String, signature: AstFunctionSignature, span_value: SourceSpan, body_span: SourceSpan, has_body: Bool) -> Vec[EffectFunctionEntry] {
    vec.push(entries, effect_function_entry(module_path, signature.name.value, effect_or_capability_names(signature.effect_names), effect_or_capability_names(signature.capability_names), vec.new_vec(), vec.new_vec(), span_value, body_span, has_body))
}

fn collect_effect_entries_for_item(entries: Vec[EffectFunctionEntry], item: AstProgramItem, module_path: String) -> Vec[EffectFunctionEntry] {
    match item.function_item {
        Some(function_item) => append_signature_effect_entry(entries, module_path, function_item.signature, function_item.span, function_item.body.span, true),
        None => match item.function_signature {
            Some(signature) => append_signature_effect_entry(entries, module_path, signature, item.span, item.span, false),
            None => match item.impl_item {
                Some(impl_item) => if true {
                    let mut out = entries;
                    let mut index = 0;
                    while index < vec.vec_len(impl_item.methods) {
                        match vec.get(impl_item.methods, index) {
                            Some(method) => if true {
                                out = append_signature_effect_entry(out, module_path, method.signature, method.span, method.body.span, true);
                                ()
                            } else {
                                ()
                            },
                            None => (),
                        };
                        index = index + 1;
                    };
                    out
                } else {
                    entries
                },
                None => entries,
            },
        },
    }
}

fn collect_effect_entries(units: Vec[ResolveUnit]) -> Vec[EffectFunctionEntry] {
    let mut entries: Vec[EffectFunctionEntry] = vec.new_vec();
    let mut unit_index = 0;
    while unit_index < vec.vec_len(units) {
        match vec.get(units, unit_index) {
            Some(unit) => if true {
                let mut item_index = 0;
                while item_index < vec.vec_len(unit.program.items) {
                    match vec.get(unit.program.items, item_index) {
                        Some(item) => if true {
                            entries = collect_effect_entries_for_item(entries, item, unit.module_path);
                            ()
                        } else {
                            ()
                        },
                        None => (),
                    };
                    item_index = item_index + 1;
                };
                ()
            } else {
                ()
            },
            None => (),
        };
        unit_index = unit_index + 1;
    };
    entries
}

fn resolve_call_effect_entry(expr: AstExpr, entries: Vec[EffectFunctionEntry], units: Vec[ResolveUnit], resolver: ResolverOutput, module_path: String) -> Option[EffectFunctionEntry] {
    match lookup_value_symbol(units, resolver, module_path, expr.name, ResolverFunctionSymbol(), ResolverValueNamespace()) {
        Some(symbol) => match find_effect_entry(entries, symbol.module_path, symbol.name) {
            Some(entry) => Some(entry),
            None => find_effect_entry_by_name(entries, symbol.name),
        },
        None => if string.contains(expr.name, ".") {
            find_effect_entry_by_name(entries, path_tail(expr.name))
        } else {
            find_effect_entry_by_name(entries, expr.name)
        },
    }
}

fn append_call_effect_diagnostics(diagnostics: Vec[Diagnostic], caller: EffectFunctionEntry, callee: EffectFunctionEntry, span_value: SourceSpan, max_errors: Int) -> Vec[Diagnostic] {
    let mut missing: Vec[String] = vec.new_vec();
    let mut index = 0;
    while index < vec.vec_len(callee.effect_names) {
        match vec.get(callee.effect_names, index) {
            Some(effect) => if string_vec_contains(caller.effect_names, effect) {
                ()
            } else {
                missing = push_unique_string(missing, effect);
                ()
            },
            None => (),
        };
        index = index + 1;
    };
    if vec.vec_len(missing) == 0 {
        diagnostics
    } else {
        let mut parts: Vec[String] = vec.new_vec();
        parts = vec.push(parts, "calling '");
        parts = vec.push(parts, callee.name);
        parts = vec.push(parts, "' requires undeclared effects: ");
        parts = vec.push(parts, string.join(missing, ", "));
        append_diagnostic_if_room(diagnostics, max_errors, with_help(error(diagnostic_code("E2001"), span_value, string.join(parts, "")), "add the required effects on the enclosing function"))
    }
}

fn merge_scan(left: EffectScan, right: EffectScan) -> EffectScan {
    effect_scan(append_all_diagnostics(left.diagnostics, right.diagnostics, 100000), append_unique_strings(left.effect_names, right.effect_names), append_effect_calls(left.call_edges, right.call_edges))
}

fn append_effect_calls(left: Vec[EffectCallEdge], right: Vec[EffectCallEdge]) -> Vec[EffectCallEdge] {
    let mut out = left;
    let mut index = 0;
    while index < vec.vec_len(right) {
        match vec.get(right, index) {
            Some(edge) => if true {
                out = vec.push(out, edge);
                ()
            } else {
                ()
            },
            None => (),
        };
        index = index + 1;
    };
    out
}

fn scan_expr_effects(expr: AstExpr, caller: EffectFunctionEntry, entries: Vec[EffectFunctionEntry], units: Vec[ResolveUnit], resolver: ResolverOutput, diagnostics: Vec[Diagnostic], max_errors: Int) -> EffectScan {
    let mut out = effect_scan(diagnostics, vec.new_vec(), vec.new_vec());
    match expr.kind {
        AstCallExpr => match resolve_call_effect_entry(expr, entries, units, resolver, caller.module_path) {
            Some(callee) => if vec.vec_len(callee.effect_names) > 0 || callee.has_body {
                out = effect_scan(append_call_effect_diagnostics(out.diagnostics, caller, callee, expr.span, max_errors), append_unique_strings(out.effect_names, callee.effect_names), vec.push(out.call_edges, effect_call_edge(caller.module_path, caller.name, callee.module_path, callee.name, callee.effect_names, expr.span)));
                ()
            } else {
                ()
            },
            None => (),
        },
        _ => (),
    };
    let mut index = 0;
    while index < expr.direct_child_count {
        match direct_expr_at(expr, index) {
            Some(child) => if true {
                out = merge_scan(out, scan_expr_effects(child, caller, entries, units, resolver, vec.new_vec(), max_errors));
                ()
            } else {
                ()
            },
            None => (),
        };
        index = index + 1;
    };
    effect_scan(out.diagnostics, out.effect_names, out.call_edges)
}

fn scan_statement_effects(statement: AstStatement, caller: EffectFunctionEntry, entries: Vec[EffectFunctionEntry], units: Vec[ResolveUnit], resolver: ResolverOutput, diagnostics: Vec[Diagnostic], max_errors: Int) -> EffectScan {
    match statement.expr {
        Some(expr) => scan_expr_effects(expr, caller, entries, units, resolver, diagnostics, max_errors),
        None => effect_scan(diagnostics, vec.new_vec(), vec.new_vec()),
    }
}

fn scan_block_effects(block: AstBlock, caller: EffectFunctionEntry, entries: Vec[EffectFunctionEntry], units: Vec[ResolveUnit], resolver: ResolverOutput, diagnostics: Vec[Diagnostic], max_errors: Int) -> EffectScan {
    let mut out = effect_scan(diagnostics, vec.new_vec(), vec.new_vec());
    let mut index = 0;
    while index < vec.vec_len(block.statements) {
        match vec.get(block.statements, index) {
            Some(statement) => if true {
                out = merge_scan(out, scan_statement_effects(statement, caller, entries, units, resolver, vec.new_vec(), max_errors));
                ()
            } else {
                ()
            },
            None => (),
        };
        index = index + 1;
    };
    match block.tail_expr {
        Some(expr) => if true {
            out = merge_scan(out, scan_expr_effects(expr, caller, entries, units, resolver, vec.new_vec(), max_errors));
            ()
        } else {
            ()
        },
        None => (),
    };
    out
}

fn analyze_effect_body(entries: Vec[EffectFunctionEntry], caller: EffectFunctionEntry, body: AstBlock, units: Vec[ResolveUnit], resolver: ResolverOutput, diagnostics: Vec[Diagnostic], max_errors: Int) -> EffectScan {
    scan_block_effects(body, caller, entries, units, resolver, diagnostics, max_errors)
}

fn effect_entry_with_scan(entry: EffectFunctionEntry, scanned: EffectScan) -> EffectFunctionEntry {
    effect_function_entry(entry.module_path, entry.name, entry.effect_names, entry.capability_names, append_unique_strings(entry.direct_effect_names, scanned.effect_names), append_effect_calls(entry.call_edges, scanned.call_edges), entry.span, entry.body_span, entry.has_body)
}

fn effect_entries_with_body_scans(entries: Vec[EffectFunctionEntry], units: Vec[ResolveUnit], resolver: ResolverOutput, diagnostics: Vec[Diagnostic], max_errors: Int) -> EffectBodyResult {
    let mut out_entries = entries;
    let mut out_diagnostics = diagnostics;
    let mut unit_index = 0;
    while unit_index < vec.vec_len(units) {
        match vec.get(units, unit_index) {
            Some(unit) => if true {
                let mut item_index = 0;
                while item_index < vec.vec_len(unit.program.items) {
                    match vec.get(unit.program.items, item_index) {
                        Some(item) => match item.function_item {
                            Some(function_item) => match find_effect_entry(out_entries, unit.module_path, function_item.signature.name.value) {
                                Some(caller) => if true {
                                    let scanned = analyze_effect_body(out_entries, caller, function_item.body, units, resolver, vec.new_vec(), max_errors);
                                    out_diagnostics = append_all_diagnostics(out_diagnostics, scanned.diagnostics, max_errors);
                                    out_entries = replace_effect_entry(out_entries, effect_entry_with_scan(caller, scanned));
                                    ()
                                } else {
                                    ()
                                },
                                None => (),
                            },
                            None => match item.impl_item {
                                Some(impl_item) => if true {
                                    let mut method_index = 0;
                                    while method_index < vec.vec_len(impl_item.methods) {
                                        match vec.get(impl_item.methods, method_index) {
                                            Some(method) => match find_effect_entry(out_entries, unit.module_path, method.signature.name.value) {
                                                Some(caller) => if true {
                                                    let scanned = analyze_effect_body(out_entries, caller, method.body, units, resolver, vec.new_vec(), max_errors);
                                                    out_diagnostics = append_all_diagnostics(out_diagnostics, scanned.diagnostics, max_errors);
                                                    out_entries = replace_effect_entry(out_entries, effect_entry_with_scan(caller, scanned));
                                                    ()
                                                } else {
                                                    ()
                                                },
                                                None => (),
                                            },
                                            None => (),
                                        };
                                        method_index = method_index + 1;
                                    };
                                    ()
                                } else {
                                    ()
                                },
                                None => (),
                            },
                        },
                        None => (),
                    };
                    item_index = item_index + 1;
                };
                ()
            } else {
                ()
            },
            None => (),
        };
        unit_index = unit_index + 1;
    };
    effect_body_result(out_entries, out_diagnostics)
}

fn effect_closure_for_key(entries: Vec[EffectFunctionEntry], key: String, visiting: Vec[String]) -> Vec[String] {
    if string_vec_contains(visiting, key) {
        vec.new_vec()
    } else {
        match find_effect_entry_by_key(entries, key) {
            Some(entry) => if true {
                let mut out = entry.direct_effect_names;
                let mut next_visiting = vec.push(visiting, key);
                let mut index = 0;
                while index < vec.vec_len(entry.call_edges) {
                    match vec.get(entry.call_edges, index) {
                        Some(edge) => if true {
                            out = append_unique_strings(out, edge.effect_names);
                            out = append_unique_strings(out, effect_closure_for_key(entries, effect_call_callee_key(edge), next_visiting));
                            ()
                        } else {
                            ()
                        },
                        None => (),
                    };
                    index = index + 1;
                };
                out
            } else {
                vec.new_vec()
            },
            None => vec.new_vec(),
        }
    }
}

fn find_effect_path_from_key(entries: Vec[EffectFunctionEntry], key: String, effect: String, visited: Vec[String], path: Vec[String], first_source: Int, first_start: Int, first_end: Int, has_first_span: Bool, fallback_source: Int, fallback_start: Int, fallback_end: Int) -> EffectPath {
    if string_vec_contains(visited, key) {
        effect_path(vec.new_vec(), span(source_id(fallback_source), fallback_start, fallback_end), false)
    } else {
        match find_effect_entry_by_key(entries, key) {
            Some(entry) => if true {
                let mut out: Vec[String] = vec.new_vec();
                let mut out_source = fallback_source;
                let mut out_start = fallback_start;
                let mut out_end = fallback_end;
                let mut found = false;
                let mut next_visited = vec.push(visited, key);
                let mut index = 0;
                while !found && index < vec.vec_len(entry.call_edges) {
                    match vec.get(entry.call_edges, index) {
                        Some(edge) => if true {
                            let mut next_path = path;
                            let next_source = if has_first_span { first_source } else { edge.span.source.value };
                            let next_start = if has_first_span { first_start } else { edge.span.start };
                            let next_end = if has_first_span { first_end } else { edge.span.end };
                            next_path = vec.push(next_path, edge.callee_name);
                            if string_vec_contains(edge.effect_names, effect) {
                                out = next_path;
                                out_source = next_source;
                                out_start = next_start;
                                out_end = next_end;
                                found = true;
                            } else {
                                let nested = find_effect_path_from_key(entries, effect_call_callee_key(edge), effect, next_visited, next_path, next_source, next_start, next_end, true, fallback_source, fallback_start, fallback_end);
                                if nested.found {
                                    out = nested.names;
                                    out_source = nested.span.source.value;
                                    out_start = nested.span.start;
                                    out_end = nested.span.end;
                                    found = true;
                                } else {
                                    ()
                                };
                            };
                            ()
                        } else {
                            ()
                        },
                        None => (),
                    };
                    index = index + 1;
                };
                effect_path(out, span(source_id(out_source), out_start, out_end), found)
            } else {
                effect_path(vec.new_vec(), span(source_id(fallback_source), fallback_start, fallback_end), false)
            },
            None => effect_path(vec.new_vec(), span(source_id(fallback_source), fallback_start, fallback_end), false),
        }
    }
}

fn append_transitive_effect_diagnostics(diagnostics: Vec[Diagnostic], entries: Vec[EffectFunctionEntry], max_errors: Int) -> Vec[Diagnostic] {
    let mut out = diagnostics;
    let mut index = 0;
    while index < vec.vec_len(entries) {
        match vec.get(entries, index) {
            Some(entry) => if entry.has_body {
                let closure = effect_closure_for_key(entries, effect_entry_key(entry), vec.new_vec());
                let mut effect_index = 0;
                while effect_index < vec.vec_len(closure) {
                    match vec.get(closure, effect_index) {
                        Some(effect) => if string_vec_contains(entry.effect_names, effect) {
                            ()
                        } else {
                            let mut start_path: Vec[String] = vec.new_vec();
                            start_path = vec.push(start_path, entry.name);
                            let path = find_effect_path_from_key(entries, effect_entry_key(entry), effect, vec.new_vec(), start_path, entry.span.source.value, entry.span.start, entry.span.end, false, entry.span.source.value, entry.span.start, entry.span.end);
                            if path.found && vec.vec_len(path.names) >= 3 {
                                let mut parts: Vec[String] = vec.new_vec();
                                parts = vec.push(parts, "function '");
                                parts = vec.push(parts, entry.name);
                                parts = vec.push(parts, "' requires transitive effect '");
                                parts = vec.push(parts, effect);
                                parts = vec.push(parts, "' via call path ");
                                parts = vec.push(parts, string.join(path.names, " -> "));
                                out = append_diagnostic_if_room(out, max_errors, with_help(error(diagnostic_code("E2005"), path.span, string.join(parts, "")), "declare the transitive effect on the caller or refactor the call chain"));
                                ()
                            } else {
                                ()
                            };
                        },
                        None => (),
                    };
                    effect_index = effect_index + 1;
                };
                ()
            } else {
                ()
            },
            None => (),
        };
        index = index + 1;
    };
    out
}

fn append_capability_authority_diagnostics(diagnostics: Vec[Diagnostic], entries: Vec[EffectFunctionEntry], max_errors: Int) -> Vec[Diagnostic] {
    let mut out = diagnostics;
    let mut index = 0;
    while index < vec.vec_len(entries) {
        match vec.get(entries, index) {
            Some(entry) => if entry.has_body {
                let mut required = append_unique_strings(entry.effect_names, effect_closure_for_key(entries, effect_entry_key(entry), vec.new_vec()));
                let mut effect_index = 0;
                while effect_index < vec.vec_len(required) {
                    match vec.get(required, effect_index) {
                        Some(effect) => if string_vec_contains(entry.capability_names, effect) {
                            ()
                        } else {
                            let mut start_path: Vec[String] = vec.new_vec();
                            start_path = vec.push(start_path, entry.name);
                            let path = find_effect_path_from_key(entries, effect_entry_key(entry), effect, vec.new_vec(), start_path, entry.span.source.value, entry.span.start, entry.span.end, false, entry.span.source.value, entry.span.start, entry.span.end);
                            let mut parts: Vec[String] = vec.new_vec();
                            parts = vec.push(parts, "function '");
                            parts = vec.push(parts, entry.name);
                            parts = vec.push(parts, "' requires capability '");
                            parts = vec.push(parts, effect);
                            if path.found && vec.vec_len(path.names) > 1 {
                                parts = vec.push(parts, "' via call path ");
                                parts = vec.push(parts, string.join(path.names, " -> "));
                            } else {
                                parts = vec.push(parts, "'");
                            };
                            out = append_diagnostic_if_room(out, max_errors, with_help(error(diagnostic_code("E2009"), path.span, string.join(parts, "")), "declare the required capability on the caller and thread authority through callers"));
                            ()
                        },
                        None => (),
                    };
                    effect_index = effect_index + 1;
                };
                ()
            } else {
                ()
            },
            None => (),
        };
        index = index + 1;
    };
    out
}

fn contract_proof(expr: AstExpr) -> String {
    match expr.kind {
        AstBoolExpr => if expr.name == "true" {
            "true"
        } else if expr.name == "false" {
            "false"
        } else {
            "unknown"
        },
        AstBinaryExpr => if expr.op == "==" {
            let left = match direct_expr_at(expr, 0) { Some(value) => value, None => simple_expr(AstUnitExpr(), "", "", expr.span, "()") };
            let right = match direct_expr_at(expr, 1) { Some(value) => value, None => simple_expr(AstUnitExpr(), "", "", expr.span, "()") };
            if left.text == right.text && left.text != "" {
                "true"
            } else {
                "unknown"
            }
        } else {
            "unknown"
        },
        _ => "unknown",
    }
}

fn append_static_contract_diagnostic(diagnostics: Vec[Diagnostic], kind: String, function_name: String, expr: AstExpr, max_errors: Int) -> Vec[Diagnostic] {
    let proof = contract_proof(expr);
    if proof == "false" {
        let mut parts: Vec[String] = vec.new_vec();
        parts = vec.push(parts, kind);
        parts = vec.push(parts, " contract for '");
        parts = vec.push(parts, function_name);
        parts = vec.push(parts, "' is always false");
        if kind == "requires" {
            append_diagnostic_if_room(diagnostics, max_errors, with_help(error(diagnostic_code("E4001"), expr.span, string.join(parts, "")), "fix the contract or function preconditions"))
        } else {
            append_diagnostic_if_room(diagnostics, max_errors, with_help(error(diagnostic_code("E4002"), expr.span, string.join(parts, "")), "fix the postcondition expression"))
        }
    } else if proof == "true" {
        let mut parts: Vec[String] = vec.new_vec();
        parts = vec.push(parts, kind);
        parts = vec.push(parts, " contract for '");
        parts = vec.push(parts, function_name);
        parts = vec.push(parts, "' discharged at compile time");
        append_diagnostic_if_room(diagnostics, max_errors, note(diagnostic_code("E4005"), expr.span, string.join(parts, "")))
    } else {
        let mut parts: Vec[String] = vec.new_vec();
        parts = vec.push(parts, kind);
        parts = vec.push(parts, " contract for '");
        parts = vec.push(parts, function_name);
        parts = vec.push(parts, "' kept as residual runtime obligation");
        append_diagnostic_if_room(diagnostics, max_errors, note(diagnostic_code("E4003"), expr.span, string.join(parts, "")))
    }
}

fn append_contract_purity_diagnostics(diagnostics: Vec[Diagnostic], expr: AstExpr, entries: Vec[EffectFunctionEntry], units: Vec[ResolveUnit], resolver: ResolverOutput, module_path: String, max_errors: Int) -> Vec[Diagnostic] {
    let mut out = diagnostics;
    match expr.kind {
        AstCallExpr => match resolve_call_effect_entry(expr, entries, units, resolver, module_path) {
            Some(callee) => if vec.vec_len(callee.effect_names) > 0 {
                out = append_diagnostic_if_room(out, max_errors, with_help(error(diagnostic_code("E2002"), expr.span, "contracts must be pure; effectful call found"), "remove IO/time/rand/net/fs calls from requires/ensures/invariant"));
                ()
            } else {
                ()
            },
            None => (),
        },
        _ => (),
    };
    let mut index = 0;
    while index < expr.direct_child_count {
        match direct_expr_at(expr, index) {
            Some(child) => if true {
                out = append_contract_purity_diagnostics(out, child, entries, units, resolver, module_path, max_errors);
                ()
            } else {
                ()
            },
            None => (),
        };
        index = index + 1;
    };
    out
}

fn append_contract_type_diagnostic(env: TypecheckEnv, units: Vec[ResolveUnit], resolver: ResolverOutput, semantics: SemanticOutput, expr: AstExpr, expected_code: String, message: String, max_errors: Int) -> TypecheckEnv {
    let checked = infer_expr(expr, env, units, resolver, semantics, max_errors, "Bool");
    if types_compatible(units, checked.env.module_path, "Bool", checked.type_text) {
        checked.env
    } else {
        env_error(checked.env, max_errors, expected_code, expr.span, message, "found a non-Bool contract expression")
    }
}

fn append_result_binding(env: TypecheckEnv, signature: AstFunctionSignature) -> TypecheckEnv {
    append_binding(env, typecheck_binding(env.module_path, signature.name.value, "result", type_text(signature.return_type), false, TypecheckTemporaryValue(), signature.span))
}

fn check_function_contracts(function_item: AstFunctionDecl, module_path: String, units: Vec[ResolveUnit], resolver: ResolverOutput, semantics: SemanticOutput, entries: Vec[EffectFunctionEntry], diagnostics: Vec[Diagnostic], max_errors: Int) -> Vec[Diagnostic] {
    let mut out = diagnostics;
    match function_item.requires_expr {
        Some(expr) => if true {
            let env = initial_env_for_signature(module_path, function_item.signature, out);
            let checked_env = append_contract_type_diagnostic(env, units, resolver, semantics, expr, "E1200", "requires contract must have type Bool", max_errors);
            out = checked_env.diagnostics;
            out = append_contract_purity_diagnostics(out, expr, entries, units, resolver, module_path, max_errors);
            out = append_static_contract_diagnostic(out, "requires", function_item.signature.name.value, expr, max_errors);
            ()
        } else {
            ()
        },
        None => (),
    };
    match function_item.ensures_expr {
        Some(expr) => if true {
            let env = append_result_binding(initial_env_for_signature(module_path, function_item.signature, out), function_item.signature);
            let checked_env = append_contract_type_diagnostic(env, units, resolver, semantics, expr, "E1201", "ensures contract must have type Bool", max_errors);
            out = checked_env.diagnostics;
            out = append_contract_purity_diagnostics(out, expr, entries, units, resolver, module_path, max_errors);
            out = append_static_contract_diagnostic(out, "ensures", function_item.signature.name.value, expr, max_errors);
            ()
        } else {
            ()
        },
        None => (),
    };
    out
}

fn check_impl_method_contracts(method: AstImplMethod, module_path: String, units: Vec[ResolveUnit], resolver: ResolverOutput, semantics: SemanticOutput, entries: Vec[EffectFunctionEntry], diagnostics: Vec[Diagnostic], max_errors: Int) -> Vec[Diagnostic] {
    let fake_function = function_decl(method.signature, method.requires_expr, method.ensures_expr, method.body, method.span);
    check_function_contracts(fake_function, module_path, units, resolver, semantics, entries, diagnostics, max_errors)
}

fn append_contract_diagnostics_for_item(diagnostics: Vec[Diagnostic], item: AstProgramItem, module_path: String, units: Vec[ResolveUnit], resolver: ResolverOutput, semantics: SemanticOutput, entries: Vec[EffectFunctionEntry], max_errors: Int) -> Vec[Diagnostic] {
    match item.function_item {
        Some(function_item) => check_function_contracts(function_item, module_path, units, resolver, semantics, entries, diagnostics, max_errors),
        None => match item.impl_item {
            Some(impl_item) => if true {
                let mut out = diagnostics;
                let mut index = 0;
                while index < vec.vec_len(impl_item.methods) {
                    match vec.get(impl_item.methods, index) {
                        Some(method) => if true {
                            out = check_impl_method_contracts(method, module_path, units, resolver, semantics, entries, out, max_errors);
                            ()
                        } else {
                            ()
                        },
                        None => (),
                    };
                    index = index + 1;
                };
                out
            } else {
                diagnostics
            },
            None => diagnostics,
        },
    }
}

fn append_contract_diagnostics(diagnostics: Vec[Diagnostic], units: Vec[ResolveUnit], resolver: ResolverOutput, semantics: SemanticOutput, entries: Vec[EffectFunctionEntry], max_errors: Int) -> Vec[Diagnostic] {
    let mut out = diagnostics;
    let mut unit_index = 0;
    while unit_index < vec.vec_len(units) {
        match vec.get(units, unit_index) {
            Some(unit) => if true {
                let mut item_index = 0;
                while item_index < vec.vec_len(unit.program.items) {
                    match vec.get(unit.program.items, item_index) {
                        Some(item) => if true {
                            out = append_contract_diagnostics_for_item(out, item, unit.module_path, units, resolver, semantics, entries, max_errors);
                            ()
                        } else {
                            ()
                        },
                        None => (),
                    };
                    item_index = item_index + 1;
                };
                ()
            } else {
                ()
            },
            None => (),
        };
        unit_index = unit_index + 1;
    };
    out
}

fn append_effect_declaration_diagnostics_for_entries(diagnostics: Vec[Diagnostic], entries: Vec[EffectFunctionEntry], max_errors: Int) -> Vec[Diagnostic] {
    let mut out = diagnostics;
    let mut index = 0;
    while index < vec.vec_len(entries) {
        match vec.get(entries, index) {
            Some(entry) => if true {
                out = append_effect_declaration_diagnostics(out, entry.effect_names, entry.span, max_errors);
                out = append_capability_declaration_diagnostics(out, entry.capability_names, entry.span, max_errors);
                ()
            } else {
                ()
            },
            None => (),
        };
        index = index + 1;
    };
    out
}

fn append_effect_capability_contract_diagnostics(output: TypecheckOutput, units: Vec[ResolveUnit], resolver: ResolverOutput, semantics: SemanticOutput, max_errors: Int) -> TypecheckOutput {
    let entries = collect_effect_entries(units);
    let mut diagnostics = append_effect_declaration_diagnostics_for_entries(output.diagnostics, entries, max_errors);
    diagnostics = append_contract_diagnostics(diagnostics, units, resolver, semantics, entries, max_errors);
    let body_result = effect_entries_with_body_scans(entries, units, resolver, diagnostics, max_errors);
    diagnostics = append_transitive_effect_diagnostics(body_result.diagnostics, body_result.entries, max_errors);
    diagnostics = append_capability_authority_diagnostics(diagnostics, body_result.entries, max_errors);
    typecheck_output(output.entry_module, output.functions, output.bindings, output.instantiations, diagnostics)
}

pub fn typecheck_resolved_units(units: Vec[ResolveUnit], resolver: ResolverOutput, max_errors: Int) -> TypecheckOutput {
    let semantics = analyze_resolved_units(units, resolver, max_errors);
    let mut out = typecheck_output(resolver.entry_module, vec.new_vec(), vec.new_vec(), vec.new_vec(), append_all_diagnostics(resolver.diagnostics, semantics.diagnostics, max_errors));
    let mut unit_index = 0;
    while unit_index < vec.vec_len(units) {
        match vec.get(units, unit_index) {
            Some(unit) => if true {
                let mut item_index = 0;
                while item_index < vec.vec_len(unit.program.items) {
                    match vec.get(unit.program.items, item_index) {
                        Some(item) => if true {
                            out = check_item(item, unit.module_path, units, resolver, semantics, out, max_errors);
                            ()
                        } else {
                            ()
                        },
                        None => (),
                    };
                    item_index = item_index + 1;
                };
                ()
            } else {
                ()
            },
            None => (),
        };
        unit_index = unit_index + 1;
    };
    append_effect_capability_contract_diagnostics(out, units, resolver, semantics, max_errors)
}

pub fn typecheck_units(units: Vec[ResolveUnit], entry_module: String, max_errors: Int) -> TypecheckOutput {
    let resolver = resolve_units(units, entry_module, max_errors);
    typecheck_resolved_units(units, resolver, max_errors)
}

pub fn typecheck_program(program: AstProgram, max_errors: Int) -> TypecheckOutput {
    let mut units: Vec[ResolveUnit] = vec.new_vec();
    units = vec.push(units, resolve_unit(program));
    typecheck_units(units, program_module_path_for_typecheck(program), max_errors)
}

fn program_module_path_for_typecheck(program: AstProgram) -> String {
    match program.module_item {
        Some(module_item) => module_item.path.text,
        None => "<root>",
    }
}

pub fn typecheck_function_count(value: TypecheckOutput) -> Int {
    vec.vec_len(value.functions)
}

pub fn typecheck_binding_count(value: TypecheckOutput) -> Int {
    vec.vec_len(value.bindings)
}

pub fn typecheck_instantiation_count(value: TypecheckOutput) -> Int {
    vec.vec_len(value.instantiations)
}

pub fn typecheck_diagnostic_count(value: TypecheckOutput) -> Int {
    vec.vec_len(value.diagnostics)
}

pub fn typecheck_has_diagnostic_code(value: TypecheckOutput, code: String) -> Bool {
    let mut found = false;
    let mut index = 0;
    while !found && index < vec.vec_len(value.diagnostics) {
        match vec.get(value.diagnostics, index) {
            Some(diag) => if diag.code.value == code {
                found = true;
            } else {
                ()
            },
            None => (),
        };
        index = index + 1;
    };
    found
}

pub fn typecheck_has_function(value: TypecheckOutput, module_path: String, name: String, return_type: String) -> Bool {
    let mut found = false;
    let mut index = 0;
    while !found && index < vec.vec_len(value.functions) {
        match vec.get(value.functions, index) {
            Some(item) => if item.module_path == module_path && item.name == name && item.return_type == return_type && item.typed_body {
                found = true;
            } else {
                ()
            },
            None => (),
        };
        index = index + 1;
    };
    found
}

pub fn typecheck_has_binding(value: TypecheckOutput, function_name: String, name: String, type_text_value: String) -> Bool {
    let mut found = false;
    let mut index = 0;
    while !found && index < vec.vec_len(value.bindings) {
        match vec.get(value.bindings, index) {
            Some(item) => if item.function_name == function_name && item.name == name && item.type_text == type_text_value {
                found = true;
            } else {
                ()
            },
            None => (),
        };
        index = index + 1;
    };
    found
}

pub fn typecheck_has_instantiation(value: TypecheckOutput, name: String, kind: String, type_arg: String) -> Bool {
    let mut found = false;
    let mut index = 0;
    while !found && index < vec.vec_len(value.instantiations) {
        match vec.get(value.instantiations, index) {
            Some(item) => if item.name == name && item.kind == kind {
                let mut arg_found = false;
                let mut arg_index = 0;
                while !arg_found && arg_index < vec.vec_len(item.type_args) {
                    match vec.get(item.type_args, arg_index) {
                        Some(arg) => if arg == type_arg {
                            arg_found = true;
                        } else {
                            ()
                        },
                        None => (),
                    };
                    arg_index = arg_index + 1;
                };
                if arg_found {
                    found = true;
                } else {
                    ()
                }
            } else {
                ()
            },
            None => (),
        };
        index = index + 1;
    };
    found
}
