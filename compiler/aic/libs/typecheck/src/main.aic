module compiler.typecheck;

import compiler.source;
import compiler.diagnostics;
import compiler.ast;
import compiler.frontend;
import compiler.semantics;
import std.option;
import std.string;
import std.vec;

pub enum TypecheckTypeKind {
    TypecheckUnitType,
    TypecheckBoolType,
    TypecheckIntType,
    TypecheckUIntType,
    TypecheckFloatType,
    TypecheckStringType,
    TypecheckCharType,
    TypecheckNamedType,
    TypecheckFunctionType,
    TypecheckDynTraitType,
    TypecheckHoleType,
    TypecheckUnknownType,
}

pub enum TypecheckValueKind {
    TypecheckLocalValue,
    TypecheckConstValue,
    TypecheckFunctionValue,
    TypecheckVariantValue,
    TypecheckTemporaryValue,
}

pub struct TypecheckType {
    pub kind: TypecheckTypeKind,
    pub text: String,
    pub name: String,
    pub arity: Int,
    pub span: SourceSpan,
}

pub struct TypecheckBinding {
    pub module_path: String,
    pub function_name: String,
    pub name: String,
    pub type_text: String,
    pub mutable: Bool,
    pub value_kind: TypecheckValueKind,
    pub span: SourceSpan,
}

pub struct TypecheckFunction {
    pub module_path: String,
    pub name: String,
    pub return_type: String,
    pub param_count: Int,
    pub typed_body: Bool,
    pub span: SourceSpan,
}

pub struct TypecheckInstantiation {
    pub module_path: String,
    pub name: String,
    pub kind: String,
    pub type_args: Vec[String],
    pub span: SourceSpan,
}

pub struct TypecheckOutput {
    pub entry_module: String,
    pub functions: Vec[TypecheckFunction],
    pub bindings: Vec[TypecheckBinding],
    pub instantiations: Vec[TypecheckInstantiation],
    pub diagnostics: Vec[Diagnostic],
}

struct GenericMap {
    names: Vec[String],
    values: Vec[String],
}

struct TypeAliasEntry {
    module_path: String,
    alias_item: AstTypeAliasDecl,
}

struct TypeAliasIndex {
    entries: Vec[TypeAliasEntry],
}

struct TypecheckEnv {
    module_path: String,
    function_name: String,
    return_type: String,
    bindings: Vec[TypecheckBinding],
    generic_map: GenericMap,
    aliases: TypeAliasIndex,
    diagnostics: Vec[Diagnostic],
    instantiations: Vec[TypecheckInstantiation],
    in_loop: Bool,
    loop_break_types: Vec[String],
}

struct ExprCheck {
    env: TypecheckEnv,
    type_text: String,
}

struct EffectCallEdge {
    caller_module: String,
    caller_name: String,
    callee_module: String,
    callee_name: String,
    effect_names: Vec[String],
    span: SourceSpan,
}

struct EffectFunctionEntry {
    module_path: String,
    name: String,
    effect_names: Vec[String],
    capability_names: Vec[String],
    direct_effect_names: Vec[String],
    call_edges: Vec[EffectCallEdge],
    span: SourceSpan,
    body_span: SourceSpan,
    has_body: Bool,
}

struct EffectScan {
    diagnostics: Vec[Diagnostic],
    effect_names: Vec[String],
    call_edges: Vec[EffectCallEdge],
}

struct EffectBodyResult {
    entries: Vec[EffectFunctionEntry],
    diagnostics: Vec[Diagnostic],
}

struct EffectPath {
    names: Vec[String],
    span: SourceSpan,
    found: Bool,
}

struct EffectKey {
    module_path: String,
    name: String,
}

struct OwnershipBinding {
    name: String,
    type_text: String,
    mutable: Bool,
    span: SourceSpan,
}

struct ActiveBorrow {
    target: String,
    mutable: Bool,
    owner: String,
    span: SourceSpan,
}

struct MovedBinding {
    name: String,
    span: SourceSpan,
}

struct ResourceUse {
    name: String,
    kind: String,
    closed_by: String,
    span: SourceSpan,
}

struct ResourceProtocolOp {
    kind: String,
    terminal: Bool,
    api: String,
    first_param_base_type: String,
}

struct OwnershipState {
    bindings: Vec[OwnershipBinding],
    borrows: Vec[ActiveBorrow],
    moved: Vec[MovedBinding],
    resources: Vec[ResourceUse],
    diagnostics: Vec[Diagnostic],
}

pub fn typecheck_type(kind: TypecheckTypeKind, text: String, name: String, arity: Int, span: SourceSpan) -> TypecheckType {
    TypecheckType {
        kind: kind,
        text: text,
        name: name,
        arity: arity,
        span: span,
    }
}

pub fn typecheck_binding(module_path: String, function_name: String, name: String, type_text_value: String, mutable: Bool, value_kind: TypecheckValueKind, span: SourceSpan) -> TypecheckBinding {
    TypecheckBinding {
        module_path: module_path,
        function_name: function_name,
        name: name,
        type_text: type_text_value,
        mutable: mutable,
        value_kind: value_kind,
        span: span,
    }
}

pub fn typecheck_function(module_path: String, name: String, return_type: String, param_count_value: Int, typed_body: Bool, span: SourceSpan) -> TypecheckFunction {
    TypecheckFunction {
        module_path: module_path,
        name: name,
        return_type: return_type,
        param_count: param_count_value,
        typed_body: typed_body,
        span: span,
    }
}

pub fn typecheck_instantiation(module_path: String, name: String, kind: String, type_args: Vec[String], span: SourceSpan) -> TypecheckInstantiation {
    TypecheckInstantiation {
        module_path: module_path,
        name: name,
        kind: kind,
        type_args: type_args,
        span: span,
    }
}

pub fn typecheck_output(entry_module: String, functions: Vec[TypecheckFunction], bindings: Vec[TypecheckBinding], instantiations: Vec[TypecheckInstantiation], diagnostics: Vec[Diagnostic]) -> TypecheckOutput {
    TypecheckOutput {
        entry_module: entry_module,
        functions: functions,
        bindings: bindings,
        instantiations: instantiations,
        diagnostics: diagnostics,
    }
}

fn generic_map(names: Vec[String], values: Vec[String]) -> GenericMap {
    GenericMap {
        names: names,
        values: values,
    }
}

fn empty_generic_map() -> GenericMap {
    generic_map(vec.new_vec(), vec.new_vec())
}

fn type_alias_entry(module_path: String, alias_item: AstTypeAliasDecl) -> TypeAliasEntry {
    TypeAliasEntry {
        module_path: module_path,
        alias_item: alias_item,
    }
}

fn type_alias_index(entries: Vec[TypeAliasEntry]) -> TypeAliasIndex {
    TypeAliasIndex {
        entries: entries,
    }
}

fn empty_type_alias_index() -> TypeAliasIndex {
    type_alias_index(vec.new_vec())
}

fn typecheck_env(module_path: String, function_name: String, return_type: String, bindings: Vec[TypecheckBinding], generic_map_value: GenericMap, aliases: TypeAliasIndex, diagnostics: Vec[Diagnostic], instantiations: Vec[TypecheckInstantiation], in_loop: Bool, loop_break_types: Vec[String]) -> TypecheckEnv {
    TypecheckEnv {
        module_path: module_path,
        function_name: function_name,
        return_type: return_type,
        bindings: bindings,
        generic_map: generic_map_value,
        aliases: aliases,
        diagnostics: diagnostics,
        instantiations: instantiations,
        in_loop: in_loop,
        loop_break_types: loop_break_types,
    }
}

fn expr_check(env: TypecheckEnv, type_text_value: String) -> ExprCheck {
    ExprCheck {
        env: env,
        type_text: type_text_value,
    }
}

fn effect_call_edge(caller_module: String, caller_name: String, callee_module: String, callee_name: String, effect_names: Vec[String], span: SourceSpan) -> EffectCallEdge {
    EffectCallEdge {
        caller_module: caller_module,
        caller_name: caller_name,
        callee_module: callee_module,
        callee_name: callee_name,
        effect_names: effect_names,
        span: span,
    }
}

fn effect_function_entry(module_path: String, name: String, effect_names: Vec[String], capability_names: Vec[String], direct_effect_names: Vec[String], call_edges: Vec[EffectCallEdge], span: SourceSpan, body_span: SourceSpan, has_body: Bool) -> EffectFunctionEntry {
    EffectFunctionEntry {
        module_path: module_path,
        name: name,
        effect_names: effect_names,
        capability_names: capability_names,
        direct_effect_names: direct_effect_names,
        call_edges: call_edges,
        span: span,
        body_span: body_span,
        has_body: has_body,
    }
}

fn effect_scan(diagnostics: Vec[Diagnostic], effect_names: Vec[String], call_edges: Vec[EffectCallEdge]) -> EffectScan {
    EffectScan {
        diagnostics: diagnostics,
        effect_names: effect_names,
        call_edges: call_edges,
    }
}

fn effect_body_result(entries: Vec[EffectFunctionEntry], diagnostics: Vec[Diagnostic]) -> EffectBodyResult {
    EffectBodyResult {
        entries: entries,
        diagnostics: diagnostics,
    }
}

fn effect_path(names: Vec[String], span: SourceSpan, found: Bool) -> EffectPath {
    EffectPath {
        names: names,
        span: span,
        found: found,
    }
}

fn ownership_binding(name: String, type_text_value: String, mutable: Bool, span_value: SourceSpan) -> OwnershipBinding {
    OwnershipBinding {
        name: name,
        type_text: type_text_value,
        mutable: mutable,
        span: span_value,
    }
}

fn active_borrow(target: String, mutable: Bool, owner: String, span_value: SourceSpan) -> ActiveBorrow {
    ActiveBorrow {
        target: target,
        mutable: mutable,
        owner: owner,
        span: span_value,
    }
}

fn moved_binding(name: String, span_value: SourceSpan) -> MovedBinding {
    MovedBinding {
        name: name,
        span: span_value,
    }
}

fn resource_use(name: String, kind: String, closed_by: String, span_value: SourceSpan) -> ResourceUse {
    ResourceUse {
        name: name,
        kind: kind,
        closed_by: closed_by,
        span: span_value,
    }
}

fn resource_protocol_op(kind: String, terminal: Bool, api: String, first_param_base_type: String) -> ResourceProtocolOp {
    ResourceProtocolOp {
        kind: kind,
        terminal: terminal,
        api: api,
        first_param_base_type: first_param_base_type,
    }
}

fn ownership_state(bindings: Vec[OwnershipBinding], borrows: Vec[ActiveBorrow], moved: Vec[MovedBinding], resources: Vec[ResourceUse], diagnostics: Vec[Diagnostic]) -> OwnershipState {
    OwnershipState {
        bindings: bindings,
        borrows: borrows,
        moved: moved,
        resources: resources,
        diagnostics: diagnostics,
    }
}

fn same_type_kind(left: TypecheckTypeKind, right: TypecheckTypeKind) -> Bool {
    match left {
        TypecheckUnitType => match right { TypecheckUnitType => true, _ => false },
        TypecheckBoolType => match right { TypecheckBoolType => true, _ => false },
        TypecheckIntType => match right { TypecheckIntType => true, _ => false },
        TypecheckUIntType => match right { TypecheckUIntType => true, _ => false },
        TypecheckFloatType => match right { TypecheckFloatType => true, _ => false },
        TypecheckStringType => match right { TypecheckStringType => true, _ => false },
        TypecheckCharType => match right { TypecheckCharType => true, _ => false },
        TypecheckNamedType => match right { TypecheckNamedType => true, _ => false },
        TypecheckFunctionType => match right { TypecheckFunctionType => true, _ => false },
        TypecheckDynTraitType => match right { TypecheckDynTraitType => true, _ => false },
        TypecheckHoleType => match right { TypecheckHoleType => true, _ => false },
        TypecheckUnknownType => match right { TypecheckUnknownType => true, _ => false },
    }
}

fn same_value_kind(left: TypecheckValueKind, right: TypecheckValueKind) -> Bool {
    match left {
        TypecheckLocalValue => match right { TypecheckLocalValue => true, _ => false },
        TypecheckConstValue => match right { TypecheckConstValue => true, _ => false },
        TypecheckFunctionValue => match right { TypecheckFunctionValue => true, _ => false },
        TypecheckVariantValue => match right { TypecheckVariantValue => true, _ => false },
        TypecheckTemporaryValue => match right { TypecheckTemporaryValue => true, _ => false },
    }
}

fn same_symbol_kind(left: ResolverSymbolKind, right: ResolverSymbolKind) -> Bool {
    match left {
        ResolverFunctionSymbol => match right { ResolverFunctionSymbol => true, _ => false },
        ResolverStructSymbol => match right { ResolverStructSymbol => true, _ => false },
        ResolverEnumSymbol => match right { ResolverEnumSymbol => true, _ => false },
        ResolverVariantSymbol => match right { ResolverVariantSymbol => true, _ => false },
        ResolverTraitSymbol => match right { ResolverTraitSymbol => true, _ => false },
        ResolverImplSymbol => match right { ResolverImplSymbol => true, _ => false },
        ResolverConstSymbol => match right { ResolverConstSymbol => true, _ => false },
        ResolverTypeAliasSymbol => match right { ResolverTypeAliasSymbol => true, _ => false },
        ResolverFieldSymbol => match right { ResolverFieldSymbol => true, _ => false },
        ResolverMethodSymbol => match right { ResolverMethodSymbol => true, _ => false },
        ResolverModuleSymbol => match right { ResolverModuleSymbol => true, _ => false },
    }
}

fn same_namespace(left: ResolverNamespace, right: ResolverNamespace) -> Bool {
    match left {
        ResolverValueNamespace => match right { ResolverValueNamespace => true, _ => false },
        ResolverTypeNamespace => match right { ResolverTypeNamespace => true, _ => false },
        ResolverMemberNamespace => match right { ResolverMemberNamespace => true, _ => false },
        ResolverModuleNamespace => match right { ResolverModuleNamespace => true, _ => false },
    }
}

fn append_diagnostic_if_room(diagnostics: Vec[Diagnostic], max_errors: Int, diagnostic_value: Diagnostic) -> Vec[Diagnostic] {
    if vec.vec_len(diagnostics) < max_errors {
        vec.push(diagnostics, diagnostic_value)
    } else {
        diagnostics
    }
}

fn append_all_diagnostics(left: Vec[Diagnostic], right: Vec[Diagnostic], max_errors: Int) -> Vec[Diagnostic] {
    let mut out = left;
    let mut index = 0;
    while index < vec.vec_len(right) {
        match vec.get(right, index) {
            Some(diag) => if true {
                out = append_diagnostic_if_room(out, max_errors, diag);
                ()
            } else {
                ()
            },
            None => (),
        };
        index = index + 1;
    };
    out
}

fn env_error(env: TypecheckEnv, max_errors: Int, code: String, span_value: SourceSpan, message: String, help: String) -> TypecheckEnv {
    let diag = if help == "" {
        error(diagnostic_code(code), span_value, message)
    } else {
        with_help(error(diagnostic_code(code), span_value, message), help)
    };
    typecheck_env(env.module_path, env.function_name, env.return_type, env.bindings, env.generic_map, env.aliases, append_diagnostic_if_room(env.diagnostics, max_errors, diag), env.instantiations, env.in_loop, env.loop_break_types)
}

fn env_with_loop_state(env: TypecheckEnv, in_loop: Bool, loop_break_types: Vec[String]) -> TypecheckEnv {
    typecheck_env(env.module_path, env.function_name, env.return_type, env.bindings, env.generic_map, env.aliases, env.diagnostics, env.instantiations, in_loop, loop_break_types)
}

fn env_with_loop(env: TypecheckEnv, in_loop: Bool) -> TypecheckEnv {
    typecheck_env(env.module_path, env.function_name, env.return_type, env.bindings, env.generic_map, env.aliases, env.diagnostics, env.instantiations, in_loop, env.loop_break_types)
}

fn loop_break_type_stack_push(stack: Vec[String], value: String) -> Vec[String] {
    vec.push(stack, value)
}

fn loop_break_type_stack_top(stack: Vec[String]) -> String {
    let len = vec.vec_len(stack);
    if len == 0 {
        ""
    } else {
        match vec.get(stack, len - 1) {
            Some(value) => value,
            None => "",
        }
    }
}

fn loop_break_type_stack_set_top(stack: Vec[String], value: String) -> Vec[String] {
    let mut out: Vec[String] = vec.new_vec();
    let mut index = 0;
    let last = vec.vec_len(stack) - 1;
    while index < vec.vec_len(stack) {
        match vec.get(stack, index) {
            Some(item) => if index == last {
                out = vec.push(out, value);
                ()
            } else {
                out = vec.push(out, item);
                ()
            },
            None => (),
        };
        index = index + 1;
    };
    out
}

fn env_push_loop(env: TypecheckEnv, break_type: String) -> TypecheckEnv {
    env_with_loop_state(env, true, loop_break_type_stack_push(env.loop_break_types, break_type))
}

fn env_restore_loop_state(env: TypecheckEnv, outer: TypecheckEnv) -> TypecheckEnv {
    env_with_loop_state(env, outer.in_loop, outer.loop_break_types)
}

fn append_binding(env: TypecheckEnv, item: TypecheckBinding) -> TypecheckEnv {
    typecheck_env(env.module_path, env.function_name, env.return_type, vec.push(env.bindings, item), env.generic_map, env.aliases, env.diagnostics, env.instantiations, env.in_loop, env.loop_break_types)
}

fn clone_typecheck_bindings(bindings: Vec[TypecheckBinding]) -> Vec[TypecheckBinding] {
    let mut out: Vec[TypecheckBinding] = vec.new_vec();
    let mut index = 0;
    while index < vec.vec_len(bindings) {
        match vec.get(bindings, index) {
            Some(binding) => if true {
                out = vec.push(out, binding);
                ()
            } else {
                ()
            },
            None => (),
        };
        index = index + 1;
    };
    out
}

fn env_with_bindings(env: TypecheckEnv, bindings: Vec[TypecheckBinding]) -> TypecheckEnv {
    typecheck_env(env.module_path, env.function_name, env.return_type, bindings, env.generic_map, env.aliases, env.diagnostics, env.instantiations, env.in_loop, env.loop_break_types)
}

fn append_instantiation(env: TypecheckEnv, item: TypecheckInstantiation) -> TypecheckEnv {
    if has_instantiation(env.instantiations, item.name, item.kind, item.type_args) {
        env
    } else {
        typecheck_env(env.module_path, env.function_name, env.return_type, env.bindings, env.generic_map, env.aliases, env.diagnostics, vec.push(env.instantiations, item), env.in_loop, env.loop_break_types)
    }
}

fn append_function(output: TypecheckOutput, item: TypecheckFunction) -> TypecheckOutput {
    typecheck_output(output.entry_module, vec.push(output.functions, item), output.bindings, output.instantiations, output.diagnostics)
}

fn append_bindings(output: TypecheckOutput, bindings: Vec[TypecheckBinding]) -> TypecheckOutput {
    let mut out = output;
    let mut index = 0;
    while index < vec.vec_len(bindings) {
        match vec.get(bindings, index) {
            Some(binding) => if true {
                out = typecheck_output(out.entry_module, out.functions, vec.push(out.bindings, binding), out.instantiations, out.diagnostics);
                ()
            } else {
                ()
            },
            None => (),
        };
        index = index + 1;
    };
    out
}

fn append_instantiations(output: TypecheckOutput, instantiations: Vec[TypecheckInstantiation]) -> TypecheckOutput {
    let mut out = output;
    let mut index = 0;
    while index < vec.vec_len(instantiations) {
        match vec.get(instantiations, index) {
            Some(item) => if has_instantiation(out.instantiations, item.name, item.kind, item.type_args) {
                ()
            } else {
                out = typecheck_output(out.entry_module, out.functions, out.bindings, vec.push(out.instantiations, item), out.diagnostics);
            },
            None => (),
        };
        index = index + 1;
    };
    out
}

fn output_with_diagnostics(output: TypecheckOutput, diagnostics: Vec[Diagnostic], max_errors: Int) -> TypecheckOutput {
    typecheck_output(output.entry_module, output.functions, output.bindings, output.instantiations, append_all_diagnostics(output.diagnostics, diagnostics, max_errors))
}

fn same_string_vec(left: Vec[String], right: Vec[String]) -> Bool {
    if vec.vec_len(left) != vec.vec_len(right) {
        false
    } else {
        let mut ok = true;
        let mut index = 0;
        while ok && index < vec.vec_len(left) {
            let left_value = match vec.get(left, index) { Some(value) => value, None => "" };
            let right_value = match vec.get(right, index) { Some(value) => value, None => "" };
            if left_value == right_value {
                ()
            } else {
                ok = false;
            };
            index = index + 1;
        };
        ok
    }
}

fn string_vec_contains(values: Vec[String], value: String) -> Bool {
    let mut found = false;
    let mut index = 0;
    while !found && index < vec.vec_len(values) {
        match vec.get(values, index) {
            Some(item) => if item == value {
                found = true;
            } else {
                ()
            },
            None => (),
        };
        index = index + 1;
    };
    found
}

fn push_unique_string(values: Vec[String], value: String) -> Vec[String] {
    if string_vec_contains(values, value) {
        values
    } else {
        vec.push(values, value)
    }
}

fn append_unique_strings(left: Vec[String], right: Vec[String]) -> Vec[String] {
    let mut out = left;
    let mut index = 0;
    while index < vec.vec_len(right) {
        match vec.get(right, index) {
            Some(value) => if true {
                out = push_unique_string(out, value);
                ()
            } else {
                ()
            },
            None => (),
        };
        index = index + 1;
    };
    out
}

fn join3(left: String, middle: String, right: String) -> String {
    let mut parts: Vec[String] = vec.new_vec();
    parts = vec.push(parts, left);
    parts = vec.push(parts, middle);
    parts = vec.push(parts, right);
    string.join(parts, "")
}

fn has_instantiation(items: Vec[TypecheckInstantiation], name: String, kind: String, type_args: Vec[String]) -> Bool {
    let mut found = false;
    let mut index = 0;
    while !found && index < vec.vec_len(items) {
        match vec.get(items, index) {
            Some(item) => if item.name == name && item.kind == kind && same_string_vec(item.type_args, type_args) {
                found = true;
            } else {
                ()
            },
            None => (),
        };
        index = index + 1;
    };
    found
}

fn path_tail(path: String) -> String {
    let parts = string.split(path, ".");
    let count = vec.vec_len(parts);
    if count == 0 {
        path
    } else {
        match vec.get(parts, count - 1) {
            Some(value) => value,
            None => path,
        }
    }
}

fn path_prefix(path: String) -> String {
    let parts = string.split(path, ".");
    let count = vec.vec_len(parts);
    if count <= 1 {
        ""
    } else {
        let mut prefix: Vec[String] = vec.new_vec();
        let mut index = 0;
        while index + 1 < count {
            match vec.get(parts, index) {
                Some(value) => if true {
                    prefix = vec.push(prefix, value);
                    ()
                } else {
                    ()
                },
                None => (),
            };
            index = index + 1;
        };
        string.join(prefix, ".")
    }
}

fn source_contains_type_args(text: String) -> Bool {
    string.contains(text, "[") && string.contains(text, "]")
}

fn nominal_type_name(text: String) -> String {
    if source_contains_type_args(text) {
        let parts = string.split(text, "[");
        match vec.get(parts, 0) {
            Some(value) => value,
            None => text,
        }
    } else if string.starts_with(text, "dyn ") {
        string.substring(text, 4, string.len(text))
    } else {
        text
    }
}

fn push_generic_arg(out: Vec[String], raw: String) -> Vec[String] {
    let trimmed = string.trim(raw);
    if trimmed == "" {
        out
    } else {
        vec.push(out, trimmed)
    }
}

fn generic_arg_texts(text: String) -> Vec[String] {
    let mut out: Vec[String] = vec.new_vec();
    let mut in_args = false;
    let mut done = false;
    let mut depth = 0;
    let mut arg_start = 0;
    let mut index = 0;
    while !done && index < string.len(text) {
        let ch = match string.char_at(text, index) {
            Some(value) => value,
            None => "",
        };
        if ch == "[" {
            if in_args {
                depth = depth + 1;
            } else {
                in_args = true;
                arg_start = index + 1;
            }
        } else if ch == "]" {
            if in_args && depth == 0 {
                out = push_generic_arg(out, string.substring(text, arg_start, index));
                done = true;
            } else if in_args {
                depth = depth - 1;
            } else {
                ()
            }
        } else if ch == "," && in_args && depth == 0 {
            out = push_generic_arg(out, string.substring(text, arg_start, index));
            arg_start = index + 1;
        } else {
            ()
        };
        index = index + 1;
    };
    out
}

fn type_from_text(text: String, span_value: SourceSpan) -> TypecheckType {
    if text == "()" {
        typecheck_type(TypecheckUnitType(), text, text, 0, span_value)
    } else if text == "Bool" {
        typecheck_type(TypecheckBoolType(), text, text, 0, span_value)
    } else if text == "String" {
        typecheck_type(TypecheckStringType(), text, text, 0, span_value)
    } else if text == "Char" {
        typecheck_type(TypecheckCharType(), text, text, 0, span_value)
    } else if is_signed_int_type(text) {
        typecheck_type(TypecheckIntType(), text, text, 0, span_value)
    } else if is_unsigned_int_type(text) {
        typecheck_type(TypecheckUIntType(), text, text, 0, span_value)
    } else if is_float_type(text) {
        typecheck_type(TypecheckFloatType(), text, text, 0, span_value)
    } else if string.starts_with(text, "Fn(") {
        typecheck_type(TypecheckFunctionType(), text, "Fn", 0, span_value)
    } else if string.starts_with(text, "dyn ") {
        typecheck_type(TypecheckDynTraitType(), text, nominal_type_name(text), 0, span_value)
    } else if text == "_" {
        typecheck_type(TypecheckHoleType(), text, text, 0, span_value)
    } else if text == "" || text == "<unknown>" {
        typecheck_type(TypecheckUnknownType(), "<unknown>", "<unknown>", 0, span_value)
    } else {
        typecheck_type(TypecheckNamedType(), text, nominal_type_name(text), vec.vec_len(generic_arg_texts(text)), span_value)
    }
}

fn is_signed_int_type(text: String) -> Bool {
    text == "Int" || text == "Int8" || text == "Int16" || text == "Int32" || text == "Int64" || text == "Int128" || text == "isize"
}

fn is_unsigned_int_type(text: String) -> Bool {
    text == "UInt" || text == "UInt8" || text == "UInt16" || text == "UInt32" || text == "UInt64" || text == "UInt128" || text == "usize"
}

fn is_integer_type(text: String) -> Bool {
    is_signed_int_type(text) || is_unsigned_int_type(text)
}

fn integer_type_is_signed(text: String) -> Bool {
    text == "Int" || text == "Int8" || text == "Int16" || text == "Int32" || text == "Int64" || text == "Int128" || text == "isize"
}

fn integer_type_bits(text: String) -> Int {
    if text == "Int8" || text == "UInt8" {
        8
    } else if text == "Int16" || text == "UInt16" {
        16
    } else if text == "Int32" || text == "UInt32" {
        32
    } else if text == "Int128" || text == "UInt128" {
        128
    } else {
        64
    }
}

fn integer_conversion_is_lossless(expected: String, found: String) -> Bool {
    if is_integer_type(expected) && is_integer_type(found) {
        let expected_signed = integer_type_is_signed(expected);
        let found_signed = integer_type_is_signed(found);
        let expected_bits = integer_type_bits(expected);
        let found_bits = integer_type_bits(found);
        if expected_signed && found_signed {
            found_bits <= expected_bits
        } else if expected_signed && !found_signed {
            expected_bits > found_bits
        } else if !expected_signed && !found_signed {
            found_bits <= expected_bits
        } else {
            false
        }
    } else {
        false
    }
}

fn is_float_type(text: String) -> Bool {
    text == "Float" || text == "Float32" || text == "Float64"
}

fn collect_type_aliases(units: Vec[ResolveUnit]) -> TypeAliasIndex {
    let mut entries: Vec[TypeAliasEntry] = vec.new_vec();
    let mut unit_index = 0;
    while unit_index < vec.vec_len(units) {
        match vec.get(units, unit_index) {
            Some(unit) => if true {
                let mut item_index = 0;
                while item_index < vec.vec_len(unit.program.items) {
                    match vec.get(unit.program.items, item_index) {
                        Some(item) => match item.type_alias_item {
                            Some(alias_item) => if true {
                                entries = vec.push(entries, type_alias_entry(unit.module_path, alias_item));
                                ()
                            } else {
                                ()
                            },
                            None => (),
                        },
                        None => (),
                    };
                    item_index = item_index + 1;
                };
                ()
            } else {
                ()
            },
            None => (),
        };
        unit_index = unit_index + 1;
    };
    type_alias_index(entries)
}

fn canonical_type_text(aliases: TypeAliasIndex, module_path: String, text: String) -> String {
    if text == "Float" {
        "Float64"
    } else if text == "UInt" {
        "usize"
    } else {
        match find_type_alias(aliases, module_path, nominal_type_name(text)) {
            Some(alias_item) => expand_type_alias(alias_item, text),
            None => match find_consistent_type_alias(aliases, nominal_type_name(text)) {
                Some(alias_item) => expand_type_alias(alias_item, text),
                None => text,
            },
        }
    }
}

fn type_alias_matches_arity(alias_item: AstTypeAliasDecl, text: String) -> Bool {
    vec.vec_len(alias_item.generic_params.params) == vec.vec_len(generic_arg_texts(text))
}

fn expand_type_alias(alias_item: AstTypeAliasDecl, text: String) -> String {
    if type_alias_matches_arity(alias_item, text) {
        substitute_type_alias(alias_item, generic_arg_texts(text))
    } else {
        text
    }
}

fn substitute_type_alias(alias_item: AstTypeAliasDecl, args: Vec[String]) -> String {
    let mut out = type_text(alias_item.target_type);
    let mut index = 0;
    while index < vec.vec_len(alias_item.generic_params.params) {
        match vec.get(alias_item.generic_params.params, index) {
            Some(param) => match vec.get(args, index) {
                Some(arg) => if true {
                    out = string.replace(out, param.name.value, arg);
                    ()
                } else {
                    ()
                },
                None => (),
            },
            None => (),
        };
        index = index + 1;
    };
    out
}

fn types_compatible(aliases: TypeAliasIndex, module_path: String, expected: String, found: String) -> Bool {
    let expected_canonical = canonical_type_text(aliases, module_path, expected);
    let found_canonical = canonical_type_text(aliases, module_path, found);
    if expected == "<unknown>" || found == "<unknown>" || expected == "_" || found == "_" {
        true
    } else if expected == found || expected_canonical == found_canonical {
        true
    } else if string.starts_with(expected, "Fn") && found == "Fn" {
        true
    } else if expected == "Fn" && string.starts_with(found, "Fn") {
        true
    } else if integer_conversion_is_lossless(expected_canonical, found_canonical) {
        true
    } else {
        false
    }
}

fn find_type_alias(aliases: TypeAliasIndex, module_path: String, name: String) -> Option[AstTypeAliasDecl] {
    let mut out: Option[AstTypeAliasDecl] = None();
    let mut found = false;
    let mut index = 0;
    while !found && index < vec.vec_len(aliases.entries) {
        match vec.get(aliases.entries, index) {
            Some(entry) => if entry.module_path == module_path && entry.alias_item.name.value == name {
                out = Some(entry.alias_item);
                found = true;
            } else {
                ()
            },
            None => (),
        };
        index = index + 1;
    };
    out
}

fn same_type_alias_shape(left: AstTypeAliasDecl, right: AstTypeAliasDecl) -> Bool {
    type_text(left.target_type) == type_text(right.target_type) && vec.vec_len(left.generic_params.params) == vec.vec_len(right.generic_params.params)
}

fn find_consistent_type_alias(aliases: TypeAliasIndex, name: String) -> Option[AstTypeAliasDecl] {
    let mut out: Option[AstTypeAliasDecl] = None();
    let mut count = 0;
    let mut consistent = true;
    let mut index = 0;
    while index < vec.vec_len(aliases.entries) {
        match vec.get(aliases.entries, index) {
            Some(entry) => if entry.alias_item.name.value == name {
                if count == 0 {
                    out = Some(entry.alias_item);
                    count = 1;
                } else {
                    match out {
                        Some(existing) => if same_type_alias_shape(existing, entry.alias_item) {
                            count = count + 1;
                        } else {
                            consistent = false;
                            count = count + 1;
                        },
                        None => (),
                    }
                }
            } else {
                ()
            },
            None => (),
        };
        index = index + 1;
    };
    if count > 0 && consistent {
        out
    } else {
        None()
    }
}

fn find_binding(bindings: Vec[TypecheckBinding], name: String) -> Option[TypecheckBinding] {
    let mut out: Option[TypecheckBinding] = None();
    let mut found = false;
    let mut index = 0;
    while !found && index < vec.vec_len(bindings) {
        match vec.get(bindings, index) {
            Some(binding) => if binding.name == name {
                out = Some(binding);
                found = true;
            } else {
                ()
            },
            None => (),
        };
        index = index + 1;
    };
    out
}

fn add_or_update_generic(map: GenericMap, name: String, value: String) -> GenericMap {
    let mut names = map.names;
    let mut values = map.values;
    let mut found = false;
    let mut index = 0;
    while !found && index < vec.vec_len(names) {
        match vec.get(names, index) {
            Some(existing) => if existing == name {
                found = true;
            } else {
                ()
            },
            None => (),
        };
        index = index + 1;
    };
    if found {
        map
    } else {
        names = vec.push(names, name);
        values = vec.push(values, value);
        generic_map(names, values)
    }
}

fn generic_value(map: GenericMap, name: String) -> Option[String] {
    let mut out: Option[String] = None();
    let mut found = false;
    let mut index = 0;
    while !found && index < vec.vec_len(map.names) {
        match vec.get(map.names, index) {
            Some(existing) => if existing == name {
                out = vec.get(map.values, index);
                found = true;
            } else {
                ()
            },
            None => (),
        };
        index = index + 1;
    };
    out
}

fn add_generic_bindings_from_type(map: GenericMap, params: AstGenericParamList, pattern_text: String, found_text: String) -> GenericMap {
    if found_text == "<unknown>" || found_text == "_" {
        map
    } else if is_generic_param(params, pattern_text) {
        add_or_update_generic(map, pattern_text, found_text)
    } else if nominal_type_name(pattern_text) == nominal_type_name(found_text) {
        let pattern_args = generic_arg_texts(pattern_text);
        let found_args = generic_arg_texts(found_text);
        let mut out = map;
        let mut index = 0;
        while index < vec.vec_len(pattern_args) && index < vec.vec_len(found_args) {
            match vec.get(pattern_args, index) {
                Some(pattern_arg) => match vec.get(found_args, index) {
                    Some(found_arg) => if true {
                        out = add_generic_bindings_from_type(out, params, pattern_arg, found_arg);
                        ()
                    } else {
                        ()
                    },
                    None => (),
                },
                None => (),
            };
            index = index + 1;
        };
        out
    } else {
        map
    }
}

fn add_expected_return_generics(map: GenericMap, params: AstGenericParamList, return_text: String, expected: String) -> GenericMap {
    if expected == "<unknown>" || expected == "_" {
        map
    } else {
        add_generic_bindings_from_type(map, params, return_text, expected)
    }
}

fn instantiate_type_text(text: String, map: GenericMap) -> String {
    let mut out = text;
    let mut index = 0;
    while index < vec.vec_len(map.names) {
        match vec.get(map.names, index) {
            Some(name) => match vec.get(map.values, index) {
                Some(value) => if true {
                    out = string.replace(out, name, value);
                    ()
                } else {
                    ()
                },
                None => (),
            },
            None => (),
        };
        index = index + 1;
    };
    out
}

fn module_exists(units: Vec[ResolveUnit], module_path: String) -> Bool {
    let mut found = false;
    let mut index = 0;
    while !found && index < vec.vec_len(units) {
        match vec.get(units, index) {
            Some(unit) => if unit.module_path == module_path {
                found = true;
            } else {
                ()
            },
            None => (),
        };
        index = index + 1;
    };
    found
}

fn import_alias_is_ambiguous(imports: Vec[ResolvedImport], module_path: String, alias: String) -> Bool {
    let mut count = 0;
    let mut index = 0;
    while index < vec.vec_len(imports) {
        match vec.get(imports, index) {
            Some(import_item) => if import_item.module_path == module_path && import_item.alias == alias && import_item.resolved {
                count = count + 1;
            } else {
                ()
            },
            None => (),
        };
        index = index + 1;
    };
    count > 1
}

fn resolve_import_alias(imports: Vec[ResolvedImport], module_path: String, alias: String) -> Option[String] {
    let mut out: Option[String] = None();
    let mut found = false;
    let mut index = 0;
    while !found && index < vec.vec_len(imports) {
        match vec.get(imports, index) {
            Some(import_item) => if import_item.module_path == module_path && import_item.alias == alias && import_item.resolved && !import_item.ambiguous {
                out = Some(import_item.import_path);
                found = true;
            } else {
                ()
            },
            None => (),
        };
        index = index + 1;
    };
    out
}

fn can_access_symbol(symbol: ResolvedSymbol, requester_module: String) -> Bool {
    if symbol.module_path == requester_module {
        true
    } else {
        match symbol.visibility {
            PublicVisibility => true,
            PublicCrateVisibility => true,
            PrivateVisibility => false,
        }
    }
}

fn find_symbol(symbols: Vec[ResolvedSymbol], module_path: String, name: String, kind: ResolverSymbolKind, namespace: ResolverNamespace) -> Option[ResolvedSymbol] {
    let mut out: Option[ResolvedSymbol] = None();
    let mut found = false;
    let mut index = 0;
    while !found && index < vec.vec_len(symbols) {
        match vec.get(symbols, index) {
            Some(symbol) => if symbol.module_path == module_path && symbol.name == name && same_symbol_kind(symbol.kind, kind) && same_namespace(symbol.namespace, namespace) {
                out = Some(symbol);
                found = true;
            } else {
                ()
            },
            None => (),
        };
        index = index + 1;
    };
    out
}

fn find_member_symbol(symbols: Vec[ResolvedSymbol], owner_name: String, name: String, kind: ResolverSymbolKind) -> Option[ResolvedSymbol] {
    let mut out: Option[ResolvedSymbol] = None();
    let mut found = false;
    let mut index = 0;
    while !found && index < vec.vec_len(symbols) {
        match vec.get(symbols, index) {
            Some(symbol) => if symbol.owner_name == owner_name && symbol.name == name && same_symbol_kind(symbol.kind, kind) {
                out = Some(symbol);
                found = true;
            } else {
                ()
            },
            None => (),
        };
        index = index + 1;
    };
    out
}

fn lookup_unqualified_symbol(symbols: Vec[ResolvedSymbol], imports: Vec[ResolvedImport], requester_module: String, name: String, kind: ResolverSymbolKind, namespace: ResolverNamespace) -> Option[ResolvedSymbol] {
    let own = find_symbol(symbols, requester_module, name, kind, namespace);
    match own {
        Some(_) => own,
        None => if true {
            let mut out: Option[ResolvedSymbol] = None();
            let mut found = false;
            let mut index = 0;
            while !found && index < vec.vec_len(imports) {
                match vec.get(imports, index) {
                    Some(import_item) => if import_item.module_path == requester_module && import_item.resolved && !import_item.ambiguous {
                        match find_symbol(symbols, import_item.import_path, name, kind, namespace) {
                            Some(symbol) => if can_access_symbol(symbol, requester_module) {
                                out = Some(symbol);
                                found = true;
                            } else {
                                ()
                            },
                            None => (),
                        };
                    } else {
                        ()
                    },
                    None => (),
                };
                index = index + 1;
            };
            out
        } else {
            None()
        },
    }
}

fn resolve_qualified_module(imports: Vec[ResolvedImport], units: Vec[ResolveUnit], requester_module: String, module_text: String) -> Option[String] {
    if module_exists(units, module_text) {
        Some(module_text)
    } else if string.contains(module_text, ".") {
        None()
    } else {
        resolve_import_alias(imports, requester_module, module_text)
    }
}

fn lookup_value_symbol(units: Vec[ResolveUnit], resolver: ResolverOutput, module_path: String, name: String, kind: ResolverSymbolKind, namespace: ResolverNamespace) -> Option[ResolvedSymbol] {
    let module_text = path_prefix(name);
    let item_name = path_tail(name);
    if module_text == "" {
        lookup_unqualified_symbol(resolver.symbols, resolver.imports, module_path, item_name, kind, namespace)
    } else {
        match resolve_qualified_module(resolver.imports, units, module_path, module_text) {
            Some(target_module) => find_symbol(resolver.symbols, target_module, item_name, kind, namespace),
            None => None(),
        }
    }
}

fn symbol_type_name_by_id(symbols: Vec[ResolvedSymbol], id: ResolverSymbolId) -> String {
    let mut out = "<unknown>";
    let mut found = false;
    let mut index = 0;
    while !found && index < vec.vec_len(symbols) {
        match vec.get(symbols, index) {
            Some(symbol) => if symbol.id.value == id.value {
                out = symbol.type_name;
                found = true;
            } else {
                ()
            },
            None => (),
        };
        index = index + 1;
    };
    out
}

