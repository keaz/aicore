fn enum_name_for_variant(units: Vec[ResolveUnit], variant_name: String) -> String {
    let mut out = "<unknown>";
    let mut found = false;
    let mut unit_index = 0;
    while !found && unit_index < vec.vec_len(units) {
        match vec.get(units, unit_index) {
            Some(unit) => if true {
                let mut item_index = 0;
                while !found && item_index < vec.vec_len(unit.program.items) {
                    match vec.get(unit.program.items, item_index) {
                        Some(item) => match item.enum_item {
                            Some(enum_item) => if true {
                                let mut variant_index = 0;
                                while !found && variant_index < vec.vec_len(enum_item.variants) {
                                    match vec.get(enum_item.variants, variant_index) {
                                        Some(variant) => if variant.name.value == variant_name {
                                            out = enum_item.name.value;
                                            found = true;
                                        } else {
                                            ()
                                        },
                                        None => (),
                                    };
                                    variant_index = variant_index + 1;
                                };
                                ()
                            } else {
                                ()
                            },
                            None => (),
                        },
                        None => (),
                    };
                    item_index = item_index + 1;
                };
                ()
            } else {
                ()
            },
            None => (),
        };
        unit_index = unit_index + 1;
    };
    out
}

fn direct_expr_index_at(expr: AstExpr, child_index: Int) -> Int {
    let mut out = -1;
    let mut found = false;
    let mut direct_index = 0;
    let mut node_index = 0;
    while !found && node_index < vec.vec_len(expr.nodes) {
        match vec.get(expr.nodes, node_index) {
            Some(node) => if node.depth == 1 {
                if direct_index == child_index {
                    out = node_index;
                    found = true;
                } else {
                    direct_index = direct_index + 1;
                }
            } else {
                ()
            },
            None => (),
        };
        node_index = node_index + 1;
    };
    out
}

fn direct_expr_node_at(expr: AstExpr, child_index: Int) -> Option[AstExprNode] {
    let node_index = direct_expr_index_at(expr, child_index);
    if node_index < 0 {
        None()
    } else {
        vec.get(expr.nodes, node_index)
    }
}

fn expr_from_node(node: AstExprNode) -> AstExpr {
    simple_expr(node.kind, node.op, node.name, node.span, node.text)
}

fn expr_node_with_depth_offset(node: AstExprNode, depth_offset: Int) -> AstExprNode {
    ast_expr_node(node.kind, node.role, node.op, node.name, node.direct_child_count, node.depth - depth_offset, node.patterns, node.match_arms, node.span, node.text)
}

fn expr_from_node_index(expr: AstExpr, node_index: Int) -> Option[AstExpr] {
    match vec.get(expr.nodes, node_index) {
        Some(root) => if true {
            let mut nodes: Vec[AstExprNode] = vec.new_vec();
            let mut index = node_index + 1;
            let mut collect = true;
            while collect && index < vec.vec_len(expr.nodes) {
                match vec.get(expr.nodes, index) {
                    Some(node) => if node.depth > root.depth {
                        nodes = vec.push(nodes, expr_node_with_depth_offset(node, root.depth));
                    } else {
                        collect = false;
                    },
                    None => (),
                };
                index = index + 1;
            };
            Some(ast_expr(root.kind, root.op, root.name, root.direct_child_count, nodes, root.patterns, root.match_arms, root.span, root.text))
        } else {
            None()
        },
        None => None(),
    }
}

fn direct_expr_at(expr: AstExpr, child_index: Int) -> Option[AstExpr] {
    let node_index = direct_expr_index_at(expr, child_index);
    if node_index < 0 {
        None()
    } else {
        expr_from_node_index(expr, node_index)
    }
}

fn role_tail(role: String, prefix: String) -> String {
    if string.starts_with(role, prefix) {
        string.substring(role, string.len(prefix), string.len(role))
    } else {
        ""
    }
}

fn role_part(role: String, index: Int) -> String {
    let parts = string.split(role, ":");
    match vec.get(parts, index) {
        Some(value) => value,
        None => "",
    }
}

fn block_let_name(role: String) -> String {
    if string.starts_with(role, "let:") {
        role_part(role, 1)
    } else {
        ""
    }
}

fn block_let_type(role: String) -> String {
    if string.starts_with(role, "let:") {
        role_part(role, 2)
    } else {
        "<unknown>"
    }
}

fn block_let_mutable(role: String) -> Bool {
    role_part(role, 3) == "mut"
}

fn call_arg_count(expr: AstExpr) -> Int {
    let mut count = 0;
    let mut index = 0;
    while index < vec.vec_len(expr.nodes) {
        match vec.get(expr.nodes, index) {
            Some(node) => if node.depth == 1 && string.starts_with(node.role, "arg") {
                count = count + 1;
            } else {
                ()
            },
            None => (),
        };
        index = index + 1;
    };
    count
}

fn call_arg_index_at(expr: AstExpr, arg_index: Int) -> Int {
    let mut out = -1;
    let mut found = false;
    let mut count = 0;
    let mut index = 0;
    while !found && index < vec.vec_len(expr.nodes) {
        match vec.get(expr.nodes, index) {
            Some(node) => if node.depth == 1 && string.starts_with(node.role, "arg") {
                if count == arg_index {
                    out = index;
                    found = true;
                } else {
                    count = count + 1;
                }
            } else {
                ()
            },
            None => (),
        };
        index = index + 1;
    };
    out
}

fn call_arg_node(expr: AstExpr, arg_index: Int) -> Option[AstExprNode] {
    let node_index = call_arg_index_at(expr, arg_index);
    if node_index < 0 {
        None()
    } else {
        vec.get(expr.nodes, node_index)
    }
}

fn call_arg_expr(expr: AstExpr, arg_index: Int) -> Option[AstExpr] {
    let node_index = call_arg_index_at(expr, arg_index);
    if node_index < 0 {
        None()
    } else {
        expr_from_node_index(expr, node_index)
    }
}

fn field_value_count(expr: AstExpr) -> Int {
    let mut count = 0;
    let mut index = 0;
    while index < vec.vec_len(expr.nodes) {
        match vec.get(expr.nodes, index) {
            Some(node) => if node.depth == 1 && string.starts_with(node.role, "field:") {
                count = count + 1;
            } else {
                ()
            },
            None => (),
        };
        index = index + 1;
    };
    count
}

fn struct_field_index_at(expr: AstExpr, field_index: Int) -> Int {
    let mut out = -1;
    let mut found = false;
    let mut count = 0;
    let mut index = 0;
    while !found && index < vec.vec_len(expr.nodes) {
        match vec.get(expr.nodes, index) {
            Some(node) => if node.depth == 1 && string.starts_with(node.role, "field:") {
                if count == field_index {
                    out = index;
                    found = true;
                } else {
                    count = count + 1;
                }
            } else {
                ()
            },
            None => (),
        };
        index = index + 1;
    };
    out
}

fn struct_field_node(expr: AstExpr, field_index: Int) -> Option[AstExprNode] {
    let node_index = struct_field_index_at(expr, field_index);
    if node_index < 0 {
        None()
    } else {
        vec.get(expr.nodes, node_index)
    }
}

fn struct_field_expr(expr: AstExpr, field_index: Int) -> Option[AstExpr] {
    let node_index = struct_field_index_at(expr, field_index);
    if node_index < 0 {
        None()
    } else {
        expr_from_node_index(expr, node_index)
    }
}

fn field_name_exists(names: Vec[String], name: String) -> Bool {
    let mut found = false;
    let mut index = 0;
    while !found && index < vec.vec_len(names) {
        match vec.get(names, index) {
            Some(existing) => if existing == name {
                found = true;
            } else {
                ()
            },
            None => (),
        };
        index = index + 1;
    };
    found
}

fn struct_field_type(item: AstStructDecl, receiver_type: String, name: String) -> String {
    let struct_args = generic_arg_texts(receiver_type);
    let mut map = empty_generic_map();
    let mut gen_index = 0;
    while gen_index < vec.vec_len(item.generic_params.params) {
        match vec.get(item.generic_params.params, gen_index) {
            Some(param) => match vec.get(struct_args, gen_index) {
                Some(value) => if true {
                    map = add_or_update_generic(map, param.name.value, value);
                    ()
                } else {
                    ()
                },
                None => (),
            },
            None => (),
        };
        gen_index = gen_index + 1;
    };
    let mut out = "<unknown>";
    let mut found = false;
    let mut index = 0;
    while !found && index < vec.vec_len(item.fields) {
        match vec.get(item.fields, index) {
            Some(field) => if field.name.value == name {
                out = instantiate_type_text(type_text(field.type_ref), map);
                found = true;
            } else {
                ()
            },
            None => (),
        };
        index = index + 1;
    };
    out
}

fn has_trait_impl(semantics: SemanticOutput, trait_name: String, type_name_value: String) -> Bool {
    let mut found = false;
    let mut index = 0;
    while !found && index < vec.vec_len(semantics.impls) {
        match vec.get(semantics.impls, index) {
            Some(item) => if item.trait_name == trait_name && item.target_type == type_name_value && !item.conflicting {
                found = true;
            } else {
                ()
            },
            None => (),
        };
        index = index + 1;
    };
    found
}

fn generic_param_bound_count(params: AstGenericParamList, generic_name: String) -> Int {
    let mut out = 0;
    let mut found = false;
    let mut index = 0;
    while !found && index < vec.vec_len(params.params) {
        match vec.get(params.params, index) {
            Some(param) => if param.name.value == generic_name {
                out = vec.vec_len(param.bounds);
                found = true;
            } else {
                ()
            },
            None => (),
        };
        index = index + 1;
    };
    out
}

fn check_generic_bounds(env: TypecheckEnv, params: AstGenericParamList, semantics: SemanticOutput, max_errors: Int, span_value: SourceSpan) -> TypecheckEnv {
    let mut out = env;
    let mut index = 0;
    while index < vec.vec_len(params.params) {
        match vec.get(params.params, index) {
            Some(param) => match generic_value(out.generic_map, param.name.value) {
                Some(actual) => if true {
                    let mut bound_index = 0;
                    while bound_index < vec.vec_len(param.bounds) {
                        match vec.get(param.bounds, bound_index) {
                            Some(bound) => if has_trait_impl(semantics, bound.value, actual) {
                                ()
                            } else {
                                let mut parts: Vec[String] = vec.new_vec();
                                parts = vec.push(parts, "type '");
                                parts = vec.push(parts, actual);
                                parts = vec.push(parts, "' does not satisfy trait bound '");
                                parts = vec.push(parts, bound.value);
                                parts = vec.push(parts, "'");
                                out = env_error(out, max_errors, "E1258", span_value, string.join(parts, ""), "add a matching trait impl or choose a type that satisfies the bound");
                            },
                            None => (),
                        };
                        bound_index = bound_index + 1;
                    };
                    ()
                } else {
                    ()
                },
                None => (),
            },
            None => (),
        };
        index = index + 1;
    };
    out
}

fn infer_expr(expr: AstExpr, env: TypecheckEnv, units: Vec[ResolveUnit], resolver: ResolverOutput, semantics: SemanticOutput, max_errors: Int, expected: String) -> ExprCheck {
    match expr.kind {
        AstIntExpr => infer_int_literal(expr, env, units, max_errors, expected),
        AstFloatExpr => infer_float_literal(expr, env, expected),
        AstBoolExpr => expr_check(env, "Bool"),
        AstStringExpr => expr_check(env, "String"),
        AstTemplateExpr => expr_check(env, "String"),
        AstCharExpr => expr_check(env, "Char"),
        AstUnitExpr => expr_check(env, "()"),
        AstNameExpr => infer_name_expr(expr, env, units, resolver, max_errors),
        AstCallExpr => infer_call_expr(expr, env, units, resolver, semantics, max_errors, expected),
        AstStructLiteralExpr => infer_struct_literal(expr, env, units, resolver, semantics, max_errors),
        AstFieldAccessExpr => infer_field_access(expr, env, units, resolver, semantics, max_errors),
        AstBinaryExpr => infer_binary_expr(expr, env, units, resolver, semantics, max_errors),
        AstUnaryExpr => infer_unary_expr(expr, env, units, resolver, semantics, max_errors),
        AstTupleExpr => expr_check(infer_all_children(expr, env, units, resolver, semantics, max_errors).env, "Tuple"),
        AstBlockExpr => infer_block_expr(expr, env, units, resolver, semantics, max_errors, expected),
        AstIfExpr => infer_if_expr(expr, env, units, resolver, semantics, max_errors, expected),
        AstWhileExpr => infer_while_expr(expr, env, units, resolver, semantics, max_errors),
        AstForExpr => infer_for_expr(expr, env, units, resolver, semantics, max_errors),
        AstLoopExpr => infer_loop_expr(expr, env, units, resolver, semantics, max_errors, expected),
        AstBreakExpr => infer_break_expr(expr, env, units, resolver, semantics, max_errors),
        AstContinueExpr => if env.in_loop {
            expr_check(env, "()")
        } else {
            expr_check(env_error(env, max_errors, "E1276", expr.span, "continue outside loop", "move continue into a loop body"), "()")
        },
        AstMatchExpr => infer_match_expr(expr, env, units, resolver, semantics, max_errors, expected),
        AstBorrowExpr => infer_first_child_or_unknown(expr, env, units, resolver, semantics, max_errors),
        AstAwaitExpr => infer_first_child_or_unknown(expr, env, units, resolver, semantics, max_errors),
        AstTryExpr => infer_try_expr(expr, env, units, resolver, semantics, max_errors),
        AstClosureExpr => expr_check(env, "Fn"),
    }
}

fn infer_all_children(expr: AstExpr, env: TypecheckEnv, units: Vec[ResolveUnit], resolver: ResolverOutput, semantics: SemanticOutput, max_errors: Int) -> ExprCheck {
    let mut out_env = env;
    let mut index = 0;
    while index < expr.direct_child_count {
        match direct_expr_at(expr, index) {
            Some(child_expr) => if true {
                let checked = infer_expr(child_expr, out_env, units, resolver, semantics, max_errors, "<unknown>");
                out_env = checked.env;
                ()
            } else {
                ()
            },
            None => (),
        };
        index = index + 1;
    };
    expr_check(out_env, "<unknown>")
}

fn infer_block_expr(expr: AstExpr, env: TypecheckEnv, units: Vec[ResolveUnit], resolver: ResolverOutput, semantics: SemanticOutput, max_errors: Int, expected: String) -> ExprCheck {
    let module_path = env.module_path;
    let function_name = env.function_name;
    let mut out_env = env;
    let mut result_type = "()";
    let mut index = 0;
    while index < expr.direct_child_count {
        match direct_expr_node_at(expr, index) {
            Some(node) => match direct_expr_at(expr, index) {
                Some(child_expr) => if string.starts_with(node.role, "let:") {
                    let let_name = block_let_name(node.role);
                    let declared = block_let_type(node.role);
                    let child_expected = if declared == "<unknown>" { "<unknown>" } else { declared };
                    let checked = infer_expr(child_expr, out_env, units, resolver, semantics, max_errors, child_expected);
                    let final_type = if declared == "<unknown>" { checked.type_text } else { declared };
                    out_env = checked.env;
                    if declared != "<unknown>" {
                        out_env = check_expected_type(out_env, units, module_path, node.span, "let binding", declared, checked.type_text, max_errors);
                    } else {
                        ()
                    };
                    out_env = append_binding(out_env, typecheck_binding(module_path, function_name, let_name, final_type, block_let_mutable(node.role), TypecheckLocalValue(), node.span));
                    result_type = "()";
                    ()
                } else if string.starts_with(node.role, "assign:") {
                    let target = role_tail(node.role, "assign:");
                    match find_binding(out_env.bindings, target) {
                        Some(binding) => if binding.mutable {
                            let checked = infer_expr(child_expr, out_env, units, resolver, semantics, max_errors, binding.type_text);
                            out_env = check_expected_type(checked.env, units, module_path, node.span, "assignment", binding.type_text, checked.type_text, max_errors);
                            ()
                        } else {
                            out_env = env_error(out_env, max_errors, "E1266", node.span, "cannot assign to immutable binding", "declare the binding with `let mut` before assigning");
                            ()
                        },
                        None => if true {
                            out_env = env_error(out_env, max_errors, "E1208", node.span, "unknown assignment target", "assign only to a declared local binding");
                            ()
                        } else {
                            ()
                        },
                    };
                    result_type = "()";
                    ()
                } else {
                    let child_expected = if node.role == "tail" || node.role == "return" { expected } else { "<unknown>" };
                    let checked = infer_expr(child_expr, out_env, units, resolver, semantics, max_errors, child_expected);
                    out_env = checked.env;
                    if node.role == "tail" || node.role == "return" {
                        result_type = checked.type_text;
                    } else {
                        result_type = "()";
                    };
                    ()
                },
                None => (),
            },
            None => (),
        };
        index = index + 1;
    };
    expr_check(out_env, result_type)
}

fn infer_first_child_or_unknown(expr: AstExpr, env: TypecheckEnv, units: Vec[ResolveUnit], resolver: ResolverOutput, semantics: SemanticOutput, max_errors: Int) -> ExprCheck {
    match direct_expr_at(expr, 0) {
        Some(child_expr) => infer_expr(child_expr, env, units, resolver, semantics, max_errors, "<unknown>"),
        None => expr_check(env, "<unknown>"),
    }
}

fn infer_int_literal(expr: AstExpr, env: TypecheckEnv, units: Vec[ResolveUnit], max_errors: Int, expected: String) -> ExprCheck {
    let expected_canonical = canonical_type_text(env.aliases, env.module_path, expected);
    let out_type = if is_integer_type(expected_canonical) { expected } else { "Int" };
    let range_type = if is_integer_type(expected_canonical) { expected_canonical } else { out_type };
    let out_env = if literal_exceeds_small_width(expr.name, range_type) {
        let mut parts: Vec[String] = vec.new_vec();
        parts = vec.push(parts, "integer literal '");
        parts = vec.push(parts, expr.name);
        parts = vec.push(parts, "' is outside the range of '");
        parts = vec.push(parts, range_type);
        parts = vec.push(parts, "'");
        env_error(env, max_errors, "E1204", expr.span, string.join(parts, ""), "choose a wider integer type or reduce the literal value")
    } else {
        env
    };
    expr_check(out_env, out_type)
}

fn literal_exceeds_small_width(literal: String, ty: String) -> Bool {
    if ty == "Int8" || ty == "UInt8" {
        string.len(literal) > 3
    } else if ty == "Int16" || ty == "UInt16" {
        string.len(literal) > 5
    } else {
        false
    }
}

fn infer_float_literal(expr: AstExpr, env: TypecheckEnv, expected: String) -> ExprCheck {
    if is_float_type(expected) {
        expr_check(env, expected)
    } else {
        expr_check(env, "Float64")
    }
}

fn infer_name_expr(expr: AstExpr, env: TypecheckEnv, units: Vec[ResolveUnit], resolver: ResolverOutput, max_errors: Int) -> ExprCheck {
    match find_binding(env.bindings, expr.name) {
        Some(binding) => expr_check(env, binding.type_text),
        None => match lookup_value_symbol(units, resolver, env.module_path, expr.name, ResolverConstSymbol(), ResolverValueNamespace()) {
            Some(symbol) => expr_check(env, symbol.type_name),
            None => match lookup_value_symbol(units, resolver, env.module_path, expr.name, ResolverFunctionSymbol(), ResolverValueNamespace()) {
                Some(symbol) => expr_check(env, symbol.type_name),
                None => match lookup_value_symbol(units, resolver, env.module_path, expr.name, ResolverVariantSymbol(), ResolverMemberNamespace()) {
                    Some(symbol) => expr_check(env, symbol.type_name),
                    None => if expr.name == "None" {
                        expr_check(env, "Option")
                    } else {
                        let mut parts: Vec[String] = vec.new_vec();
                        parts = vec.push(parts, "unknown symbol '");
                        parts = vec.push(parts, expr.name);
                        parts = vec.push(parts, "'");
                        expr_check(env_error(env, max_errors, "E1208", expr.span, string.join(parts, ""), "declare or import the symbol before use"), "<unknown>")
                    },
                },
            },
        },
    }
}

fn infer_call_expr(expr: AstExpr, env: TypecheckEnv, units: Vec[ResolveUnit], resolver: ResolverOutput, semantics: SemanticOutput, max_errors: Int, expected: String) -> ExprCheck {
    if expr.name == "Some" {
        infer_builtin_variant(expr, env, units, resolver, semantics, max_errors, expected, "Option", "Some", 1)
    } else if expr.name == "None" {
        infer_builtin_variant(expr, env, units, resolver, semantics, max_errors, expected, "Option", "None", 0)
    } else if expr.name == "Ok" {
        infer_builtin_variant(expr, env, units, resolver, semantics, max_errors, expected, "Result", "Ok", 1)
    } else if expr.name == "Err" {
        infer_builtin_variant(expr, env, units, resolver, semantics, max_errors, expected, "Result", "Err", 1)
    } else if string.contains(expr.name, ".") {
        infer_qualified_or_member_call(expr, env, units, resolver, semantics, max_errors, expected)
    } else {
        match lookup_value_symbol(units, resolver, env.module_path, expr.name, ResolverFunctionSymbol(), ResolverValueNamespace()) {
            Some(symbol) => match find_function_signature(units, symbol.module_path, symbol.name) {
                Some(signature) => check_function_call(expr, env, units, resolver, semantics, max_errors, signature, symbol.module_path, symbol.name, expected),
                None => expr_check(env, symbol.type_name),
            },
            None => match lookup_value_symbol(units, resolver, env.module_path, expr.name, ResolverVariantSymbol(), ResolverMemberNamespace()) {
                Some(symbol) => check_declared_variant_call(expr, env, units, resolver, semantics, max_errors, symbol),
                None => infer_name_expr(simple_expr(AstNameExpr(), "", expr.name, expr.span, expr.name), env, units, resolver, max_errors),
            },
        }
    }
}

fn infer_builtin_variant(expr: AstExpr, env: TypecheckEnv, units: Vec[ResolveUnit], resolver: ResolverOutput, semantics: SemanticOutput, max_errors: Int, expected: String, type_name_value: String, variant_name: String, expected_args: Int) -> ExprCheck {
    let mut out_env = env;
    if call_arg_count(expr) != expected_args {
        let mut parts: Vec[String] = vec.new_vec();
        parts = vec.push(parts, "variant '");
        parts = vec.push(parts, variant_name);
        parts = vec.push(parts, "' expects a different argument count");
        out_env = env_error(out_env, max_errors, "E1215", expr.span, string.join(parts, ""), "adjust the number of variant arguments");
    } else {
        let mut index = 0;
        while index < call_arg_count(expr) {
            match call_arg_expr(expr, index) {
                Some(arg_expr) => if true {
                    let checked = infer_expr(arg_expr, out_env, units, resolver, semantics, max_errors, "<unknown>");
                    out_env = checked.env;
                    ()
                } else {
                    ()
                },
                None => (),
            };
            index = index + 1;
        };
    };
    if expected != "<unknown>" && string.starts_with(expected, type_name_value) {
        expr_check(out_env, expected)
    } else {
        expr_check(out_env, type_name_value)
    }
}

fn check_function_call(expr: AstExpr, env: TypecheckEnv, units: Vec[ResolveUnit], resolver: ResolverOutput, semantics: SemanticOutput, max_errors: Int, signature: AstFunctionSignature, module_path: String, symbol_name: String, expected: String) -> ExprCheck {
    let requester_module = env.module_path;
    let mut out_env = env;
    let arg_count = call_arg_count(expr);
    if arg_count != vec.vec_len(signature.params) {
        let mut parts: Vec[String] = vec.new_vec();
        parts = vec.push(parts, "function '");
        parts = vec.push(parts, symbol_name);
        parts = vec.push(parts, "' expects a different argument count");
        out_env = env_error(out_env, max_errors, "E1214", expr.span, string.join(parts, ""), "adjust the number of call arguments");
    } else {
        let mut generic_map_value = empty_generic_map();
        let mut index = 0;
        while index < arg_count {
            match call_arg_node(expr, index) {
                Some(arg_node) => match call_arg_expr(expr, index) {
                    Some(arg_expr) => match vec.get(signature.params, index) {
                    Some(param) => if true {
                        let param_type = type_text(param.type_ref);
                        let expected_type = instantiate_type_text(param_type, generic_map_value);
                        let checked = infer_expr(arg_expr, out_env, units, resolver, semantics, max_errors, expected_type);
                        out_env = checked.env;
                        let next_generic_map = add_generic_bindings_from_type(generic_map_value, signature.generic_params, param_type, checked.type_text);
                        let final_expected_type = instantiate_type_text(param_type, next_generic_map);
                        if is_generic_param(signature.generic_params, param_type) {
                            match generic_value(generic_map_value, param_type) {
                                Some(existing) => if types_compatible(out_env.aliases, requester_module, existing, checked.type_text) {
                                    ()
                                } else {
                                    let mut parts: Vec[String] = vec.new_vec();
                                    parts = vec.push(parts, "generic argument mismatch for '");
                                    parts = vec.push(parts, param_type);
                                    parts = vec.push(parts, "': expected '");
                                    parts = vec.push(parts, existing);
                                    parts = vec.push(parts, "', found '");
                                    parts = vec.push(parts, checked.type_text);
                                    parts = vec.push(parts, "'");
                                    out_env = env_error(out_env, max_errors, "E1214", arg_node.span, string.join(parts, ""), "pass values with the same inferred generic type");
                                },
                                None => if true {
                                    generic_map_value = next_generic_map;
                                    ()
                                } else {
                                    ()
                                },
                            };
                        } else if types_compatible(out_env.aliases, requester_module, final_expected_type, checked.type_text) {
                            generic_map_value = next_generic_map;
                        } else {
                            let mut parts: Vec[String] = vec.new_vec();
                            parts = vec.push(parts, "argument type mismatch for call to '");
                            parts = vec.push(parts, symbol_name);
                            parts = vec.push(parts, "': expected '");
                            parts = vec.push(parts, final_expected_type);
                            parts = vec.push(parts, "', found '");
                            parts = vec.push(parts, checked.type_text);
                            parts = vec.push(parts, "'");
                            out_env = env_error(out_env, max_errors, "E1214", arg_node.span, string.join(parts, ""), "change the argument type or function signature");
                        };
                        let named_arg = role_tail(arg_node.role, "arg:");
                        if named_arg != "" && named_arg != param.name.value {
                            let mut named_parts: Vec[String] = vec.new_vec();
                            named_parts = vec.push(named_parts, "unknown named argument '");
                            named_parts = vec.push(named_parts, named_arg);
                            named_parts = vec.push(named_parts, "' for function '");
                            named_parts = vec.push(named_parts, symbol_name);
                            named_parts = vec.push(named_parts, "'");
                            out_env = env_error(out_env, max_errors, "E1213", arg_node.span, string.join(named_parts, ""), "use a parameter name declared by the function signature");
                        } else {
                            ()
                        };
                        ()
                    } else {
                        ()
                    },
                    None => (),
                    },
                    None => (),
                },
                None => (),
            };
            index = index + 1;
        };
        generic_map_value = add_expected_return_generics(generic_map_value, signature.generic_params, type_text(signature.return_type), expected);
        out_env = typecheck_env(out_env.module_path, out_env.function_name, out_env.return_type, out_env.bindings, generic_map_value, out_env.aliases, out_env.diagnostics, out_env.instantiations, out_env.in_loop, out_env.loop_break_types);
        out_env = check_generic_bounds(out_env, signature.generic_params, semantics, max_errors, expr.span);
        if vec.vec_len(generic_map_value.names) > 0 {
            out_env = append_instantiation(out_env, typecheck_instantiation(module_path, symbol_name, "function", generic_map_value.values, expr.span));
        } else {
            ()
        };
    };
    let return_text = instantiate_type_text(type_text(signature.return_type), out_env.generic_map);
    expr_check(out_env, return_text)
}

fn is_generic_param(params: AstGenericParamList, name: String) -> Bool {
    let mut found = false;
    let mut index = 0;
    while !found && index < vec.vec_len(params.params) {
        match vec.get(params.params, index) {
            Some(param) => if param.name.value == name {
                found = true;
            } else {
                ()
            },
            None => (),
        };
        index = index + 1;
    };
    found
}

fn check_declared_variant_call(expr: AstExpr, env: TypecheckEnv, units: Vec[ResolveUnit], resolver: ResolverOutput, semantics: SemanticOutput, max_errors: Int, symbol: ResolvedSymbol) -> ExprCheck {
    match find_enum_variant(units, symbol.name) {
        Some(variant) => if true {
            let expected_args = match variant.payload_type { Some(_) => 1, None => 0 };
            let requester_module = env.module_path;
            let mut out_env = env;
            if call_arg_count(expr) != expected_args {
                out_env = env_error(out_env, max_errors, "E1215", expr.span, "variant argument count mismatch", "adjust the variant constructor arguments");
            } else {
                match variant.payload_type {
                    Some(payload_type) => match call_arg_node(expr, 0) {
                        Some(arg_node) => match call_arg_expr(expr, 0) {
                            Some(arg_expr) => if true {
                            let checked = infer_expr(arg_expr, out_env, units, resolver, semantics, max_errors, type_text(payload_type));
                            out_env = checked.env;
                            if types_compatible(out_env.aliases, requester_module, type_text(payload_type), checked.type_text) {
                                ()
                            } else {
                                out_env = env_error(out_env, max_errors, "E1216", arg_node.span, "variant payload type mismatch", "pass a payload with the declared variant type");
                            };
                            ()
                        } else {
                            ()
                        },
                            None => (),
                        },
                        None => (),
                    },
                    None => (),
                };
            };
            expr_check(out_env, enum_name_for_variant(units, symbol.name))
        } else {
            expr_check(env, symbol.type_name)
        },
        None => expr_check(env, symbol.type_name),
    }
}

fn infer_member_call(expr: AstExpr, env: TypecheckEnv, units: Vec[ResolveUnit], resolver: ResolverOutput, semantics: SemanticOutput, max_errors: Int) -> ExprCheck {
    let receiver_name = path_prefix(expr.name);
    let method_name = path_tail(expr.name);
    let receiver_type = match find_binding(env.bindings, receiver_name) {
        Some(binding) => binding.type_text,
        None => "<unknown>",
    };
    match find_member_symbol(resolver.symbols, receiver_type, method_name, ResolverMethodSymbol()) {
        Some(symbol) => expr_check(env, symbol.type_name),
        None => if receiver_type == "<unknown>" {
            expr_check(env, "<unknown>")
        } else {
            let mut out_type = "<unknown>";
            let mut found = false;
            let mut index = 0;
            while !found && index < vec.vec_len(resolver.symbols) {
                match vec.get(resolver.symbols, index) {
                    Some(symbol) => if same_symbol_kind(symbol.kind, ResolverMethodSymbol()) && symbol.name == method_name {
                        out_type = symbol.type_name;
                        found = true;
                    } else {
                        ()
                    },
                    None => (),
                };
                index = index + 1;
            };
            if found {
                expr_check(env, out_type)
            } else {
                let mut parts: Vec[String] = vec.new_vec();
                parts = vec.push(parts, "unknown method '");
                parts = vec.push(parts, method_name);
                parts = vec.push(parts, "' for type '");
                parts = vec.push(parts, receiver_type);
                parts = vec.push(parts, "'");
                expr_check(env_error(env, max_errors, "E1228", expr.span, string.join(parts, ""), "declare an impl method for the receiver type"), "<unknown>")
            }
        },
    }
}

fn infer_qualified_or_member_call(expr: AstExpr, env: TypecheckEnv, units: Vec[ResolveUnit], resolver: ResolverOutput, semantics: SemanticOutput, max_errors: Int, expected: String) -> ExprCheck {
    match lookup_value_symbol(units, resolver, env.module_path, expr.name, ResolverFunctionSymbol(), ResolverValueNamespace()) {
        Some(symbol) => match find_function_signature(units, symbol.module_path, symbol.name) {
            Some(signature) => check_function_call(expr, env, units, resolver, semantics, max_errors, signature, symbol.module_path, symbol.name, expected),
            None => expr_check(env, symbol.type_name),
        },
        None => infer_member_call(expr, env, units, resolver, semantics, max_errors),
    }
}

fn infer_struct_literal(expr: AstExpr, env: TypecheckEnv, units: Vec[ResolveUnit], resolver: ResolverOutput, semantics: SemanticOutput, max_errors: Int) -> ExprCheck {
    match find_struct_decl(units, expr.name) {
        Some(struct_item) => if true {
            let requester_module = env.module_path;
            let mut out_env = env;
            let mut seen: Vec[String] = vec.new_vec();
            let mut index = 0;
            while index < field_value_count(expr) {
                match struct_field_node(expr, index) {
                    Some(node) => match struct_field_expr(expr, index) {
                        Some(field_expr) => if true {
                        let field_name = role_tail(node.role, "field:");
                        if field_name_exists(seen, field_name) {
                            out_env = env_error(out_env, max_errors, "E1254", node.span, "duplicate field in struct literal", "remove the duplicate field initializer");
                        } else {
                            seen = vec.push(seen, field_name);
                        };
                        let expected_type = struct_field_type(struct_item, struct_item.name.value, field_name);
                        if expected_type == "<unknown>" {
                            let mut parts: Vec[String] = vec.new_vec();
                            parts = vec.push(parts, "unknown field '");
                            parts = vec.push(parts, field_name);
                            parts = vec.push(parts, "' for struct '");
                            parts = vec.push(parts, struct_item.name.value);
                            parts = vec.push(parts, "'");
                            out_env = env_error(out_env, max_errors, "E1228", node.span, string.join(parts, ""), "use a field declared by the struct");
                        } else {
                            let checked = infer_expr(field_expr, out_env, units, resolver, semantics, max_errors, expected_type);
                            out_env = checked.env;
                            if types_compatible(out_env.aliases, requester_module, expected_type, checked.type_text) {
                                ()
                            } else {
                                out_env = env_error(out_env, max_errors, "E1204", node.span, "struct field initializer type mismatch", "change the initializer to match the field type");
                            };
                        };
                        ()
                    } else {
                        ()
                    },
                        None => (),
                    },
                    None => (),
                };
                index = index + 1;
            };
            expr_check(out_env, expr.name)
        } else {
            expr_check(env, expr.name)
        },
        None => expr_check(env_error(env, max_errors, "E1208", expr.span, "unknown struct literal type", "declare the struct before constructing it"), "<unknown>"),
    }
}

fn infer_field_access(expr: AstExpr, env: TypecheckEnv, units: Vec[ResolveUnit], resolver: ResolverOutput, semantics: SemanticOutput, max_errors: Int) -> ExprCheck {
    match direct_expr_at(expr, 0) {
        Some(base_expr) => if true {
            let checked = infer_expr(base_expr, env, units, resolver, semantics, max_errors, "<unknown>");
            let base_type = checked.type_text;
            match find_struct_decl(units, nominal_type_name(base_type)) {
                Some(struct_item) => if true {
                    let field_type = struct_field_type(struct_item, base_type, expr.name);
                    if field_type == "<unknown>" {
                        let mut parts: Vec[String] = vec.new_vec();
                        parts = vec.push(parts, "unknown field '");
                        parts = vec.push(parts, expr.name);
                        parts = vec.push(parts, "' for type '");
                        parts = vec.push(parts, base_type);
                        parts = vec.push(parts, "'");
                        expr_check(env_error(checked.env, max_errors, "E1228", expr.span, string.join(parts, ""), "use a field declared by the receiver type"), "<unknown>")
                    } else {
                        expr_check(checked.env, field_type)
                    }
                } else {
                    expr_check(checked.env, "<unknown>")
                },
                None => expr_check(checked.env, "<unknown>"),
            }
        } else {
            expr_check(env, "<unknown>")
        },
        None => expr_check(env, "<unknown>"),
    }
}

fn infer_binary_expr(expr: AstExpr, env: TypecheckEnv, units: Vec[ResolveUnit], resolver: ResolverOutput, semantics: SemanticOutput, max_errors: Int) -> ExprCheck {
    let requester_module = env.module_path;
    let left = match direct_expr_at(expr, 0) { Some(child_expr) => child_expr, None => simple_expr(AstUnitExpr(), "", "", expr.span, "()") };
    let right = match direct_expr_at(expr, 1) { Some(child_expr) => child_expr, None => simple_expr(AstUnitExpr(), "", "", expr.span, "()") };
    let left_checked = infer_expr(left, env, units, resolver, semantics, max_errors, "<unknown>");
    let right_checked = infer_expr(right, left_checked.env, units, resolver, semantics, max_errors, left_checked.type_text);
    let left_type = left_checked.type_text;
    let right_type = right_checked.type_text;
    let left_canonical = canonical_type_text(env.aliases, requester_module, left_type);
    let right_canonical = canonical_type_text(env.aliases, requester_module, right_type);
    if expr.op == "&&" || expr.op == "||" {
        let out_env = if left_type == "Bool" && right_type == "Bool" {
            right_checked.env
        } else {
            env_error(right_checked.env, max_errors, "E1204", expr.span, "logical operators require Bool operands", "convert both operands to Bool")
        };
        expr_check(out_env, "Bool")
    } else if expr.op == "==" || expr.op == "!=" {
        let out_env = if types_compatible(right_checked.env.aliases, requester_module, left_type, right_type) {
            right_checked.env
        } else {
            env_error(right_checked.env, max_errors, "E1231", expr.span, "equality operands must have matching types", "compare values of the same type")
        };
        expr_check(out_env, "Bool")
    } else if is_ordering_op(expr.op) {
        if types_compatible(right_checked.env.aliases, requester_module, left_type, right_type) && (is_integer_type(left_canonical) || is_float_type(left_canonical) || left_canonical == "Char") && (is_integer_type(right_canonical) || is_float_type(right_canonical) || right_canonical == "Char") {
            expr_check(right_checked.env, "Bool")
        } else {
            expr_check(env_error(right_checked.env, max_errors, "E1232", expr.span, "comparison operators require matching integer, float, or Char operands", "use matching comparable operand types"), "Bool")
        }
    } else if is_arithmetic_op(expr.op) {
        if types_compatible(right_checked.env.aliases, requester_module, left_type, right_type) && (is_integer_type(left_canonical) || is_float_type(left_canonical)) && (is_integer_type(right_canonical) || is_float_type(right_canonical)) {
            expr_check(right_checked.env, left_type)
        } else {
            expr_check(env_error(right_checked.env, max_errors, "E1230", expr.span, "arithmetic operators require matching numeric operand types", "use matching integer or float operand types"), left_type)
        }
    } else {
        expr_check(right_checked.env, left_type)
    }
}

fn is_ordering_op(op: String) -> Bool {
    op == "<" || op == "<=" || op == ">" || op == ">="
}

fn is_arithmetic_op(op: String) -> Bool {
    op == "+" || op == "-" || op == "*" || op == "/" || op == "%" || op == "&" || op == "|" || op == "^" || op == "<<" || op == ">>" || op == ">>>"
}

fn infer_unary_expr(expr: AstExpr, env: TypecheckEnv, units: Vec[ResolveUnit], resolver: ResolverOutput, semantics: SemanticOutput, max_errors: Int) -> ExprCheck {
    let checked = infer_first_child_or_unknown(expr, env, units, resolver, semantics, max_errors);
    if expr.op == "!" && checked.type_text != "Bool" {
        expr_check(env_error(checked.env, max_errors, "E1204", expr.span, "logical not requires Bool operand", "use a Bool expression"), "Bool")
    } else if expr.op == "-" && !is_integer_type(checked.type_text) && !is_float_type(checked.type_text) {
        expr_check(env_error(checked.env, max_errors, "E1204", expr.span, "numeric negation requires numeric operand", "use an integer or float expression"), checked.type_text)
    } else {
        checked
    }
}

fn infer_if_expr(expr: AstExpr, env: TypecheckEnv, units: Vec[ResolveUnit], resolver: ResolverOutput, semantics: SemanticOutput, max_errors: Int, expected: String) -> ExprCheck {
    let cond = match direct_expr_at(expr, 0) { Some(child_expr) => child_expr, None => simple_expr(AstBoolExpr(), "", "true", expr.span, "true") };
    let cond_checked = infer_expr(cond, env, units, resolver, semantics, max_errors, "Bool");
    let mut out_env = if cond_checked.type_text == "Bool" {
        cond_checked.env
    } else {
        env_error(cond_checked.env, max_errors, "E1204", expr.span, "if condition must be Bool", "use a Bool expression as the condition")
    };
    if expr.direct_child_count >= 3 {
        match direct_expr_at(expr, 1) {
            Some(then_expr) => match direct_expr_at(expr, 2) {
                Some(else_expr) => if true {
                    let checked_then = infer_expr(then_expr, out_env, units, resolver, semantics, max_errors, expected);
                    let checked_else = infer_expr(else_expr, checked_then.env, units, resolver, semantics, max_errors, checked_then.type_text);
                    out_env = checked_else.env;
                    if types_compatible(checked_else.env.aliases, env.module_path, checked_then.type_text, checked_else.type_text) {
                        expr_check(out_env, checked_then.type_text)
                    } else {
                        expr_check(env_error(out_env, max_errors, "E1204", expr.span, "if branches must have matching types", "make both branches return the same type"), checked_then.type_text)
                    }
                } else {
                    expr_check(out_env, "()")
                },
                None => expr_check(out_env, "()"),
            },
            None => expr_check(out_env, "()"),
        }
    } else {
        match direct_expr_at(expr, 1) {
            Some(else_expr) => if true {
                let checked_else = infer_expr(else_expr, out_env, units, resolver, semantics, max_errors, expected);
                out_env = checked_else.env;
                expr_check(out_env, checked_else.type_text)
            } else {
                expr_check(out_env, "()")
            },
            None => expr_check(out_env, "()"),
        }
    }
}

fn infer_while_expr(expr: AstExpr, env: TypecheckEnv, units: Vec[ResolveUnit], resolver: ResolverOutput, semantics: SemanticOutput, max_errors: Int) -> ExprCheck {
    match direct_expr_at(expr, 0) {
        Some(cond_expr) => if true {
            let checked = infer_expr(cond_expr, env, units, resolver, semantics, max_errors, "Bool");
            let out_env = if checked.type_text == "Bool" {
                checked.env
            } else {
                env_error(checked.env, max_errors, "E1273", cond_expr.span, "while condition must be Bool", "use a Bool expression as the loop condition")
            };
            let loop_env = env_push_loop(out_env, "()");
            match direct_expr_at(expr, 1) {
                Some(body_expr) => if true {
                    let checked_body = infer_expr(body_expr, loop_env, units, resolver, semantics, max_errors, env.return_type);
                    expr_check(env_restore_loop_state(checked_body.env, env), "()")
                } else {
                    expr_check(out_env, "()")
                },
                None => expr_check(out_env, "()"),
            }
        } else {
            expr_check(env, "()")
        },
        None => expr_check(env, "()"),
    }
}

fn infer_loop_expr(expr: AstExpr, env: TypecheckEnv, units: Vec[ResolveUnit], resolver: ResolverOutput, semantics: SemanticOutput, max_errors: Int, expected: String) -> ExprCheck {
    let loop_env = env_push_loop(env, "");
    match direct_expr_at(expr, 0) {
        Some(body_expr) => if true {
            let checked_body = infer_expr(body_expr, loop_env, units, resolver, semantics, max_errors, expected);
            let break_type = loop_break_type_stack_top(checked_body.env.loop_break_types);
            let result_type = if break_type == "" { checked_body.type_text } else { break_type };
            expr_check(env_restore_loop_state(checked_body.env, env), result_type)
        } else {
            expr_check(env, "()")
        },
        None => expr_check(env, "()"),
    }
}

fn infer_for_expr(expr: AstExpr, env: TypecheckEnv, units: Vec[ResolveUnit], resolver: ResolverOutput, semantics: SemanticOutput, max_errors: Int) -> ExprCheck {
    let module_path = env.module_path;
    let function_name = env.function_name;
    let checked = infer_first_child_or_unknown(expr, env, units, resolver, semantics, max_errors);
    let loop_binding = typecheck_binding(module_path, function_name, expr.name, "Int", true, TypecheckLocalValue(), expr.span);
    let loop_env = env_push_loop(append_binding(checked.env, loop_binding), "()");
    match direct_expr_at(expr, 1) {
        Some(body_expr) => if true {
            let checked_body = infer_expr(body_expr, loop_env, units, resolver, semantics, max_errors, env.return_type);
            expr_check(env_restore_loop_state(env_with_bindings(checked_body.env, clone_typecheck_bindings(checked.env.bindings)), env), "()")
        } else {
            expr_check(checked.env, "()")
        },
        None => expr_check(checked.env, "()"),
    }
}

fn infer_break_expr(expr: AstExpr, env: TypecheckEnv, units: Vec[ResolveUnit], resolver: ResolverOutput, semantics: SemanticOutput, max_errors: Int) -> ExprCheck {
    if !env.in_loop {
        expr_check(env_error(env, max_errors, "E1275", expr.span, "break outside loop", "move break into a loop body"), "()")
    } else {
        let checked = match direct_expr_at(expr, 0) {
            Some(child_expr) => infer_expr(child_expr, env, units, resolver, semantics, max_errors, "<unknown>"),
            None => expr_check(env, "()"),
        };
        let current = loop_break_type_stack_top(checked.env.loop_break_types);
        if current == "" {
            let updated_stack = loop_break_type_stack_set_top(checked.env.loop_break_types, checked.type_text);
            expr_check(env_with_loop_state(checked.env, checked.env.in_loop, updated_stack), checked.type_text)
        } else if types_compatible(checked.env.aliases, checked.env.module_path, current, checked.type_text) {
            expr_check(checked.env, current)
        } else {
            let mut parts: Vec[String] = vec.new_vec();
            parts = vec.push(parts, "break type '");
            parts = vec.push(parts, checked.type_text);
            parts = vec.push(parts, "' does not match loop break type '");
            parts = vec.push(parts, current);
            parts = vec.push(parts, "'");
            expr_check(env_error(checked.env, max_errors, "E1274", expr.span, string.join(parts, ""), "ensure every break in the loop has the same type"), current)
        }
    }
}

fn infer_try_expr(expr: AstExpr, env: TypecheckEnv, units: Vec[ResolveUnit], resolver: ResolverOutput, semantics: SemanticOutput, max_errors: Int) -> ExprCheck {
    let checked = infer_first_child_or_unknown(expr, env, units, resolver, semantics, max_errors);
    let ty = checked.type_text;
    if string.starts_with(ty, "Result[") {
        let args = generic_arg_texts(ty);
        match vec.get(args, 0) {
            Some(ok_type) => expr_check(checked.env, ok_type),
            None => expr_check(checked.env, "<unknown>"),
        }
    } else {
        expr_check(checked.env, "<unknown>")
    }
}

fn simple_pattern_binding_name(text: String) -> String {
    if text == "" || text == "_" || text == "true" || text == "false" || string.contains(text, "(") || string.contains(text, "{") || string.contains(text, "|") {
        ""
    } else {
        text
    }
}

fn variant_pattern_payload_name(text: String, variant: String) -> String {
    let prefix = join3(variant, "(", "");
    if string.starts_with(text, prefix) && string.ends_with(text, ")") {
        simple_pattern_binding_name(string.substring(text, string.len(prefix), string.len(text) - 1))
    } else {
        ""
    }
}

fn variant_pattern_name(text: String) -> String {
    if string.contains(text, "(") && string.ends_with(text, ")") {
        let parts = string.split(text, "(");
        match vec.get(parts, 0) {
            Some(name) => name,
            None => "",
        }
    } else {
        ""
    }
}

fn variant_payload_binding_name(text: String) -> String {
    let variant_name = variant_pattern_name(text);
    if variant_name == "" {
        ""
    } else {
        variant_pattern_payload_name(text, variant_name)
    }
}

fn declared_variant_payload_type(units: Vec[ResolveUnit], variant_name: String) -> String {
    match find_enum_variant(units, variant_name) {
        Some(variant) => match variant.payload_type {
            Some(payload_type) => type_text(payload_type),
            None => "<unknown>",
        },
        None => "<unknown>",
    }
}

fn option_payload_type(scrutinee_type: String) -> String {
    let args = generic_arg_texts(scrutinee_type);
    match vec.get(args, 0) {
        Some(value) => value,
        None => "<unknown>",
    }
}

fn result_payload_type(scrutinee_type: String, index: Int) -> String {
    let args = generic_arg_texts(scrutinee_type);
    match vec.get(args, index) {
        Some(value) => value,
        None => "<unknown>",
    }
}

fn bind_match_pattern(env: TypecheckEnv, units: Vec[ResolveUnit], scrutinee_type: String, pattern_text_value: String, span_value: SourceSpan) -> TypecheckEnv {
    let arm_base = env_with_bindings(env, clone_typecheck_bindings(env.bindings));
    let some_name = variant_pattern_payload_name(pattern_text_value, "Some");
    if some_name != "" {
        append_binding(arm_base, typecheck_binding(env.module_path, env.function_name, some_name, option_payload_type(scrutinee_type), false, TypecheckLocalValue(), span_value))
    } else {
        let ok_name = variant_pattern_payload_name(pattern_text_value, "Ok");
        if ok_name != "" {
            append_binding(arm_base, typecheck_binding(env.module_path, env.function_name, ok_name, result_payload_type(scrutinee_type, 0), false, TypecheckLocalValue(), span_value))
        } else {
            let err_name = variant_pattern_payload_name(pattern_text_value, "Err");
            if err_name != "" {
                append_binding(arm_base, typecheck_binding(env.module_path, env.function_name, err_name, result_payload_type(scrutinee_type, 1), false, TypecheckLocalValue(), span_value))
            } else {
                let payload_name = variant_payload_binding_name(pattern_text_value);
                if payload_name != "" {
                    append_binding(arm_base, typecheck_binding(env.module_path, env.function_name, payload_name, declared_variant_payload_type(units, variant_pattern_name(pattern_text_value)), false, TypecheckLocalValue(), span_value))
                } else {
                    let var_name = simple_pattern_binding_name(pattern_text_value);
                    if var_name != "" {
                        append_binding(arm_base, typecheck_binding(env.module_path, env.function_name, var_name, scrutinee_type, false, TypecheckLocalValue(), span_value))
                    } else {
                        arm_base
                    }
                }
            }
        }
    }
}

fn merge_arm_env(outer: TypecheckEnv, arm: TypecheckEnv) -> TypecheckEnv {
    typecheck_env(outer.module_path, outer.function_name, outer.return_type, outer.bindings, arm.generic_map, outer.aliases, arm.diagnostics, arm.instantiations, outer.in_loop, outer.loop_break_types)
}

fn infer_match_expr(expr: AstExpr, env: TypecheckEnv, units: Vec[ResolveUnit], resolver: ResolverOutput, semantics: SemanticOutput, max_errors: Int, expected: String) -> ExprCheck {
    let requester_module = env.module_path;
    let scrutinee_expr = match direct_expr_at(expr, 0) { Some(child_expr) => child_expr, None => simple_expr(AstUnitExpr(), "", "", expr.span, "()") };
    let scrutinee = infer_expr(scrutinee_expr, env, units, resolver, semantics, max_errors, "<unknown>");
    let mut out_env = scrutinee.env;
    let mut child_index = 1;
    let mut result_type = expected;
    let mut arm_index = 0;
    while arm_index < vec.vec_len(expr.match_arms) {
        match vec.get(expr.match_arms, arm_index) {
            Some(arm) => if true {
                let mut arm_env = bind_match_pattern(out_env, units, scrutinee.type_text, arm.pattern_text, arm.span);
                if arm.guard_text != "" {
                    let mut guard_checked = false;
                    match direct_expr_node_at(expr, child_index) {
                        Some(guard_node) => match direct_expr_at(expr, child_index) {
                            Some(guard_expr) => if true {
                                let guard_check = infer_expr(guard_expr, arm_env, units, resolver, semantics, max_errors, "Bool");
                                arm_env = guard_check.env;
                                guard_checked = true;
                                if guard_check.type_text == "Bool" {
                                    ()
                                } else {
                                    arm_env = env_error(arm_env, max_errors, "E1270", guard_node.span, "match guard must be Bool", "use a Bool expression as the guard");
                                };
                                ()
                            } else {
                                ()
                            },
                            None => (),
                        },
                        None => (),
                    };
                    if guard_checked {
                        ()
                    } else {
                        arm_env = env_error(arm_env, max_errors, "E1270", arm.span, "match guard must be Bool", "use a Bool expression as the guard");
                    };
                    child_index = child_index + 1;
                } else {
                    ()
                };
                match direct_expr_node_at(expr, child_index) {
                    Some(body_node) => match direct_expr_at(expr, child_index) {
                        Some(body_expr) => if true {
                            let body_expected = if result_type == "<unknown>" { expected } else { result_type };
                            let body_check = infer_expr(body_expr, arm_env, units, resolver, semantics, max_errors, body_expected);
                            arm_env = body_check.env;
                            if result_type == "<unknown>" {
                                result_type = body_check.type_text;
                            } else if types_compatible(arm_env.aliases, requester_module, result_type, body_check.type_text) {
                                ()
                            } else {
                                arm_env = env_error(arm_env, max_errors, "E1204", body_node.span, "match arm body type mismatch", "make all match arms produce the same type");
                            };
                            ()
                        } else {
                            ()
                        },
                        None => (),
                    },
                    None => (),
                };
                out_env = merge_arm_env(out_env, arm_env);
                child_index = child_index + 1;
                ()
            } else {
                ()
            },
            None => (),
        };
        arm_index = arm_index + 1;
    };
    out_env = check_match_exhaustiveness(expr, out_env, scrutinee.type_text, max_errors);
    expr_check(out_env, result_type)
}

fn check_match_exhaustiveness(expr: AstExpr, env: TypecheckEnv, scrutinee_type: String, max_errors: Int) -> TypecheckEnv {
    let mut out = env;
    if scrutinee_type == "Bool" {
        let mut has_true = false;
        let mut has_false = false;
        let mut has_wildcard = false;
        let mut index = 0;
        while index < vec.vec_len(expr.match_arms) {
            match vec.get(expr.match_arms, index) {
                Some(arm) => if arm.guard_text == "" {
                    if string.contains(arm.pattern_text, "_") {
                        has_wildcard = true;
                    } else if string.contains(arm.pattern_text, "true") {
                        has_true = true;
                    } else if string.contains(arm.pattern_text, "false") {
                        has_false = true;
                    } else {
                        ()
                    }
                } else {
                    ()
                },
                None => (),
            };
            index = index + 1;
        };
        if has_wildcard || (has_true && has_false) {
            out
        } else {
            env_error(out, max_errors, "E1246", expr.span, "non-exhaustive Bool match", "cover both true and false without guarded-only arms")
        }
    } else if string.starts_with(scrutinee_type, "Option") {
        let has_some = match_has_pattern(expr, "Some");
        let has_none = match_has_pattern(expr, "None");
        if has_some && has_none {
            out
        } else {
            env_error(out, max_errors, "E1246", expr.span, "non-exhaustive Option match", "cover Some and None variants")
        }
    } else if string.starts_with(scrutinee_type, "Result") {
        let has_ok = match_has_pattern(expr, "Ok");
        let has_err = match_has_pattern(expr, "Err");
        if has_ok && has_err {
            out
        } else {
            env_error(out, max_errors, "E1248", expr.span, "non-exhaustive Result match", "cover Ok and Err variants")
        }
    } else {
        out
    }
}

fn match_has_pattern(expr: AstExpr, pattern_name: String) -> Bool {
    if match_has_arm_text_pattern(expr, pattern_name) {
        true
    } else if match_has_pattern_node(expr, pattern_name) {
        true
    } else {
        match_text_has_unguarded_pattern(expr.text, pattern_name)
    }
}

fn match_has_arm_text_pattern(expr: AstExpr, pattern_name: String) -> Bool {
    let mut found = false;
    let mut index = 0;
    while !found && index < vec.vec_len(expr.match_arms) {
        match vec.get(expr.match_arms, index) {
            Some(arm) => if arm.guard_text == "" && string.contains(arm.pattern_text, pattern_name) {
                found = true;
            } else {
                ()
            },
            None => (),
        };
        index = index + 1;
    };
    found
}

fn match_has_pattern_node(expr: AstExpr, pattern_name: String) -> Bool {
    let mut found = false;
    let mut index = 0;
    while !found && index < vec.vec_len(expr.patterns) {
        match vec.get(expr.patterns, index) {
            Some(node) => if node.role == "arm" && node.name == pattern_name {
                found = true;
            } else {
                ()
            },
            None => (),
        };
        index = index + 1;
    };
    found
}

fn last_text_part(text: String, separator: String) -> String {
    let parts = string.split(text, separator);
    let count = vec.vec_len(parts);
    if count == 0 {
        text
    } else {
        match vec.get(parts, count - 1) {
            Some(value) => value,
            None => text,
        }
    }
}

fn match_text_has_unguarded_pattern(text: String, pattern_name: String) -> Bool {
    let arrow_parts = string.split(text, "=>");
    let mut found = false;
    let mut index = 0;
    while !found && index + 1 < vec.vec_len(arrow_parts) {
        match vec.get(arrow_parts, index) {
            Some(part) => if true {
                let after_comma = last_text_part(part, ",");
                let header = last_text_part(after_comma, "{");
                if string.contains(header, pattern_name) && !string.contains(header, "if") {
                    found = true;
                } else {
                    ()
                };
                ()
            } else {
                ()
            },
            None => (),
        };
        index = index + 1;
    };
    found
}

fn check_expected_type(env: TypecheckEnv, units: Vec[ResolveUnit], module_path: String, span_value: SourceSpan, context: String, expected: String, found: String, max_errors: Int) -> TypecheckEnv {
    if types_compatible(env.aliases, module_path, expected, found) {
        env
    } else {
        let mut parts: Vec[String] = vec.new_vec();
        parts = vec.push(parts, context);
        parts = vec.push(parts, " type mismatch: expected '");
        parts = vec.push(parts, expected);
        parts = vec.push(parts, "', found '");
        parts = vec.push(parts, found);
        parts = vec.push(parts, "'");
        env_error(env, max_errors, "E1204", span_value, string.join(parts, ""), "change the expression or declared type so they match")
    }
}

fn check_statement(statement: AstStatement, env: TypecheckEnv, units: Vec[ResolveUnit], resolver: ResolverOutput, semantics: SemanticOutput, max_errors: Int) -> TypecheckEnv {
    let module_path = env.module_path;
    let function_name = env.function_name;
    let return_type = env.return_type;
    match statement.kind {
        AstLetStatement => match statement.expr {
            Some(expr) => if true {
                let expected = match statement.type_ref { Some(ty) => type_text(ty), None => "<unknown>" };
                let checked = infer_expr(expr, env, units, resolver, semantics, max_errors, expected);
                let mut out_env = checked.env;
                let final_type = if expected == "<unknown>" { checked.type_text } else { expected };
                if expected != "<unknown>" {
                    out_env = check_expected_type(out_env, units, module_path, statement.span, "let binding", expected, checked.type_text, max_errors);
                } else {
                    ()
                };
                out_env = append_binding(out_env, typecheck_binding(module_path, function_name, statement.name, final_type, statement.mutable, TypecheckLocalValue(), statement.span));
                out_env
            } else {
                env
            },
            None => env,
        },
        AstAssignStatement => match statement.expr {
            Some(expr) => match find_binding(env.bindings, statement.target) {
                Some(binding) => if binding.mutable {
                    let checked = infer_expr(expr, env, units, resolver, semantics, max_errors, binding.type_text);
                    check_expected_type(checked.env, units, module_path, statement.span, "assignment", binding.type_text, checked.type_text, max_errors)
                } else {
                    env_error(env, max_errors, "E1266", statement.span, "cannot assign to immutable binding", "declare the binding with `let mut` before assigning")
                },
                None => env_error(env, max_errors, "E1208", statement.span, "unknown assignment target", "assign only to a declared local binding"),
            },
            None => env,
        },
        AstReturnStatement => match statement.expr {
            Some(expr) => if true {
                let checked = infer_expr(expr, env, units, resolver, semantics, max_errors, return_type);
                check_expected_type(checked.env, units, module_path, statement.span, "return", return_type, checked.type_text, max_errors)
            } else {
                env
            },
            None => check_expected_type(env, units, module_path, statement.span, "return", return_type, "()", max_errors),
        },
        AstExprStatement => match statement.expr {
            Some(expr) => infer_expr(expr, env, units, resolver, semantics, max_errors, "<unknown>").env,
            None => env,
        },
    }
}

fn check_block(block: AstBlock, env: TypecheckEnv, units: Vec[ResolveUnit], resolver: ResolverOutput, semantics: SemanticOutput, max_errors: Int) -> TypecheckEnv {
    let module_path = env.module_path;
    let return_type = env.return_type;
    let mut out_env = env;
    let mut index = 0;
    while index < vec.vec_len(block.statements) {
        match vec.get(block.statements, index) {
            Some(statement) => if true {
                out_env = check_statement(statement, out_env, units, resolver, semantics, max_errors);
                ()
            } else {
                ()
            },
            None => (),
        };
        index = index + 1;
    };
    match block.tail_expr {
        Some(expr) => if true {
            let checked = infer_expr(expr, out_env, units, resolver, semantics, max_errors, return_type);
            out_env = check_expected_type(checked.env, units, module_path, expr.span, "function return", return_type, checked.type_text, max_errors);
            ()
        } else {
            ()
        },
        None => (),
    };
    out_env
}

fn initial_env_for_signature(module_path: String, signature: AstFunctionSignature, diagnostics: Vec[Diagnostic], aliases: TypeAliasIndex) -> TypecheckEnv {
    let mut bindings: Vec[TypecheckBinding] = vec.new_vec();
    let mut index = 0;
    while index < vec.vec_len(signature.params) {
        match vec.get(signature.params, index) {
            Some(param) => if true {
                bindings = vec.push(bindings, typecheck_binding(module_path, signature.name.value, param.name.value, type_text(param.type_ref), true, TypecheckLocalValue(), param.span));
                ()
            } else {
                ()
            },
            None => (),
        };
        index = index + 1;
    };
    typecheck_env(module_path, signature.name.value, type_text(signature.return_type), bindings, empty_generic_map(), aliases, diagnostics, vec.new_vec(), false, vec.new_vec())
}

fn check_function_item(function_item: AstFunctionDecl, module_path: String, units: Vec[ResolveUnit], resolver: ResolverOutput, semantics: SemanticOutput, aliases: TypeAliasIndex, output: TypecheckOutput, max_errors: Int) -> TypecheckOutput {
    let env = initial_env_for_signature(module_path, function_item.signature, output.diagnostics, aliases);
    let checked = check_block(function_item.body, env, units, resolver, semantics, max_errors);
    let mut out = typecheck_output(output.entry_module, output.functions, output.bindings, output.instantiations, checked.diagnostics);
    out = append_function(out, typecheck_function(module_path, function_item.signature.name.value, type_text(function_item.signature.return_type), vec.vec_len(function_item.signature.params), true, function_item.span));
    out = append_bindings(out, checked.bindings);
    append_instantiations(out, checked.instantiations)
}

fn check_impl_method(method: AstImplMethod, module_path: String, units: Vec[ResolveUnit], resolver: ResolverOutput, semantics: SemanticOutput, aliases: TypeAliasIndex, output: TypecheckOutput, max_errors: Int) -> TypecheckOutput {
    let env = initial_env_for_signature(module_path, method.signature, output.diagnostics, aliases);
    let checked = check_block(method.body, env, units, resolver, semantics, max_errors);
    let mut out = typecheck_output(output.entry_module, output.functions, output.bindings, output.instantiations, checked.diagnostics);
    out = append_function(out, typecheck_function(module_path, method.signature.name.value, type_text(method.signature.return_type), vec.vec_len(method.signature.params), true, method.span));
    out = append_bindings(out, checked.bindings);
    append_instantiations(out, checked.instantiations)
}

fn check_const_item(const_item: AstConstDecl, module_path: String, units: Vec[ResolveUnit], resolver: ResolverOutput, semantics: SemanticOutput, aliases: TypeAliasIndex, output: TypecheckOutput, max_errors: Int) -> TypecheckOutput {
    match const_item.initializer_expr {
        Some(expr) => if true {
            let env = typecheck_env(module_path, const_item.name.value, type_text(const_item.type_ref), vec.new_vec(), empty_generic_map(), aliases, output.diagnostics, vec.new_vec(), false, vec.new_vec());
            let checked = infer_expr(expr, env, units, resolver, semantics, max_errors, type_text(const_item.type_ref));
            let checked_env = check_expected_type(checked.env, units, module_path, const_item.span, "const initializer", type_text(const_item.type_ref), checked.type_text, max_errors);
            typecheck_output(output.entry_module, output.functions, output.bindings, output.instantiations, checked_env.diagnostics)
        } else {
            output
        },
        None => output,
    }
}

fn check_struct_defaults(struct_item: AstStructDecl, module_path: String, units: Vec[ResolveUnit], resolver: ResolverOutput, semantics: SemanticOutput, aliases: TypeAliasIndex, output: TypecheckOutput, max_errors: Int) -> TypecheckOutput {
    let mut out = output;
    let mut index = 0;
    while index < vec.vec_len(struct_item.fields) {
        match vec.get(struct_item.fields, index) {
            Some(field) => match field.default_expr {
                Some(expr) => if true {
                    let env = typecheck_env(module_path, struct_item.name.value, type_text(field.type_ref), vec.new_vec(), empty_generic_map(), aliases, out.diagnostics, vec.new_vec(), false, vec.new_vec());
                    let checked = infer_expr(expr, env, units, resolver, semantics, max_errors, type_text(field.type_ref));
                    let checked_env = check_expected_type(checked.env, units, module_path, field.span, "field default", type_text(field.type_ref), checked.type_text, max_errors);
                    out = typecheck_output(out.entry_module, out.functions, out.bindings, out.instantiations, checked_env.diagnostics);
                    ()
                } else {
                    ()
                },
                None => (),
            },
            None => (),
        };
        index = index + 1;
    };
    out
}

fn check_item(item: AstProgramItem, module_path: String, units: Vec[ResolveUnit], resolver: ResolverOutput, semantics: SemanticOutput, aliases: TypeAliasIndex, output: TypecheckOutput, max_errors: Int) -> TypecheckOutput {
    match item.function_item {
        Some(function_item) => check_function_item(function_item, module_path, units, resolver, semantics, aliases, output, max_errors),
        None => match item.const_item {
            Some(const_item) => check_const_item(const_item, module_path, units, resolver, semantics, aliases, output, max_errors),
            None => match item.struct_item {
                Some(struct_item) => check_struct_defaults(struct_item, module_path, units, resolver, semantics, aliases, output, max_errors),
                None => match item.impl_item {
                    Some(impl_item) => if true {
                        let mut out = output;
                        let mut index = 0;
                        while index < vec.vec_len(impl_item.methods) {
                            match vec.get(impl_item.methods, index) {
                                Some(method) => if true {
                                    out = check_impl_method(method, module_path, units, resolver, semantics, aliases, out, max_errors);
                                    ()
                                } else {
                                    ()
                                },
                                None => (),
                            };
                            index = index + 1;
                        };
                        out
                    } else {
                        output
                    },
                    None => output,
                },
            },
        },
    }
}

fn effect_or_capability_names(text: String) -> Vec[String] {
    if text == "" {
        vec.new_vec()
    } else {
        string.split(text, ",")
    }
}

fn known_effect(name: String) -> Bool {
    name == "io" || name == "fs" || name == "net" || name == "time" || name == "rand" || name == "env" || name == "proc" || name == "concurrency"
}

fn known_capability(name: String) -> Bool {
    known_effect(name)
}

fn append_effect_declaration_diagnostics(diagnostics: Vec[Diagnostic], names: Vec[String], span_value: SourceSpan, max_errors: Int) -> Vec[Diagnostic] {
    let mut out = diagnostics;
    let mut seen: Vec[String] = vec.new_vec();
    let mut index = 0;
    while index < vec.vec_len(names) {
        match vec.get(names, index) {
            Some(name) => if !known_effect(name) {
                let mut parts: Vec[String] = vec.new_vec();
                parts = vec.push(parts, "unknown effect '");
                parts = vec.push(parts, name);
                parts = vec.push(parts, "'");
                out = append_diagnostic_if_room(out, max_errors, with_help(error(diagnostic_code("E2003"), span_value, string.join(parts, "")), "known effects: io, fs, net, time, rand, env, proc, concurrency"));
                ()
            } else if string_vec_contains(seen, name) {
                let mut parts: Vec[String] = vec.new_vec();
                parts = vec.push(parts, "duplicate effect '");
                parts = vec.push(parts, name);
                parts = vec.push(parts, "' in signature");
                out = append_diagnostic_if_room(out, max_errors, error(diagnostic_code("E2004"), span_value, string.join(parts, "")));
                ()
            } else {
                seen = vec.push(seen, name);
                ()
            },
            None => (),
        };
        index = index + 1;
    };
    out
}

fn append_capability_declaration_diagnostics(diagnostics: Vec[Diagnostic], names: Vec[String], span_value: SourceSpan, max_errors: Int) -> Vec[Diagnostic] {
    let mut out = diagnostics;
    let mut seen: Vec[String] = vec.new_vec();
    let mut index = 0;
    while index < vec.vec_len(names) {
        match vec.get(names, index) {
            Some(name) => if !known_capability(name) {
                let mut parts: Vec[String] = vec.new_vec();
                parts = vec.push(parts, "unknown capability '");
                parts = vec.push(parts, name);
                parts = vec.push(parts, "'");
                out = append_diagnostic_if_room(out, max_errors, with_help(error(diagnostic_code("E2007"), span_value, string.join(parts, "")), "known capabilities: io, fs, net, time, rand, env, proc, concurrency"));
                ()
            } else if string_vec_contains(seen, name) {
                let mut parts: Vec[String] = vec.new_vec();
                parts = vec.push(parts, "duplicate capability '");
                parts = vec.push(parts, name);
                parts = vec.push(parts, "' in signature");
                out = append_diagnostic_if_room(out, max_errors, error(diagnostic_code("E2008"), span_value, string.join(parts, "")));
                ()
            } else {
                seen = vec.push(seen, name);
                ()
            },
            None => (),
        };
        index = index + 1;
    };
    out
}

fn function_effect_key(module_path: String, name: String) -> String {
    if module_path == "" || module_path == "<root>" {
        name
    } else {
        let mut parts: Vec[String] = vec.new_vec();
        parts = vec.push(parts, module_path);
        parts = vec.push(parts, "::");
        parts = vec.push(parts, name);
        string.join(parts, "")
    }
}

fn effect_entry_key(entry: EffectFunctionEntry) -> String {
    function_effect_key(entry.module_path, entry.name)
}

fn effect_call_callee_key(edge: EffectCallEdge) -> String {
    function_effect_key(edge.callee_module, edge.callee_name)
}

fn effect_key(module_path: String, name: String) -> EffectKey {
    EffectKey {
        module_path: module_path,
        name: name,
    }
}

fn effect_entry_struct_key(entry: EffectFunctionEntry) -> EffectKey {
    effect_key(entry.module_path, entry.name)
}

fn effect_call_callee_struct_key(edge: EffectCallEdge) -> EffectKey {
    effect_key(edge.callee_module, edge.callee_name)
}

fn same_effect_key(left: EffectKey, right: EffectKey) -> Bool {
    left.module_path == right.module_path && left.name == right.name
}

fn effect_key_vec_contains(values: Vec[EffectKey], value: EffectKey) -> Bool {
    let mut found = false;
    let mut index = 0;
    while !found && index < vec.vec_len(values) {
        match vec.get(values, index) {
            Some(item) => if same_effect_key(item, value) {
                found = true;
            } else {
                ()
            },
            None => (),
        };
        index = index + 1;
    };
    found
}

fn find_effect_entry_by_struct_key(entries: Vec[EffectFunctionEntry], key: EffectKey) -> Option[EffectFunctionEntry] {
    let mut out: Option[EffectFunctionEntry] = None();
    let mut found = false;
    let mut index = 0;
    while !found && index < vec.vec_len(entries) {
        match vec.get(entries, index) {
            Some(entry) => if entry.module_path == key.module_path && entry.name == key.name {
                out = Some(entry);
                found = true;
            } else {
                ()
            },
            None => (),
        };
        index = index + 1;
    };
    out
}

fn find_effect_entry(entries: Vec[EffectFunctionEntry], module_path: String, name: String) -> Option[EffectFunctionEntry] {
    let mut out: Option[EffectFunctionEntry] = None();
    let mut found = false;
    let mut index = 0;
    while !found && index < vec.vec_len(entries) {
        match vec.get(entries, index) {
            Some(entry) => if entry.module_path == module_path && entry.name == name {
                out = Some(entry);
                found = true;
            } else {
                ()
            },
            None => (),
        };
        index = index + 1;
    };
    out
}

fn find_effect_entry_by_key(entries: Vec[EffectFunctionEntry], key: String) -> Option[EffectFunctionEntry] {
    let mut out: Option[EffectFunctionEntry] = None();
    let mut found = false;
    let mut index = 0;
    while !found && index < vec.vec_len(entries) {
        match vec.get(entries, index) {
            Some(entry) => if effect_entry_key(entry) == key {
                out = Some(entry);
                found = true;
            } else {
                ()
            },
            None => (),
        };
        index = index + 1;
    };
    out
}

fn find_effect_entry_by_name(entries: Vec[EffectFunctionEntry], name: String) -> Option[EffectFunctionEntry] {
    let mut out: Option[EffectFunctionEntry] = None();
    let mut found = false;
    let mut index = 0;
    while !found && index < vec.vec_len(entries) {
        match vec.get(entries, index) {
            Some(entry) => if entry.name == name {
                out = Some(entry);
                found = true;
            } else {
                ()
            },
            None => (),
        };
        index = index + 1;
    };
    out
}

fn replace_effect_entry(entries: Vec[EffectFunctionEntry], updated: EffectFunctionEntry) -> Vec[EffectFunctionEntry] {
    let mut out: Vec[EffectFunctionEntry] = vec.new_vec();
    let mut index = 0;
    while index < vec.vec_len(entries) {
        match vec.get(entries, index) {
            Some(entry) => if effect_entry_key(entry) == effect_entry_key(updated) {
                out = vec.push(out, updated);
                ()
            } else {
                out = vec.push(out, entry);
                ()
            },
            None => (),
        };
        index = index + 1;
    };
    out
}

fn append_signature_effect_entry(entries: Vec[EffectFunctionEntry], module_path: String, signature: AstFunctionSignature, span_value: SourceSpan, body_span: SourceSpan, has_body: Bool) -> Vec[EffectFunctionEntry] {
    vec.push(entries, effect_function_entry(module_path, signature.name.value, effect_or_capability_names(signature.effect_names), effect_or_capability_names(signature.capability_names), vec.new_vec(), vec.new_vec(), span_value, body_span, has_body))
}

fn collect_effect_entries_for_item(entries: Vec[EffectFunctionEntry], item: AstProgramItem, module_path: String) -> Vec[EffectFunctionEntry] {
    match item.function_item {
        Some(function_item) => append_signature_effect_entry(entries, module_path, function_item.signature, function_item.span, function_item.body.span, true),
        None => match item.function_signature {
            Some(signature) => append_signature_effect_entry(entries, module_path, signature, item.span, item.span, false),
            None => match item.impl_item {
                Some(impl_item) => if true {
                    let mut out = entries;
                    let mut index = 0;
                    while index < vec.vec_len(impl_item.methods) {
                        match vec.get(impl_item.methods, index) {
                            Some(method) => if true {
                                out = append_signature_effect_entry(out, module_path, method.signature, method.span, method.body.span, true);
                                ()
                            } else {
                                ()
                            },
                            None => (),
                        };
                        index = index + 1;
                    };
                    out
                } else {
                    entries
                },
                None => entries,
            },
        },
    }
}

fn collect_effect_entries(units: Vec[ResolveUnit]) -> Vec[EffectFunctionEntry] {
    let mut entries: Vec[EffectFunctionEntry] = vec.new_vec();
    let mut unit_index = 0;
    while unit_index < vec.vec_len(units) {
        match vec.get(units, unit_index) {
            Some(unit) => if true {
                let mut item_index = 0;
                while item_index < vec.vec_len(unit.program.items) {
                    match vec.get(unit.program.items, item_index) {
                        Some(item) => if true {
                            entries = collect_effect_entries_for_item(entries, item, unit.module_path);
                            ()
                        } else {
                            ()
                        },
                        None => (),
                    };
                    item_index = item_index + 1;
                };
                ()
            } else {
                ()
            },
            None => (),
        };
        unit_index = unit_index + 1;
    };
    entries
}

fn resolve_call_effect_entry_by_name(name: String, entries: Vec[EffectFunctionEntry], units: Vec[ResolveUnit], resolver: ResolverOutput, module_path: String) -> Option[EffectFunctionEntry] {
    let module_text = path_prefix(name);
    let item_name = path_tail(name);
    if module_text == "" {
        match find_effect_entry(entries, module_path, item_name) {
            Some(entry) => Some(entry),
            None => find_effect_entry_by_name(entries, item_name),
        }
    } else {
        match resolve_qualified_module(resolver.imports, units, module_path, module_text) {
            Some(target_module) => match find_effect_entry(entries, target_module, item_name) {
                Some(entry) => Some(entry),
                None => find_effect_entry_by_name(entries, item_name),
            },
            None => find_effect_entry_by_name(entries, item_name),
        }
    }
}

fn resolve_call_effect_entry(expr: AstExpr, entries: Vec[EffectFunctionEntry], units: Vec[ResolveUnit], resolver: ResolverOutput, module_path: String) -> Option[EffectFunctionEntry] {
    resolve_call_effect_entry_by_name(expr.name, entries, units, resolver, module_path)
}

fn append_call_effect_diagnostics(diagnostics: Vec[Diagnostic], caller: EffectFunctionEntry, callee: EffectFunctionEntry, span_value: SourceSpan, max_errors: Int) -> Vec[Diagnostic] {
    let mut missing: Vec[String] = vec.new_vec();
    let mut index = 0;
    while index < vec.vec_len(callee.effect_names) {
        match vec.get(callee.effect_names, index) {
            Some(effect) => if string_vec_contains(caller.effect_names, effect) {
                ()
            } else {
                missing = push_unique_string(missing, effect);
                ()
            },
            None => (),
        };
        index = index + 1;
    };
    if vec.vec_len(missing) == 0 {
        diagnostics
    } else {
        let mut parts: Vec[String] = vec.new_vec();
        parts = vec.push(parts, "calling '");
        parts = vec.push(parts, callee.name);
        parts = vec.push(parts, "' requires undeclared effects: ");
        parts = vec.push(parts, string.join(missing, ", "));
        append_diagnostic_if_room(diagnostics, max_errors, with_help(error(diagnostic_code("E2001"), span_value, string.join(parts, "")), "add the required effects on the enclosing function"))
    }
}

fn merge_scan(left: EffectScan, right: EffectScan) -> EffectScan {
    effect_scan(append_all_diagnostics(left.diagnostics, right.diagnostics, 100000), append_unique_strings(left.effect_names, right.effect_names), append_effect_calls(left.call_edges, right.call_edges))
}

fn append_effect_calls(left: Vec[EffectCallEdge], right: Vec[EffectCallEdge]) -> Vec[EffectCallEdge] {
    let mut out = left;
    let mut index = 0;
    while index < vec.vec_len(right) {
        match vec.get(right, index) {
            Some(edge) => if true {
                out = vec.push(out, edge);
                ()
            } else {
                ()
            },
            None => (),
        };
        index = index + 1;
    };
    out
}

fn scan_call_effects(out: EffectScan, kind: AstExprKind, name: String, span_value: SourceSpan, caller: EffectFunctionEntry, entries: Vec[EffectFunctionEntry], units: Vec[ResolveUnit], resolver: ResolverOutput, max_errors: Int) -> EffectScan {
    let mut next = out;
    match kind {
        AstCallExpr => match resolve_call_effect_entry_by_name(name, entries, units, resolver, caller.module_path) {
            Some(callee) => if vec.vec_len(callee.effect_names) > 0 || vec.vec_len(callee.direct_effect_names) > 0 {
                next = effect_scan(append_call_effect_diagnostics(next.diagnostics, caller, callee, span_value, max_errors), append_unique_strings(next.effect_names, callee.effect_names), vec.push(next.call_edges, effect_call_edge(caller.module_path, caller.name, callee.module_path, callee.name, callee.effect_names, span_value)));
                ()
            } else {
                ()
            },
            None => (),
        },
        _ => (),
    };
    next
}

fn scan_expr_effects(expr: AstExpr, caller: EffectFunctionEntry, entries: Vec[EffectFunctionEntry], units: Vec[ResolveUnit], resolver: ResolverOutput, diagnostics: Vec[Diagnostic], max_errors: Int) -> EffectScan {
    let mut out = scan_call_effects(effect_scan(diagnostics, vec.new_vec(), vec.new_vec()), expr.kind, expr.name, expr.span, caller, entries, units, resolver, max_errors);
    let mut index = 0;
    while index < vec.vec_len(expr.nodes) {
        match vec.get(expr.nodes, index) {
            Some(node) => if true {
                out = scan_call_effects(out, node.kind, node.name, node.span, caller, entries, units, resolver, max_errors);
                ()
            } else {
                ()
            },
            None => (),
        };
        index = index + 1;
    };
    effect_scan(out.diagnostics, out.effect_names, out.call_edges)
}

fn scan_statement_effects(statement: AstStatement, caller: EffectFunctionEntry, entries: Vec[EffectFunctionEntry], units: Vec[ResolveUnit], resolver: ResolverOutput, diagnostics: Vec[Diagnostic], max_errors: Int) -> EffectScan {
    match statement.expr {
        Some(expr) => scan_expr_effects(expr, caller, entries, units, resolver, diagnostics, max_errors),
        None => effect_scan(diagnostics, vec.new_vec(), vec.new_vec()),
    }
}

fn scan_block_effects(block: AstBlock, caller: EffectFunctionEntry, entries: Vec[EffectFunctionEntry], units: Vec[ResolveUnit], resolver: ResolverOutput, diagnostics: Vec[Diagnostic], max_errors: Int) -> EffectScan {
    let mut out = effect_scan(diagnostics, vec.new_vec(), vec.new_vec());
    let mut index = 0;
    while index < vec.vec_len(block.statements) {
        match vec.get(block.statements, index) {
            Some(statement) => if true {
                out = merge_scan(out, scan_statement_effects(statement, caller, entries, units, resolver, vec.new_vec(), max_errors));
                ()
            } else {
                ()
            },
            None => (),
        };
        index = index + 1;
    };
    match block.tail_expr {
        Some(expr) => if true {
            out = merge_scan(out, scan_expr_effects(expr, caller, entries, units, resolver, vec.new_vec(), max_errors));
            ()
        } else {
            ()
        },
        None => (),
    };
    out
}

fn analyze_effect_body(entries: Vec[EffectFunctionEntry], caller: EffectFunctionEntry, body: AstBlock, units: Vec[ResolveUnit], resolver: ResolverOutput, diagnostics: Vec[Diagnostic], max_errors: Int) -> EffectScan {
    scan_block_effects(body, caller, entries, units, resolver, diagnostics, max_errors)
}

fn effect_entry_with_scan(entry: EffectFunctionEntry, scanned: EffectScan) -> EffectFunctionEntry {
    effect_function_entry(entry.module_path, entry.name, entry.effect_names, entry.capability_names, append_unique_strings(entry.direct_effect_names, scanned.effect_names), append_effect_calls(entry.call_edges, scanned.call_edges), entry.span, entry.body_span, entry.has_body)
}

fn effect_entries_with_body_scans(entries: Vec[EffectFunctionEntry], units: Vec[ResolveUnit], resolver: ResolverOutput, diagnostics: Vec[Diagnostic], max_errors: Int) -> EffectBodyResult {
    let mut out_entries = entries;
    let mut out_diagnostics = diagnostics;
    let mut unit_index = 0;
    while unit_index < vec.vec_len(units) {
        match vec.get(units, unit_index) {
            Some(unit) => if true {
                let mut item_index = 0;
                while item_index < vec.vec_len(unit.program.items) {
                    match vec.get(unit.program.items, item_index) {
                        Some(item) => match item.function_item {
                            Some(function_item) => match find_effect_entry(out_entries, unit.module_path, function_item.signature.name.value) {
                                Some(caller) => if true {
                                    let scanned = analyze_effect_body(out_entries, caller, function_item.body, units, resolver, vec.new_vec(), max_errors);
                                    out_diagnostics = append_all_diagnostics(out_diagnostics, scanned.diagnostics, max_errors);
                                    out_entries = replace_effect_entry(out_entries, effect_entry_with_scan(caller, scanned));
                                    ()
                                } else {
                                    ()
                                },
                                None => (),
                            },
                            None => match item.impl_item {
                                Some(impl_item) => if true {
                                    let mut method_index = 0;
                                    while method_index < vec.vec_len(impl_item.methods) {
                                        match vec.get(impl_item.methods, method_index) {
                                            Some(method) => match find_effect_entry(out_entries, unit.module_path, method.signature.name.value) {
                                                Some(caller) => if true {
                                                    let scanned = analyze_effect_body(out_entries, caller, method.body, units, resolver, vec.new_vec(), max_errors);
                                                    out_diagnostics = append_all_diagnostics(out_diagnostics, scanned.diagnostics, max_errors);
                                                    out_entries = replace_effect_entry(out_entries, effect_entry_with_scan(caller, scanned));
                                                    ()
                                                } else {
                                                    ()
                                                },
                                                None => (),
                                            },
                                            None => (),
                                        };
                                        method_index = method_index + 1;
                                    };
                                    ()
                                } else {
                                    ()
                                },
                                None => (),
                            },
                        },
                        None => (),
                    };
                    item_index = item_index + 1;
                };
                ()
            } else {
                ()
            },
            None => (),
        };
        unit_index = unit_index + 1;
    };
    effect_body_result(out_entries, out_diagnostics)
}

fn effect_closure_for_entry(entries: Vec[EffectFunctionEntry], entry: EffectFunctionEntry) -> Vec[String] {
    let mut out: Vec[String] = vec.new_vec();
    let mut visited: Vec[EffectKey] = vec.new_vec();
    let mut work: Vec[EffectFunctionEntry] = vec.new_vec();
    let mut work_keys: Vec[EffectKey] = vec.new_vec();
    work = vec.push(work, entry);
    work_keys = vec.push(work_keys, effect_entry_struct_key(entry));
    let mut work_index = 0;
    while work_index < vec.vec_len(work) {
        match vec.get(work, work_index) {
            Some(current) => if effect_key_vec_contains(visited, effect_entry_struct_key(current)) {
                ()
            } else {
                visited = vec.push(visited, effect_entry_struct_key(current));
                out = append_unique_strings(out, current.direct_effect_names);
                let mut edge_index = 0;
                while edge_index < vec.vec_len(current.call_edges) {
                    match vec.get(current.call_edges, edge_index) {
                        Some(edge) => if true {
                            let callee_key = effect_call_callee_struct_key(edge);
                            out = append_unique_strings(out, edge.effect_names);
                            if effect_key_vec_contains(visited, callee_key) || effect_key_vec_contains(work_keys, callee_key) {
                                ()
                            } else {
                                match find_effect_entry_by_struct_key(entries, callee_key) {
                                    Some(callee) => if true {
                                        work = vec.push(work, callee);
                                        work_keys = vec.push(work_keys, callee_key);
                                        ()
                                    } else {
                                        ()
                                    },
                                    None => (),
                                };
                            };
                            ()
                        } else {
                            ()
                        },
                        None => (),
                    };
                    edge_index = edge_index + 1;
                };
                ()
            },
            None => (),
        };
        work_index = work_index + 1;
    };
    out
}

fn entry_needs_transitive_effect_diagnostics(entry: EffectFunctionEntry) -> Bool {
    entry.has_body && vec.vec_len(entry.call_edges) > 0
}

fn entry_needs_capability_authority_diagnostics(entry: EffectFunctionEntry) -> Bool {
    entry.has_body && (vec.vec_len(entry.effect_names) > 0 || vec.vec_len(entry.call_edges) > 0)
}

fn find_effect_path_from_key(entries: Vec[EffectFunctionEntry], key: String, effect: String, visited: Vec[String], path: Vec[String], first_source: Int, first_start: Int, first_end: Int, has_first_span: Bool, fallback_source: Int, fallback_start: Int, fallback_end: Int) -> EffectPath {
    if string_vec_contains(visited, key) {
        effect_path(vec.new_vec(), span(source_id(fallback_source), fallback_start, fallback_end), false)
    } else {
        match find_effect_entry_by_key(entries, key) {
            Some(entry) => if true {
                let mut out: Vec[String] = vec.new_vec();
                let mut out_source = fallback_source;
                let mut out_start = fallback_start;
                let mut out_end = fallback_end;
                let mut found = false;
                let mut next_visited = vec.push(visited, key);
                let mut index = 0;
                while !found && index < vec.vec_len(entry.call_edges) {
                    match vec.get(entry.call_edges, index) {
                        Some(edge) => if true {
                            let mut next_path = path;
                            let next_source = if has_first_span { first_source } else { edge.span.source.value };
                            let next_start = if has_first_span { first_start } else { edge.span.start };
                            let next_end = if has_first_span { first_end } else { edge.span.end };
                            next_path = vec.push(next_path, edge.callee_name);
                            if string_vec_contains(edge.effect_names, effect) {
                                out = next_path;
                                out_source = next_source;
                                out_start = next_start;
                                out_end = next_end;
                                found = true;
                            } else {
                                let nested = find_effect_path_from_key(entries, effect_call_callee_key(edge), effect, next_visited, next_path, next_source, next_start, next_end, true, fallback_source, fallback_start, fallback_end);
                                if nested.found {
                                    out = nested.names;
                                    out_source = nested.span.source.value;
                                    out_start = nested.span.start;
                                    out_end = nested.span.end;
                                    found = true;
                                } else {
                                    ()
                                };
                            };
                            ()
                        } else {
                            ()
                        },
                        None => (),
                    };
                    index = index + 1;
                };
                effect_path(out, span(source_id(out_source), out_start, out_end), found)
            } else {
                effect_path(vec.new_vec(), span(source_id(fallback_source), fallback_start, fallback_end), false)
            },
            None => effect_path(vec.new_vec(), span(source_id(fallback_source), fallback_start, fallback_end), false),
        }
    }
}

fn append_transitive_effect_diagnostics(diagnostics: Vec[Diagnostic], entries: Vec[EffectFunctionEntry], max_errors: Int) -> Vec[Diagnostic] {
    let mut out = diagnostics;
    let mut index = 0;
    while index < vec.vec_len(entries) {
        match vec.get(entries, index) {
            Some(entry) => if entry_needs_transitive_effect_diagnostics(entry) {
                let closure = effect_closure_for_entry(entries, entry);
                let mut effect_index = 0;
                while effect_index < vec.vec_len(closure) {
                    match vec.get(closure, effect_index) {
                        Some(effect) => if string_vec_contains(entry.effect_names, effect) {
                            ()
                        } else {
                            let mut start_path: Vec[String] = vec.new_vec();
                            start_path = vec.push(start_path, entry.name);
                            let path = find_effect_path_from_key(entries, effect_entry_key(entry), effect, vec.new_vec(), start_path, entry.span.source.value, entry.span.start, entry.span.end, false, entry.span.source.value, entry.span.start, entry.span.end);
                            if path.found && vec.vec_len(path.names) >= 3 {
                                let mut parts: Vec[String] = vec.new_vec();
                                parts = vec.push(parts, "function '");
                                parts = vec.push(parts, entry.name);
                                parts = vec.push(parts, "' requires transitive effect '");
                                parts = vec.push(parts, effect);
                                parts = vec.push(parts, "' via call path ");
                                parts = vec.push(parts, string.join(path.names, " -> "));
                                out = append_diagnostic_if_room(out, max_errors, with_help(error(diagnostic_code("E2005"), path.span, string.join(parts, "")), "declare the transitive effect on the caller or refactor the call chain"));
                                ()
                            } else {
                                ()
                            };
                        },
                        None => (),
                    };
                    effect_index = effect_index + 1;
                };
                ()
            } else {
                ()
            },
            None => (),
        };
        index = index + 1;
    };
    out
}

fn append_capability_authority_diagnostics(diagnostics: Vec[Diagnostic], entries: Vec[EffectFunctionEntry], max_errors: Int) -> Vec[Diagnostic] {
    let mut out = diagnostics;
    let mut index = 0;
    while index < vec.vec_len(entries) {
        match vec.get(entries, index) {
            Some(entry) => if entry_needs_capability_authority_diagnostics(entry) {
                let mut required = append_unique_strings(entry.effect_names, effect_closure_for_entry(entries, entry));
                let mut effect_index = 0;
                while effect_index < vec.vec_len(required) {
                    match vec.get(required, effect_index) {
                        Some(effect) => if string_vec_contains(entry.capability_names, effect) {
                            ()
                        } else {
                            let mut start_path: Vec[String] = vec.new_vec();
                            start_path = vec.push(start_path, entry.name);
                            let path = find_effect_path_from_key(entries, effect_entry_key(entry), effect, vec.new_vec(), start_path, entry.span.source.value, entry.span.start, entry.span.end, false, entry.span.source.value, entry.span.start, entry.span.end);
                            let mut parts: Vec[String] = vec.new_vec();
                            parts = vec.push(parts, "function '");
                            parts = vec.push(parts, entry.name);
                            parts = vec.push(parts, "' requires capability '");
                            parts = vec.push(parts, effect);
                            if path.found && vec.vec_len(path.names) > 1 {
                                parts = vec.push(parts, "' via call path ");
                                parts = vec.push(parts, string.join(path.names, " -> "));
                            } else {
                                parts = vec.push(parts, "'");
                            };
                            out = append_diagnostic_if_room(out, max_errors, with_help(error(diagnostic_code("E2009"), path.span, string.join(parts, "")), "declare the required capability on the caller and thread authority through callers"));
                            ()
                        },
                        None => (),
                    };
                    effect_index = effect_index + 1;
                };
                ()
            } else {
                ()
            },
            None => (),
        };
        index = index + 1;
    };
    out
}

fn contract_proof(expr: AstExpr) -> String {
    match expr.kind {
        AstBoolExpr => if expr.name == "true" {
            "true"
        } else if expr.name == "false" {
            "false"
        } else {
            "unknown"
        },
        AstBinaryExpr => if expr.op == "==" {
            let left = match direct_expr_at(expr, 0) { Some(value) => value, None => simple_expr(AstUnitExpr(), "", "", expr.span, "()") };
            let right = match direct_expr_at(expr, 1) { Some(value) => value, None => simple_expr(AstUnitExpr(), "", "", expr.span, "()") };
            if left.text == right.text && left.text != "" {
                "true"
            } else {
                "unknown"
            }
        } else {
            "unknown"
        },
        _ => "unknown",
    }
}

fn append_static_contract_diagnostic(diagnostics: Vec[Diagnostic], kind: String, function_name: String, expr: AstExpr, max_errors: Int) -> Vec[Diagnostic] {
    let proof = contract_proof(expr);
    if proof == "false" {
        let mut parts: Vec[String] = vec.new_vec();
        parts = vec.push(parts, kind);
        parts = vec.push(parts, " contract for '");
        parts = vec.push(parts, function_name);
        parts = vec.push(parts, "' is always false");
        if kind == "requires" {
            append_diagnostic_if_room(diagnostics, max_errors, with_help(error(diagnostic_code("E4001"), expr.span, string.join(parts, "")), "fix the contract or function preconditions"))
        } else {
            append_diagnostic_if_room(diagnostics, max_errors, with_help(error(diagnostic_code("E4002"), expr.span, string.join(parts, "")), "fix the postcondition expression"))
        }
    } else if proof == "true" {
        let mut parts: Vec[String] = vec.new_vec();
        parts = vec.push(parts, kind);
        parts = vec.push(parts, " contract for '");
        parts = vec.push(parts, function_name);
        parts = vec.push(parts, "' discharged at compile time");
        append_diagnostic_if_room(diagnostics, max_errors, note(diagnostic_code("E4005"), expr.span, string.join(parts, "")))
    } else {
        let mut parts: Vec[String] = vec.new_vec();
        parts = vec.push(parts, kind);
        parts = vec.push(parts, " contract for '");
        parts = vec.push(parts, function_name);
        parts = vec.push(parts, "' kept as residual runtime obligation");
        append_diagnostic_if_room(diagnostics, max_errors, note(diagnostic_code("E4003"), expr.span, string.join(parts, "")))
    }
}

fn append_contract_purity_diagnostics(diagnostics: Vec[Diagnostic], expr: AstExpr, entries: Vec[EffectFunctionEntry], units: Vec[ResolveUnit], resolver: ResolverOutput, module_path: String, max_errors: Int) -> Vec[Diagnostic] {
    let mut out = diagnostics;
    match expr.kind {
        AstCallExpr => match resolve_call_effect_entry(expr, entries, units, resolver, module_path) {
            Some(callee) => if vec.vec_len(callee.effect_names) > 0 {
                out = append_diagnostic_if_room(out, max_errors, with_help(error(diagnostic_code("E2002"), expr.span, "contracts must be pure; effectful call found"), "remove IO/time/rand/net/fs calls from requires/ensures/invariant"));
                ()
            } else {
                ()
            },
            None => (),
        },
        _ => (),
    };
    let mut index = 0;
    while index < expr.direct_child_count {
        match direct_expr_at(expr, index) {
            Some(child) => if true {
                out = append_contract_purity_diagnostics(out, child, entries, units, resolver, module_path, max_errors);
                ()
            } else {
                ()
            },
            None => (),
        };
        index = index + 1;
    };
    out
}

fn append_contract_type_diagnostic(env: TypecheckEnv, units: Vec[ResolveUnit], resolver: ResolverOutput, semantics: SemanticOutput, expr: AstExpr, expected_code: String, message: String, max_errors: Int) -> TypecheckEnv {
    let checked = infer_expr(expr, env, units, resolver, semantics, max_errors, "Bool");
    if types_compatible(checked.env.aliases, checked.env.module_path, "Bool", checked.type_text) {
        checked.env
    } else {
        env_error(checked.env, max_errors, expected_code, expr.span, message, "found a non-Bool contract expression")
    }
}

fn append_result_binding(env: TypecheckEnv, signature: AstFunctionSignature) -> TypecheckEnv {
    append_binding(env, typecheck_binding(env.module_path, signature.name.value, "result", type_text(signature.return_type), false, TypecheckTemporaryValue(), signature.span))
}

fn check_function_contracts(function_item: AstFunctionDecl, module_path: String, units: Vec[ResolveUnit], resolver: ResolverOutput, semantics: SemanticOutput, aliases: TypeAliasIndex, entries: Vec[EffectFunctionEntry], diagnostics: Vec[Diagnostic], max_errors: Int) -> Vec[Diagnostic] {
    let mut out = diagnostics;
    match function_item.requires_expr {
        Some(expr) => if true {
            let env = initial_env_for_signature(module_path, function_item.signature, out, aliases);
            let checked_env = append_contract_type_diagnostic(env, units, resolver, semantics, expr, "E1200", "requires contract must have type Bool", max_errors);
            out = checked_env.diagnostics;
            out = append_contract_purity_diagnostics(out, expr, entries, units, resolver, module_path, max_errors);
            out = append_static_contract_diagnostic(out, "requires", function_item.signature.name.value, expr, max_errors);
            ()
        } else {
            ()
        },
        None => (),
    };
    match function_item.ensures_expr {
        Some(expr) => if true {
            let env = append_result_binding(initial_env_for_signature(module_path, function_item.signature, out, aliases), function_item.signature);
            let checked_env = append_contract_type_diagnostic(env, units, resolver, semantics, expr, "E1201", "ensures contract must have type Bool", max_errors);
            out = checked_env.diagnostics;
            out = append_contract_purity_diagnostics(out, expr, entries, units, resolver, module_path, max_errors);
            out = append_static_contract_diagnostic(out, "ensures", function_item.signature.name.value, expr, max_errors);
            ()
        } else {
            ()
        },
        None => (),
    };
    out
}

fn check_impl_method_contracts(method: AstImplMethod, module_path: String, units: Vec[ResolveUnit], resolver: ResolverOutput, semantics: SemanticOutput, aliases: TypeAliasIndex, entries: Vec[EffectFunctionEntry], diagnostics: Vec[Diagnostic], max_errors: Int) -> Vec[Diagnostic] {
    let fake_function = function_decl(method.signature, method.requires_expr, method.ensures_expr, method.body, method.span);
    check_function_contracts(fake_function, module_path, units, resolver, semantics, aliases, entries, diagnostics, max_errors)
}

fn append_contract_diagnostics_for_item(diagnostics: Vec[Diagnostic], item: AstProgramItem, module_path: String, units: Vec[ResolveUnit], resolver: ResolverOutput, semantics: SemanticOutput, aliases: TypeAliasIndex, entries: Vec[EffectFunctionEntry], max_errors: Int) -> Vec[Diagnostic] {
    match item.function_item {
        Some(function_item) => check_function_contracts(function_item, module_path, units, resolver, semantics, aliases, entries, diagnostics, max_errors),
        None => match item.impl_item {
            Some(impl_item) => if true {
                let mut out = diagnostics;
                let mut index = 0;
                while index < vec.vec_len(impl_item.methods) {
                    match vec.get(impl_item.methods, index) {
                        Some(method) => if true {
                            out = check_impl_method_contracts(method, module_path, units, resolver, semantics, aliases, entries, out, max_errors);
                            ()
                        } else {
                            ()
                        },
                        None => (),
                    };
                    index = index + 1;
                };
                out
            } else {
                diagnostics
            },
            None => diagnostics,
        },
    }
}

fn append_contract_diagnostics(diagnostics: Vec[Diagnostic], units: Vec[ResolveUnit], resolver: ResolverOutput, semantics: SemanticOutput, aliases: TypeAliasIndex, entries: Vec[EffectFunctionEntry], max_errors: Int) -> Vec[Diagnostic] {
    let mut out = diagnostics;
    let mut unit_index = 0;
    while unit_index < vec.vec_len(units) {
        match vec.get(units, unit_index) {
            Some(unit) => if true {
                let mut item_index = 0;
                while item_index < vec.vec_len(unit.program.items) {
                    match vec.get(unit.program.items, item_index) {
                        Some(item) => if true {
                            out = append_contract_diagnostics_for_item(out, item, unit.module_path, units, resolver, semantics, aliases, entries, max_errors);
                            ()
                        } else {
                            ()
                        },
                        None => (),
                    };
                    item_index = item_index + 1;
                };
                ()
            } else {
                ()
            },
            None => (),
        };
        unit_index = unit_index + 1;
    };
    out
}

fn append_effect_declaration_diagnostics_for_entries(diagnostics: Vec[Diagnostic], entries: Vec[EffectFunctionEntry], max_errors: Int) -> Vec[Diagnostic] {
    let mut out = diagnostics;
    let mut index = 0;
    while index < vec.vec_len(entries) {
        match vec.get(entries, index) {
            Some(entry) => if true {
                out = append_effect_declaration_diagnostics(out, entry.effect_names, entry.span, max_errors);
                out = append_capability_declaration_diagnostics(out, entry.capability_names, entry.span, max_errors);
                ()
            } else {
                ()
            },
            None => (),
        };
        index = index + 1;
    };
    out
}

fn append_effect_capability_contract_diagnostics(output: TypecheckOutput, units: Vec[ResolveUnit], resolver: ResolverOutput, semantics: SemanticOutput, aliases: TypeAliasIndex, max_errors: Int) -> TypecheckOutput {
    let entries = collect_effect_entries(units);
    let mut diagnostics = append_effect_declaration_diagnostics_for_entries(output.diagnostics, entries, max_errors);
    diagnostics = append_contract_diagnostics(diagnostics, units, resolver, semantics, aliases, entries, max_errors);
    if vec.vec_len(diagnostics) >= max_errors {
        typecheck_output(output.entry_module, output.functions, output.bindings, output.instantiations, diagnostics)
    } else {
        let body_result = effect_entries_with_body_scans(entries, units, resolver, diagnostics, max_errors);
        diagnostics = append_transitive_effect_diagnostics(body_result.diagnostics, body_result.entries, max_errors);
        diagnostics = append_capability_authority_diagnostics(diagnostics, body_result.entries, max_errors);
        typecheck_output(output.entry_module, output.functions, output.bindings, output.instantiations, diagnostics)
    }
}

fn state_with_diagnostics(state: OwnershipState, diagnostics: Vec[Diagnostic]) -> OwnershipState {
    ownership_state(state.bindings, state.borrows, state.moved, state.resources, diagnostics)
}

fn state_error(state: OwnershipState, max_errors: Int, code: String, span_value: SourceSpan, message: String, help: String) -> OwnershipState {
    let diag = if help == "" {
        error(diagnostic_code(code), span_value, message)
    } else {
        with_help(error(diagnostic_code(code), span_value, message), help)
    };
    state_with_diagnostics(state, append_diagnostic_if_room(state.diagnostics, max_errors, diag))
}

fn type_base_name(type_value: String) -> String {
    let generic_parts = string.split(type_value, "[");
    let head = match vec.get(generic_parts, 0) { Some(value) => value, None => type_value };
    path_tail(head)
}

fn binding_root(target: String) -> String {
    let parts = string.split(target, ".");
    match vec.get(parts, 0) {
        Some(value) => value,
        None => target,
    }
}

fn targets_overlap(left: String, right: String) -> Bool {
    left == right || string.starts_with(left, join3(right, ".", "")) || string.starts_with(right, join3(left, ".", ""))
}

fn find_ownership_binding(bindings: Vec[OwnershipBinding], name: String) -> Option[OwnershipBinding] {
    let mut out: Option[OwnershipBinding] = None();
    let mut found = false;
    let mut index = 0;
    while !found && index < vec.vec_len(bindings) {
        match vec.get(bindings, index) {
            Some(binding) => if binding.name == name {
                out = Some(binding);
                found = true;
            } else {
                ()
            },
            None => (),
        };
        index = index + 1;
    };
    out
}

fn replace_ownership_binding(bindings: Vec[OwnershipBinding], updated: OwnershipBinding) -> Vec[OwnershipBinding] {
    let mut out: Vec[OwnershipBinding] = vec.new_vec();
    let mut replaced = false;
    let mut index = 0;
    while index < vec.vec_len(bindings) {
        match vec.get(bindings, index) {
            Some(binding) => if binding.name == updated.name {
                out = vec.push(out, updated);
                replaced = true;
                ()
            } else {
                out = vec.push(out, binding);
                ()
            },
            None => (),
        };
        index = index + 1;
    };
    if replaced {
        out
    } else {
        vec.push(out, updated)
    }
}

fn remove_moved_binding(moved: Vec[MovedBinding], name: String) -> Vec[MovedBinding] {
    let mut out: Vec[MovedBinding] = vec.new_vec();
    let mut index = 0;
    while index < vec.vec_len(moved) {
        match vec.get(moved, index) {
            Some(item) => if item.name == name {
                ()
            } else {
                out = vec.push(out, item);
                ()
            },
            None => (),
        };
        index = index + 1;
    };
    out
}

fn add_moved_binding(moved: Vec[MovedBinding], name: String, span_value: SourceSpan) -> Vec[MovedBinding] {
    vec.push(remove_moved_binding(moved, name), moved_binding(name, span_value))
}

fn find_moved_binding(moved: Vec[MovedBinding], name: String) -> Option[MovedBinding] {
    let root = binding_root(name);
    let mut out: Option[MovedBinding] = None();
    let mut found = false;
    let mut index = 0;
    while !found && index < vec.vec_len(moved) {
        match vec.get(moved, index) {
            Some(item) => if item.name == root {
                out = Some(item);
                found = true;
            } else {
                ()
            },
            None => (),
        };
        index = index + 1;
    };
    out
}

fn remove_borrows_for_owner(borrows: Vec[ActiveBorrow], owner: String) -> Vec[ActiveBorrow] {
    let mut out: Vec[ActiveBorrow] = vec.new_vec();
    let mut index = 0;
    while index < vec.vec_len(borrows) {
        match vec.get(borrows, index) {
            Some(item) => if item.owner == owner {
                ()
            } else {
                out = vec.push(out, item);
                ()
            },
            None => (),
        };
        index = index + 1;
    };
    out
}

fn remove_matching_borrow(borrows: Vec[ActiveBorrow], target: String, mutable: Bool, owner: String, span_value: SourceSpan) -> Vec[ActiveBorrow] {
    let mut out: Vec[ActiveBorrow] = vec.new_vec();
    let mut removed = false;
    let mut index = 0;
    while index < vec.vec_len(borrows) {
        match vec.get(borrows, index) {
            Some(item) => if !removed && item.target == target && item.mutable == mutable && item.owner == owner && item.span.start == span_value.start && item.span.end == span_value.end {
                removed = true;
                ()
            } else {
                out = vec.push(out, item);
                ()
            },
            None => (),
        };
        index = index + 1;
    };
    out
}

fn find_overlapping_borrow(borrows: Vec[ActiveBorrow], target: String) -> Option[ActiveBorrow] {
    let mut out: Option[ActiveBorrow] = None();
    let mut found = false;
    let mut index = 0;
    while !found && index < vec.vec_len(borrows) {
        match vec.get(borrows, index) {
            Some(item) => if targets_overlap(target, item.target) {
                out = Some(item);
                found = true;
            } else {
                ()
            },
            None => (),
        };
        index = index + 1;
    };
    out
}

fn find_overlapping_mutable_borrow(borrows: Vec[ActiveBorrow], target: String) -> Option[ActiveBorrow] {
    let mut out: Option[ActiveBorrow] = None();
    let mut found = false;
    let mut index = 0;
    while !found && index < vec.vec_len(borrows) {
        match vec.get(borrows, index) {
            Some(item) => if item.mutable && targets_overlap(target, item.target) {
                out = Some(item);
                found = true;
            } else {
                ()
            },
            None => (),
        };
        index = index + 1;
    };
    out
}

fn check_use_after_move_state(state: OwnershipState, name: String, span_value: SourceSpan, max_errors: Int) -> OwnershipState {
    match find_moved_binding(state.moved, name) {
        Some(moved) => if true {
            let mut parts: Vec[String] = vec.new_vec();
            parts = vec.push(parts, "use of moved value '");
            parts = vec.push(parts, moved.name);
            parts = vec.push(parts, "'");
            state_error(state, max_errors, "E1277", span_value, string.join(parts, ""), "reinitialize the binding before using it again")
        } else {
            state
        },
        None => state,
    }
}

fn borrow_target_path(expr: AstExpr) -> Option[String] {
    match expr.kind {
        AstNameExpr => Some(expr.name),
        AstFieldAccessExpr => match direct_expr_at(expr, 0) {
            Some(base) => match borrow_target_path(base) {
                Some(base_path) => Some(join3(base_path, ".", expr.name)),
                None => None(),
            },
            None => None(),
        },
        _ => None(),
    }
}

fn acquire_borrow_state(state: OwnershipState, target: String, mutable: Bool, owner: String, span_value: SourceSpan, max_errors: Int) -> OwnershipState {
    let root = binding_root(target);
    let mut out = check_use_after_move_state(state, root, span_value, max_errors);
    match find_moved_binding(out.moved, root) {
        Some(_) => out,
        None => match find_ownership_binding(out.bindings, root) {
            Some(binding) => if mutable && !binding.mutable {
                let mut parts: Vec[String] = vec.new_vec();
                parts = vec.push(parts, "cannot take mutable borrow of immutable binding '");
                parts = vec.push(parts, binding.name);
                parts = vec.push(parts, "'");
                state_error(out, max_errors, "E1267", span_value, string.join(parts, ""), join3("declare `", binding.name, "` as mutable"))
            } else if mutable {
                match find_overlapping_borrow(out.borrows, target) {
                    Some(conflict) => if true {
                        let mut parts: Vec[String] = vec.new_vec();
                        parts = vec.push(parts, "cannot take mutable borrow of '");
                        parts = vec.push(parts, target);
                        parts = vec.push(parts, "' because it is already borrowed");
                        state_error(out, max_errors, "E1263", span_value, string.join(parts, ""), "release the previous borrow before taking a mutable borrow")
                    } else {
                        out
                    },
                    None => ownership_state(out.bindings, vec.push(out.borrows, active_borrow(target, mutable, owner, span_value)), out.moved, out.resources, out.diagnostics),
                }
            } else {
                match find_overlapping_mutable_borrow(out.borrows, target) {
                    Some(conflict) => if true {
                        let mut parts: Vec[String] = vec.new_vec();
                        parts = vec.push(parts, "cannot take immutable borrow of '");
                        parts = vec.push(parts, target);
                        parts = vec.push(parts, "' while a mutable borrow is active");
                        state_error(out, max_errors, "E1264", span_value, string.join(parts, ""), "end the mutable borrow before taking shared borrows")
                    } else {
                        out
                    },
                    None => ownership_state(out.bindings, vec.push(out.borrows, active_borrow(target, mutable, owner, span_value)), out.moved, out.resources, out.diagnostics),
                }
            },
            None => out,
        },
    }
}

fn release_temp_borrow_state(state: OwnershipState, target: String, mutable: Bool, span_value: SourceSpan) -> OwnershipState {
    ownership_state(state.bindings, remove_matching_borrow(state.borrows, target, mutable, "", span_value), state.moved, state.resources, state.diagnostics)
}

fn type_text_from_optional(value: Option[AstType]) -> String {
    match value {
        Some(ty) => type_text(ty),
        None => "<unknown>",
    }
}

fn is_let_statement_kind(kind: AstStatementKind) -> Bool {
    match kind {
        AstLetStatement => true,
        AstAssignStatement => false,
        AstExprStatement => false,
        AstReturnStatement => false,
    }
}

fn is_assign_statement_kind(kind: AstStatementKind) -> Bool {
    match kind {
        AstLetStatement => false,
        AstAssignStatement => true,
        AstExprStatement => false,
        AstReturnStatement => false,
    }
}

fn infer_ownership_type(expr: AstExpr, state: OwnershipState, declared_type: String) -> String {
    if declared_type != "<unknown>" {
        declared_type
    } else {
        match expr.kind {
            AstNameExpr => match find_ownership_binding(state.bindings, expr.name) {
                Some(binding) => binding.type_text,
                None => "<unknown>",
            },
            AstStructLiteralExpr => expr.name,
            AstIntExpr => "Int",
            AstFloatExpr => "Float64",
            AstBoolExpr => "Bool",
            AstStringExpr => "String",
            AstCharExpr => "Char",
            AstUnitExpr => "()",
            _ => "<unknown>",
        }
    }
}

fn is_movable_type(units: Vec[ResolveUnit], type_value: String) -> Bool {
    let base = type_base_name(type_value);
    match find_struct_decl(units, base) {
        Some(_) => true,
        None => match find_enum_decl(units, base) {
            Some(_) => true,
            None => false,
        },
    }
}

fn track_move_from_expr(state: OwnershipState, binding_name: String, expr: AstExpr, units: Vec[ResolveUnit], max_errors: Int) -> OwnershipState {
    match expr.kind {
        AstNameExpr => if expr.name == binding_name {
            state
        } else {
            match find_ownership_binding(state.bindings, expr.name) {
                Some(binding) => if is_movable_type(units, binding.type_text) {
                    match find_overlapping_borrow(state.borrows, expr.name) {
                        Some(conflict) => if true {
                            let mut parts: Vec[String] = vec.new_vec();
                            parts = vec.push(parts, "cannot move '");
                            parts = vec.push(parts, expr.name);
                            parts = vec.push(parts, "' while it is borrowed as '");
                            parts = vec.push(parts, conflict.target);
                            parts = vec.push(parts, "'");
                            state_error(state, max_errors, "E1278", expr.span, string.join(parts, ""), "end the borrow before moving this value")
                        } else {
                            state
                        },
                        None => ownership_state(state.bindings, state.borrows, add_moved_binding(state.moved, expr.name, expr.span), state.resources, state.diagnostics),
                    }
                } else {
                    state
                },
                None => state,
            }
        },
        _ => state,
    }
}

fn resource_protocol_op_for_name(raw_name: String) -> Option[ResourceProtocolOp] {
    let name = path_tail(raw_name);
    if name == "file_close" {
        Some(resource_protocol_op("FileHandle", true, name, "FileHandle"))
    } else if name == "file_read_line" || name == "file_write_str" {
        Some(resource_protocol_op("FileHandle", false, name, "FileHandle"))
    } else if name == "tcp_close" {
        Some(resource_protocol_op("TcpHandle", true, name, "Int"))
    } else if name == "tcp_send" || name == "tcp_recv" {
        Some(resource_protocol_op("TcpHandle", false, name, "Int"))
    } else if name == "udp_close" {
        Some(resource_protocol_op("UdpHandle", true, name, "Int"))
    } else if name == "udp_send_to" || name == "udp_recv_from" {
        Some(resource_protocol_op("UdpHandle", false, name, "Int"))
    } else if name == "tls_close" {
        Some(resource_protocol_op("TlsStream", true, name, "TlsStream"))
    } else if string.starts_with(name, "tls_send") || string.starts_with(name, "tls_recv") || name == "tls_version" || name == "tls_version_code" || name == "tls_peer_subject" || name == "tls_peer_issuer" || name == "tls_peer_fingerprint_sha256" || name == "tls_peer_san_entries" || name == "tls_peer_cn" {
        Some(resource_protocol_op("TlsStream", false, name, "TlsStream"))
    } else if name == "wait" || name == "kill" {
        Some(resource_protocol_op("ProcessHandle", true, name, "Int"))
    } else if name == "is_running" {
        Some(resource_protocol_op("ProcessHandle", false, name, "Int"))
    } else if name == "close_channel" {
        Some(resource_protocol_op("IntChannel", true, name, "IntChannel"))
    } else if name == "send_int" || name == "recv_int" {
        Some(resource_protocol_op("IntChannel", false, name, "IntChannel"))
    } else if name == "close_sender" {
        Some(resource_protocol_op("Sender", true, name, "Sender"))
    } else if name == "send" || name == "try_send" {
        Some(resource_protocol_op("Sender", false, name, "Sender"))
    } else if name == "close_receiver" {
        Some(resource_protocol_op("Receiver", true, name, "Receiver"))
    } else if name == "recv" || name == "try_recv" || name == "recv_timeout" {
        Some(resource_protocol_op("Receiver", false, name, "Receiver"))
    } else if name == "close_mutex" {
        Some(resource_protocol_op("IntMutex", true, name, "IntMutex"))
    } else if name == "lock_int" || name == "unlock_int" {
        Some(resource_protocol_op("IntMutex", false, name, "IntMutex"))
    } else if name == "close_rwlock" {
        Some(resource_protocol_op("IntRwLock", true, name, "IntRwLock"))
    } else if name == "read_lock_int" || name == "write_lock_int" || name == "write_unlock_int" {
        Some(resource_protocol_op("IntRwLock", false, name, "IntRwLock"))
    } else if name == "join_task" || name == "cancel_task" {
        Some(resource_protocol_op("Task", true, name, "Task"))
    } else if name == "async_wait_int" {
        Some(resource_protocol_op("AsyncIntOp", true, name, "AsyncIntOp"))
    } else if name == "async_wait_string" {
        Some(resource_protocol_op("AsyncStringOp", true, name, "AsyncStringOp"))
    } else {
        None()
    }
}

fn find_resource_use(resources: Vec[ResourceUse], name: String, kind: String) -> Option[ResourceUse] {
    let mut out: Option[ResourceUse] = None();
    let mut found = false;
    let mut index = 0;
    while !found && index < vec.vec_len(resources) {
        match vec.get(resources, index) {
            Some(item) => if item.name == name && item.kind == kind {
                out = Some(item);
                found = true;
            } else {
                ()
            },
            None => (),
        };
        index = index + 1;
    };
    out
}

fn remove_resource_uses_for_name(resources: Vec[ResourceUse], name: String) -> Vec[ResourceUse] {
    let mut out: Vec[ResourceUse] = vec.new_vec();
    let mut index = 0;
    while index < vec.vec_len(resources) {
        match vec.get(resources, index) {
            Some(item) => if item.name == name {
                ()
            } else {
                out = vec.push(out, item);
                ()
            },
            None => (),
        };
        index = index + 1;
    };
    out
}

fn add_resource_use(resources: Vec[ResourceUse], name: String, kind: String, closed_by: String, span_value: SourceSpan) -> Vec[ResourceUse] {
    vec.push(remove_resource_uses_for_name(resources, name), resource_use(name, kind, closed_by, span_value))
}

fn check_resource_protocol_call(state: OwnershipState, expr: AstExpr, max_errors: Int, allow_closed_use: Bool) -> OwnershipState {
    match resource_protocol_op_for_name(expr.name) {
        Some(op) => match call_arg_expr(expr, 0) {
            Some(first_arg) => match first_arg.kind {
                AstNameExpr => match find_ownership_binding(state.bindings, first_arg.name) {
                    Some(binding) => if type_base_name(binding.type_text) == op.first_param_base_type {
                        match find_resource_use(state.resources, first_arg.name, op.kind) {
                            Some(previous) => if allow_closed_use {
                                state
                            } else {
                                let mut parts: Vec[String] = vec.new_vec();
                                parts = vec.push(parts, "resource protocol violation: '");
                                parts = vec.push(parts, op.api);
                                parts = vec.push(parts, "' called after terminal '");
                                parts = vec.push(parts, previous.closed_by);
                                parts = vec.push(parts, "' on closed ");
                                parts = vec.push(parts, op.kind);
                                parts = vec.push(parts, " '");
                                parts = vec.push(parts, first_arg.name);
                                parts = vec.push(parts, "'");
                                state_error(state, max_errors, "E2006", expr.span, string.join(parts, ""), join3("create a new ", op.kind, " before calling this API again"))
                            },
                            None => if op.terminal {
                                ownership_state(state.bindings, state.borrows, state.moved, add_resource_use(state.resources, first_arg.name, op.kind, op.api, expr.span), state.diagnostics)
                            } else {
                                state
                            },
                        }
                    } else {
                        state
                    },
                    None => state,
                },
                _ => state,
            },
            None => state,
        },
        None => state,
    }
}

fn merge_moved_states(left: Vec[MovedBinding], right: Vec[MovedBinding]) -> Vec[MovedBinding] {
    let mut out = left;
    let mut index = 0;
    while index < vec.vec_len(right) {
        match vec.get(right, index) {
            Some(item) => if true {
                out = add_moved_binding(out, item.name, item.span);
                ()
            } else {
                ()
            },
            None => (),
        };
        index = index + 1;
    };
    out
}

fn check_ownership_expr(expr: AstExpr, state: OwnershipState, units: Vec[ResolveUnit], max_errors: Int, allow_closed_use: Bool) -> OwnershipState {
    let mut out = state;
    match expr.kind {
        AstNameExpr => if true {
            out = check_use_after_move_state(out, expr.name, expr.span, max_errors);
            ()
        } else {
            ()
        },
        AstBorrowExpr => match direct_expr_at(expr, 0) {
            Some(inner) => match borrow_target_path(inner) {
                Some(target) => if true {
                    let mutable = expr.name == "mut";
                    out = acquire_borrow_state(out, target, mutable, "", expr.span, max_errors);
                    out = check_ownership_expr(inner, out, units, max_errors, false);
                    out = release_temp_borrow_state(out, target, mutable, expr.span);
                    ()
                } else {
                    ()
                },
                None => if true {
                    out = state_error(out, max_errors, "E1268", expr.span, "borrow target must be a local variable or field path", "use `&name`, `&mut name`, or `&name.field` on a local binding");
                    out = check_ownership_expr(inner, out, units, max_errors, false);
                    ()
                } else {
                    ()
                },
            },
            None => (),
        },
        AstCallExpr => if true {
            let mut index = 0;
            while index < expr.direct_child_count {
                match direct_expr_at(expr, index) {
                    Some(child) => if true {
                        out = check_ownership_expr(child, out, units, max_errors, false);
                        ()
                    } else {
                        ()
                    },
                    None => (),
                };
                index = index + 1;
            };
            out = check_resource_protocol_call(out, expr, max_errors, allow_closed_use);
            ()
        } else {
            ()
        },
        AstIfExpr => if true {
            match direct_expr_at(expr, 0) {
                Some(cond) => if true {
                    out = check_ownership_expr(cond, out, units, max_errors, false);
                    ()
                } else {
                    ()
                },
                None => (),
            };
            let mut merged = out.moved;
            let mut index = 1;
            while index < expr.direct_child_count {
                match direct_expr_at(expr, index) {
                    Some(child) => if true {
                        let branch_state = check_ownership_expr(child, ownership_state(out.bindings, out.borrows, out.moved, out.resources, out.diagnostics), units, max_errors, false);
                        merged = merge_moved_states(merged, branch_state.moved);
                        out = state_with_diagnostics(out, branch_state.diagnostics);
                        ()
                    } else {
                        ()
                    },
                    None => (),
                };
                index = index + 1;
            };
            out = ownership_state(out.bindings, out.borrows, merged, out.resources, out.diagnostics);
            ()
        } else {
            ()
        },
        AstMatchExpr => if true {
            match direct_expr_at(expr, 0) {
                Some(scrutinee) => if true {
                    out = check_ownership_expr(scrutinee, out, units, max_errors, true);
                    ()
                } else {
                    ()
                },
                None => (),
            };
            let mut merged = out.moved;
            let mut index = 1;
            while index < expr.direct_child_count {
                match direct_expr_at(expr, index) {
                    Some(child) => if true {
                        let branch_state = check_ownership_expr(child, ownership_state(out.bindings, out.borrows, out.moved, out.resources, out.diagnostics), units, max_errors, false);
                        merged = merge_moved_states(merged, branch_state.moved);
                        out = state_with_diagnostics(out, branch_state.diagnostics);
                        ()
                    } else {
                        ()
                    },
                    None => (),
                };
                index = index + 1;
            };
            out = ownership_state(out.bindings, out.borrows, merged, out.resources, out.diagnostics);
            ()
        } else {
            ()
        },
        _ => if true {
            let mut index = 0;
            while index < expr.direct_child_count {
                match direct_expr_at(expr, index) {
                    Some(child) => if true {
                        out = check_ownership_expr(child, out, units, max_errors, false);
                        ()
                    } else {
                        ()
                    },
                    None => (),
                };
                index = index + 1;
            };
            ()
        } else {
            ()
        },
    };
    out
}

fn check_ownership_let_statement(statement: AstStatement, state: OwnershipState, units: Vec[ResolveUnit], max_errors: Int) -> OwnershipState {
    let mut result = state;
    match statement.expr {
        Some(expr) => if true {
            let mut out = result;
            match expr.kind {
                AstBorrowExpr => match direct_expr_at(expr, 0) {
                    Some(inner) => match borrow_target_path(inner) {
                        Some(target) => if true {
                            out = acquire_borrow_state(out, target, expr.name == "mut", statement.name, expr.span, max_errors);
                            out = check_ownership_expr(inner, out, units, max_errors, false);
                            ()
                        } else {
                            ()
                        },
                        None => if true {
                            out = state_error(out, max_errors, "E1268", expr.span, "borrow target must be a local variable or field path", "use `&name`, `&mut name`, or `&name.field` on a local binding");
                            out = check_ownership_expr(inner, out, units, max_errors, false);
                            ()
                        } else {
                            ()
                        },
                    },
                    None => (),
                },
                _ => if true {
                    out = check_ownership_expr(expr, out, units, max_errors, false);
                    ()
                } else {
                    ()
                },
            };
            out = track_move_from_expr(out, statement.name, expr, units, max_errors);
            let declared = type_text_from_optional(statement.type_ref);
            let binding_type = infer_ownership_type(expr, out, declared);
            result = ownership_state(replace_ownership_binding(out.bindings, ownership_binding(statement.name, binding_type, statement.mutable, statement.span)), out.borrows, remove_moved_binding(out.moved, statement.name), remove_resource_uses_for_name(out.resources, statement.name), out.diagnostics);
            ()
        } else {
            ()
        },
        None => (),
    };
    result
}

fn check_ownership_assign_statement(statement: AstStatement, state: OwnershipState, units: Vec[ResolveUnit], max_errors: Int) -> OwnershipState {
    let mut result = state;
    match statement.expr {
        Some(expr) => if true {
            result = check_ownership_assign_expr(statement, expr, result, units, max_errors);
            ()
        } else {
            ()
        },
        None => (),
    };
    result
}

fn check_ownership_assign_expr(statement: AstStatement, expr: AstExpr, state: OwnershipState, units: Vec[ResolveUnit], max_errors: Int) -> OwnershipState {
    let mut out = check_ownership_expr(expr, state, units, max_errors, false);
    match find_overlapping_borrow(out.borrows, statement.target) {
        Some(_) => if true {
            let mut parts: Vec[String] = vec.new_vec();
            parts = vec.push(parts, "cannot assign to '");
            parts = vec.push(parts, statement.target);
            parts = vec.push(parts, "' while it is actively borrowed");
            out = state_error(out, max_errors, "E1265", statement.span, string.join(parts, ""), "release or narrow the borrow scope before mutating this binding");
            ()
        } else {
            ()
        },
        None => (),
    };
    let binding_type = infer_ownership_type(expr, out, "<unknown>");
    let mut bindings = out.bindings;
    match find_ownership_binding(out.bindings, statement.target) {
        Some(existing) => if true {
            let mut assigned_type = binding_type;
            if binding_type == "<unknown>" {
                assigned_type = existing.type_text;
            } else {
                ()
            };
            bindings = replace_ownership_binding(out.bindings, ownership_binding(statement.target, assigned_type, existing.mutable, existing.span));
            ()
        } else {
            ()
        },
        None => (),
    };
    ownership_state(bindings, out.borrows, remove_moved_binding(out.moved, statement.target), remove_resource_uses_for_name(out.resources, statement.target), out.diagnostics)
}

fn check_ownership_optional_expr_statement(statement: AstStatement, state: OwnershipState, units: Vec[ResolveUnit], max_errors: Int) -> OwnershipState {
    let mut result = state;
    match statement.expr {
        Some(expr) => if true {
            result = check_ownership_expr(expr, result, units, max_errors, false);
            ()
        } else {
            ()
        },
        None => (),
    };
    result
}

fn check_ownership_statement(statement: AstStatement, state: OwnershipState, units: Vec[ResolveUnit], max_errors: Int) -> OwnershipState {
    if is_let_statement_kind(statement.kind) {
        check_ownership_let_statement(statement, state, units, max_errors)
    } else {
        if is_assign_statement_kind(statement.kind) {
            check_ownership_assign_statement(statement, state, units, max_errors)
        } else {
            check_ownership_optional_expr_statement(statement, state, units, max_errors)
        }
    }
}

fn check_ownership_block(block: AstBlock, state: OwnershipState, units: Vec[ResolveUnit], max_errors: Int) -> OwnershipState {
    let mut out = state;
    let mut introduced: Vec[String] = vec.new_vec();
    let mut index = 0;
    while index < vec.vec_len(block.statements) {
        match vec.get(block.statements, index) {
            Some(statement) => if true {
                if is_let_statement_kind(statement.kind) {
                    introduced = vec.push(introduced, statement.name);
                } else {
                    ()
                };
                out = check_ownership_statement(statement, out, units, max_errors);
                ()
            } else {
                ()
            },
            None => (),
        };
        index = index + 1;
    };
    match block.tail_expr {
        Some(expr) => if true {
            out = check_ownership_expr(expr, out, units, max_errors, false);
            ()
        } else {
            ()
        },
        None => (),
    };
    let mut release_index = 0;
    while release_index < vec.vec_len(introduced) {
        match vec.get(introduced, release_index) {
            Some(name) => if true {
                out = ownership_state(out.bindings, remove_borrows_for_owner(out.borrows, name), out.moved, out.resources, out.diagnostics);
                ()
            } else {
                ()
            },
            None => (),
        };
        release_index = release_index + 1;
    };
    out
}

fn ownership_state_for_signature(signature: AstFunctionSignature, diagnostics: Vec[Diagnostic]) -> OwnershipState {
    let mut bindings: Vec[OwnershipBinding] = vec.new_vec();
    let mut index = 0;
    while index < vec.vec_len(signature.params) {
        match vec.get(signature.params, index) {
            Some(param) => if true {
                bindings = vec.push(bindings, ownership_binding(param.name.value, type_text(param.type_ref), false, param.span));
                ()
            } else {
                ()
            },
            None => (),
        };
        index = index + 1;
    };
    ownership_state(bindings, vec.new_vec(), vec.new_vec(), vec.new_vec(), diagnostics)
}

fn append_ownership_diagnostics_for_function(diagnostics: Vec[Diagnostic], signature: AstFunctionSignature, body: AstBlock, units: Vec[ResolveUnit], max_errors: Int) -> Vec[Diagnostic] {
    let state = ownership_state_for_signature(signature, diagnostics);
    let checked = check_ownership_block(body, state, units, max_errors);
    checked.diagnostics
}

fn append_ownership_diagnostics_for_item(diagnostics: Vec[Diagnostic], item: AstProgramItem, units: Vec[ResolveUnit], max_errors: Int) -> Vec[Diagnostic] {
    match item.function_item {
        Some(function_item) => append_ownership_diagnostics_for_function(diagnostics, function_item.signature, function_item.body, units, max_errors),
        None => match item.impl_item {
            Some(impl_item) => if true {
                let mut out = diagnostics;
                let mut index = 0;
                while index < vec.vec_len(impl_item.methods) {
                    match vec.get(impl_item.methods, index) {
                        Some(method) => if true {
                            out = append_ownership_diagnostics_for_function(out, method.signature, method.body, units, max_errors);
                            ()
                        } else {
                            ()
                        },
                        None => (),
                    };
                    index = index + 1;
                };
                out
            } else {
                diagnostics
            },
            None => diagnostics,
        },
    }
}

fn append_ownership_resource_diagnostics(output: TypecheckOutput, units: Vec[ResolveUnit], max_errors: Int) -> TypecheckOutput {
    let mut diagnostics = output.diagnostics;
    let mut unit_index = 0;
    while unit_index < vec.vec_len(units) {
        match vec.get(units, unit_index) {
            Some(unit) => if true {
                let mut item_index = 0;
                while item_index < vec.vec_len(unit.program.items) {
                    match vec.get(unit.program.items, item_index) {
                        Some(item) => if true {
                            diagnostics = append_ownership_diagnostics_for_item(diagnostics, item, units, max_errors);
                            ()
                        } else {
                            ()
                        },
                        None => (),
                    };
                    item_index = item_index + 1;
                };
                ()
            } else {
                ()
            },
            None => (),
        };
        unit_index = unit_index + 1;
    };
    typecheck_output(output.entry_module, output.functions, output.bindings, output.instantiations, diagnostics)
}

pub fn typecheck_resolved_units(units: Vec[ResolveUnit], resolver: ResolverOutput, max_errors: Int) -> TypecheckOutput {
    let semantics = analyze_resolved_units(units, resolver, max_errors);
    let aliases = collect_type_aliases(units);
    let mut out = typecheck_output(resolver.entry_module, vec.new_vec(), vec.new_vec(), vec.new_vec(), append_all_diagnostics(resolver.diagnostics, semantics.diagnostics, max_errors));
    let mut unit_index = 0;
    while unit_index < vec.vec_len(units) {
        match vec.get(units, unit_index) {
            Some(unit) => if true {
                let mut item_index = 0;
                while item_index < vec.vec_len(unit.program.items) {
                    match vec.get(unit.program.items, item_index) {
                        Some(item) => if true {
                            out = check_item(item, unit.module_path, units, resolver, semantics, aliases, out, max_errors);
                            ()
                        } else {
                            ()
                        },
                        None => (),
                    };
                    item_index = item_index + 1;
                };
                ()
            } else {
                ()
            },
            None => (),
        };
        unit_index = unit_index + 1;
    };
    append_ownership_resource_diagnostics(append_effect_capability_contract_diagnostics(out, units, resolver, semantics, aliases, max_errors), units, max_errors)
}

pub fn typecheck_units(units: Vec[ResolveUnit], entry_module: String, max_errors: Int) -> TypecheckOutput {
    let resolver = resolve_units(units, entry_module, max_errors);
    typecheck_resolved_units(units, resolver, max_errors)
}

pub fn typecheck_program(program: AstProgram, max_errors: Int) -> TypecheckOutput {
    let mut units: Vec[ResolveUnit] = vec.new_vec();
    units = vec.push(units, resolve_unit(program));
    typecheck_units(units, program_module_path_for_typecheck(program), max_errors)
}

fn program_module_path_for_typecheck(program: AstProgram) -> String {
    match program.module_item {
        Some(module_item) => module_item.path.text,
        None => "<root>",
    }
}

pub fn typecheck_function_count(value: TypecheckOutput) -> Int {
    vec.vec_len(value.functions)
}

pub fn typecheck_binding_count(value: TypecheckOutput) -> Int {
    vec.vec_len(value.bindings)
}

pub fn typecheck_instantiation_count(value: TypecheckOutput) -> Int {
    vec.vec_len(value.instantiations)
}

pub fn typecheck_diagnostic_count(value: TypecheckOutput) -> Int {
    vec.vec_len(value.diagnostics)
}

pub fn typecheck_has_diagnostic_code(value: TypecheckOutput, code: String) -> Bool {
    let mut found = false;
    let mut index = 0;
    while !found && index < vec.vec_len(value.diagnostics) {
        match vec.get(value.diagnostics, index) {
            Some(diag) => if diag.code.value == code {
                found = true;
            } else {
                ()
            },
            None => (),
        };
        index = index + 1;
    };
    found
}

pub fn typecheck_has_function(value: TypecheckOutput, module_path: String, name: String, return_type: String) -> Bool {
    let mut found = false;
    let mut index = 0;
    while !found && index < vec.vec_len(value.functions) {
        match vec.get(value.functions, index) {
            Some(item) => if item.module_path == module_path && item.name == name && item.return_type == return_type && item.typed_body {
                found = true;
            } else {
                ()
            },
            None => (),
        };
        index = index + 1;
    };
    found
}

pub fn typecheck_has_binding(value: TypecheckOutput, function_name: String, name: String, type_text_value: String) -> Bool {
    let mut found = false;
    let mut index = 0;
    while !found && index < vec.vec_len(value.bindings) {
        match vec.get(value.bindings, index) {
            Some(item) => if item.function_name == function_name && item.name == name && item.type_text == type_text_value {
                found = true;
            } else {
                ()
            },
            None => (),
        };
        index = index + 1;
    };
    found
}

pub fn typecheck_has_instantiation(value: TypecheckOutput, name: String, kind: String, type_arg: String) -> Bool {
    let mut found = false;
    let mut index = 0;
    while !found && index < vec.vec_len(value.instantiations) {
        match vec.get(value.instantiations, index) {
            Some(item) => if item.name == name && item.kind == kind {
                let mut arg_found = false;
                let mut arg_index = 0;
                while !arg_found && arg_index < vec.vec_len(item.type_args) {
                    match vec.get(item.type_args, arg_index) {
                        Some(arg) => if arg == type_arg {
                            arg_found = true;
                        } else {
                            ()
                        },
                        None => (),
                    };
                    arg_index = arg_index + 1;
                };
                if arg_found {
                    found = true;
                } else {
                    ()
                }
            } else {
                ()
            },
            None => (),
        };
        index = index + 1;
    };
    found
}
