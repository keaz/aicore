    value.text
}

pub fn pattern_child_count(value: AstPattern) -> Int {
    value.direct_child_count
}

pub fn pattern_node_count(value: AstPattern) -> Int {
    vec.vec_len(value.nodes)
}

pub fn statement_text(value: AstStatement) -> String {
    value.text
}

pub fn statement_count(value: AstBlock) -> Int {
    vec.vec_len(value.statements)
}

pub fn block_text(value: AstBlock) -> String {
    value.text
}

pub fn block_has_tail(value: AstBlock) -> Bool {
    match value.tail_expr {
        Some(_) => true,
        None => false,
    }
}

pub fn block_has_required_tail(value: AstBlock) -> Bool {
    if block_has_tail(value) {
        true
    } else {
        let count = vec.vec_len(value.statements);
        if count == 0 {
            false
        } else {
            match vec.get(value.statements, count - 1) {
                Some(statement) => match statement.kind {
                    AstReturnStatement => true,
                    AstLetStatement => false,
                    AstAssignStatement => false,
                    AstExprStatement => false,
                },
                None => false,
            }
        }
    }
}

pub fn param_text(value: AstParam) -> String {
    let mut parts: Vec[String] = vec.new_vec();
    parts = vec.push(parts, value.name.value);
    parts = vec.push(parts, ":");
    parts = vec.push(parts, type_text(value.type_ref));
    string.join(parts, "")
}

pub fn param_list_text(values: Vec[AstParam]) -> String {
    let mut parts: Vec[String] = vec.new_vec();
    let mut index = 0;
    while index < vec.vec_len(values) {
        match vec.get(values, index) {
            Some(param) => if true {
                parts = vec.push(parts, param_text(param));
                ()
            } else {
                ()
            },
            None => (),
        };
        index = index + 1;
    };
    string.join(parts, ",")
}

pub fn function_signature_text(value: AstFunctionSignature) -> String {
    let mut parts: Vec[String] = vec.new_vec();
    parts = vec.push(parts, "fn");
    parts = vec.push(parts, value.name.value);
    if generic_params_text(value.generic_params) != "" {
        parts = vec.push(parts, "[");
        parts = vec.push(parts, generic_params_text(value.generic_params));
        parts = vec.push(parts, "]");
    } else {
        ()
    };
    parts = vec.push(parts, "(");
    parts = vec.push(parts, param_list_text(value.params));
    parts = vec.push(parts, ")->");
    parts = vec.push(parts, type_text(value.return_type));
    if value.effect_names != "" {
        parts = vec.push(parts, "effects{");
        parts = vec.push(parts, value.effect_names);
        parts = vec.push(parts, "}");
    } else {
        ()
    };
    if value.capability_names != "" {
        parts = vec.push(parts, "capabilities{");
        parts = vec.push(parts, value.capability_names);
        parts = vec.push(parts, "}");
    } else {
        ()
    };
    string.join(parts, "")
}

pub fn impl_method_text(value: AstImplMethod) -> String {
    let mut parts: Vec[String] = vec.new_vec();
    parts = vec.push(parts, function_signature_text(value.signature));
    parts = vec.push(parts, block_text(value.body));
    string.join(parts, "")
}

pub fn impl_methods_text(values: Vec[AstImplMethod]) -> String {
    let mut parts: Vec[String] = vec.new_vec();
    let mut index = 0;
    while index < vec.vec_len(values) {
        match vec.get(values, index) {
            Some(method) => if true {
                parts = vec.push(parts, impl_method_text(method));
                ()
            } else {
                ()
            },
            None => (),
        };
        index = index + 1;
    };
    string.join(parts, "")
}

