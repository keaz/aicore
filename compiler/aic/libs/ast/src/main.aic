    vec.vec_len(value.nodes)
}

pub fn expr_pattern_node_count(value: AstExpr) -> Int {
    vec.vec_len(value.patterns)
}

pub fn expr_match_arm_count(value: AstExpr) -> Int {
    vec.vec_len(value.match_arms)
}

