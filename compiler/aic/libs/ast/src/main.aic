module compiler.ast;

import compiler.source;
import compiler.syntax;
import std.option;
import std.result;
import std.string;
import std.vec;

pub enum AstError {
    ExpectedIdentifier,
    ExpectedKeyword,
    EmptyName,
}

pub enum AstVisibility {
    PrivateVisibility,
    PublicVisibility,
    PublicCrateVisibility,
}

pub enum AstItemKind {
    FunctionItem,
    StructItem,
    EnumItem,
    TraitItem,
    ImplItem,
    TypeAliasItem,
    ConstItem,
}

pub enum AstTypeKind {
    AstUnitType,
    AstNamedType,
    AstDynTraitType,
    AstHoleType,
}

pub enum AstLiteralKind {
    AstIntLiteral,
    AstFloatLiteral,
    AstBoolLiteral,
    AstStringLiteral,
    AstCharLiteral,
    AstUnitLiteral,
}

pub enum AstExprKind {
    AstIntExpr,
    AstFloatExpr,
    AstBoolExpr,
    AstStringExpr,
    AstCharExpr,
    AstTemplateExpr,
    AstUnitExpr,
    AstNameExpr,
    AstCallExpr,
    AstClosureExpr,
    AstIfExpr,
    AstWhileExpr,
    AstForExpr,
    AstLoopExpr,
    AstBreakExpr,
    AstContinueExpr,
    AstMatchExpr,
    AstBinaryExpr,
    AstUnaryExpr,
    AstBorrowExpr,
    AstAwaitExpr,
    AstTryExpr,
    AstStructLiteralExpr,
    AstTupleExpr,
    AstFieldAccessExpr,
    AstBlockExpr,
}

pub enum AstPatternKind {
    AstWildcardPattern,
    AstVarPattern,
    AstIntPattern,
    AstBoolPattern,
    AstCharPattern,
    AstStringPattern,
    AstUnitPattern,
    AstOrPattern,
    AstVariantPattern,
    AstTuplePattern,
    AstStructPattern,
}

pub enum AstStatementKind {
    AstLetStatement,
    AstAssignStatement,
    AstExprStatement,
    AstReturnStatement,
}

pub enum AstAttributeValueKind {
    AstAttributeStringValue,
    AstAttributeIntValue,
    AstAttributeBoolValue,
    AstAttributeIdentValue,
}

pub struct AstName {
