    AstPatternNode {
        kind: kind,
        role: role,
        name: name,
        direct_child_count: direct_child_count,
        depth: depth,
        span: span,
        text: text,
    }
}

pub fn ast_match_arm(pattern_text: String, guard_text: String, body_text: String, span: SourceSpan, text: String) -> AstMatchArmNode {
    AstMatchArmNode {
        pattern_text: pattern_text,
        guard_text: guard_text,
        body_text: body_text,
        span: span,
        text: text,
    }
}

pub fn ast_pattern(kind: AstPatternKind, name: String, direct_child_count: Int, nodes: Vec[AstPatternNode], span: SourceSpan, text: String) -> AstPattern {
    AstPattern {
        kind: kind,
        name: name,
        direct_child_count: direct_child_count,
        nodes: nodes,
        span: span,
        text: text,
    }
}

pub fn ast_expr(
    kind: AstExprKind,
    op: String,
    name: String,
    direct_child_count: Int,
    nodes: Vec[AstExprNode],
    patterns: Vec[AstPatternNode],
    match_arms: Vec[AstMatchArmNode],
    span: SourceSpan,
    text: String,
) -> AstExpr {
    AstExpr {
        kind: kind,
        op: op,
        name: name,
        direct_child_count: direct_child_count,
        nodes: nodes,
        patterns: patterns,
        match_arms: match_arms,
        span: span,
        text: text,
    }
}

fn expr_node_from_expr(value: AstExpr, role: String, depth: Int) -> AstExprNode {
    ast_expr_node(value.kind, role, value.op, value.name, value.direct_child_count, depth, value.span, value.text)
}

fn nested_expr_node(value: AstExprNode, depth_offset: Int) -> AstExprNode {
    ast_expr_node(value.kind, value.role, value.op, value.name, value.direct_child_count, value.depth + depth_offset, value.span, value.text)
}

pub fn pattern_node_from_pattern(value: AstPattern, role: String, depth: Int) -> AstPatternNode {
    ast_pattern_node(value.kind, role, value.name, value.direct_child_count, depth, value.span, value.text)
}

pub fn nested_pattern_node(value: AstPatternNode, depth_offset: Int) -> AstPatternNode {
    ast_pattern_node(value.kind, value.role, value.name, value.direct_child_count, value.depth + depth_offset, value.span, value.text)
}

fn flatten_expr_children(children: Vec[AstExpr], role: String) -> Vec[AstExprNode] {
    let mut nodes: Vec[AstExprNode] = vec.new_vec();
    let mut index = 0;
    while index < vec.vec_len(children) {
        match vec.get(children, index) {
            Some(child) => if true {
                nodes = vec.push(nodes, expr_node_from_expr(child, role, 1));
                let mut nested_index = 0;
                while nested_index < vec.vec_len(child.nodes) {
                    match vec.get(child.nodes, nested_index) {
                        Some(node) => if true {
                            nodes = vec.push(nodes, nested_expr_node(node, 1));
                            ()
                        } else {
                            ()
                        },
                        None => (),
                    };
                    nested_index = nested_index + 1;
                };
                ()
            } else {
                ()
            },
            None => (),
        };
        index = index + 1;
    };
    nodes
}

fn flatten_pattern_children(children: Vec[AstPattern], role: String) -> Vec[AstPatternNode] {
    let mut nodes: Vec[AstPatternNode] = vec.new_vec();
    let mut index = 0;
    while index < vec.vec_len(children) {
        match vec.get(children, index) {
            Some(child) => if true {
                nodes = vec.push(nodes, pattern_node_from_pattern(child, role, 1));
                let mut nested_index = 0;
                while nested_index < vec.vec_len(child.nodes) {
                    match vec.get(child.nodes, nested_index) {
                        Some(node) => if true {
                            nodes = vec.push(nodes, nested_pattern_node(node, 1));
                            ()
                        } else {
                            ()
                        },
                        None => (),
                    };
                    nested_index = nested_index + 1;
                };
                ()
            } else {
                ()
            },
            None => (),
        };
        index = index + 1;
    };
    nodes
}

pub fn simple_expr(kind: AstExprKind, op: String, name: String, span: SourceSpan, text: String) -> AstExpr {
    ast_expr(kind, op, name, 0, vec.new_vec(), vec.new_vec(), vec.new_vec(), span, text)
}

pub fn expr_with_children(kind: AstExprKind, op: String, name: String, children: Vec[AstExpr], patterns: Vec[AstPatternNode], span: SourceSpan, text: String) -> AstExpr {
    ast_expr(kind, op, name, vec.vec_len(children), flatten_expr_children(children, "child"), patterns, vec.new_vec(), span, text)
}

pub fn match_expr_with_arms(children: Vec[AstExpr], patterns: Vec[AstPatternNode], match_arms: Vec[AstMatchArmNode], span: SourceSpan, text: String) -> AstExpr {
    ast_expr(AstMatchExpr(), "", "", vec.vec_len(children), flatten_expr_children(children, "child"), patterns, match_arms, span, text)
}

pub fn simple_pattern(kind: AstPatternKind, name: String, span: SourceSpan, text: String) -> AstPattern {
    ast_pattern(kind, name, 0, vec.new_vec(), span, text)
}

pub fn pattern_with_children(kind: AstPatternKind, name: String, children: Vec[AstPattern], span: SourceSpan, text: String) -> AstPattern {
    ast_pattern(kind, name, vec.vec_len(children), flatten_pattern_children(children, "child"), span, text)
}

pub fn ast_statement(
    kind: AstStatementKind,
    name: String,
    target: String,
    mutable: Bool,
    type_ref: Option[AstType],
    pattern: Option[AstPattern],
    expr: Option[AstExpr],
    span: SourceSpan,
    text: String,
) -> AstStatement {
    AstStatement {
        kind: kind,
        name: name,
        target: target,
        mutable: mutable,
        type_ref: type_ref,
        pattern: pattern,
        expr: expr,
        span: span,
        text: text,
    }
}

pub fn ast_block(statements: Vec[AstStatement], tail_expr: Option[AstExpr], span: SourceSpan, text: String) -> AstBlock {
    AstBlock {
        statements: statements,
        tail_expr: tail_expr,
        span: span,
        text: text,
    }
}

pub fn ast_param(name: AstName, type_ref: AstType, span: SourceSpan) -> AstParam {
    ast_param_with_attrs(vec.new_vec(), name, type_ref, span)
}

pub fn ast_param_with_attrs(attrs: Vec[AstAttribute], name: AstName, type_ref: AstType, span: SourceSpan) -> AstParam {
    AstParam {
        attrs: attrs,
        name: name,
        type_ref: type_ref,
        span: span,
    }
}

pub fn function_signature(
    name: AstName,
    generic_params: AstGenericParamList,
    params: Vec[AstParam],
    return_type: AstType,
    effect_names: String,
    capability_names: String,
    span: SourceSpan,
) -> AstFunctionSignature {
    function_signature_with_attrs(vec.new_vec(), name, generic_params, params, return_type, effect_names, capability_names, span)
}

pub fn function_signature_with_attrs(
    attrs: Vec[AstAttribute],
    name: AstName,
    generic_params: AstGenericParamList,
    params: Vec[AstParam],
    return_type: AstType,
    effect_names: String,
    capability_names: String,
    span: SourceSpan,
) -> AstFunctionSignature {
    AstFunctionSignature {
        attrs: attrs,
        name: name,
        generic_params: generic_params,
        params: params,
        return_type: return_type,
        effect_names: effect_names,
        capability_names: capability_names,
        span: span,
    }
}

pub fn function_signature_with_new_attrs(value: AstFunctionSignature, attrs: Vec[AstAttribute]) -> AstFunctionSignature {
    let signature_span = match vec.get(attrs, 0) {
        Some(attr) => merge(attr.span, value.span),
        None => value.span,
    };
    function_signature_with_attrs(attrs, value.name, value.generic_params, value.params, value.return_type, value.effect_names, value.capability_names, signature_span)
}

pub fn function_decl(
    signature: AstFunctionSignature,
    requires_expr: Option[AstExpr],
