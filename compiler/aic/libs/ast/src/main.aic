    pub items: Vec[AstProgramItem],
    pub source_map: Vec[AstSourceMapEntry],
    pub span: SourceSpan,
}

pub struct AstLiteral {
    pub kind: AstLiteralKind,
    pub token: Token,
}

pub fn ast_name(value: String, span: SourceSpan) -> AstName {
    AstName {
        value: value,
        span: span,
    }
}

pub fn module_path(text: String, span: SourceSpan) -> AstModulePath {
    AstModulePath {
        text: text,
        span: span,
    }
}

pub fn module_decl(path: AstModulePath, span: SourceSpan) -> AstModuleDecl {
    AstModuleDecl {
        path: path,
        span: span,
    }
}

pub fn import_decl(path: AstModulePath, span: SourceSpan) -> AstImportDecl {
    AstImportDecl {
        path: path,
        span: span,
    }
}

pub fn ast_name_from_token(value: Token) -> Result[AstName, AstError] {
    match value.kind {
        Identifier => Ok(AstName {
            value: value.lexeme,
            span: value.span,
        }),
        _ => Err(ExpectedIdentifier()),
    }
}

pub fn keyword_name_from_token(value: Token) -> Result[AstName, AstError] {
    match value.kind {
        Keyword => Ok(AstName {
            value: value.lexeme,
            span: value.span,
        }),
        _ => Err(ExpectedKeyword()),
    }
}

pub fn item_header(kind: AstItemKind, visibility: AstVisibility, name: AstName, span: SourceSpan) -> AstItemHeader {
    AstItemHeader {
        kind: kind,
        visibility: visibility,
        name: name,
        span: span,
    }
}

pub fn ast_attribute_arg(name: String, value: String, kind: AstAttributeValueKind, named: Bool, span: SourceSpan, text: String) -> AstAttributeArg {
    AstAttributeArg {
        name: name,
        value: value,
        kind: kind,
        named: named,
        span: span,
        text: text,
    }
}

pub fn ast_attribute(name: String, args: Vec[AstAttributeArg], span: SourceSpan, text: String) -> AstAttribute {
    AstAttribute {
        name: name,
        args: args,
        span: span,
        text: text,
    }
}

pub fn ast_source_map_entry(kind: String, name: String, span: SourceSpan) -> AstSourceMapEntry {
    AstSourceMapEntry {
        kind: kind,
        name: name,
        span: span,
    }
}

pub fn ast_program_item(
    kind: AstItemKind,
    name: AstName,
    visibility: AstVisibility,
    attrs: Vec[AstAttribute],
    function_item: Option[AstFunctionDecl],
    function_signature: Option[AstFunctionSignature],
    struct_item: Option[AstStructDecl],
    enum_item: Option[AstEnumDecl],
    type_alias_item: Option[AstTypeAliasDecl],
    const_item: Option[AstConstDecl],
    trait_item: Option[AstTraitDecl],
    impl_item: Option[AstImplDecl],
    is_signature_only: Bool,
    modifier_names: String,
    span: SourceSpan,
) -> AstProgramItem {
    AstProgramItem {
        kind: kind,
        name: name,
        visibility: visibility,
        attrs: attrs,
        function_item: function_item,
        function_signature: function_signature,
        struct_item: struct_item,
        enum_item: enum_item,
        type_alias_item: type_alias_item,
        const_item: const_item,
        trait_item: trait_item,
        impl_item: impl_item,
        is_signature_only: is_signature_only,
        modifier_names: modifier_names,
        span: span,
    }
}

pub fn ast_program(
    source: SourceId,
    module_item: Option[AstModuleDecl],
    imports: Vec[AstImportDecl],
    items: Vec[AstProgramItem],
    source_map: Vec[AstSourceMapEntry],
    span: SourceSpan,
) -> AstProgram {
    AstProgram {
        source: source,
        module_item: module_item,
        imports: imports,
        items: items,
        source_map: source_map,
        span: span,
    }
}

pub fn ast_type_node(kind: AstTypeKind, name: String, direct_arg_count: Int, depth: Int, span: SourceSpan, text: String) -> AstTypeNode {
    AstTypeNode {
        kind: kind,
        name: name,
        direct_arg_count: direct_arg_count,
        depth: depth,
        span: span,
        text: text,
    }
}

pub fn ast_type(kind: AstTypeKind, name: String, direct_arg_count: Int, nodes: Vec[AstTypeNode], span: SourceSpan, text: String) -> AstType {
    AstType {
        kind: kind,
        name: name,
        direct_arg_count: direct_arg_count,
        nodes: nodes,
        span: span,
        text: text,
    }
}

pub fn unit_type(span: SourceSpan) -> AstType {
    ast_type(AstUnitType(), "", 0, vec.new_vec(), span, "()")
}

fn type_node_from_type(value: AstType, depth: Int) -> AstTypeNode {
    ast_type_node(value.kind, value.name, value.direct_arg_count, depth, value.span, value.text)
}

fn nested_type_node(value: AstTypeNode, depth_offset: Int) -> AstTypeNode {
    ast_type_node(value.kind, value.name, value.direct_arg_count, value.depth + depth_offset, value.span, value.text)
}

fn flatten_type_args(args: Vec[AstType]) -> Vec[AstTypeNode] {
    let mut nodes: Vec[AstTypeNode] = vec.new_vec();
    let mut index = 0;
    while index < vec.vec_len(args) {
        match vec.get(args, index) {
            Some(arg) => if true {
                nodes = vec.push(nodes, type_node_from_type(arg, 1));
                let mut nested_index = 0;
                while nested_index < vec.vec_len(arg.nodes) {
                    match vec.get(arg.nodes, nested_index) {
                        Some(node) => if true {
                            nodes = vec.push(nodes, nested_type_node(node, 1));
                            ()
                        } else {
                            ()
                        },
                        None => (),
                    };
                    nested_index = nested_index + 1;
                };
                ()
            } else {
                ()
            },
            None => (),
        };
        index = index + 1;
    };
    nodes
}

fn type_args_text(args: Vec[AstType], separator: String) -> String {
    let mut parts: Vec[String] = vec.new_vec();
    let mut index = 0;
    while index < vec.vec_len(args) {
        match vec.get(args, index) {
            Some(arg) => if true {
                parts = vec.push(parts, type_text(arg));
                ()
            } else {
                ()
            },
            None => (),
        };
        index = index + 1;
    };
    string.join(parts, separator)
}

fn named_type_text_from_args(name: String, args: Vec[AstType]) -> String {
    if name == "Tuple" {
        let mut parts: Vec[String] = vec.new_vec();
        parts = vec.push(parts, "(");
        parts = vec.push(parts, type_args_text(args, ","));
        parts = vec.push(parts, ")");
        string.join(parts, "")
    } else if name == "Fn" {
        fn_type_text_from_args(args)
    } else if vec.vec_len(args) == 0 {
        name
    } else {
        let mut parts: Vec[String] = vec.new_vec();
        parts = vec.push(parts, name);
        parts = vec.push(parts, "[");
        parts = vec.push(parts, type_args_text(args, ","));
        parts = vec.push(parts, "]");
        string.join(parts, "")
    }
}

fn fn_type_text_from_args(args: Vec[AstType]) -> String {
    let arg_count = vec.vec_len(args);
    if arg_count == 0 {
        "Fn"
    } else {
        let mut param_parts: Vec[String] = vec.new_vec();
        let mut index = 0;
        while index + 1 < arg_count {
            match vec.get(args, index) {
                Some(arg) => if true {
                    param_parts = vec.push(param_parts, type_text(arg));
                    ()
                } else {
                    ()
                },
                None => (),
            };
            index = index + 1;
        };
        let params_text = string.join(param_parts, ",");
        let return_text = match vec.get(args, arg_count - 1) {
            Some(arg) => type_text(arg),
            None => "()",
        };
        let mut parts: Vec[String] = vec.new_vec();
        parts = vec.push(parts, "Fn(");
        parts = vec.push(parts, params_text);
        parts = vec.push(parts, ")->");
        parts = vec.push(parts, return_text);
        string.join(parts, "")
    }
}

pub fn named_type(name: String, args: Vec[AstType], span: SourceSpan) -> AstType {
    ast_type(AstNamedType(), name, vec.vec_len(args), flatten_type_args(args), span, named_type_text_from_args(name, args))
}

pub fn dyn_trait_type(name: String, span: SourceSpan) -> AstType {
    let mut parts: Vec[String] = vec.new_vec();
    parts = vec.push(parts, "dyn ");
    parts = vec.push(parts, name);
    ast_type(AstDynTraitType(), name, 0, vec.new_vec(), span, string.join(parts, ""))
}

pub fn hole_type(span: SourceSpan) -> AstType {
    ast_type(AstHoleType(), "", 0, vec.new_vec(), span, "_")
}

pub fn type_with_span(value: AstType, span: SourceSpan) -> AstType {
    ast_type(value.kind, value.name, value.direct_arg_count, value.nodes, span, value.text)
}

pub fn ast_generic_param(name: AstName, bounds: Vec[AstName], span: SourceSpan) -> AstGenericParam {
    AstGenericParam {
        name: name,
        bounds: bounds,
        span: span,
    }
}

pub fn ast_generic_params(params: Vec[AstGenericParam], span: SourceSpan) -> AstGenericParamList {
    AstGenericParamList {
        params: params,
        span: span,
    }
}

pub fn empty_generic_params(span: SourceSpan) -> AstGenericParamList {
    ast_generic_params(vec.new_vec(), span)
}

