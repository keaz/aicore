    ast_field_with_attrs(vec.new_vec(), name, visibility, type_ref, default_expr, default_text, span)
}

pub fn ast_field_with_attrs(attrs: Vec[AstAttribute], name: AstName, visibility: AstVisibility, type_ref: AstType, default_expr: Option[AstExpr], default_text: String, span: SourceSpan) -> AstField {
