    pub function_item: Option[AstFunctionDecl],
    pub function_signature: Option[AstFunctionSignature],
    pub struct_item: Option[AstStructDecl],
    pub enum_item: Option[AstEnumDecl],
    pub type_alias_item: Option[AstTypeAliasDecl],
    pub const_item: Option[AstConstDecl],
    pub trait_item: Option[AstTraitDecl],
    pub impl_item: Option[AstImplDecl],
    pub is_signature_only: Bool,
    pub modifier_names: String,
    pub span: SourceSpan,
}

pub struct AstProgram {
    pub source: SourceId,
    pub module_item: Option[AstModuleDecl],
