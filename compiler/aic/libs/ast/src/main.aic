pub fn literal_from_token(value: Token) -> Result[AstLiteral, AstError] {
    match value.kind {
        IntegerLiteral => Ok(AstLiteral {
            kind: AstIntLiteral(),
            token: value,
        }),
        FloatLiteral => Ok(AstLiteral {
            kind: AstFloatLiteral(),
            token: value,
        }),
        StringLiteral => Ok(AstLiteral {
            kind: AstStringLiteral(),
            token: value,
        }),
        CharLiteral => Ok(AstLiteral {
            kind: AstCharLiteral(),
            token: value,
        }),
        Keyword => if value.lexeme == "true" || value.lexeme == "false" {
            Ok(AstLiteral {
                kind: AstBoolLiteral(),
                token: value,
            })
        } else {
            Err(ExpectedIdentifier())
        },
        _ => Err(ExpectedIdentifier()),
    }
}

pub fn is_numeric_literal(value: AstLiteral) -> Bool {
    match value.kind {
        AstIntLiteral => true,
        AstFloatLiteral => true,
        AstBoolLiteral => false,
        AstStringLiteral => false,
        AstCharLiteral => false,
        AstUnitLiteral => false,
    }
}
