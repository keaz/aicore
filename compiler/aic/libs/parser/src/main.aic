        }
    } else {
        match result.struct_item {
            Some(item) => ParseProgramItem {
                cursor: result.cursor,
                item: Some(ast_program_item(StructItem(), item.name, item.visibility, attrs, None(), None(), Some(item), None(), None(), None(), None(), None(), false, "", item.span)),
                diagnostic: None(),
            },
            None => ParseProgramItem {
                cursor: result.cursor,
                item: None(),
                diagnostic: Some(error(diagnostic_code("E1383"), current_token(skip_trivia(result.cursor)).span, "missing struct item")),
            },
        }
    }
}

