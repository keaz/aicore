pub fn parser_cursor(source: SourceId, tokens: Vec[Token]) -> ParserCursor {
    parser_cursor_at(source, tokens, 0)
}

pub fn parser_cursor_at(source: SourceId, tokens: Vec[Token], index: Int) -> ParserCursor
requires index >= 0 {
    ParserCursor {
        source: source,
        tokens: tokens,
        index: index,
    }
}

pub fn parser_cursor_from_source(source: SourceId, text: String) -> ParserCursor {
    parser_cursor(source, lex_all(source, text))
}

pub fn current_token(cursor: ParserCursor) -> Token {
    match vec.get(cursor.tokens, cursor.index) {
        Some(tok) => tok,
        None => eof(cursor.source, cursor.index),
    }
}

pub fn advance(cursor: ParserCursor) -> ParserCursor {
    let token_count = vec.vec_len(cursor.tokens);
    if cursor.index + 1 < token_count {
        parser_cursor_at(cursor.source, cursor.tokens, cursor.index + 1)
    } else {
        cursor
    }
}

pub fn skip_trivia(cursor: ParserCursor) -> ParserCursor {
    let mut out = cursor;
    let mut done = false;
    while !done && is_trivia(current_token(out)) {
        let next = advance(out);
        if next.index == out.index {
            done = true;
        } else {
            out = next;
        };
    };
    out
}

pub fn is_at_end(cursor: ParserCursor) -> Bool {
    match current_token(skip_trivia(cursor)).kind {
        EndOfFile => true,
        _ => false,
    }
}

pub fn at_keyword(cursor: ParserCursor, lexeme: String) -> Bool {
    is_keyword(current_token(skip_trivia(cursor)), lexeme)
}

pub fn at_operator(cursor: ParserCursor, lexeme: String) -> Bool {
    is_operator(current_token(skip_trivia(cursor)), lexeme)
}

pub fn at_delimiter(cursor: ParserCursor, lexeme: String) -> Bool {
    is_delimiter(current_token(skip_trivia(cursor)), lexeme)
}

pub fn at_identifier(cursor: ParserCursor) -> Bool {
    match current_token(skip_trivia(cursor)).kind {
        Identifier => true,
        _ => false,
    }
}

pub fn expectation_ok(cursor: ParserCursor, token: Token) -> ParseExpectation {
    ParseExpectation {
        cursor: cursor,
        token: token,
        diagnostic: None(),
    }
}

pub fn expectation_error(cursor: ParserCursor, token: Token, code: String, message: String) -> ParseExpectation {
    ParseExpectation {
        cursor: cursor,
        token: token,
        diagnostic: Some(error(diagnostic_code(code), token.span, message)),
    }
}

pub fn has_diagnostic(result: ParseExpectation) -> Bool {
    match result.diagnostic {
        Some(_) => true,
        None => false,
    }
}

pub fn has_path_diagnostic(result: ParseModulePath) -> Bool {
