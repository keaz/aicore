pub fn parse_raw_text_until_end(cursor: ParserCursor, code: String, message: String) -> ParseRawText {
    let start_cursor = skip_trivia(cursor);
    let start_token = current_token(start_cursor);
    let mut out_cursor = start_cursor;
    let mut parts: Vec[String] = vec.new_vec();
    let mut end_span = start_token.span;
    let mut saw_token = false;
    let mut done = false;
    let mut diagnostic: Option[Diagnostic] = None();

    while !done {
        let active = skip_trivia(out_cursor);
        let token = current_token(active);
        if is_at_end(active) {
            out_cursor = active;
            done = true;
        } else if is_terminal(token) {
            out_cursor = active;
            end_span = token.span;
            diagnostic = Some(error(diagnostic_code(code), token.span, message));
            done = true;
        } else {
            saw_token = true;
            parts = vec.push(parts, token.lexeme);
            end_span = token.span;
            out_cursor = advance(active);
        };
    };

    if !saw_token {
        ParseRawText {
            cursor: out_cursor,
            text: "",
            span: empty_span(start_cursor.source, start_token.span.start),
            diagnostic: Some(error(diagnostic_code(code), start_token.span, message)),
        }
    } else {
        match diagnostic {
            Some(diag) => ParseRawText {
                cursor: out_cursor,
                text: "",
                span: merge(start_token.span, end_span),
                diagnostic: Some(diag),
            },
            None => ParseRawText {
                cursor: out_cursor,
                text: string.join(parts, ""),
                span: merge(start_token.span, end_span),
                diagnostic: None(),
            },
        }
    }
}

fn struct_field_result(
    cursor: ParserCursor,
    name_token: Token,
    visibility: AstVisibility,
    type_ref: AstType,
    default_text: String,
    field_start: SourceSpan,
    field_end: SourceSpan,
) -> ParseStructField {
    ParseStructField {
        cursor: cursor,
        field: Some(ast_field(ast_name(name_token.lexeme, name_token.span), visibility, type_ref, default_text, merge(field_start, field_end))),
        diagnostic: None(),
    }
}

pub fn parse_struct_field(cursor: ParserCursor) -> ParseStructField {
    let visibility_result = parse_visibility(cursor);
    if has_visibility_diagnostic(visibility_result) {
        ParseStructField {
            cursor: visibility_result.cursor,
            field: None(),
            diagnostic: visibility_result.diagnostic,
        }
    } else {
        let name_result = expect_identifier(visibility_result.cursor, "E1121", "expected struct field name");
        if has_diagnostic(name_result) {
            ParseStructField {
                cursor: name_result.cursor,
                field: None(),
                diagnostic: name_result.diagnostic,
            }
        } else {
            let colon_result = expect_delimiter(name_result.cursor, ":", "E1122", "expected ':' after struct field name");
            if has_diagnostic(colon_result) {
                ParseStructField {
                    cursor: colon_result.cursor,
                    field: None(),
                    diagnostic: colon_result.diagnostic,
                }
            } else {
                let type_result = parse_type_ref(colon_result.cursor, true);
                if has_type_ref_diagnostic(type_result) {
                    ParseStructField {
                        cursor: type_result.cursor,
                        field: None(),
                        diagnostic: type_result.diagnostic,
                    }
                } else {
                    let mut out_cursor = type_result.cursor;
                    let mut default_text = "";
                    let mut field_end = type_result.span;
                    let mut default_diagnostic: Option[Diagnostic] = None();
                    if at_operator(out_cursor, "=") {
                        let eq_result = expect_operator(out_cursor, "=", "E1123", "expected struct field default assignment");
                        let default_result = parse_raw_text_until_field_boundary(eq_result.cursor, "E1124", "expected struct field default expression");
                        out_cursor = default_result.cursor;
                        default_text = default_result.text;
                        field_end = default_result.span;
                        default_diagnostic = default_result.diagnostic;
                    } else {
                        ()
                    };

                    match default_diagnostic {
                        Some(diag) => ParseStructField {
                            cursor: out_cursor,
                            field: None(),
                            diagnostic: Some(diag),
                        },
                        None => match visibility_result.visibility {
                            Some(visibility) => match type_result.type_ref {
                                Some(type_ref) => struct_field_result(out_cursor, name_result.token, visibility, type_ref, default_text, visibility_result.span, field_end),
                                None => ParseStructField {
                                    cursor: type_result.cursor,
                                    field: None(),
                                    diagnostic: Some(error(diagnostic_code("E1125"), type_result.span, "missing struct field type")),
                                },
                            },
                            None => ParseStructField {
                                cursor: visibility_result.cursor,
                                field: None(),
                                diagnostic: Some(error(diagnostic_code("E1126"), visibility_result.span, "missing struct field visibility")),
                            },
                        },
                    }
                }
            }
        }
    }
}

pub fn parse_struct_field_list(cursor: ParserCursor) -> ParseStructFieldList {
    let open_result = expect_delimiter(cursor, "{", "E1130", "expected struct field list opener");
    if has_diagnostic(open_result) {
        ParseStructFieldList {
            cursor: open_result.cursor,
            fields: vec.new_vec(),
            span: open_result.token.span,
            diagnostic: open_result.diagnostic,
        }
    } else {
        let mut out_cursor = open_result.cursor;
        let mut fields: Vec[AstField] = vec.new_vec();
        let mut end_span = open_result.token.span;
        let mut diagnostic: Option[Diagnostic] = None();
        let mut done = false;
        if at_delimiter(out_cursor, "}") {
            let close_result = expect_delimiter(out_cursor, "}", "E1131", "expected struct field list closer");
            out_cursor = close_result.cursor;
            end_span = close_result.token.span;
            diagnostic = close_result.diagnostic;
            done = true;
        } else {
            ()
        };

        while !done {
            let field_result = parse_struct_field(out_cursor);
            if has_struct_field_diagnostic(field_result) {
                out_cursor = field_result.cursor;
                diagnostic = field_result.diagnostic;
                done = true;
            } else {
                let field_count_before = vec.vec_len(fields);
                fields = match field_result.field {
                    Some(field) => vec.push(fields, field),
                    None => fields,
                };
                out_cursor = field_result.cursor;
                if vec.vec_len(fields) == field_count_before {
                    diagnostic = Some(error(diagnostic_code("E1132"), current_token(skip_trivia(field_result.cursor)).span, "missing struct field"));
                    done = true;
                } else if at_delimiter(out_cursor, ",") {
                    let comma_result = expect_delimiter(out_cursor, ",", "E1133", "expected struct field separator");
                    out_cursor = comma_result.cursor;
                    end_span = comma_result.token.span;
                    if at_delimiter(out_cursor, "}") {
                        let close_result = expect_delimiter(out_cursor, "}", "E1131", "expected struct field list closer");
                        out_cursor = close_result.cursor;
                        end_span = close_result.token.span;
                        diagnostic = close_result.diagnostic;
                        done = true;
                    } else {
                        ()
                    };
                } else {
                    let close_result = expect_delimiter(out_cursor, "}", "E1131", "expected struct field list closer");
                    out_cursor = close_result.cursor;
                    end_span = close_result.token.span;
                    diagnostic = close_result.diagnostic;
                    done = true;
                };
            };
        };

        ParseStructFieldList {
            cursor: out_cursor,
            fields: fields,
            span: merge(open_result.token.span, end_span),
            diagnostic: diagnostic,
        }
    }
}

fn struct_decl_result(
    cursor: ParserCursor,
    header: AstItemHeader,
    generic_params: AstGenericParamList,
    fields: Vec[AstField],
    field_span: SourceSpan,
    invariant_text: String,
    invariant_span: SourceSpan,
) -> ParseStructDecl {
    let mut item_span = merge(header.span, field_span);
    if invariant_span.start != invariant_span.end {
        item_span = merge(item_span, invariant_span);
    } else {
        ()
    };
    ParseStructDecl {
        cursor: cursor,
        struct_item: Some(struct_decl(header.name, header.visibility, generic_params, fields, invariant_text, item_span)),
        diagnostic: None(),
    }
}

pub fn parse_struct_declaration(cursor: ParserCursor) -> ParseStructDecl {
    let header_result = parse_item_header(cursor);
    if has_item_header_diagnostic(header_result) {
        ParseStructDecl {
            cursor: header_result.cursor,
            struct_item: None(),
            diagnostic: header_result.diagnostic,
        }
    } else {
        match header_result.header {
            Some(header) => if is_struct_item_kind(header.kind) {
                let generic_result = parse_optional_generic_params(header_result.cursor);
                if has_generic_params_diagnostic(generic_result) {
                    ParseStructDecl {
                        cursor: generic_result.cursor,
                        struct_item: None(),
                        diagnostic: generic_result.diagnostic,
                    }
                } else {
                    let fields_result = parse_struct_field_list(generic_result.cursor);
                    if has_struct_field_list_diagnostic(fields_result) {
                        ParseStructDecl {
                            cursor: fields_result.cursor,
                            struct_item: None(),
                            diagnostic: fields_result.diagnostic,
                        }
                    } else {
                        if at_keyword(fields_result.cursor, "invariant") {
                            let invariant_keyword = expect_keyword(fields_result.cursor, "invariant", "E1140", "expected struct invariant keyword");
                            let invariant_result = parse_raw_text_until_end(invariant_keyword.cursor, "E1141", "expected struct invariant expression");
                            if has_raw_text_diagnostic(invariant_result) {
                                ParseStructDecl {
                                    cursor: invariant_result.cursor,
                                    struct_item: None(),
                                    diagnostic: invariant_result.diagnostic,
                                }
                            } else {
                                struct_decl_result(
                                    invariant_result.cursor,
                                    header,
                                    generic_result.params,
                                    fields_result.fields,
                                    fields_result.span,
                                    invariant_result.text,
                                    merge(invariant_keyword.token.span, invariant_result.span),
                                )
                            }
                        } else {
                            struct_decl_result(
                                fields_result.cursor,
                                header,
                                generic_result.params,
                                fields_result.fields,
                                fields_result.span,
                                "",
                                empty_span(fields_result.cursor.source, current_token(skip_trivia(fields_result.cursor)).span.start),
                            )
                        }
                    }
                }
            } else {
                ParseStructDecl {
                    cursor: header_result.cursor,
                    struct_item: None(),
                    diagnostic: Some(error(diagnostic_code("E1142"), header.span, "expected struct item")),
                }
            },
            None => ParseStructDecl {
                cursor: header_result.cursor,
                struct_item: None(),
                diagnostic: Some(error(diagnostic_code("E1143"), current_token(skip_trivia(header_result.cursor)).span, "missing struct header")),
            },
        }
    }
}

fn enum_variant_result(
    cursor: ParserCursor,
    name_token: Token,
    payload_type: Option[AstType],
    variant_end: SourceSpan,
) -> ParseEnumVariant {
    ParseEnumVariant {
        cursor: cursor,
        variant: Some(enum_variant(ast_name(name_token.lexeme, name_token.span), payload_type, merge(name_token.span, variant_end))),
        diagnostic: None(),
    }
}

pub fn parse_enum_variant(cursor: ParserCursor) -> ParseEnumVariant {
    let name_result = expect_identifier(cursor, "E1150", "expected enum variant name");
    if has_diagnostic(name_result) {
        ParseEnumVariant {
            cursor: name_result.cursor,
            variant: None(),
            diagnostic: name_result.diagnostic,
        }
    } else {
        if at_delimiter(name_result.cursor, "(") {
            let open_result = expect_delimiter(name_result.cursor, "(", "E1151", "expected enum variant payload opener");
            let payload_result = parse_type_ref(open_result.cursor, false);
            if has_type_ref_diagnostic(payload_result) {
                ParseEnumVariant {
                    cursor: payload_result.cursor,
                    variant: None(),
                    diagnostic: payload_result.diagnostic,
                }
            } else {
                let close_result = expect_delimiter(payload_result.cursor, ")", "E1152", "expected ')' after enum variant payload type");
                if has_diagnostic(close_result) {
                    ParseEnumVariant {
                        cursor: close_result.cursor,
                        variant: None(),
                        diagnostic: close_result.diagnostic,
                    }
                } else {
                    match payload_result.type_ref {
                        Some(payload_type) => enum_variant_result(close_result.cursor, name_result.token, Some(payload_type), close_result.token.span),
                        None => ParseEnumVariant {
                            cursor: payload_result.cursor,
                            variant: None(),
                            diagnostic: Some(error(diagnostic_code("E1153"), payload_result.span, "missing enum variant payload type")),
                        },
                    }
                }
            }
        } else {
            enum_variant_result(name_result.cursor, name_result.token, None(), name_result.token.span)
        }
    }
}

pub fn parse_enum_variant_list(cursor: ParserCursor) -> ParseEnumVariantList {
    let open_result = expect_delimiter(cursor, "{", "E1160", "expected enum variant list opener");
    if has_diagnostic(open_result) {
        ParseEnumVariantList {
            cursor: open_result.cursor,
            variants: vec.new_vec(),
            span: open_result.token.span,
            diagnostic: open_result.diagnostic,
        }
    } else {
        let mut out_cursor = open_result.cursor;
        let mut variants: Vec[AstEnumVariant] = vec.new_vec();
        let mut end_span = open_result.token.span;
        let mut diagnostic: Option[Diagnostic] = None();
        let mut done = false;
        if at_delimiter(out_cursor, "}") {
            let close_result = expect_delimiter(out_cursor, "}", "E1161", "expected enum variant list closer");
            out_cursor = close_result.cursor;
            end_span = close_result.token.span;
            diagnostic = close_result.diagnostic;
            done = true;
        } else {
            ()
        };

        while !done {
            let variant_result = parse_enum_variant(out_cursor);
            if has_enum_variant_diagnostic(variant_result) {
                out_cursor = variant_result.cursor;
                diagnostic = variant_result.diagnostic;
                done = true;
            } else {
                let variant_count_before = vec.vec_len(variants);
                variants = match variant_result.variant {
                    Some(variant) => vec.push(variants, variant),
                    None => variants,
                };
                out_cursor = variant_result.cursor;
                if vec.vec_len(variants) == variant_count_before {
                    diagnostic = Some(error(diagnostic_code("E1162"), current_token(skip_trivia(variant_result.cursor)).span, "missing enum variant"));
                    done = true;
                } else if at_delimiter(out_cursor, ",") {
                    let comma_result = expect_delimiter(out_cursor, ",", "E1163", "expected enum variant separator");
                    out_cursor = comma_result.cursor;
                    end_span = comma_result.token.span;
                    if at_delimiter(out_cursor, "}") {
                        let close_result = expect_delimiter(out_cursor, "}", "E1161", "expected enum variant list closer");
                        out_cursor = close_result.cursor;
                        end_span = close_result.token.span;
                        diagnostic = close_result.diagnostic;
                        done = true;
                    } else {
                        ()
                    };
                } else {
                    let close_result = expect_delimiter(out_cursor, "}", "E1161", "expected enum variant list closer");
                    out_cursor = close_result.cursor;
                    end_span = close_result.token.span;
                    diagnostic = close_result.diagnostic;
                    done = true;
                };
            };
        };

        ParseEnumVariantList {
            cursor: out_cursor,
            variants: variants,
            span: merge(open_result.token.span, end_span),
            diagnostic: diagnostic,
        }
    }
}

fn enum_decl_result(
    cursor: ParserCursor,
    header: AstItemHeader,
    generic_params: AstGenericParamList,
    variants: Vec[AstEnumVariant],
    variant_span: SourceSpan,
) -> ParseEnumDecl {
    ParseEnumDecl {
        cursor: cursor,
        enum_item: Some(enum_decl(header.name, header.visibility, generic_params, variants, merge(header.span, variant_span))),
        diagnostic: None(),
    }
}

pub fn parse_enum_declaration(cursor: ParserCursor) -> ParseEnumDecl {
    let header_result = parse_item_header(cursor);
    if has_item_header_diagnostic(header_result) {
        ParseEnumDecl {
            cursor: header_result.cursor,
            enum_item: None(),
            diagnostic: header_result.diagnostic,
        }
    } else {
        match header_result.header {
            Some(header) => if is_enum_item_kind(header.kind) {
                let generic_result = parse_optional_generic_params(header_result.cursor);
                if has_generic_params_diagnostic(generic_result) {
                    ParseEnumDecl {
                        cursor: generic_result.cursor,
                        enum_item: None(),
                        diagnostic: generic_result.diagnostic,
                    }
                } else {
                    let variants_result = parse_enum_variant_list(generic_result.cursor);
                    if has_enum_variant_list_diagnostic(variants_result) {
                        ParseEnumDecl {
                            cursor: variants_result.cursor,
                            enum_item: None(),
                            diagnostic: variants_result.diagnostic,
                        }
                    } else {
                        enum_decl_result(variants_result.cursor, header, generic_result.params, variants_result.variants, variants_result.span)
                    }
                }
            } else {
                ParseEnumDecl {
                    cursor: header_result.cursor,
                    enum_item: None(),
                    diagnostic: Some(error(diagnostic_code("E1170"), header.span, "expected enum item")),
                }
            },
            None => ParseEnumDecl {
                cursor: header_result.cursor,
                enum_item: None(),
                diagnostic: Some(error(diagnostic_code("E1171"), current_token(skip_trivia(header_result.cursor)).span, "missing enum header")),
            },
        }
    }
}

fn type_alias_decl_result(
    cursor: ParserCursor,
    header: AstItemHeader,
    generic_params: AstGenericParamList,
    target_type: AstType,
    end_span: SourceSpan,
) -> ParseTypeAliasDecl {
    ParseTypeAliasDecl {
        cursor: cursor,
        alias_item: Some(type_alias_decl(header.name, generic_params, target_type, merge(header.span, end_span))),
        diagnostic: None(),
    }
}

pub fn parse_type_alias_declaration(cursor: ParserCursor) -> ParseTypeAliasDecl {
    let header_result = parse_item_header(cursor);
    if has_item_header_diagnostic(header_result) {
        ParseTypeAliasDecl {
            cursor: header_result.cursor,
            alias_item: None(),
            diagnostic: header_result.diagnostic,
        }
    } else {
        match header_result.header {
            Some(header) => if is_type_alias_item_kind(header.kind) {
                if !is_private_visibility_kind(header.visibility) {
                    ParseTypeAliasDecl {
                        cursor: header_result.cursor,
                        alias_item: None(),
                        diagnostic: Some(error(diagnostic_code("E1180"), header.span, "visibility modifiers are not supported on type aliases")),
                    }
                } else {
                    let generic_result = parse_optional_generic_params(header_result.cursor);
                    if has_generic_params_diagnostic(generic_result) {
                        ParseTypeAliasDecl {
                            cursor: generic_result.cursor,
                            alias_item: None(),
                            diagnostic: generic_result.diagnostic,
                        }
                    } else {
                        let eq_result = expect_operator(generic_result.cursor, "=", "E1181", "expected '=' in type alias declaration");
                        if has_diagnostic(eq_result) {
                            ParseTypeAliasDecl {
                                cursor: eq_result.cursor,
                                alias_item: None(),
                                diagnostic: eq_result.diagnostic,
                            }
                        } else {
                            let target_result = parse_type_ref(eq_result.cursor, false);
                            if has_type_ref_diagnostic(target_result) {
                                ParseTypeAliasDecl {
                                    cursor: target_result.cursor,
                                    alias_item: None(),
                                    diagnostic: target_result.diagnostic,
                                }
                            } else {
                                let semi_result = expect_delimiter(target_result.cursor, ";", "E1182", "expected semicolon after type alias declaration");
                                if has_diagnostic(semi_result) {
                                    ParseTypeAliasDecl {
                                        cursor: semi_result.cursor,
                                        alias_item: None(),
                                        diagnostic: semi_result.diagnostic,
                                    }
                                } else {
                                    match target_result.type_ref {
                                        Some(target_type) => type_alias_decl_result(semi_result.cursor, header, generic_result.params, target_type, semi_result.token.span),
                                        None => ParseTypeAliasDecl {
                                            cursor: target_result.cursor,
                                            alias_item: None(),
                                            diagnostic: Some(error(diagnostic_code("E1183"), target_result.span, "missing type alias target type")),
                                        },
                                    }
                                }
                            }
                        }
                    }
                }
            } else {
                ParseTypeAliasDecl {
                    cursor: header_result.cursor,
                    alias_item: None(),
                    diagnostic: Some(error(diagnostic_code("E1184"), header.span, "expected type alias item")),
                }
            },
            None => ParseTypeAliasDecl {
                cursor: header_result.cursor,
                alias_item: None(),
                diagnostic: Some(error(diagnostic_code("E1185"), current_token(skip_trivia(header_result.cursor)).span, "missing type alias header")),
            },
        }
    }
}

fn const_decl_result(
    cursor: ParserCursor,
    header: AstItemHeader,
    type_ref: AstType,
    initializer_text: String,
    end_span: SourceSpan,
) -> ParseConstDecl {
    ParseConstDecl {
        cursor: cursor,
        const_item: Some(const_decl(header.name, type_ref, initializer_text, merge(header.span, end_span))),
        diagnostic: None(),
    }
}

pub fn parse_const_declaration(cursor: ParserCursor) -> ParseConstDecl {
    let header_result = parse_item_header(cursor);
    if has_item_header_diagnostic(header_result) {
        ParseConstDecl {
            cursor: header_result.cursor,
            const_item: None(),
            diagnostic: header_result.diagnostic,
        }
    } else {
        match header_result.header {
            Some(header) => if is_const_item_kind(header.kind) {
                if !is_private_visibility_kind(header.visibility) {
                    ParseConstDecl {
                        cursor: header_result.cursor,
                        const_item: None(),
                        diagnostic: Some(error(diagnostic_code("E1190"), header.span, "visibility modifiers are not supported on const items")),
                    }
                } else {
                    let colon_result = expect_delimiter(header_result.cursor, ":", "E1191", "expected ':' after const name");
                    if has_diagnostic(colon_result) {
                        ParseConstDecl {
                            cursor: colon_result.cursor,
                            const_item: None(),
                            diagnostic: colon_result.diagnostic,
                        }
                    } else {
                        let type_result = parse_type_ref(colon_result.cursor, false);
                        if has_type_ref_diagnostic(type_result) {
                            ParseConstDecl {
                                cursor: type_result.cursor,
                                const_item: None(),
                                diagnostic: type_result.diagnostic,
                            }
                        } else {
                            let eq_result = expect_operator(type_result.cursor, "=", "E1192", "expected '=' in const declaration");
                            if has_diagnostic(eq_result) {
                                ParseConstDecl {
                                    cursor: eq_result.cursor,
                                    const_item: None(),
                                    diagnostic: eq_result.diagnostic,
                                }
                            } else {
                                let initializer_result = parse_raw_text_until_semicolon(eq_result.cursor, "E1193", "expected const initializer expression");
                                if has_raw_text_diagnostic(initializer_result) {
                                    ParseConstDecl {
                                        cursor: initializer_result.cursor,
                                        const_item: None(),
                                        diagnostic: initializer_result.diagnostic,
                                    }
                                } else {
                                    let semi_result = expect_delimiter(initializer_result.cursor, ";", "E1194", "expected semicolon after const declaration");
                                    if has_diagnostic(semi_result) {
                                        ParseConstDecl {
                                            cursor: semi_result.cursor,
                                            const_item: None(),
                                            diagnostic: semi_result.diagnostic,
                                        }
                                    } else {
                                        match type_result.type_ref {
                                            Some(type_ref) => const_decl_result(semi_result.cursor, header, type_ref, initializer_result.text, semi_result.token.span),
                                            None => ParseConstDecl {
                                                cursor: type_result.cursor,
                                                const_item: None(),
                                                diagnostic: Some(error(diagnostic_code("E1195"), type_result.span, "missing const type")),
                                            },
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            } else {
                ParseConstDecl {
                    cursor: header_result.cursor,
                    const_item: None(),
                    diagnostic: Some(error(diagnostic_code("E1196"), header.span, "expected const item")),
                }
            },
            None => ParseConstDecl {
                cursor: header_result.cursor,
                const_item: None(),
                diagnostic: Some(error(diagnostic_code("E1197"), current_token(skip_trivia(header_result.cursor)).span, "missing const header")),
            },
        }
    }
}

pub fn parse_trait_method_signature(cursor: ParserCursor) -> ParseTraitMethodSignature {
    let signature_result = parse_function_signature(cursor);
    if has_function_signature_diagnostic(signature_result) {
        ParseTraitMethodSignature {
            cursor: signature_result.cursor,
            signature: None(),
            diagnostic: signature_result.diagnostic,
        }
    } else {
        let semi_result = expect_delimiter(signature_result.cursor, ";", "E1200", "expected semicolon after trait method signature");
        if has_diagnostic(semi_result) {
            ParseTraitMethodSignature {
                cursor: semi_result.cursor,
                signature: None(),
                diagnostic: semi_result.diagnostic,
            }
        } else {
            ParseTraitMethodSignature {
                cursor: semi_result.cursor,
                signature: signature_result.signature,
                diagnostic: None(),
            }
        }
    }
}

pub fn parse_trait_method_list(cursor: ParserCursor) -> ParseTraitMethodList {
    let open_result = expect_delimiter(cursor, "{", "E1210", "expected trait method list opener");
    if has_diagnostic(open_result) {
        ParseTraitMethodList {
            cursor: open_result.cursor,
            methods: vec.new_vec(),
            span: open_result.token.span,
            diagnostic: open_result.diagnostic,
        }
    } else {
        let mut out_cursor = open_result.cursor;
        let mut methods: Vec[AstFunctionSignature] = vec.new_vec();
        let mut end_span = open_result.token.span;
        let mut diagnostic: Option[Diagnostic] = None();
        let mut done = false;
        if at_delimiter(out_cursor, "}") {
            let close_result = expect_delimiter(out_cursor, "}", "E1211", "expected trait method list closer");
            out_cursor = close_result.cursor;
            end_span = close_result.token.span;
            diagnostic = close_result.diagnostic;
            done = true;
        } else {
            ()
        };

        while !done {
            let method_result = parse_trait_method_signature(out_cursor);
            if has_trait_method_signature_diagnostic(method_result) {
                out_cursor = method_result.cursor;
                diagnostic = method_result.diagnostic;
                done = true;
            } else {
                let method_count_before = vec.vec_len(methods);
                methods = match method_result.signature {
                    Some(signature) => vec.push(methods, signature),
                    None => methods,
                };
                out_cursor = method_result.cursor;
                if vec.vec_len(methods) == method_count_before {
                    diagnostic = Some(error(diagnostic_code("E1212"), current_token(skip_trivia(method_result.cursor)).span, "missing trait method signature"));
                    done = true;
                } else if at_delimiter(out_cursor, "}") {
                    let close_result = expect_delimiter(out_cursor, "}", "E1211", "expected trait method list closer");
                    out_cursor = close_result.cursor;
                    end_span = close_result.token.span;
                    diagnostic = close_result.diagnostic;
                    done = true;
                } else {
                    ()
                };
            };
        };

        ParseTraitMethodList {
            cursor: out_cursor,
            methods: methods,
            span: merge(open_result.token.span, end_span),
            diagnostic: diagnostic,
        }
    }
}

fn trait_decl_result(
    cursor: ParserCursor,
    header: AstItemHeader,
    generic_params: AstGenericParamList,
    methods: Vec[AstFunctionSignature],
    end_span: SourceSpan,
) -> ParseTraitDecl {
    ParseTraitDecl {
        cursor: cursor,
        trait_item: Some(trait_decl(header.name, header.visibility, generic_params, methods, merge(header.span, end_span))),
        diagnostic: None(),
    }
}

pub fn parse_trait_declaration(cursor: ParserCursor) -> ParseTraitDecl {
    let header_result = parse_item_header(cursor);
    if has_item_header_diagnostic(header_result) {
        ParseTraitDecl {
            cursor: header_result.cursor,
            trait_item: None(),
            diagnostic: header_result.diagnostic,
        }
    } else {
        match header_result.header {
            Some(header) => if is_trait_item_kind(header.kind) {
                let generic_result = parse_optional_generic_params(header_result.cursor);
                if has_generic_params_diagnostic(generic_result) {
                    ParseTraitDecl {
                        cursor: generic_result.cursor,
                        trait_item: None(),
                        diagnostic: generic_result.diagnostic,
                    }
                } else {
                    if at_delimiter(generic_result.cursor, ";") {
                        let semi_result = expect_delimiter(generic_result.cursor, ";", "E1220", "expected semicolon after trait declaration");
                        if has_diagnostic(semi_result) {
                            ParseTraitDecl {
                                cursor: semi_result.cursor,
                                trait_item: None(),
                                diagnostic: semi_result.diagnostic,
                            }
                        } else {
                            trait_decl_result(semi_result.cursor, header, generic_result.params, vec.new_vec(), semi_result.token.span)
                        }
                    } else {
                        let methods_result = parse_trait_method_list(generic_result.cursor);
                        if has_trait_method_list_diagnostic(methods_result) {
                            ParseTraitDecl {
                                cursor: methods_result.cursor,
                                trait_item: None(),
                                diagnostic: methods_result.diagnostic,
                            }
                        } else {
                            trait_decl_result(methods_result.cursor, header, generic_result.params, methods_result.methods, methods_result.span)
                        }
                    }
                }
            } else {
                ParseTraitDecl {
                    cursor: header_result.cursor,
                    trait_item: None(),
                    diagnostic: Some(error(diagnostic_code("E1221"), header.span, "expected trait item")),
                }
            },
            None => ParseTraitDecl {
                cursor: header_result.cursor,
                trait_item: None(),
                diagnostic: Some(error(diagnostic_code("E1222"), current_token(skip_trivia(header_result.cursor)).span, "missing trait header")),
            },
        }
    }
}

fn impl_decl_result(
    cursor: ParserCursor,
    visibility: AstVisibility,
    start_span: SourceSpan,
    head_type: AstType,
    body_text: String,
    has_block: Bool,
    end_span: SourceSpan,
) -> ParseImplDecl {
    ParseImplDecl {
        cursor: cursor,
        impl_item: Some(impl_decl(visibility, head_type, body_text, has_block, merge(start_span, end_span))),
        diagnostic: None(),
    }
}

pub fn parse_impl_declaration(cursor: ParserCursor) -> ParseImplDecl {
    let visibility_result = parse_visibility(cursor);
    if has_visibility_diagnostic(visibility_result) {
        ParseImplDecl {
            cursor: visibility_result.cursor,
            impl_item: None(),
            diagnostic: visibility_result.diagnostic,
        }
    } else {
        let impl_keyword = expect_keyword(visibility_result.cursor, "impl", "E1230", "expected impl declaration");
        if has_diagnostic(impl_keyword) {
            ParseImplDecl {
                cursor: impl_keyword.cursor,
                impl_item: None(),
                diagnostic: impl_keyword.diagnostic,
            }
        } else {
            let head_result = parse_type_ref(impl_keyword.cursor, false);
            if has_type_ref_diagnostic(head_result) {
                ParseImplDecl {
                    cursor: head_result.cursor,
                    impl_item: None(),
                    diagnostic: head_result.diagnostic,
                }
            } else {
                match visibility_result.visibility {
                    Some(visibility) => match head_result.type_ref {
                        Some(head_type) => if at_delimiter(head_result.cursor, ";") {
                            let semi_result = expect_delimiter(head_result.cursor, ";", "E1231", "expected semicolon after impl declaration");
                            if has_diagnostic(semi_result) {
                                ParseImplDecl {
                                    cursor: semi_result.cursor,
                                    impl_item: None(),
                                    diagnostic: semi_result.diagnostic,
                                }
                            } else {
                                impl_decl_result(semi_result.cursor, visibility, merge(visibility_result.span, impl_keyword.token.span), head_type, "", false, semi_result.token.span)
                            }
                        } else if at_delimiter(head_result.cursor, "{") {
                            let open_result = expect_delimiter(head_result.cursor, "{", "E1232", "expected impl block opener");
                            let body_result = parse_raw_text_until_block_close(open_result.cursor, "E1233", "expected impl block body");
                            if has_raw_text_diagnostic(body_result) {
                                ParseImplDecl {
                                    cursor: body_result.cursor,
                                    impl_item: None(),
                                    diagnostic: body_result.diagnostic,
                                }
                            } else {
                                let close_result = expect_delimiter(body_result.cursor, "}", "E1234", "expected impl block closer");
                                if has_diagnostic(close_result) {
                                    ParseImplDecl {
                                        cursor: close_result.cursor,
                                        impl_item: None(),
                                        diagnostic: close_result.diagnostic,
                                    }
                                } else {
                                    impl_decl_result(close_result.cursor, visibility, merge(visibility_result.span, impl_keyword.token.span), head_type, body_result.text, true, close_result.token.span)
                                }
                            }
                        } else {
                            ParseImplDecl {
                                cursor: head_result.cursor,
                                impl_item: None(),
                                diagnostic: Some(error(diagnostic_code("E1235"), current_token(skip_trivia(head_result.cursor)).span, "expected semicolon or block after impl head")),
                            }
                        },
                        None => ParseImplDecl {
                            cursor: head_result.cursor,
                            impl_item: None(),
                            diagnostic: Some(error(diagnostic_code("E1236"), head_result.span, "missing impl head type")),
                        },
                    },
                    None => ParseImplDecl {
                        cursor: visibility_result.cursor,
                        impl_item: None(),
                        diagnostic: Some(error(diagnostic_code("E1237"), visibility_result.span, "missing impl visibility")),
                    },
                }
            }
        }
    }
}

pub fn remaining_token_count(cursor: ParserCursor) -> Int {
    let token_count = vec.vec_len(cursor.tokens);
    if cursor.index >= token_count {
        0
    } else {
        token_count - cursor.index
    }
}
