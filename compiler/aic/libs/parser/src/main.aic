pub fn expect_keyword(cursor: ParserCursor, lexeme: String, code: String, message: String) -> ParseExpectation {
    let active = skip_trivia(cursor);
    let token = current_token(active);
    if is_keyword(token, lexeme) {
        expectation_ok(advance(active), token)
    } else {
        expectation_error(active, token, code, message)
    }
}

pub fn expect_operator(cursor: ParserCursor, lexeme: String, code: String, message: String) -> ParseExpectation {
    let active = skip_trivia(cursor);
    let token = current_token(active);
    if is_operator(token, lexeme) {
        expectation_ok(advance(active), token)
    } else {
        expectation_error(active, token, code, message)
    }
}

pub fn expect_delimiter(cursor: ParserCursor, lexeme: String, code: String, message: String) -> ParseExpectation {
    let active = skip_trivia(cursor);
    let token = current_token(active);
    if is_delimiter(token, lexeme) {
        expectation_ok(advance(active), token)
    } else {
        expectation_error(active, token, code, message)
    }
}

pub fn expect_identifier(cursor: ParserCursor, code: String, message: String) -> ParseExpectation {
    let active = skip_trivia(cursor);
    let token = current_token(active);
    match token.kind {
        Identifier => expectation_ok(advance(active), token),
        _ => expectation_error(active, token, code, message),
    }
}

pub fn token_text(result: ParseExpectation) -> String {
    result.token.lexeme
}

pub fn parse_module_path(cursor: ParserCursor) -> ParseModulePath {
    let first = expect_identifier(cursor, "E1010", "expected module path segment");
    if has_diagnostic(first) {
        ParseModulePath {
            cursor: first.cursor,
            path: None(),
            diagnostic: first.diagnostic,
        }
    } else {
        let mut out_cursor = first.cursor;
        let mut segments: Vec[String] = vec.new_vec();
        let mut end_span = first.token.span;
        let mut diagnostic: Option[Diagnostic] = None();
        let mut done = false;
        segments = vec.push(segments, first.token.lexeme);

        while !done && at_delimiter(out_cursor, ".") {
            let dot = expect_delimiter(out_cursor, ".", "E1011", "expected module path separator");
            let next = expect_identifier(dot.cursor, "E1012", "expected module path segment after separator");
            if has_diagnostic(next) {
                out_cursor = next.cursor;
                diagnostic = next.diagnostic;
                done = true;
            } else {
                segments = vec.push(segments, next.token.lexeme);
                end_span = next.token.span;
                out_cursor = next.cursor;
            };
        };

        match diagnostic {
            Some(diag) => ParseModulePath {
                cursor: out_cursor,
                path: None(),
                diagnostic: Some(diag),
            },
            None => ParseModulePath {
                cursor: out_cursor,
                path: Some(module_path(string.join(segments, "."), merge(first.token.span, end_span))),
                diagnostic: None(),
            },
        }
    }
}

pub fn parse_module_declaration(cursor: ParserCursor) -> ParseModuleDecl {
    let module_keyword = expect_keyword(cursor, "module", "E1020", "expected module declaration");
    if has_diagnostic(module_keyword) {
        ParseModuleDecl {
            cursor: module_keyword.cursor,
            module_item: None(),
            diagnostic: module_keyword.diagnostic,
        }
    } else {
        let path_result = parse_module_path(module_keyword.cursor);
        if has_path_diagnostic(path_result) {
            ParseModuleDecl {
                cursor: path_result.cursor,
                module_item: None(),
                diagnostic: path_result.diagnostic,
            }
        } else {
            let semi = expect_delimiter(path_result.cursor, ";", "E1021", "expected semicolon after module declaration");
            if has_diagnostic(semi) {
                ParseModuleDecl {
                    cursor: semi.cursor,
                    module_item: None(),
                    diagnostic: semi.diagnostic,
                }
            } else {
                match path_result.path {
                    Some(path) => ParseModuleDecl {
                        cursor: semi.cursor,
                        module_item: Some(module_decl(path, merge(module_keyword.token.span, semi.token.span))),
                        diagnostic: None(),
                    },
                    None => ParseModuleDecl {
                        cursor: semi.cursor,
                        module_item: None(),
                        diagnostic: Some(error(diagnostic_code("E1022"), module_keyword.token.span, "missing module path")),
                    },
                }
            }
        }
    }
}

pub fn parse_import_declaration(cursor: ParserCursor) -> ParseImportDecl {
    let import_keyword = expect_keyword(cursor, "import", "E1030", "expected import declaration");
    if has_diagnostic(import_keyword) {
        ParseImportDecl {
            cursor: import_keyword.cursor,
            import_item: None(),
            diagnostic: import_keyword.diagnostic,
        }
    } else {
        let path_result = parse_module_path(import_keyword.cursor);
        if has_path_diagnostic(path_result) {
            ParseImportDecl {
                cursor: path_result.cursor,
                import_item: None(),
                diagnostic: path_result.diagnostic,
            }
        } else {
            let semi = expect_delimiter(path_result.cursor, ";", "E1031", "expected semicolon after import declaration");
            if has_diagnostic(semi) {
                ParseImportDecl {
                    cursor: semi.cursor,
                    import_item: None(),
                    diagnostic: semi.diagnostic,
                }
            } else {
                match path_result.path {
                    Some(path) => ParseImportDecl {
                        cursor: semi.cursor,
                        import_item: Some(import_decl(path, merge(import_keyword.token.span, semi.token.span))),
                        diagnostic: None(),
                    },
                    None => ParseImportDecl {
                        cursor: semi.cursor,
                        import_item: None(),
                        diagnostic: Some(error(diagnostic_code("E1032"), import_keyword.token.span, "missing import path")),
                    },
                }
            }
        }
    }
}

pub fn item_kind_from_keyword(lexeme: String) -> Option[AstItemKind] {
    if lexeme == "fn" {
        Some(FunctionItem())
    } else if lexeme == "struct" {
        Some(StructItem())
    } else if lexeme == "enum" {
        Some(EnumItem())
    } else if lexeme == "trait" {
        Some(TraitItem())
    } else if lexeme == "impl" {
        Some(ImplItem())
    } else if lexeme == "type" {
        Some(TypeAliasItem())
    } else if lexeme == "const" {
        Some(ConstItem())
    } else {
        None()
    }
}

pub fn parse_visibility(cursor: ParserCursor) -> ParseVisibility {
    let active = skip_trivia(cursor);
    let token = current_token(active);
    if is_keyword(token, "priv") {
        ParseVisibility {
            cursor: advance(active),
            visibility: Some(PrivateVisibility()),
            span: token.span,
            diagnostic: None(),
        }
    } else if is_keyword(token, "pub") {
        let pub_result = expect_keyword(active, "pub", "E1040", "expected visibility modifier");
        if at_delimiter(pub_result.cursor, "(") {
            let open_result = expect_delimiter(pub_result.cursor, "(", "E1041", "expected visibility scope opener");
            let crate_result = expect_identifier(open_result.cursor, "E1042", "expected crate visibility scope");
            if has_diagnostic(crate_result) || token_text(crate_result) != "crate" {
                ParseVisibility {
                    cursor: crate_result.cursor,
                    visibility: None(),
                    span: merge(pub_result.token.span, crate_result.token.span),
                    diagnostic: Some(error(diagnostic_code("E1042"), crate_result.token.span, "expected crate visibility scope")),
                }
            } else {
                let close_result = expect_delimiter(crate_result.cursor, ")", "E1043", "expected visibility scope closer");
                if has_diagnostic(close_result) {
                    ParseVisibility {
                        cursor: close_result.cursor,
                        visibility: None(),
                        span: merge(pub_result.token.span, close_result.token.span),
                        diagnostic: close_result.diagnostic,
                    }
                } else {
                    ParseVisibility {
                        cursor: close_result.cursor,
                        visibility: Some(PublicCrateVisibility()),
                        span: merge(pub_result.token.span, close_result.token.span),
                        diagnostic: None(),
                    }
                }
            }
        } else {
            ParseVisibility {
                cursor: pub_result.cursor,
                visibility: Some(PublicVisibility()),
                span: pub_result.token.span,
                diagnostic: None(),
            }
        }
    } else {
        ParseVisibility {
            cursor: active,
            visibility: Some(PrivateVisibility()),
            span: empty_span(active.source, token.span.start),
            diagnostic: None(),
        }
    }
}

fn skip_optional_extern_abi(cursor: ParserCursor) -> ParserCursor {
    let active = skip_trivia(cursor);
    let token = current_token(active);
    match token.kind {
        StringLiteral => advance(active),
        _ => cursor,
    }
}

fn skip_item_modifiers(cursor: ParserCursor) -> ParserCursor {
    let mut out = cursor;
    let mut done = false;
    while !done {
        if at_keyword(out, "async") || at_keyword(out, "intrinsic") || at_keyword(out, "unsafe") {
            out = advance(skip_trivia(out));
        } else if at_keyword(out, "extern") {
            out = advance(skip_trivia(out));
            out = skip_optional_extern_abi(out);
        } else {
            done = true;
        };
    };
    out
}

pub fn parse_item_kind(cursor: ParserCursor) -> ParseItemKind {
    let active = skip_trivia(cursor);
    let token = current_token(active);
    match token.kind {
        Keyword => match item_kind_from_keyword(token.lexeme) {
            Some(kind) => ParseItemKind {
                cursor: advance(active),
                kind: Some(kind),
                token: token,
                diagnostic: None(),
            },
            None => ParseItemKind {
                cursor: active,
                kind: None(),
                token: token,
                diagnostic: Some(error(diagnostic_code("E1050"), token.span, "expected item keyword")),
            },
        },
        _ => ParseItemKind {
            cursor: active,
            kind: None(),
            token: token,
            diagnostic: Some(error(diagnostic_code("E1050"), token.span, "expected item keyword")),
        },
    }
}

fn parse_item_header_after_visibility(cursor: ParserCursor, visibility: AstVisibility, start_span: SourceSpan) -> ParseItemHeader {
    let kind_result = parse_item_kind(skip_item_modifiers(cursor));
    if has_item_kind_diagnostic(kind_result) {
        ParseItemHeader {
            cursor: kind_result.cursor,
            header: None(),
            diagnostic: kind_result.diagnostic,
        }
    } else if at_delimiter(kind_result.cursor, "[") {
        match kind_result.kind {
            Some(kind) => match kind {
                ImplItem => ParseItemHeader {
                    cursor: kind_result.cursor,
                    header: Some(item_header(kind, visibility, ast_name("impl", kind_result.token.span), merge(start_span, kind_result.token.span))),
                    diagnostic: None(),
                },
                _ => ParseItemHeader {
                    cursor: kind_result.cursor,
                    header: None(),
                    diagnostic: Some(error(diagnostic_code("E1051"), current_token(skip_trivia(kind_result.cursor)).span, "expected item name")),
                },
            },
            None => ParseItemHeader {
                cursor: kind_result.cursor,
                header: None(),
                diagnostic: Some(error(diagnostic_code("E1052"), kind_result.token.span, "missing item kind")),
            },
        }
    } else {
        let name_result = expect_identifier(kind_result.cursor, "E1051", "expected item name");
        if has_diagnostic(name_result) {
            ParseItemHeader {
                cursor: name_result.cursor,
                header: None(),
                diagnostic: name_result.diagnostic,
            }
        } else {
            match kind_result.kind {
                Some(kind) => ParseItemHeader {
                    cursor: name_result.cursor,
                    header: Some(item_header(
                        kind,
                        visibility,
                        ast_name(name_result.token.lexeme, name_result.token.span),
                        merge(start_span, name_result.token.span),
                    )),
                    diagnostic: None(),
                },
                None => ParseItemHeader {
                    cursor: name_result.cursor,
                    header: None(),
                    diagnostic: Some(error(diagnostic_code("E1052"), kind_result.token.span, "missing item kind")),
                },
            }
        }
    }
}

pub fn parse_item_header(cursor: ParserCursor) -> ParseItemHeader {
    let visibility_result = parse_visibility(cursor);
    if has_visibility_diagnostic(visibility_result) {
        ParseItemHeader {
            cursor: visibility_result.cursor,
            header: None(),
            diagnostic: visibility_result.diagnostic,
        }
    } else {
        match visibility_result.visibility {
            Some(visibility) => parse_item_header_after_visibility(visibility_result.cursor, visibility, visibility_result.span),
            None => ParseItemHeader {
                cursor: visibility_result.cursor,
                header: None(),
                diagnostic: Some(error(diagnostic_code("E1053"), visibility_result.span, "missing visibility")),
            },
        }
    }
}

fn is_function_item_kind(value: AstItemKind) -> Bool {
    match value {
        FunctionItem => true,
        StructItem => false,
        EnumItem => false,
        TraitItem => false,
        ImplItem => false,
        TypeAliasItem => false,
        ConstItem => false,
    }
}

fn is_struct_item_kind(value: AstItemKind) -> Bool {
    match value {
        StructItem => true,
        FunctionItem => false,
        EnumItem => false,
        TraitItem => false,
        ImplItem => false,
        TypeAliasItem => false,
        ConstItem => false,
    }
}

fn is_enum_item_kind(value: AstItemKind) -> Bool {
    match value {
        EnumItem => true,
        FunctionItem => false,
        StructItem => false,
        TraitItem => false,
        ImplItem => false,
        TypeAliasItem => false,
        ConstItem => false,
    }
}

fn is_type_alias_item_kind(value: AstItemKind) -> Bool {
    match value {
        TypeAliasItem => true,
        FunctionItem => false,
        StructItem => false,
        EnumItem => false,
        TraitItem => false,
        ImplItem => false,
        ConstItem => false,
    }
}

fn is_const_item_kind(value: AstItemKind) -> Bool {
    match value {
        ConstItem => true,
        FunctionItem => false,
        StructItem => false,
        EnumItem => false,
        TraitItem => false,
        ImplItem => false,
        TypeAliasItem => false,
    }
}

fn is_trait_item_kind(value: AstItemKind) -> Bool {
    match value {
        TraitItem => true,
        FunctionItem => false,
        StructItem => false,
        EnumItem => false,
        ImplItem => false,
        TypeAliasItem => false,
        ConstItem => false,
    }
}

fn is_impl_item_kind(value: AstItemKind) -> Bool {
    match value {
        ImplItem => true,
        FunctionItem => false,
        StructItem => false,
        EnumItem => false,
        TraitItem => false,
        TypeAliasItem => false,
        ConstItem => false,
    }
}

fn is_private_visibility_kind(value: AstVisibility) -> Bool {
    match value {
        PrivateVisibility => true,
        PublicVisibility => false,
        PublicCrateVisibility => false,
    }
}

fn type_ref_ok(cursor: ParserCursor, value: AstType) -> ParseTypeRef {
    ParseTypeRef {
        cursor: cursor,
        type_ref: Some(value),
        span: value.span,
        diagnostic: None(),
    }
}

fn type_ref_error(cursor: ParserCursor, span: SourceSpan, code: String, message: String) -> ParseTypeRef {
    ParseTypeRef {
        cursor: cursor,
        type_ref: None(),
        span: span,
        diagnostic: Some(error(diagnostic_code(code), span, message)),
    }
}

fn type_args_error(cursor: ParserCursor, span: SourceSpan, code: String, message: String) -> ParseTypeArgs {
    ParseTypeArgs {
        cursor: cursor,
        args: vec.new_vec(),
        span: span,
        diagnostic: Some(error(diagnostic_code(code), span, message)),
    }
}

fn is_type_name_token(token: Token) -> Bool {
    match token.kind {
        Identifier => true,
        Keyword => token.lexeme == "Self",
        _ => false,
    }
}

fn is_type_ref_stop_start(token: Token, stop_at_comma: Bool) -> Bool {
    match token.kind {
        EndOfFile => true,
        Keyword => token.lexeme == "effects" || token.lexeme == "capabilities" || token.lexeme == "requires" || token.lexeme == "ensures" || token.lexeme == "where",
        Operator => token.lexeme == "=",
        Delimiter => token.lexeme == ";" || token.lexeme == "{" || token.lexeme == "}" || token.lexeme == ")" || token.lexeme == "]" || (stop_at_comma && token.lexeme == ","),
        _ => false,
    }
}

fn expect_type_name(cursor: ParserCursor, code: String, message: String) -> ParseTypeName {
    let active = skip_trivia(cursor);
    let token = current_token(active);
    if is_type_name_token(token) {
        ParseTypeName {
            cursor: advance(active),
            name: Some(ast_name(token.lexeme, token.span)),
            diagnostic: None(),
        }
    } else {
        ParseTypeName {
            cursor: active,
            name: None(),
            diagnostic: Some(error(diagnostic_code(code), token.span, message)),
        }
    }
}

fn parse_type_name_path(cursor: ParserCursor, code: String, message: String) -> ParseTypeName {
    let first = expect_type_name(cursor, code, message);
    if has_type_name_diagnostic(first) {
        first
    } else {
        match first.name {
            Some(first_name) => if true {
                let mut out_cursor = first.cursor;
                let mut segments: Vec[String] = vec.new_vec();
                let mut end_span = first_name.span;
                let mut diagnostic: Option[Diagnostic] = None();
                let mut done = false;
                segments = vec.push(segments, first_name.value);
                while !done && at_delimiter(out_cursor, "::") {
                    let separator = expect_delimiter(out_cursor, "::", code, message);
                    let next = expect_type_name(separator.cursor, code, message);
                    if has_type_name_diagnostic(next) {
                        out_cursor = next.cursor;
                        diagnostic = next.diagnostic;
                        done = true;
                    } else {
                        match next.name {
                            Some(next_name) => if true {
                                segments = vec.push(segments, next_name.value);
                                end_span = next_name.span;
                                out_cursor = next.cursor;
                                ()
                            } else {
                                ()
                            },
                            None => if true {
                                out_cursor = next.cursor;
                                diagnostic = Some(error(diagnostic_code(code), separator.token.span, message));
                                done = true;
                                ()
                            } else {
                                ()
                            },
                        }
                    };
                };
                match diagnostic {
                    Some(diag) => ParseTypeName {
                        cursor: out_cursor,
                        name: None(),
                        diagnostic: Some(diag),
                    },
                    None => ParseTypeName {
                        cursor: out_cursor,
                        name: Some(ast_name(string.join(segments, "::"), merge(first_name.span, end_span))),
                        diagnostic: None(),
                    },
                }
            } else {
                first
            },
            None => first,
        }
    }
}

fn parse_type_arg_list_after_open(cursor: ParserCursor, open_span: SourceSpan, close_code: String, close_message: String) -> ParseTypeArgs {
    let open_source = open_span.source.value;
    let open_start = open_span.start;
    let open_end = open_span.end;
    let mut out_cursor = cursor;
    let mut args: Vec[AstType] = vec.new_vec();
    let mut end_span = span(source_id(open_source), open_start, open_end);
    let mut diagnostic: Option[Diagnostic] = None();
    let mut done = false;
    if at_delimiter(out_cursor, "]") {
        ParseTypeArgs {
            cursor: out_cursor,
            args: args,
            span: span(source_id(open_source), open_start, open_end),
            diagnostic: Some(error(diagnostic_code("E1063"), current_token(skip_trivia(out_cursor)).span, "expected type reference")),
        }
    } else {
        while !done {
            let arg_result = parse_type_ref(out_cursor, true);
            if has_type_ref_diagnostic(arg_result) {
                out_cursor = arg_result.cursor;
                diagnostic = arg_result.diagnostic;
                end_span = arg_result.span;
                done = true;
            } else {
                match arg_result.type_ref {
                    Some(arg) => if true {
                        args = vec.push(args, arg);
                        end_span = arg.span;
                        out_cursor = arg_result.cursor;
                        ()
                    } else {
                        ()
                    },
                    None => if true {
                        diagnostic = Some(error(diagnostic_code("E1063"), arg_result.span, "expected type reference"));
                        done = true;
                        ()
                    } else {
                        ()
                    },
                };
                if !done {
                    if at_delimiter(out_cursor, ",") {
                        let comma = expect_delimiter(out_cursor, ",", "E1068", "expected type argument separator");
                        out_cursor = comma.cursor;
                    } else {
                        let close_result = expect_delimiter(out_cursor, "]", close_code, close_message);
                        out_cursor = close_result.cursor;
                        end_span = close_result.token.span;
                        diagnostic = close_result.diagnostic;
                        done = true;
                    }
                } else {
                    ()
                };
            };
        };

        match diagnostic {
            Some(diag) => ParseTypeArgs {
                cursor: out_cursor,
                args: vec.new_vec(),
                span: merge(span(source_id(open_source), open_start, open_end), end_span),
                diagnostic: Some(diag),
            },
            None => ParseTypeArgs {
                cursor: out_cursor,
                args: args,
                span: merge(span(source_id(open_source), open_start, open_end), end_span),
                diagnostic: None(),
            },
        }
    }
}

fn parse_generic_type_args(cursor: ParserCursor) -> ParseTypeArgs {
    let open_result = expect_delimiter(cursor, "[", "E1066", "expected type argument list opener");
    if has_diagnostic(open_result) {
        type_args_error(open_result.cursor, open_result.token.span, "E1066", "expected type argument list opener")
    } else {
        parse_type_arg_list_after_open(open_result.cursor, open_result.token.span, "E1067", "expected ']' after type arguments")
    }
}

fn parse_fn_type_args(cursor: ParserCursor, open_span: SourceSpan) -> ParseTypeArgs {
    let open_source = open_span.source.value;
    let open_start = open_span.start;
    let open_end = open_span.end;
    let mut out_cursor = cursor;
    let mut args: Vec[AstType] = vec.new_vec();
    let mut end_span = span(source_id(open_source), open_start, open_end);
    let mut diagnostic: Option[Diagnostic] = None();
    let mut done = false;
    if at_delimiter(out_cursor, ")") {
        let close = expect_delimiter(out_cursor, ")", "E1069", "expected ')' after Fn type parameters");
        out_cursor = close.cursor;
        end_span = close.token.span;
        diagnostic = close.diagnostic;
        done = true;
    } else {
        ()
    };

    while !done {
        let arg_result = parse_type_ref(out_cursor, true);
        if has_type_ref_diagnostic(arg_result) {
            out_cursor = arg_result.cursor;
            diagnostic = arg_result.diagnostic;
            end_span = arg_result.span;
            done = true;
        } else {
            match arg_result.type_ref {
                Some(arg) => if true {
                    args = vec.push(args, arg);
                    end_span = arg.span;
                    out_cursor = arg_result.cursor;
                    ()
                } else {
                    ()
                },
                None => if true {
                    diagnostic = Some(error(diagnostic_code("E1063"), arg_result.span, "expected type reference"));
                    done = true;
                    ()
                } else {
                    ()
                },
            };
            if !done {
                if at_delimiter(out_cursor, ",") {
                    let comma = expect_delimiter(out_cursor, ",", "E1068", "expected Fn type parameter separator");
                    out_cursor = comma.cursor;
                } else {
                    let close = expect_delimiter(out_cursor, ")", "E1069", "expected ')' after Fn type parameters");
                    out_cursor = close.cursor;
                    end_span = close.token.span;
                    diagnostic = close.diagnostic;
                    done = true;
                }
            } else {
                ()
            };
        };
    };

    match diagnostic {
        Some(diag) => ParseTypeArgs {
            cursor: out_cursor,
            args: vec.new_vec(),
            span: merge(span(source_id(open_source), open_start, open_end), end_span),
            diagnostic: Some(diag),
        },
        None => ParseTypeArgs {
            cursor: out_cursor,
            args: args,
            span: merge(span(source_id(open_source), open_start, open_end), end_span),
            diagnostic: None(),
        },
    }
}

fn parse_tuple_or_parenthesized_type(cursor: ParserCursor) -> ParseTypeRef {
    let open_result = expect_delimiter(cursor, "(", "E1064", "expected type tuple opener");
    if has_diagnostic(open_result) {
        type_ref_error(open_result.cursor, open_result.token.span, "E1064", "expected type tuple opener")
    } else if at_delimiter(open_result.cursor, ")") {
        let close_result = expect_delimiter(open_result.cursor, ")", "E1065", "expected ')' after unit type");
        if has_diagnostic(close_result) {
            type_ref_error(close_result.cursor, close_result.token.span, "E1065", "expected ')' after unit type")
        } else {
            type_ref_ok(close_result.cursor, unit_type(merge(open_result.token.span, close_result.token.span)))
        }
    } else {
        let first_result = parse_type_ref(open_result.cursor, true);
        if has_type_ref_diagnostic(first_result) {
            first_result
        } else {
            match first_result.type_ref {
                Some(first_type) => if at_delimiter(first_result.cursor, ",") {
                    let mut out_cursor = first_result.cursor;
                    let mut args: Vec[AstType] = vec.new_vec();
                    let mut end_span = first_type.span;
                    let mut diagnostic: Option[Diagnostic] = None();
                    let mut done = false;
                    args = vec.push(args, first_type);
                    while !done {
                        let comma = expect_delimiter(out_cursor, ",", "E1068", "expected tuple type separator");
                        out_cursor = comma.cursor;
                        let item_result = parse_type_ref(out_cursor, true);
                        if has_type_ref_diagnostic(item_result) {
                            out_cursor = item_result.cursor;
                            diagnostic = item_result.diagnostic;
                            end_span = item_result.span;
                            done = true;
                        } else {
                            match item_result.type_ref {
                                Some(item) => if true {
                                    args = vec.push(args, item);
                                    end_span = item.span;
                                    out_cursor = item_result.cursor;
                                    ()
                                } else {
                                    ()
                                },
                                None => if true {
                                    diagnostic = Some(error(diagnostic_code("E1063"), item_result.span, "expected tuple type item"));
                                    done = true;
                                    ()
                                } else {
                                    ()
                                },
                            };
                            if !done {
                                if at_delimiter(out_cursor, ",") {
                                    ()
                                } else {
                                    let close_result = expect_delimiter(out_cursor, ")", "E1065", "expected ')' after tuple type");
                                    out_cursor = close_result.cursor;
                                    end_span = close_result.token.span;
                                    diagnostic = close_result.diagnostic;
                                    done = true;
                                }
                            } else {
                                ()
                            };
                        };
                    };
                    match diagnostic {
                        Some(diag) => ParseTypeRef {
                            cursor: out_cursor,
                            type_ref: None(),
                            span: merge(open_result.token.span, end_span),
                            diagnostic: Some(diag),
                        },
                        None => type_ref_ok(out_cursor, named_type("Tuple", args, merge(open_result.token.span, end_span))),
                    }
                } else {
                    let close_result = expect_delimiter(first_result.cursor, ")", "E1065", "expected ')' after parenthesized type");
                    if has_diagnostic(close_result) {
                        type_ref_error(close_result.cursor, close_result.token.span, "E1065", "expected ')' after parenthesized type")
                    } else {
                        type_ref_ok(close_result.cursor, type_with_span(first_type, merge(open_result.token.span, close_result.token.span)))
                    }
                },
                None => type_ref_error(first_result.cursor, first_result.span, "E1063", "expected type reference"),
            }
        }
    }
}

fn parse_dyn_trait_type(cursor: ParserCursor) -> ParseTypeRef {
    let active = skip_trivia(cursor);
    let dyn_token = current_token(active);
    let name_result = parse_type_name_path(advance(active), "E1027", "expected trait name after dyn");
    if has_type_name_diagnostic(name_result) {
        ParseTypeRef {
            cursor: name_result.cursor,
            type_ref: None(),
            span: dyn_token.span,
            diagnostic: name_result.diagnostic,
        }
    } else {
        match name_result.name {
            Some(name) => type_ref_ok(name_result.cursor, dyn_trait_type(name.value, merge(dyn_token.span, name.span))),
            None => type_ref_error(name_result.cursor, dyn_token.span, "E1027", "expected trait name after dyn"),
        }
    }
}

fn parse_named_or_fn_type(cursor: ParserCursor) -> ParseTypeRef {
    let name_result = parse_type_name_path(cursor, "E1063", "expected type reference");
    if has_type_name_diagnostic(name_result) {
        ParseTypeRef {
            cursor: name_result.cursor,
            type_ref: None(),
            span: current_token(skip_trivia(cursor)).span,
            diagnostic: name_result.diagnostic,
        }
    } else {
        match name_result.name {
            Some(name) => if name.value == "Fn" && at_delimiter(name_result.cursor, "(") {
                let open_result = expect_delimiter(name_result.cursor, "(", "E1066", "expected Fn type parameter list opener");
                if has_diagnostic(open_result) {
                    type_ref_error(open_result.cursor, open_result.token.span, "E1066", "expected Fn type parameter list opener")
                } else {
                    let args_result = parse_fn_type_args(open_result.cursor, open_result.token.span);
                    if has_type_args_diagnostic(args_result) {
                        ParseTypeRef {
                            cursor: args_result.cursor,
                            type_ref: None(),
                            span: merge(name.span, args_result.span),
                            diagnostic: args_result.diagnostic,
                        }
                    } else {
                        let arrow_result = expect_operator(args_result.cursor, "->", "E1070", "expected '->' in Fn type");
                        if has_diagnostic(arrow_result) {
                            type_ref_error(arrow_result.cursor, arrow_result.token.span, "E1070", "expected '->' in Fn type")
                        } else {
                            let ret_result = parse_type_ref(arrow_result.cursor, false);
                            if has_type_ref_diagnostic(ret_result) {
                                ret_result
                            } else {
                                match ret_result.type_ref {
                                    Some(return_type) => if true {
                                        let mut args = args_result.args;
                                        args = vec.push(args, return_type);
                                        type_ref_ok(ret_result.cursor, named_type("Fn", args, merge(name.span, return_type.span)))
                                    } else {
                                        ret_result
                                    },
                                    None => type_ref_error(ret_result.cursor, ret_result.span, "E1063", "expected Fn return type"),
                                }
                            }
                        }
                    }
                }
            } else if at_delimiter(name_result.cursor, "[") {
                let args_result = parse_generic_type_args(name_result.cursor);
                if has_type_args_diagnostic(args_result) {
                    ParseTypeRef {
                        cursor: args_result.cursor,
                        type_ref: None(),
                        span: merge(name.span, args_result.span),
                        diagnostic: args_result.diagnostic,
                    }
                } else {
                    type_ref_ok(args_result.cursor, named_type(name.value, args_result.args, merge(name.span, args_result.span)))
                }
            } else {
                type_ref_ok(name_result.cursor, named_type(name.value, vec.new_vec(), name.span))
            },
            None => type_ref_error(name_result.cursor, current_token(skip_trivia(cursor)).span, "E1063", "expected type reference"),
        }
    }
}

pub fn parse_type_ref(cursor: ParserCursor, stop_at_comma: Bool) -> ParseTypeRef {
    let active = skip_trivia(cursor);
    let token = current_token(active);
    if is_type_ref_stop_start(token, stop_at_comma) || is_terminal(token) {
        type_ref_error(active, token.span, "E1063", "expected type reference")
    } else if is_delimiter(token, "_") {
        type_ref_ok(advance(active), hole_type(token.span))
    } else if is_delimiter(token, "(") {
        parse_tuple_or_parenthesized_type(active)
    } else if (token.lexeme == "dyn" && is_type_name_token(token)) {
        parse_dyn_trait_type(active)
    } else if is_type_name_token(token) {
        parse_named_or_fn_type(active)
    } else {
        type_ref_error(active, token.span, "E1060", "invalid token in type reference")
    }
}

pub fn parse_param(cursor: ParserCursor) -> ParseParam {
    let start_token = current_token(skip_trivia(cursor));
    let attrs_result = parse_attribute_list(cursor);
    if has_attribute_list_diagnostic(attrs_result) {
        ParseParam {
            cursor: attrs_result.cursor,
            param: None(),
            diagnostic: attrs_result.diagnostic,
        }
    } else {
    let name_result = expect_identifier(attrs_result.cursor, "E1070", "expected parameter name");
    if has_diagnostic(name_result) {
        ParseParam {
            cursor: name_result.cursor,
            param: None(),
            diagnostic: name_result.diagnostic,
        }
    } else {
        let colon_result = expect_delimiter(name_result.cursor, ":", "E1071", "expected ':' after parameter name");
        if has_diagnostic(colon_result) {
            ParseParam {
                cursor: colon_result.cursor,
                param: None(),
                diagnostic: colon_result.diagnostic,
            }
        } else {
            let type_result = parse_type_ref(colon_result.cursor, true);
            if has_type_ref_diagnostic(type_result) {
                ParseParam {
                    cursor: type_result.cursor,
                    param: None(),
                    diagnostic: type_result.diagnostic,
                }
            } else {
                match type_result.type_ref {
                    Some(type_ref) => ParseParam {
                        cursor: type_result.cursor,
                        param: Some(ast_param_with_attrs(attrs_result.attrs, ast_name(name_result.token.lexeme, name_result.token.span), type_ref, merge(start_token.span, type_result.span))),
                        diagnostic: None(),
                    },
                    None => ParseParam {
                        cursor: type_result.cursor,
                        param: None(),
                        diagnostic: Some(error(diagnostic_code("E1072"), type_result.span, "missing parameter type")),
                    },
                }
            }
        }
    }
    }
}

pub fn parse_param_list(cursor: ParserCursor) -> ParseParamList {
    let open_result = expect_delimiter(cursor, "(", "E1080", "expected parameter list opener");
    if has_diagnostic(open_result) {
        ParseParamList {
            cursor: open_result.cursor,
            params: vec.new_vec(),
            diagnostic: open_result.diagnostic,
        }
    } else {
        let mut out_cursor = open_result.cursor;
        let mut params: Vec[AstParam] = vec.new_vec();
        let mut diagnostic: Option[Diagnostic] = None();
        let mut done = false;
        if at_delimiter(out_cursor, ")") {
            let close_result = expect_delimiter(out_cursor, ")", "E1081", "expected parameter list closer");
            out_cursor = close_result.cursor;
            diagnostic = close_result.diagnostic;
            done = true;
        } else {
            ()
        };

        while !done {
            let param_result = parse_param(out_cursor);
            if has_param_diagnostic(param_result) {
                out_cursor = param_result.cursor;
                diagnostic = param_result.diagnostic;
                done = true;
            } else {
                let param_count_before = vec.vec_len(params);
                params = match param_result.param {
                    Some(param) => vec.push(params, param),
                    None => params,
                };
                out_cursor = param_result.cursor;
                if vec.vec_len(params) == param_count_before {
                    diagnostic = Some(error(diagnostic_code("E1082"), current_token(skip_trivia(param_result.cursor)).span, "missing parameter"));
                    done = true;
                } else if has_param_diagnostic(param_result) {
                    done = true;
                } else if at_delimiter(out_cursor, ",") {
                    let comma_result = expect_delimiter(out_cursor, ",", "E1083", "expected parameter separator");
                    out_cursor = comma_result.cursor;
                    if at_delimiter(out_cursor, ")") {
                        let close_result = expect_delimiter(out_cursor, ")", "E1081", "expected parameter list closer");
                        out_cursor = close_result.cursor;
                        diagnostic = close_result.diagnostic;
                        done = true;
                    } else {
                        ()
                    };
                } else {
                    let close_result = expect_delimiter(out_cursor, ")", "E1081", "expected parameter list closer");
                    out_cursor = close_result.cursor;
                    diagnostic = close_result.diagnostic;
                    done = true;
                };
            };
        };

        ParseParamList {
            cursor: out_cursor,
            params: params,
            diagnostic: diagnostic,
        }
    }
}

fn parse_required_name_list(cursor: ParserCursor, keyword: String, open_code: String, name_code: String, close_code: String) -> ParseNameList {
    let keyword_result = expect_keyword(cursor, keyword, open_code, "expected name list keyword");
    if has_diagnostic(keyword_result) {
        ParseNameList {
            cursor: keyword_result.cursor,
            names: "",
            span: keyword_result.token.span,
            diagnostic: keyword_result.diagnostic,
        }
    } else {
        let open_result = expect_delimiter(keyword_result.cursor, "{", open_code, "expected name list opener");
        if has_diagnostic(open_result) {
            ParseNameList {
                cursor: open_result.cursor,
                names: "",
                span: merge(keyword_result.token.span, open_result.token.span),
                diagnostic: open_result.diagnostic,
            }
        } else {
            let mut out_cursor = open_result.cursor;
            let mut names: Vec[String] = vec.new_vec();
            let mut end_span = open_result.token.span;
            let mut diagnostic: Option[Diagnostic] = None();
            let mut done = false;
            if at_delimiter(out_cursor, "}") {
                let close_result = expect_delimiter(out_cursor, "}", close_code, "expected name list closer");
                end_span = close_result.token.span;
                out_cursor = close_result.cursor;
                diagnostic = close_result.diagnostic;
                done = true;
            } else {
                ()
            };
            while !done {
                let name_result = expect_identifier(out_cursor, name_code, "expected name in list");
                if has_diagnostic(name_result) {
                    out_cursor = name_result.cursor;
                    diagnostic = name_result.diagnostic;
                    end_span = name_result.token.span;
                    done = true;
                } else {
                    names = vec.push(names, name_result.token.lexeme);
                    end_span = name_result.token.span;
                    out_cursor = name_result.cursor;
                    if at_delimiter(out_cursor, ",") {
                        let comma_result = expect_delimiter(out_cursor, ",", name_code, "expected name separator");
                        out_cursor = comma_result.cursor;
                        if at_delimiter(out_cursor, "}") {
                            let close_result = expect_delimiter(out_cursor, "}", close_code, "expected name list closer");
                            end_span = close_result.token.span;
                            out_cursor = close_result.cursor;
                            diagnostic = close_result.diagnostic;
                            done = true;
                        } else {
                            ()
                        };
                    } else {
                        let close_result = expect_delimiter(out_cursor, "}", close_code, "expected name list closer");
                        end_span = close_result.token.span;
                        out_cursor = close_result.cursor;
                        diagnostic = close_result.diagnostic;
                        done = true;
                    };
                };
            };

            ParseNameList {
                cursor: out_cursor,
                names: string.join(names, ","),
                span: merge(keyword_result.token.span, end_span),
                diagnostic: diagnostic,
            }
        }
    }
}

pub fn parse_optional_name_list(cursor: ParserCursor, keyword: String) -> ParseNameList {
    let active = skip_trivia(cursor);
    let token = current_token(active);
    if is_keyword(token, keyword) {
        parse_required_name_list(active, keyword, "E1090", "E1091", "E1092")
    } else {
        ParseNameList {
            cursor: active,
            names: "",
            span: empty_span(active.source, token.span.start),
            diagnostic: None(),
        }
    }
}

fn function_signature_result(
    cursor: ParserCursor,
    header: AstItemHeader,
    generic_params: AstGenericParamList,
    params: Vec[AstParam],
    return_type: AstType,
    return_span: SourceSpan,
    effect_names: String,
    effect_span: SourceSpan,
    capability_names: String,
    capability_span: SourceSpan,
) -> ParseFunctionSignature {
    let mut signature_span = merge(header.span, return_span);
    if effect_span.start != effect_span.end {
        signature_span = merge(signature_span, effect_span);
    } else {
        ()
    };
    if capability_span.start != capability_span.end {
        signature_span = merge(signature_span, capability_span);
    } else {
        ()
    };
    ParseFunctionSignature {
        cursor: cursor,
        signature: Some(function_signature(header.name, generic_params, params, return_type, effect_names, capability_names, signature_span)),
        diagnostic: None(),
    }
}

pub fn parse_function_signature(cursor: ParserCursor) -> ParseFunctionSignature {
    let header_result = parse_item_header(cursor);
    if has_item_header_diagnostic(header_result) {
        ParseFunctionSignature {
            cursor: header_result.cursor,
            signature: None(),
            diagnostic: header_result.diagnostic,
        }
    } else {
        match header_result.header {
            Some(header) => if is_function_item_kind(header.kind) {
                let generic_result = parse_optional_generic_params(header_result.cursor);
                if has_generic_params_diagnostic(generic_result) {
                    ParseFunctionSignature {
                        cursor: generic_result.cursor,
                        signature: None(),
                        diagnostic: generic_result.diagnostic,
                    }
                } else {
                    let params_result = parse_param_list(generic_result.cursor);
                    if has_param_list_diagnostic(params_result) {
                        ParseFunctionSignature {
                            cursor: params_result.cursor,
                            signature: None(),
                            diagnostic: params_result.diagnostic,
                        }
                    } else {
                        let arrow_result = expect_operator(params_result.cursor, "->", "E1100", "expected return type arrow");
                        if has_diagnostic(arrow_result) {
                            ParseFunctionSignature {
                                cursor: arrow_result.cursor,
                                signature: None(),
                                diagnostic: arrow_result.diagnostic,
                            }
                        } else {
                            let return_result = parse_type_ref(arrow_result.cursor, false);
                            if has_type_ref_diagnostic(return_result) {
                                ParseFunctionSignature {
                                    cursor: return_result.cursor,
                                    signature: None(),
                                    diagnostic: return_result.diagnostic,
                                }
                            } else {
                                let where_result = parse_optional_where_clause(return_result.cursor, generic_result.params);
                                if has_generic_params_diagnostic(where_result) {
                                    ParseFunctionSignature {
                                        cursor: where_result.cursor,
                                        signature: None(),
                                        diagnostic: where_result.diagnostic,
                                    }
                                } else {
                                    let effects_result = parse_optional_name_list(where_result.cursor, "effects");
                                    if has_name_list_diagnostic(effects_result) {
                                        ParseFunctionSignature {
                                            cursor: effects_result.cursor,
                                            signature: None(),
                                            diagnostic: effects_result.diagnostic,
                                        }
                                    } else {
                                        let capabilities_result = parse_optional_name_list(effects_result.cursor, "capabilities");
                                        if has_name_list_diagnostic(capabilities_result) {
                                            ParseFunctionSignature {
                                                cursor: capabilities_result.cursor,
                                                signature: None(),
                                                diagnostic: capabilities_result.diagnostic,
                                            }
                                        } else {
                                            match return_result.type_ref {
                                                Some(return_type) => function_signature_result(
                                                    capabilities_result.cursor,
                                                    header,
                                                    where_result.params,
                                                    params_result.params,
                                                    return_type,
                                                    return_result.span,
                                                    effects_result.names,
                                                    effects_result.span,
                                                    capabilities_result.names,
                                                    capabilities_result.span,
                                                ),
                                                None => ParseFunctionSignature {
                                                    cursor: return_result.cursor,
                                                    signature: None(),
                                                    diagnostic: Some(error(diagnostic_code("E1101"), return_result.span, "missing return type")),
                                                },
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            } else {
                ParseFunctionSignature {
                    cursor: header_result.cursor,
                    signature: None(),
                    diagnostic: Some(error(diagnostic_code("E1102"), header.span, "expected function item")),
                }
            },
            None => ParseFunctionSignature {
                cursor: header_result.cursor,
                signature: None(),
                diagnostic: Some(error(diagnostic_code("E1103"), current_token(skip_trivia(header_result.cursor)).span, "missing function header")),
            },
        }
    }
}

fn parse_generic_bound_list(cursor: ParserCursor, code: String, message: String) -> ParseGenericBounds {
    let start_cursor = skip_trivia(cursor);
    let start_token = current_token(start_cursor);
    let mut out_cursor = start_cursor;
    let mut bounds: Vec[AstName] = vec.new_vec();
    let mut end_span = start_token.span;
    let mut diagnostic: Option[Diagnostic] = None();
    let mut done = false;
    while !done {
        let bound_result = parse_type_name_path(out_cursor, code, message);
        if has_type_name_diagnostic(bound_result) {
            out_cursor = bound_result.cursor;
            diagnostic = bound_result.diagnostic;
            done = true;
        } else {
            match bound_result.name {
                Some(bound) => if true {
                    bounds = vec.push(bounds, bound);
                    end_span = bound.span;
                    out_cursor = bound_result.cursor;
                    ()
                } else {
                    ()
                },
                None => if true {
                    diagnostic = Some(error(diagnostic_code(code), current_token(skip_trivia(out_cursor)).span, message));
                    done = true;
                    ()
                } else {
                    ()
                },
            };
            if !done {
                if at_operator(out_cursor, "+") {
                    let plus = expect_operator(out_cursor, "+", code, "expected trait-bound separator");
                    out_cursor = plus.cursor;
                } else {
                    done = true;
                }
            } else {
                ()
            };
        };
    };
    match diagnostic {
        Some(diag) => ParseGenericBounds {
            cursor: out_cursor,
            bounds: vec.new_vec(),
            span: merge(start_token.span, end_span),
            diagnostic: Some(diag),
        },
        None => ParseGenericBounds {
            cursor: out_cursor,
            bounds: bounds,
            span: merge(start_token.span, end_span),
            diagnostic: None(),
        },
    }
}

pub fn parse_optional_generic_params(cursor: ParserCursor) -> ParseGenericParams {
    let active = skip_trivia(cursor);
    let token = current_token(active);
    if at_delimiter(active, "[") {
        let open_result = expect_delimiter(active, "[", "E1110", "expected generic parameter list opener");
        let mut out_cursor = open_result.cursor;
        let mut params: Vec[AstGenericParam] = vec.new_vec();
        let mut end_span = open_result.token.span;
        let mut diagnostic: Option[Diagnostic] = None();
        let mut done = false;

        if at_delimiter(out_cursor, "]") {
            let close_token = current_token(skip_trivia(out_cursor));
            ParseGenericParams {
                cursor: out_cursor,
                params: empty_generic_params(merge(open_result.token.span, close_token.span)),
                span: merge(open_result.token.span, close_token.span),
                diagnostic: Some(error(diagnostic_code("E1113"), close_token.span, "expected generic parameter")),
            }
        } else {
            while !done {
                let name_result = expect_identifier(out_cursor, "E1113", "expected generic parameter");
                if has_diagnostic(name_result) {
                    out_cursor = name_result.cursor;
                    diagnostic = name_result.diagnostic;
                    end_span = name_result.token.span;
                    done = true;
                } else {
                    let param_name = ast_name(name_result.token.lexeme, name_result.token.span);
                    let mut bounds: Vec[AstName] = vec.new_vec();
                    let mut param_end = name_result.token.span;
                    out_cursor = name_result.cursor;
                    if at_delimiter(out_cursor, ":") {
                        let colon = expect_delimiter(out_cursor, ":", "E1114", "expected generic bound separator");
                        let bounds_result = parse_generic_bound_list(colon.cursor, "E1115", "expected generic bound");
                        if has_generic_bounds_diagnostic(bounds_result) {
                            out_cursor = bounds_result.cursor;
                            diagnostic = bounds_result.diagnostic;
                            param_end = bounds_result.span;
                            done = true;
                        } else {
                            bounds = bounds_result.bounds;
                            param_end = bounds_result.span;
                            out_cursor = bounds_result.cursor;
                        }
                    } else {
                        ()
                    };
                    if !done {
                        params = vec.push(params, ast_generic_param(param_name, bounds, merge(param_name.span, param_end)));
                        end_span = param_end;
                        if at_delimiter(out_cursor, ",") {
                            let comma_result = expect_delimiter(out_cursor, ",", "E1116", "expected generic parameter separator");
                            out_cursor = comma_result.cursor;
                            if at_delimiter(out_cursor, "]") {
                                let close_result = expect_delimiter(out_cursor, "]", "E1111", "expected generic parameter list closer");
                                out_cursor = close_result.cursor;
                                end_span = close_result.token.span;
                                diagnostic = close_result.diagnostic;
                                done = true;
                            } else {
                                ()
                            };
                        } else {
                            let close_result = expect_delimiter(out_cursor, "]", "E1111", "expected generic parameter list closer");
                            out_cursor = close_result.cursor;
                            end_span = close_result.token.span;
                            diagnostic = close_result.diagnostic;
                            done = true;
                        }
                    } else {
                        ()
                    };
                };
            };

            match diagnostic {
                Some(diag) => ParseGenericParams {
                    cursor: out_cursor,
                    params: empty_generic_params(merge(open_result.token.span, end_span)),
                    span: merge(open_result.token.span, end_span),
                    diagnostic: Some(diag),
                },
                None => ParseGenericParams {
                    cursor: out_cursor,
                    params: ast_generic_params(params, merge(open_result.token.span, end_span)),
                    span: merge(open_result.token.span, end_span),
                    diagnostic: None(),
                },
            }
        }
    } else {
        let empty = empty_span(active.source, token.span.start);
        ParseGenericParams {
            cursor: active,
            params: empty_generic_params(empty),
            span: empty,
            diagnostic: None(),
        }
    }
}

pub fn parse_optional_where_clause(cursor: ParserCursor, params: AstGenericParamList) -> ParseGenericParams {
    let active = skip_trivia(cursor);
    let token = current_token(active);
    if at_keyword(active, "where") {
        let where_result = expect_keyword(active, "where", "E1258", "expected where clause");
        let mut out_cursor = where_result.cursor;
        let mut next_params = params;
        let mut end_span = where_result.token.span;
        let mut diagnostic: Option[Diagnostic] = None();
        let mut done = false;
        while !done {
            let name_result = expect_identifier(out_cursor, "E1020", "expected generic parameter in where clause");
            if has_diagnostic(name_result) {
                out_cursor = name_result.cursor;
                end_span = name_result.token.span;
                diagnostic = name_result.diagnostic;
                done = true;
            } else {
                let generic_name = ast_name(name_result.token.lexeme, name_result.token.span);
                let colon_result = expect_delimiter(name_result.cursor, ":", "E1023", "expected ':' after generic parameter in where clause");
                if has_diagnostic(colon_result) {
                    out_cursor = colon_result.cursor;
                    end_span = colon_result.token.span;
                    diagnostic = colon_result.diagnostic;
                    done = true;
                } else {
                    let bounds_result = parse_generic_bound_list(colon_result.cursor, "E1059", "expected trait bound in where clause");
                    if has_generic_bounds_diagnostic(bounds_result) {
                        out_cursor = bounds_result.cursor;
                        end_span = bounds_result.span;
                        diagnostic = bounds_result.diagnostic;
                        done = true;
                    } else if !generic_params_has_name(next_params, generic_name) {
                        out_cursor = bounds_result.cursor;
                        end_span = bounds_result.span;
                        diagnostic = Some(error(diagnostic_code("E1259"), generic_name.span, "where clause references unknown generic parameter"));
                        done = true;
                    } else {
                        next_params = generic_params_with_bounds(next_params, generic_name, bounds_result.bounds, merge(next_params.span, bounds_result.span));
                        out_cursor = bounds_result.cursor;
                        end_span = bounds_result.span;
                        if at_delimiter(out_cursor, ",") {
                            let comma = expect_delimiter(out_cursor, ",", "E1260", "expected where-clause separator");
                            out_cursor = comma.cursor;
                        } else {
                            done = true;
                        }
                    }
                }
            };
        };
        match diagnostic {
            Some(diag) => ParseGenericParams {
                cursor: out_cursor,
                params: next_params,
                span: merge(where_result.token.span, end_span),
                diagnostic: Some(diag),
            },
            None => ParseGenericParams {
                cursor: out_cursor,
                params: next_params,
                span: merge(where_result.token.span, end_span),
                diagnostic: None(),
            },
        }
    } else {
        ParseGenericParams {
            cursor: active,
            params: params,
            span: empty_span(active.source, token.span.start),
            diagnostic: None(),
        }
    }
}

fn raw_text_stop_for_field(token: Token, bracket_depth: Int, paren_depth: Int, brace_depth: Int) -> Bool {
    if bracket_depth == 0 && paren_depth == 0 && brace_depth == 0 {
        match token.kind {
            EndOfFile => true,
            Delimiter => token.lexeme == "," || token.lexeme == "}",
            _ => false,
        }
    } else {
        match token.kind {
            EndOfFile => true,
            _ => false,
        }
    }
}

pub fn parse_raw_text_until_field_boundary(cursor: ParserCursor, code: String, message: String) -> ParseRawText {
    let start_cursor = skip_trivia(cursor);
    let start_token = current_token(start_cursor);
    let mut out_cursor = start_cursor;
    let mut parts: Vec[String] = vec.new_vec();
    let mut end_span = start_token.span;
    let mut bracket_depth = 0;
    let mut paren_depth = 0;
    let mut brace_depth = 0;
    let mut saw_token = false;
    let mut done = false;
    let mut diagnostic: Option[Diagnostic] = None();

    while !done {
        let active = skip_trivia(out_cursor);
        let token = current_token(active);
        if raw_text_stop_for_field(token, bracket_depth, paren_depth, brace_depth) {
            done = true;
            out_cursor = active;
        } else if is_terminal(token) {
            done = true;
            out_cursor = active;
            diagnostic = Some(error(diagnostic_code(code), token.span, message));
        } else {
            saw_token = true;
            parts = vec.push(parts, token.lexeme);
            end_span = token.span;
            if is_delimiter(token, "[") {
                bracket_depth = bracket_depth + 1;
            } else if is_delimiter(token, "]") {
                bracket_depth = bracket_depth - 1;
                if bracket_depth < 0 {
                    diagnostic = Some(error(diagnostic_code(code), token.span, message));
                    done = true;
                } else {
                    ()
                };
            } else if is_delimiter(token, "(") {
                paren_depth = paren_depth + 1;
            } else if is_delimiter(token, ")") {
                paren_depth = paren_depth - 1;
                if paren_depth < 0 {
                    diagnostic = Some(error(diagnostic_code(code), token.span, message));
                    done = true;
                } else {
                    ()
                };
            } else if is_delimiter(token, "{") {
                brace_depth = brace_depth + 1;
            } else if is_delimiter(token, "}") {
                brace_depth = brace_depth - 1;
                if brace_depth < 0 {
                    diagnostic = Some(error(diagnostic_code(code), token.span, message));
                    done = true;
                } else {
                    ()
                };
            } else {
                ()
            };
            out_cursor = advance(active);
        };
    };

    if !saw_token {
        ParseRawText {
            cursor: out_cursor,
            text: "",
            span: empty_span(start_cursor.source, start_token.span.start),
            diagnostic: Some(error(diagnostic_code(code), start_token.span, message)),
        }
    } else {
        match diagnostic {
            Some(diag) => ParseRawText {
                cursor: out_cursor,
                text: "",
                span: merge(start_token.span, end_span),
                diagnostic: Some(diag),
            },
            None => ParseRawText {
                cursor: out_cursor,
                text: string.join(parts, ""),
                span: merge(start_token.span, end_span),
                diagnostic: None(),
            },
        }
    }
}

fn raw_text_stop_for_semicolon(token: Token, bracket_depth: Int, paren_depth: Int, brace_depth: Int) -> Bool {
    if bracket_depth == 0 && paren_depth == 0 && brace_depth == 0 {
        match token.kind {
            EndOfFile => true,
            Delimiter => token.lexeme == ";",
            _ => false,
        }
    } else {
        match token.kind {
            EndOfFile => true,
            _ => false,
        }
    }
}

pub fn parse_raw_text_until_semicolon(cursor: ParserCursor, code: String, message: String) -> ParseRawText {
    let start_cursor = skip_trivia(cursor);
    let start_token = current_token(start_cursor);
    let mut out_cursor = start_cursor;
    let mut parts: Vec[String] = vec.new_vec();
    let mut end_span = start_token.span;
    let mut bracket_depth = 0;
    let mut paren_depth = 0;
    let mut brace_depth = 0;
    let mut saw_token = false;
    let mut done = false;
    let mut diagnostic: Option[Diagnostic] = None();

    while !done {
        let active = skip_trivia(out_cursor);
        let token = current_token(active);
        if raw_text_stop_for_semicolon(token, bracket_depth, paren_depth, brace_depth) {
            done = true;
            out_cursor = active;
        } else if is_terminal(token) {
            done = true;
            out_cursor = active;
            diagnostic = Some(error(diagnostic_code(code), token.span, message));
        } else {
            saw_token = true;
            parts = vec.push(parts, token.lexeme);
            end_span = token.span;
            if is_delimiter(token, "[") {
                bracket_depth = bracket_depth + 1;
            } else if is_delimiter(token, "]") {
                bracket_depth = bracket_depth - 1;
                if bracket_depth < 0 {
                    diagnostic = Some(error(diagnostic_code(code), token.span, message));
                    done = true;
                } else {
                    ()
                };
            } else if is_delimiter(token, "(") {
                paren_depth = paren_depth + 1;
            } else if is_delimiter(token, ")") {
                paren_depth = paren_depth - 1;
                if paren_depth < 0 {
                    diagnostic = Some(error(diagnostic_code(code), token.span, message));
                    done = true;
                } else {
                    ()
                };
            } else if is_delimiter(token, "{") {
                brace_depth = brace_depth + 1;
            } else if is_delimiter(token, "}") {
                brace_depth = brace_depth - 1;
                if brace_depth < 0 {
                    diagnostic = Some(error(diagnostic_code(code), token.span, message));
                    done = true;
                } else {
                    ()
                };
            } else {
                ()
            };
            out_cursor = advance(active);
        };
    };

    if !saw_token {
        ParseRawText {
            cursor: out_cursor,
            text: "",
            span: empty_span(start_cursor.source, start_token.span.start),
            diagnostic: Some(error(diagnostic_code(code), start_token.span, message)),
        }
    } else {
        match diagnostic {
            Some(diag) => ParseRawText {
                cursor: out_cursor,
                text: "",
                span: merge(start_token.span, end_span),
                diagnostic: Some(diag),
            },
            None => ParseRawText {
                cursor: out_cursor,
                text: string.join(parts, ""),
                span: merge(start_token.span, end_span),
                diagnostic: None(),
            },
        }
    }
}

fn raw_text_stop_for_block_close(token: Token, bracket_depth: Int, paren_depth: Int, brace_depth: Int) -> Bool {
    if bracket_depth == 0 && paren_depth == 0 && brace_depth == 0 {
        match token.kind {
            EndOfFile => true,
            Delimiter => token.lexeme == "}",
            _ => false,
        }
    } else {
        match token.kind {
            EndOfFile => true,
            _ => false,
        }
    }
}

pub fn parse_raw_text_until_block_close(cursor: ParserCursor, code: String, message: String) -> ParseRawText {
    let start_cursor = skip_trivia(cursor);
    let start_token = current_token(start_cursor);
    let mut out_cursor = start_cursor;
    let mut parts: Vec[String] = vec.new_vec();
    let mut end_span = start_token.span;
    let mut bracket_depth = 0;
    let mut paren_depth = 0;
    let mut brace_depth = 0;
    let mut saw_token = false;
    let mut done = false;
    let mut diagnostic: Option[Diagnostic] = None();

    while !done {
        let active = skip_trivia(out_cursor);
        let token = current_token(active);
        if raw_text_stop_for_block_close(token, bracket_depth, paren_depth, brace_depth) {
            done = true;
            out_cursor = active;
        } else if is_terminal(token) {
            done = true;
            out_cursor = active;
            diagnostic = Some(error(diagnostic_code(code), token.span, message));
        } else {
            saw_token = true;
            parts = vec.push(parts, token.lexeme);
            end_span = token.span;
            if is_delimiter(token, "[") {
                bracket_depth = bracket_depth + 1;
            } else if is_delimiter(token, "]") {
                bracket_depth = bracket_depth - 1;
                if bracket_depth < 0 {
                    diagnostic = Some(error(diagnostic_code(code), token.span, message));
                    done = true;
                } else {
                    ()
                };
            } else if is_delimiter(token, "(") {
                paren_depth = paren_depth + 1;
            } else if is_delimiter(token, ")") {
                paren_depth = paren_depth - 1;
                if paren_depth < 0 {
                    diagnostic = Some(error(diagnostic_code(code), token.span, message));
                    done = true;
                } else {
                    ()
                };
            } else if is_delimiter(token, "{") {
                brace_depth = brace_depth + 1;
            } else if is_delimiter(token, "}") {
                brace_depth = brace_depth - 1;
                if brace_depth < 0 {
                    diagnostic = Some(error(diagnostic_code(code), token.span, message));
                    done = true;
                } else {
                    ()
                };
            } else {
                ()
            };
            out_cursor = advance(active);
        };
    };

    match diagnostic {
        Some(diag) => ParseRawText {
            cursor: out_cursor,
            text: "",
            span: merge(start_token.span, end_span),
            diagnostic: Some(diag),
        },
        None => if saw_token {
            ParseRawText {
                cursor: out_cursor,
                text: string.join(parts, ""),
                span: merge(start_token.span, end_span),
                diagnostic: None(),
            }
        } else {
            ParseRawText {
                cursor: out_cursor,
                text: "",
                span: empty_span(start_cursor.source, start_token.span.start),
                diagnostic: None(),
            }
        },
    }
}

pub fn parse_raw_text_until_end(cursor: ParserCursor, code: String, message: String) -> ParseRawText {
    let start_cursor = skip_trivia(cursor);
    let start_token = current_token(start_cursor);
    let mut out_cursor = start_cursor;
    let mut parts: Vec[String] = vec.new_vec();
    let mut end_span = start_token.span;
    let mut saw_token = false;
    let mut done = false;
    let mut diagnostic: Option[Diagnostic] = None();

    while !done {
        let active = skip_trivia(out_cursor);
        let token = current_token(active);
        if is_at_end(active) {
            out_cursor = active;
            done = true;
        } else if is_terminal(token) {
            out_cursor = active;
            end_span = token.span;
            diagnostic = Some(error(diagnostic_code(code), token.span, message));
            done = true;
        } else {
            saw_token = true;
            parts = vec.push(parts, token.lexeme);
            end_span = token.span;
            out_cursor = advance(active);
        };
    };

    if !saw_token {
        ParseRawText {
            cursor: out_cursor,
            text: "",
            span: empty_span(start_cursor.source, start_token.span.start),
            diagnostic: Some(error(diagnostic_code(code), start_token.span, message)),
        }
    } else {
        match diagnostic {
            Some(diag) => ParseRawText {
                cursor: out_cursor,
                text: "",
                span: merge(start_token.span, end_span),
                diagnostic: Some(diag),
            },
            None => ParseRawText {
                cursor: out_cursor,
                text: string.join(parts, ""),
                span: merge(start_token.span, end_span),
                diagnostic: None(),
            },
        }
    }
}

fn expr_ok(cursor: ParserCursor, expr: AstExpr) -> ParseExpr {
    ParseExpr {
        cursor: cursor,
        expr: Some(expr),
        span: expr.span,
        diagnostic: None(),
    }
}

fn expr_error(cursor: ParserCursor, span: SourceSpan, code: String, message: String) -> ParseExpr {
    ParseExpr {
        cursor: cursor,
        expr: None(),
        span: span,
        diagnostic: Some(error(diagnostic_code(code), span, message)),
    }
}

fn pattern_ok(cursor: ParserCursor, pattern: AstPattern) -> ParsePattern {
    ParsePattern {
        cursor: cursor,
        pattern: Some(pattern),
        span: pattern.span,
        diagnostic: None(),
    }
}

fn pattern_error(cursor: ParserCursor, span: SourceSpan, code: String, message: String) -> ParsePattern {
    ParsePattern {
        cursor: cursor,
        pattern: None(),
        span: span,
        diagnostic: Some(error(diagnostic_code(code), span, message)),
    }
}

fn expr_stop_token(token: Token) -> Bool {
    match token.kind {
        EndOfFile => true,
        Invalid => true,
        Delimiter => token.lexeme == "," || token.lexeme == ";" || token.lexeme == ")" || token.lexeme == "]" || token.lexeme == "}",
        Operator => token.lexeme == "=>",
        Keyword => token.lexeme == "else" || token.lexeme == "effects" || token.lexeme == "capabilities" || token.lexeme == "requires" || token.lexeme == "ensures" || token.lexeme == "invariant" || token.lexeme == "where",
        _ => false,
    }
}

fn has_optional_diagnostic(value: Option[Diagnostic]) -> Bool {
    match value {
        Some(_) => true,
        None => false,
    }
}

fn is_identifier_token(value: Token) -> Bool {
    match value.kind {
        Identifier => true,
        _ => false,
    }
}

fn looks_like_struct_literal(cursor: ParserCursor) -> Bool {
    let open_cursor = skip_trivia(cursor);
    if !at_delimiter(open_cursor, "{") {
        false
    } else {
        let first_field_cursor = skip_trivia(advance(open_cursor));
        let first_field = current_token(first_field_cursor);
        if is_delimiter(first_field, "}") {
            true
        } else if is_identifier_token(first_field) {
            at_delimiter(advance(first_field_cursor), ":")
        } else {
            false
        }
    }
}

fn binary_precedence(token: Token) -> Int {
    if is_operator(token, "||") {
        1
    } else if is_operator(token, "&&") {
        2
    } else if is_operator(token, "|") {
        3
    } else if is_operator(token, "^") {
        4
    } else if is_operator(token, "&") {
        5
    } else if is_operator(token, "==") || is_operator(token, "!=") {
        6
    } else if is_operator(token, "<") || is_operator(token, "<=") || is_operator(token, ">") || is_operator(token, ">=") {
        7
    } else if is_operator(token, "<<") || is_operator(token, ">>") || is_operator(token, ">>>") {
        8
    } else if is_operator(token, "+") || is_operator(token, "-") {
        9
    } else if is_operator(token, "*") || is_operator(token, "/") || is_operator(token, "%") {
        10
    } else if is_delimiter(token, "..") {
        7
    } else {
        0
    }
}

fn merge_expr_text(left: String, op: String, right: String) -> String {
    let mut parts: Vec[String] = vec.new_vec();
    parts = vec.push(parts, left);
    parts = vec.push(parts, op);
    parts = vec.push(parts, right);
    string.join(parts, "")
}

fn wrap_text(open: String, inner: String, close: String) -> String {
    let mut parts: Vec[String] = vec.new_vec();
    parts = vec.push(parts, open);
    parts = vec.push(parts, inner);
    parts = vec.push(parts, close);
    string.join(parts, "")
}

fn join_expr_text(values: Vec[AstExpr], separator: String) -> String {
    let mut parts: Vec[String] = vec.new_vec();
    let mut index = 0;
    while index < vec.vec_len(values) {
        match vec.get(values, index) {
            Some(expr) => if true {
                parts = vec.push(parts, expr.text);
                ()
            } else {
                ()
            },
            None => (),
        };
        index = index + 1;
    };
    string.join(parts, separator)
}

fn join_pattern_text(values: Vec[AstPattern], separator: String) -> String {
    let mut parts: Vec[String] = vec.new_vec();
    let mut index = 0;
    while index < vec.vec_len(values) {
        match vec.get(values, index) {
            Some(pattern) => if true {
                parts = vec.push(parts, pattern.text);
                ()
            } else {
                ()
            },
            None => (),
        };
        index = index + 1;
    };
    string.join(parts, separator)
}

fn parse_binary_expr(cursor: ParserCursor, min_precedence: Int) -> ParseExpr {
    let first = parse_unary_expr(cursor);
    if has_expr_diagnostic(first) {
        first
    } else {
        match first.expr {
            Some(first_expr) => if true {
                let mut out_cursor = first.cursor;
                let mut expr = first_expr;
                let mut diagnostic: Option[Diagnostic] = None();
                let mut done = false;
                while !done {
                    let active = skip_trivia(out_cursor);
                    let token = current_token(active);
                    let precedence = binary_precedence(token);
                    if precedence < min_precedence || precedence == 0 {
                        done = true;
                    } else {
                        out_cursor = advance(active);
                        let rhs_result = parse_binary_expr(out_cursor, precedence + 1);
                        if has_expr_diagnostic(rhs_result) {
                            out_cursor = rhs_result.cursor;
                            diagnostic = rhs_result.diagnostic;
                            done = true;
                        } else {
                            match rhs_result.expr {
                                Some(rhs) => if true {
                                    let lhs_text = expr.text;
                                    let lhs_span = expr.span;
                                    let rhs_text = rhs.text;
                                    let rhs_span = rhs.span;
                                    let mut children: Vec[AstExpr] = vec.new_vec();
                                    children = vec.push(children, expr);
                                    children = vec.push(children, rhs);
                                    expr = expr_with_children(AstBinaryExpr(), token.lexeme, "", children, vec.new_vec(), merge(lhs_span, rhs_span), merge_expr_text(lhs_text, token.lexeme, rhs_text));
                                    out_cursor = rhs_result.cursor;
                                    ()
                                } else {
                                    ()
                                },
                                None => if true {
                                    diagnostic = Some(error(diagnostic_code("E1301"), rhs_result.span, "expected right-hand expression"));
                                    done = true;
                                    ()
                                } else {
                                    ()
                                },
                            }
                        }
                    };
                };
                match diagnostic {
                    Some(diag) => ParseExpr {
                        cursor: out_cursor,
                        expr: None(),
                        span: expr.span,
                        diagnostic: Some(diag),
                    },
                    None => expr_ok(out_cursor, expr),
                }
            } else {
                first
            },
            None => expr_error(first.cursor, first.span, "E1300", "expected expression"),
        }
    }
}

pub fn parse_expr(cursor: ParserCursor) -> ParseExpr {
    parse_binary_expr(cursor, 1)
}

pub fn parse_expression(cursor: ParserCursor) -> ParseExpr {
    parse_expr(cursor)
}

fn parse_unary_expr(cursor: ParserCursor) -> ParseExpr {
    let active = skip_trivia(cursor);
    let token = current_token(active);
    if is_operator(token, "|") || is_operator(token, "||") {
        parse_closure_expr(active)
    } else if is_operator(token, "&") {
        let after_amp = advance(active);
        let mutable = at_keyword(after_amp, "mut");
        let value_cursor = if mutable { advance(skip_trivia(after_amp)) } else { after_amp };
        let inner = parse_unary_expr(value_cursor);
        if has_expr_diagnostic(inner) {
            inner
        } else {
            match inner.expr {
                Some(expr) => if true {
                    let name = if mutable { "mut" } else { "" };
                    let text = if mutable { wrap_text("&mut ", expr.text, "") } else { wrap_text("&", expr.text, "") };
                    let end_span = expr.span;
                    let mut children: Vec[AstExpr] = vec.new_vec();
                    children = vec.push(children, expr);
                    expr_ok(inner.cursor, expr_with_children(AstBorrowExpr(), "&", name, children, vec.new_vec(), merge(token.span, end_span), text))
                } else {
                    inner
                },
                None => expr_error(inner.cursor, inner.span, "E1300", "expected borrowed expression"),
            }
        }
    } else if at_keyword(active, "await") {
        let inner = parse_unary_expr(advance(active));
        if has_expr_diagnostic(inner) {
            inner
        } else {
            match inner.expr {
                Some(expr) => if true {
                    let end_span = expr.span;
                    let mut children: Vec[AstExpr] = vec.new_vec();
                    children = vec.push(children, expr);
                    expr_ok(inner.cursor, expr_with_children(AstAwaitExpr(), "await", "", children, vec.new_vec(), merge(token.span, end_span), wrap_text("await ", expr.text, "")))
                } else {
                    inner
                },
                None => expr_error(inner.cursor, inner.span, "E1300", "expected awaited expression"),
            }
        }
    } else if is_operator(token, "-") || is_operator(token, "!") || is_operator(token, "~") {
        let inner = parse_unary_expr(advance(active));
        if has_expr_diagnostic(inner) {
            inner
        } else {
            match inner.expr {
                Some(expr) => if true {
                    let end_span = expr.span;
                    let mut children: Vec[AstExpr] = vec.new_vec();
                    children = vec.push(children, expr);
                    expr_ok(inner.cursor, expr_with_children(AstUnaryExpr(), token.lexeme, "", children, vec.new_vec(), merge(token.span, end_span), wrap_text(token.lexeme, expr.text, "")))
                } else {
                    inner
                },
                None => expr_error(inner.cursor, inner.span, "E1300", "expected unary expression"),
            }
        }
    } else {
        parse_postfix_expr(active)
    }
}

fn parse_postfix_expr(cursor: ParserCursor) -> ParseExpr {
    let first = parse_primary_expr(cursor);
    if has_expr_diagnostic(first) {
        first
    } else {
        match first.expr {
            Some(first_expr) => if true {
                let mut out_cursor = first.cursor;
                let mut expr = first_expr;
                let mut diagnostic: Option[Diagnostic] = None();
                let mut done = false;
                while !done {
                    if at_delimiter(out_cursor, "(") {
                        let open = expect_delimiter(out_cursor, "(", "E1310", "expected function argument list opener");
                        let args_result = parse_call_args(open.cursor, open.token.span, expr.text);
                        if has_expr_diagnostic(args_result) {
                            out_cursor = args_result.cursor;
                            diagnostic = args_result.diagnostic;
                            done = true;
                        } else {
                            match args_result.expr {
                                Some(call_expr) => if true {
                                    expr = ast_expr(call_expr.kind, call_expr.op, call_expr.name, call_expr.direct_child_count, call_expr.nodes, call_expr.patterns, call_expr.match_arms, merge(expr.span, call_expr.span), call_expr.text);
                                    out_cursor = args_result.cursor;
                                    ()
                                } else {
                                    ()
                                },
                                None => if true {
                                    diagnostic = args_result.diagnostic;
                                    done = true;
                                    ()
                                } else {
                                    ()
                                },
                            }
                        }
                    } else if at_delimiter(out_cursor, ".") {
                        let dot = expect_delimiter(out_cursor, ".", "E1311", "expected field access separator");
                        let field_token = current_token(skip_trivia(dot.cursor));
                        if at_identifier(dot.cursor) || match field_token.kind { IntegerLiteral => true, _ => false } {
                            let field_cursor = advance(skip_trivia(dot.cursor));
                            let field_name = field_token.lexeme;
                            let lhs_span = expr.span;
                            let lhs_text = expr.text;
                            let mut children: Vec[AstExpr] = vec.new_vec();
                            children = vec.push(children, expr);
                            expr = expr_with_children(AstFieldAccessExpr(), ".", field_name, children, vec.new_vec(), merge(lhs_span, field_token.span), merge_expr_text(lhs_text, ".", field_token.lexeme));
                            out_cursor = field_cursor;
                        } else {
                            out_cursor = dot.cursor;
                            diagnostic = Some(error(diagnostic_code("E1312"), field_token.span, "expected field name or tuple index after '.'"));
                            done = true;
                        }
                    } else if at_operator(out_cursor, "?") {
                        let question = expect_operator(out_cursor, "?", "E1313", "expected result propagation operator");
                        let expr_span = expr.span;
                        let expr_text_value = expr.text;
                        let mut children: Vec[AstExpr] = vec.new_vec();
                        children = vec.push(children, expr);
                        expr = expr_with_children(AstTryExpr(), "?", "", children, vec.new_vec(), merge(expr_span, question.token.span), wrap_text(expr_text_value, "?", ""));
                        out_cursor = question.cursor;
                    } else {
                        done = true;
                    }
                };
                match diagnostic {
                    Some(diag) => ParseExpr {
                        cursor: out_cursor,
                        expr: None(),
                        span: expr.span,
                        diagnostic: Some(diag),
                    },
                    None => expr_ok(out_cursor, expr),
                }
            } else {
                first
            },
            None => expr_error(first.cursor, first.span, "E1300", "expected expression"),
        }
    }
}

fn parse_call_args(cursor: ParserCursor, open_span: SourceSpan, callee_text: String) -> ParseExpr {
    let open_source = open_span.source.value;
    let open_start = open_span.start;
    let open_end = open_span.end;
    let open_copy = span(source_id(open_source), open_start, open_end);
    let mut out_cursor = cursor;
    let mut args: Vec[AstExpr] = vec.new_vec();
    let mut arg_roles: Vec[String] = vec.new_vec();
    let mut text_parts: Vec[String] = vec.new_vec();
    let mut saw_named = false;
    let mut diagnostic: Option[Diagnostic] = None();
    let mut end_span = span(source_id(open_source), open_start, open_end);
    let mut done = false;
    text_parts = vec.push(text_parts, callee_text);
    text_parts = vec.push(text_parts, "(");
    while !done && !at_delimiter(out_cursor, ")") {
        if vec.vec_len(args) > 0 {
            text_parts = vec.push(text_parts, ",");
        } else {
            ()
        };
        let active = skip_trivia(out_cursor);
        let token = current_token(active);
        let after_name = advance(active);
        if at_identifier(active) && at_delimiter(after_name, ":") {
            let colon = expect_delimiter(after_name, ":", "E1314", "expected ':' after named argument");
            let value = parse_expr(colon.cursor);
            if has_expr_diagnostic(value) {
                diagnostic = value.diagnostic;
                out_cursor = value.cursor;
                end_span = value.span;
                done = true;
            } else {
                match value.expr {
                    Some(expr) => if true {
                        text_parts = vec.push(text_parts, token.lexeme);
                        text_parts = vec.push(text_parts, ":");
                        text_parts = vec.push(text_parts, expr.text);
                        end_span = expr.span;
                        args = vec.push(args, expr);
                        arg_roles = vec.push(arg_roles, wrap_text("arg:", token.lexeme, ""));
                        out_cursor = value.cursor;
                        saw_named = true;
                        ()
                    } else {
                        ()
                    },
                    None => if true {
                        diagnostic = Some(error(diagnostic_code("E1315"), value.span, "expected named argument value"));
                        done = true;
                        ()
                    } else {
                        ()
                    },
                }
            }
        } else {
            let value = parse_expr(out_cursor);
            if has_expr_diagnostic(value) {
                diagnostic = value.diagnostic;
                out_cursor = value.cursor;
                end_span = value.span;
                done = true;
            } else {
                match value.expr {
                    Some(expr) => if true {
                        if saw_named {
                            diagnostic = Some(error(diagnostic_code("E1092"), expr.span, "positional arguments cannot follow named arguments"));
                            done = true;
                        } else {
                            text_parts = vec.push(text_parts, expr.text);
                            end_span = expr.span;
                            args = vec.push(args, expr);
                            arg_roles = vec.push(arg_roles, "arg");
                            out_cursor = value.cursor;
                        };
                        ()
                    } else {
                        ()
                    },
                    None => if true {
                        diagnostic = Some(error(diagnostic_code("E1316"), value.span, "expected function argument"));
                        done = true;
                        ()
                    } else {
                        ()
                    },
                }
            }
        };
        if !done {
            if at_delimiter(out_cursor, ",") {
                let comma = expect_delimiter(out_cursor, ",", "E1317", "expected argument separator");
                out_cursor = comma.cursor;
            } else {
                done = true;
            }
        } else {
            ()
        };
    };
    if has_optional_diagnostic(diagnostic) {
        ParseExpr {
            cursor: out_cursor,
            expr: None(),
            span: merge(open_copy, end_span),
            diagnostic: diagnostic,
        }
    } else {
        let close = expect_delimiter(out_cursor, ")", "E1035", "expected ')' after function arguments");
        if has_diagnostic(close) {
            expr_error(close.cursor, close.token.span, "E1035", "expected ')' after function arguments")
        } else {
            text_parts = vec.push(text_parts, ")");
            let text = string.join(text_parts, "");
            expr_ok(close.cursor, expr_with_child_roles(AstCallExpr(), "", callee_text, args, arg_roles, vec.new_vec(), merge(open_copy, close.token.span), text))
        }
    }
}

fn parse_primary_expr(cursor: ParserCursor) -> ParseExpr {
    let active = skip_trivia(cursor);
    let token = current_token(active);
    if expr_stop_token(token) {
        expr_error(active, token.span, "E1300", "expected expression")
    } else {
        match token.kind {
            IntegerLiteral => expr_ok(advance(active), simple_expr(AstIntExpr(), "", token.lexeme, token.span, token.lexeme)),
            FloatLiteral => expr_ok(advance(active), simple_expr(AstFloatExpr(), "", token.lexeme, token.span, token.lexeme)),
            StringLiteral => expr_ok(advance(active), simple_expr(AstStringExpr(), "", token.lexeme, token.span, token.lexeme)),
            TemplateLiteral => expr_ok(advance(active), simple_expr(AstTemplateExpr(), "", token.lexeme, token.span, token.lexeme)),
            CharLiteral => expr_ok(advance(active), simple_expr(AstCharExpr(), "", token.lexeme, token.span, token.lexeme)),
            Keyword => if token.lexeme == "true" || token.lexeme == "false" {
                expr_ok(advance(active), simple_expr(AstBoolExpr(), "", token.lexeme, token.span, token.lexeme))
            } else if token.lexeme == "if" {
                parse_if_expr(active)
            } else if token.lexeme == "match" {
                parse_match_expr(active)
            } else if token.lexeme == "while" {
                parse_while_expr(active)
            } else if token.lexeme == "loop" {
                parse_loop_expr(active)
            } else if token.lexeme == "for" {
                parse_for_expr(active)
            } else if token.lexeme == "break" {
                parse_break_expr(active)
            } else if token.lexeme == "continue" {
                expr_ok(advance(active), simple_expr(AstContinueExpr(), "", "", token.span, "continue"))
            } else if token.lexeme == "unsafe" {
                parse_unsafe_block_expr(active)
            } else {
                expr_error(active, token.span, "E1300", "expected expression")
            },
            Identifier => parse_name_or_struct_expr(active),
            Delimiter => if token.lexeme == "(" {
                parse_tuple_or_parenthesized_expr(active)
            } else if token.lexeme == "{" {
                let block = parse_block(active);
                if has_block_diagnostic(block) {
                    ParseExpr {
                        cursor: block.cursor,
                        expr: None(),
                        span: token.span,
                        diagnostic: block.diagnostic,
                    }
                } else {
                    match block.block {
                        Some(value) => if true {
                            expr_ok(block.cursor, simple_expr(AstBlockExpr(), "", "", value.span, value.text))
                        } else {
                            expr_error(block.cursor, token.span, "E1300", "expected block")
                        },
                        None => expr_error(block.cursor, token.span, "E1300", "expected block"),
                    }
                }
            } else {
                expr_error(active, token.span, "E1300", "expected expression")
            },
            _ => expr_error(active, token.span, "E1300", "expected expression"),
        }
    }
}

fn parse_tuple_or_parenthesized_expr(cursor: ParserCursor) -> ParseExpr {
    let open = expect_delimiter(cursor, "(", "E1320", "expected expression tuple opener");
    if has_diagnostic(open) {
        expr_error(open.cursor, open.token.span, "E1320", "expected expression tuple opener")
    } else if at_delimiter(open.cursor, ")") {
        let close = expect_delimiter(open.cursor, ")", "E1037", "expected ')' after unit expression");
        if has_diagnostic(close) {
            expr_error(close.cursor, close.token.span, "E1037", "expected ')' after unit expression")
        } else {
            expr_ok(close.cursor, simple_expr(AstUnitExpr(), "", "", merge(open.token.span, close.token.span), "()"))
        }
    } else {
        let first = parse_expr(open.cursor);
        if has_expr_diagnostic(first) {
            first
        } else {
            match first.expr {
                Some(first_expr) => if at_delimiter(first.cursor, ",") {
                    let mut out_cursor = first.cursor;
                    let mut values: Vec[AstExpr] = vec.new_vec();
                    let mut end_span = first_expr.span;
                    let mut diagnostic: Option[Diagnostic] = None();
                    let mut done = false;
                    values = vec.push(values, first_expr);
                    while !done {
                        let comma = expect_delimiter(out_cursor, ",", "E1321", "expected tuple expression separator");
                        out_cursor = comma.cursor;
                        if at_delimiter(out_cursor, ")") {
                            done = true;
                        } else {
                            let item = parse_expr(out_cursor);
                            if has_expr_diagnostic(item) {
                                out_cursor = item.cursor;
                                diagnostic = item.diagnostic;
                                end_span = item.span;
                                done = true;
                            } else {
                                match item.expr {
                                    Some(expr) => if true {
                                        end_span = expr.span;
                                        values = vec.push(values, expr);
                                        out_cursor = item.cursor;
                                        ()
                                    } else {
                                        ()
                                    },
                                    None => if true {
                                        diagnostic = Some(error(diagnostic_code("E1322"), item.span, "expected tuple expression item"));
                                        done = true;
                                        ()
                                    } else {
                                        ()
                                    },
                                };
                                if !done && !at_delimiter(out_cursor, ",") {
                                    done = true;
                                } else {
                                    ()
                                }
                            }
                        }
                    };
                    match diagnostic {
                        Some(diag) => ParseExpr {
                            cursor: out_cursor,
                            expr: None(),
                            span: merge(open.token.span, end_span),
                            diagnostic: Some(diag),
                        },
                        None => if true {
                            let close = expect_delimiter(out_cursor, ")", "E1037", "expected ')' after tuple expression");
                            if has_diagnostic(close) {
                                expr_error(close.cursor, close.token.span, "E1037", "expected ')' after tuple expression")
                            } else {
                                let text = wrap_text("(", join_expr_text(values, ","), ")");
                                expr_ok(close.cursor, expr_with_children(AstTupleExpr(), "", "", values, vec.new_vec(), merge(open.token.span, close.token.span), text))
                            }
                        } else {
                            expr_error(out_cursor, end_span, "E1322", "expected tuple expression item")
                        },
                    }
                } else {
                    let close = expect_delimiter(first.cursor, ")", "E1037", "expected ')' after expression");
                    if has_diagnostic(close) {
                        expr_error(close.cursor, close.token.span, "E1037", "expected ')' after expression")
                    } else {
                        expr_ok(close.cursor, simple_expr(first_expr.kind, first_expr.op, first_expr.name, merge(open.token.span, close.token.span), first_expr.text))
                    }
                },
                None => expr_error(first.cursor, first.span, "E1300", "expected expression"),
            }
        }
    }
}

fn parse_name_path(cursor: ParserCursor, code: String, message: String) -> ParseTypeName {
    parse_type_name_path(cursor, code, message)
}

fn parse_name_or_struct_expr(cursor: ParserCursor) -> ParseExpr {
    let name_result = parse_name_path(cursor, "E1323", "expected name expression");
    if has_type_name_diagnostic(name_result) {
        ParseExpr {
            cursor: name_result.cursor,
            expr: None(),
            span: current_token(skip_trivia(cursor)).span,
            diagnostic: name_result.diagnostic,
        }
    } else {
        match name_result.name {
            Some(name) => if looks_like_struct_literal(name_result.cursor) {
                let open = expect_delimiter(name_result.cursor, "{", "E1324", "expected struct literal opener");
                let fields = parse_struct_literal_fields(open.cursor, open.token.span, name.value);
                if has_expr_diagnostic(fields) {
                    fields
                } else {
                    fields
                }
            } else {
                expr_ok(name_result.cursor, simple_expr(AstNameExpr(), "", name.value, name.span, name.value))
            },
            None => expr_error(name_result.cursor, current_token(skip_trivia(cursor)).span, "E1323", "expected name expression"),
        }
    }
}

fn parse_struct_literal_fields(cursor: ParserCursor, open_span: SourceSpan, name: String) -> ParseExpr {
    let open_source = open_span.source.value;
    let open_start = open_span.start;
    let open_end = open_span.end;
    let open_copy = span(source_id(open_source), open_start, open_end);
    let mut out_cursor = cursor;
    let mut values: Vec[AstExpr] = vec.new_vec();
    let mut roles: Vec[String] = vec.new_vec();
    let mut text_parts: Vec[String] = vec.new_vec();
    let mut end_span = span(source_id(open_source), open_start, open_end);
    let mut diagnostic: Option[Diagnostic] = None();
    let mut done = false;
    text_parts = vec.push(text_parts, name);
    text_parts = vec.push(text_parts, "{");
    while !done && !at_delimiter(out_cursor, "}") {
        if vec.vec_len(values) > 0 {
            text_parts = vec.push(text_parts, ",");
        } else {
            ()
        };
        let field = expect_identifier(out_cursor, "E1038", "expected struct field name");
        if has_diagnostic(field) {
            diagnostic = field.diagnostic;
            out_cursor = field.cursor;
            end_span = field.token.span;
            done = true;
        } else {
            let colon = expect_delimiter(field.cursor, ":", "E1039", "expected ':' after field name");
            if has_diagnostic(colon) {
                diagnostic = colon.diagnostic;
                out_cursor = colon.cursor;
                end_span = colon.token.span;
                done = true;
            } else {
                let value = parse_expr(colon.cursor);
                if has_expr_diagnostic(value) {
                    diagnostic = value.diagnostic;
                    out_cursor = value.cursor;
                    end_span = value.span;
                    done = true;
                } else {
                    match value.expr {
                        Some(expr) => if true {
                            text_parts = vec.push(text_parts, field.token.lexeme);
                            text_parts = vec.push(text_parts, ":");
                            text_parts = vec.push(text_parts, expr.text);
                            end_span = expr.span;
                            values = vec.push(values, expr);
                            roles = vec.push(roles, wrap_text("field:", field.token.lexeme, ""));
                            out_cursor = value.cursor;
                            ()
                        } else {
                            ()
                        },
                        None => if true {
                            diagnostic = Some(error(diagnostic_code("E1325"), value.span, "expected struct field value"));
                            done = true;
                            ()
                        } else {
                            ()
                        },
                    };
                    if !done {
                        if at_delimiter(out_cursor, ",") {
                            let comma = expect_delimiter(out_cursor, ",", "E1326", "expected struct literal field separator");
                            out_cursor = comma.cursor;
                        } else {
                            done = true;
                        }
                    } else {
                        ()
                    }
                }
            }
        }
    };
    match diagnostic {
        Some(diag) => ParseExpr {
            cursor: out_cursor,
            expr: None(),
            span: merge(open_copy, end_span),
            diagnostic: Some(diag),
        },
        None => if true {
            let close = expect_delimiter(out_cursor, "}", "E1040", "expected '}' after struct literal");
            if has_diagnostic(close) {
                expr_error(close.cursor, close.token.span, "E1040", "expected '}' after struct literal")
            } else {
                text_parts = vec.push(text_parts, "}");
                expr_ok(close.cursor, expr_with_child_roles(AstStructLiteralExpr(), "", name, values, roles, vec.new_vec(), merge(open_copy, close.token.span), string.join(text_parts, "")))
            }
        } else {
            expr_error(out_cursor, open_copy, "E1325", "expected struct literal")
        },
    }
}

fn parse_if_expr(cursor: ParserCursor) -> ParseExpr {
    let keyword = expect_keyword(cursor, "if", "E1330", "expected if expression");
    if has_diagnostic(keyword) {
        expr_error(keyword.cursor, keyword.token.span, "E1330", "expected if expression")
    } else {
        let cond = parse_expr(keyword.cursor);
        if has_expr_diagnostic(cond) {
            cond
        } else {
            match cond.expr {
                Some(cond_expr) => if true {
                    let then_block = parse_block(cond.cursor);
                    if has_block_diagnostic(then_block) {
                        ParseExpr {
                            cursor: then_block.cursor,
                            expr: None(),
                            span: merge(keyword.token.span, cond_expr.span),
                            diagnostic: then_block.diagnostic,
                        }
                    } else {
                        let else_keyword = expect_keyword(then_block.cursor, "else", "E1042", "expected else branch for if expression");
                        if has_diagnostic(else_keyword) {
                            expr_error(else_keyword.cursor, else_keyword.token.span, "E1042", "expected else branch for if expression")
                        } else {
                            let else_expr = if at_keyword(else_keyword.cursor, "if") {
                                parse_if_expr(else_keyword.cursor)
                            } else {
                                let else_block = parse_block(else_keyword.cursor);
                                if has_block_diagnostic(else_block) {
                                    ParseExpr {
                                        cursor: else_block.cursor,
                                        expr: None(),
                                        span: else_keyword.token.span,
                                        diagnostic: else_block.diagnostic,
                                    }
                                } else {
                                    match else_block.block {
                                        Some(block) => expr_ok(else_block.cursor, simple_expr(AstBlockExpr(), "", "", block.span, block.text)),
                                        None => expr_error(else_block.cursor, else_keyword.token.span, "E1331", "expected else block"),
                                    }
                                }
                            };
                            if has_expr_diagnostic(else_expr) {
                                else_expr
                            } else {
                                match else_expr.expr {
                                    Some(else_value) => if true {
                                        let then_text = match then_block.block {
                                            Some(block) => block.text,
                                            None => "",
                                        };
                                        let text = wrap_text("if ", cond_expr.text, wrap_text(then_text, "else", else_value.text));
                                        let mut children: Vec[AstExpr] = vec.new_vec();
                                        children = vec.push(children, cond_expr);
                                        children = vec.push(children, else_value);
                                        expr_ok(else_expr.cursor, expr_with_children(AstIfExpr(), "", "", children, vec.new_vec(), merge(keyword.token.span, else_value.span), text))
                                    } else {
                                        else_expr
                                    },
                                    None => expr_error(else_expr.cursor, else_expr.span, "E1331", "expected else expression"),
                                }
                            }
                        }
                    }
                } else {
                    cond
                },
                None => expr_error(cond.cursor, cond.span, "E1332", "expected if condition"),
            }
        }
    }
}

fn parse_while_expr(cursor: ParserCursor) -> ParseExpr {
    let keyword = expect_keyword(cursor, "while", "E1333", "expected while expression");
    if has_diagnostic(keyword) {
        expr_error(keyword.cursor, keyword.token.span, "E1333", "expected while expression")
    } else {
        let cond = parse_expr(keyword.cursor);
        if has_expr_diagnostic(cond) {
            cond
        } else {
            match cond.expr {
                Some(cond_expr) => if true {
                    let body = parse_block(cond.cursor);
                    if has_block_diagnostic(body) {
                        ParseExpr {
                            cursor: body.cursor,
                            expr: None(),
                            span: cond_expr.span,
                            diagnostic: body.diagnostic,
                        }
                    } else {
                        match body.block {
                            Some(block) => if true {
                                let mut children: Vec[AstExpr] = vec.new_vec();
                                children = vec.push(children, cond_expr);
                                expr_ok(body.cursor, expr_with_children(AstWhileExpr(), "", "", children, vec.new_vec(), merge(keyword.token.span, block.span), wrap_text("while ", cond_expr.text, block.text)))
                            } else {
                                expr_error(body.cursor, cond_expr.span, "E1334", "expected while body")
                            },
                            None => expr_error(body.cursor, cond_expr.span, "E1334", "expected while body"),
                        }
                    }
                } else {
                    cond
                },
                None => expr_error(cond.cursor, cond.span, "E1335", "expected while condition"),
            }
        }
    }
}

fn parse_loop_expr(cursor: ParserCursor) -> ParseExpr {
    let keyword = expect_keyword(cursor, "loop", "E1336", "expected loop expression");
    if has_diagnostic(keyword) {
        expr_error(keyword.cursor, keyword.token.span, "E1336", "expected loop expression")
    } else {
        let body = parse_block(keyword.cursor);
        if has_block_diagnostic(body) {
            ParseExpr {
                cursor: body.cursor,
                expr: None(),
                span: keyword.token.span,
                diagnostic: body.diagnostic,
            }
        } else {
            match body.block {
                Some(block) => expr_ok(body.cursor, simple_expr(AstLoopExpr(), "", "", merge(keyword.token.span, block.span), wrap_text("loop", block.text, ""))),
                None => expr_error(body.cursor, keyword.token.span, "E1337", "expected loop body"),
            }
        }
    }
}

fn parse_for_expr(cursor: ParserCursor) -> ParseExpr {
    let keyword = expect_keyword(cursor, "for", "E1338", "expected for expression");
    if has_diagnostic(keyword) {
        expr_error(keyword.cursor, keyword.token.span, "E1338", "expected for expression")
    } else {
        let binding = expect_identifier(keyword.cursor, "E1031", "expected loop binding name after for");
        if has_diagnostic(binding) {
            expr_error(binding.cursor, binding.token.span, "E1031", "expected loop binding name after for")
        } else {
            let in_keyword = expect_keyword(binding.cursor, "in", "E1041", "expected in after loop binding");
            if has_diagnostic(in_keyword) {
                expr_error(in_keyword.cursor, in_keyword.token.span, "E1041", "expected in after loop binding")
            } else {
                let iterable = parse_expr(in_keyword.cursor);
                if has_expr_diagnostic(iterable) {
                    iterable
                } else {
                    match iterable.expr {
                        Some(value) => if true {
                            let body = parse_block(iterable.cursor);
                            if has_block_diagnostic(body) {
                                ParseExpr {
                                    cursor: body.cursor,
                                    expr: None(),
                                    span: value.span,
                                    diagnostic: body.diagnostic,
                                }
                            } else {
                                match body.block {
                                    Some(block) => if true {
                                        let mut children: Vec[AstExpr] = vec.new_vec();
                                        children = vec.push(children, value);
                                        expr_ok(body.cursor, expr_with_children(AstForExpr(), "in", binding.token.lexeme, children, vec.new_vec(), merge(keyword.token.span, block.span), wrap_text("for ", binding.token.lexeme, wrap_text(" in ", value.text, block.text))))
                                    } else {
                                        expr_error(body.cursor, value.span, "E1339", "expected for body")
                                    },
                                    None => expr_error(body.cursor, value.span, "E1339", "expected for body"),
                                }
                            }
                        } else {
                            iterable
                        },
                        None => expr_error(iterable.cursor, iterable.span, "E1340", "expected for iterable expression"),
                    }
                }
            }
        }
    }
}

fn parse_break_expr(cursor: ParserCursor) -> ParseExpr {
    let keyword = expect_keyword(cursor, "break", "E1341", "expected break expression");
    if has_diagnostic(keyword) {
        expr_error(keyword.cursor, keyword.token.span, "E1341", "expected break expression")
    } else if expr_stop_token(current_token(skip_trivia(keyword.cursor))) {
        expr_ok(keyword.cursor, simple_expr(AstBreakExpr(), "", "", keyword.token.span, "break"))
    } else {
        let value = parse_expr(keyword.cursor);
        if has_expr_diagnostic(value) {
            value
        } else {
            match value.expr {
                Some(expr) => if true {
                    let mut children: Vec[AstExpr] = vec.new_vec();
                    children = vec.push(children, expr);
                    expr_ok(value.cursor, expr_with_children(AstBreakExpr(), "", "", children, vec.new_vec(), merge(keyword.token.span, expr.span), wrap_text("break ", expr.text, "")))
                } else {
                    value
                },
                None => expr_ok(keyword.cursor, simple_expr(AstBreakExpr(), "", "", keyword.token.span, "break")),
            }
        }
    }
}

fn parse_unsafe_block_expr(cursor: ParserCursor) -> ParseExpr {
    let keyword = expect_keyword(cursor, "unsafe", "E1342", "expected unsafe expression");
    if has_diagnostic(keyword) {
        expr_error(keyword.cursor, keyword.token.span, "E1342", "expected unsafe expression")
    } else {
        let body = parse_block(keyword.cursor);
        if has_block_diagnostic(body) {
            ParseExpr {
                cursor: body.cursor,
                expr: None(),
                span: keyword.token.span,
                diagnostic: body.diagnostic,
            }
        } else {
            match body.block {
                Some(block) => expr_ok(body.cursor, simple_expr(AstBlockExpr(), "unsafe", "", merge(keyword.token.span, block.span), wrap_text("unsafe", block.text, ""))),
                None => expr_error(body.cursor, keyword.token.span, "E1343", "expected unsafe block"),
            }
        }
    }
}

fn parse_closure_expr(cursor: ParserCursor) -> ParseExpr {
    let active = skip_trivia(cursor);
    let token = current_token(active);
    let mut out_cursor = active;
    let mut param_texts: Vec[String] = vec.new_vec();
    let mut diagnostic: Option[Diagnostic] = None();
    if is_operator(token, "||") {
        out_cursor = advance(active);
    } else {
        let open = expect_operator(active, "|", "E1071", "expected '|' to start closure expression");
        if has_diagnostic(open) {
            out_cursor = open.cursor;
            diagnostic = open.diagnostic;
        } else {
            out_cursor = open.cursor;
        };
        let mut done = false;
        while !done && !at_operator(out_cursor, "|") && !has_optional_diagnostic(diagnostic) {
            let param = expect_identifier(out_cursor, "E1072", "expected closure parameter name");
            if has_diagnostic(param) {
                out_cursor = param.cursor;
                diagnostic = param.diagnostic;
                done = true;
            } else {
                let mut param_text = param.token.lexeme;
                out_cursor = param.cursor;
                if at_delimiter(out_cursor, ":") {
                    let colon = expect_delimiter(out_cursor, ":", "E1072", "expected closure parameter type separator");
                    let ty = parse_type_ref(colon.cursor, true);
                    if has_type_ref_diagnostic(ty) {
                        out_cursor = ty.cursor;
                        diagnostic = ty.diagnostic;
                        done = true;
                    } else {
                        match ty.type_ref {
                            Some(type_ref) => if true {
                                param_text = merge_expr_text(param_text, ":", type_text(type_ref));
                                out_cursor = ty.cursor;
                                ()
                            } else {
                                ()
                            },
                            None => if true {
                                out_cursor = ty.cursor;
                                diagnostic = Some(error(diagnostic_code("E1072"), ty.span, "expected closure parameter type"));
                                done = true;
                                ()
                            } else {
                                ()
                            },
                        }
                    }
                } else {
                    ()
                };
                if has_optional_diagnostic(diagnostic) {
                    ()
                } else {
                    param_texts = vec.push(param_texts, param_text);
                    if at_delimiter(out_cursor, ",") {
                        let comma = expect_delimiter(out_cursor, ",", "E1072", "expected closure parameter separator");
                        out_cursor = comma.cursor;
                    } else {
                        done = true;
                    }
                };
            }
        };
        if has_optional_diagnostic(diagnostic) {
            ()
        } else {
            let close = expect_operator(out_cursor, "|", "E1073", "expected '|' to end closure parameters");
            if has_diagnostic(close) {
                out_cursor = close.cursor;
                diagnostic = close.diagnostic;
            } else {
                out_cursor = close.cursor;
            }
        }
    };
    match diagnostic {
        Some(diag) => ParseExpr {
            cursor: out_cursor,
            expr: None(),
            span: token.span,
            diagnostic: Some(diag),
        },
        None => if true {
            let arrow = expect_operator(out_cursor, "->", "E1074", "expected '->' after closure parameters");
            if has_diagnostic(arrow) {
                expr_error(arrow.cursor, arrow.token.span, "E1074", "expected '->' after closure parameters")
            } else {
                let ret = parse_type_ref(arrow.cursor, false);
                if has_type_ref_diagnostic(ret) {
                    ParseExpr {
                        cursor: ret.cursor,
                        expr: None(),
                        span: ret.span,
                        diagnostic: ret.diagnostic,
                    }
                } else {
                    let body = parse_block(ret.cursor);
                    if has_block_diagnostic(body) {
                        ParseExpr {
                            cursor: body.cursor,
                            expr: None(),
                            span: ret.span,
                            diagnostic: body.diagnostic,
                        }
                    } else {
                        match body.block {
                            Some(block) => if true {
                                let ret_text = match ret.type_ref {
                                    Some(type_ref) => type_text(type_ref),
                                    None => "()",
                                };
                                let text = wrap_text("|", string.join(param_texts, ","), wrap_text("|->", ret_text, block.text));
                                expr_ok(body.cursor, simple_expr(AstClosureExpr(), "->", "", merge(token.span, block.span), text))
                            } else {
                                expr_error(body.cursor, ret.span, "E1344", "expected closure body")
                            },
                            None => expr_error(body.cursor, ret.span, "E1344", "expected closure body"),
                        }
                    }
                }
            }
        } else {
            expr_error(out_cursor, token.span, "E1344", "expected closure expression")
        },
    }
}

fn parse_match_expr(cursor: ParserCursor) -> ParseExpr {
    let keyword = expect_keyword(cursor, "match", "E1345", "expected match expression");
    if has_diagnostic(keyword) {
        expr_error(keyword.cursor, keyword.token.span, "E1345", "expected match expression")
    } else {
        let matched = parse_expr(keyword.cursor);
        if has_expr_diagnostic(matched) {
            matched
        } else {
            match matched.expr {
                Some(match_value) => if true {
                    let open = expect_delimiter(matched.cursor, "{", "E1043", "expected '{' for match arms");
                    if has_diagnostic(open) {
                        expr_error(open.cursor, open.token.span, "E1043", "expected '{' for match arms")
                    } else {
                        let mut out_cursor = open.cursor;
                        let mut children: Vec[AstExpr] = vec.new_vec();
                        let mut pattern_nodes: Vec[AstPatternNode] = vec.new_vec();
                        let mut match_arms: Vec[AstMatchArmNode] = vec.new_vec();
                        let mut text_parts: Vec[String] = vec.new_vec();
                        let mut diagnostic: Option[Diagnostic] = None();
                        let mut end_span = open.token.span;
                        let mut done = false;
                        children = vec.push(children, match_value);
                        text_parts = vec.push(text_parts, "match");
                        text_parts = vec.push(text_parts, match_value.text);
                        text_parts = vec.push(text_parts, "{");
                        while !done && !at_delimiter(out_cursor, "}") {
                            let pattern = parse_pattern(out_cursor);
                            if has_pattern_diagnostic(pattern) {
                                diagnostic = pattern.diagnostic;
                                out_cursor = pattern.cursor;
                                end_span = pattern.span;
                                done = true;
                            } else {
                                match pattern.pattern {
                                    Some(pat) => if true {
                                        let pat_text = pat.text;
                                        let pat_span = pat.span;
                                        let mut guard_text = "";
                                        pattern_nodes = vec.push(pattern_nodes, pattern_node_from_pattern(pat, "arm", 1));
                                        let mut pat_nested = 0;
                                        while pat_nested < vec.vec_len(pat.nodes) {
                                            match vec.get(pat.nodes, pat_nested) {
                                                Some(node) => if true {
                                                    pattern_nodes = vec.push(pattern_nodes, nested_pattern_node(node, 1));
                                                    ()
                                                } else {
                                                    ()
                                                },
                                                None => (),
                                            };
                                            pat_nested = pat_nested + 1;
                                        };
                                        text_parts = vec.push(text_parts, pat_text);
                                        out_cursor = pattern.cursor;
                                        if at_keyword(out_cursor, "if") {
                                            let guard_keyword = expect_keyword(out_cursor, "if", "E1346", "expected match guard");
                                            let guard = parse_expr(guard_keyword.cursor);
                                            if has_expr_diagnostic(guard) {
                                                diagnostic = guard.diagnostic;
                                                out_cursor = guard.cursor;
                                                end_span = guard.span;
                                                done = true;
                                            } else {
                                                match guard.expr {
                                                    Some(guard_expr) => if true {
                                                        text_parts = vec.push(text_parts, "if");
                                                        text_parts = vec.push(text_parts, guard_expr.text);
                                                        guard_text = guard_expr.text;
                                                        children = vec.push(children, guard_expr);
                                                        out_cursor = guard.cursor;
                                                        ()
                                                    } else {
                                                        ()
                                                    },
                                                    None => if true {
                                                        diagnostic = Some(error(diagnostic_code("E1346"), guard.span, "expected match guard expression"));
                                                        done = true;
                                                        ()
                                                    } else {
                                                        ()
                                                    },
                                                }
                                            }
                                        } else {
                                            ()
                                        };
                                        if !done {
                                            let arrow = expect_operator(out_cursor, "=>", "E1044", "expected '=>' in match arm");
                                            if has_diagnostic(arrow) {
                                                diagnostic = arrow.diagnostic;
                                                out_cursor = arrow.cursor;
                                                end_span = arrow.token.span;
                                                done = true;
                                            } else {
                                                let body = parse_expr(arrow.cursor);
                                                if has_expr_diagnostic(body) {
                                                    diagnostic = body.diagnostic;
                                                    out_cursor = body.cursor;
                                                    end_span = body.span;
                                                    done = true;
                                                } else {
                                                match body.expr {
                                                    Some(body_expr) => if true {
                                                        let body_text_value = body_expr.text;
                                                        let body_span_value = body_expr.span;
                                                        let arm_text = if guard_text == "" {
                                                            wrap_text(pat_text, "=>", body_text_value)
                                                        } else {
                                                            wrap_text(pat_text, wrap_text("if", guard_text, "=>"), body_text_value)
                                                        };
                                                        text_parts = vec.push(text_parts, "=>");
                                                        text_parts = vec.push(text_parts, body_text_value);
                                                        match_arms = vec.push(match_arms, ast_match_arm(pat_text, guard_text, body_text_value, merge(pat_span, body_span_value), arm_text));
                                                        children = vec.push(children, body_expr);
                                                        out_cursor = body.cursor;
                                                        end_span = body_span_value;
                                                        if at_delimiter(out_cursor, ",") {
                                                            let comma = expect_delimiter(out_cursor, ",", "E1347", "expected match arm separator");
                                                                text_parts = vec.push(text_parts, ",");
                                                                out_cursor = comma.cursor;
                                                            } else {
                                                                done = true;
                                                            };
                                                            ()
                                                        } else {
                                                            ()
                                                        },
                                                        None => if true {
                                                            diagnostic = Some(error(diagnostic_code("E1348"), body.span, "expected match arm body"));
                                                            done = true;
                                                            ()
                                                        } else {
                                                            ()
                                                        },
                                                    }
                                                }
                                            }
                                        } else {
                                            ()
                                        };
                                        ()
                                    } else {
                                        ()
                                    },
                                    None => if true {
                                        diagnostic = Some(error(diagnostic_code("E1048"), pattern.span, "expected match pattern"));
                                        done = true;
                                        ()
                                    } else {
                                        ()
                                    },
                                }
                            }
                        };
                        match diagnostic {
                            Some(diag) => ParseExpr {
                                cursor: out_cursor,
                                expr: None(),
                                span: merge(keyword.token.span, end_span),
                                diagnostic: Some(diag),
                            },
                            None => if true {
                                let close = expect_delimiter(out_cursor, "}", "E1045", "expected '}' after match arms");
                                if has_diagnostic(close) {
                                    expr_error(close.cursor, close.token.span, "E1045", "expected '}' after match arms")
                                } else {
                                    text_parts = vec.push(text_parts, "}");
                                    expr_ok(close.cursor, match_expr_with_arms(children, pattern_nodes, match_arms, merge(keyword.token.span, close.token.span), string.join(text_parts, "")))
                                }
                            } else {
                                expr_error(out_cursor, end_span, "E1348", "expected match expression")
                            },
                        }
                    }
                } else {
                    matched
                },
                None => expr_error(matched.cursor, matched.span, "E1349", "expected match scrutinee"),
            }
        }
    }
}

pub fn parse_pattern(cursor: ParserCursor) -> ParsePattern {
    let first = parse_pattern_atom(cursor);
    if has_pattern_diagnostic(first) {
        first
    } else {
        match first.pattern {
            Some(first_pattern) => if at_operator(first.cursor, "|") {
                let mut out_cursor = first.cursor;
                let mut patterns: Vec[AstPattern] = vec.new_vec();
                let mut end_span = first_pattern.span;
                let mut diagnostic: Option[Diagnostic] = None();
                let mut done = false;
                patterns = vec.push(patterns, first_pattern);
                while !done && at_operator(out_cursor, "|") {
                    let pipe = expect_operator(out_cursor, "|", "E1350", "expected pattern separator");
                    let next = parse_pattern_atom(pipe.cursor);
                    if has_pattern_diagnostic(next) {
                        diagnostic = next.diagnostic;
                        out_cursor = next.cursor;
                        end_span = next.span;
                        done = true;
                    } else {
                        match next.pattern {
                            Some(pattern) => if true {
                                end_span = pattern.span;
                                patterns = vec.push(patterns, pattern);
                                out_cursor = next.cursor;
                                ()
                            } else {
                                ()
                            },
                            None => if true {
                                diagnostic = Some(error(diagnostic_code("E1048"), next.span, "expected match pattern"));
                                done = true;
                                ()
                            } else {
                                ()
                            },
                        }
                    }
                };
                match diagnostic {
                    Some(diag) => ParsePattern {
                        cursor: out_cursor,
                        pattern: None(),
                        span: merge(first.span, end_span),
                        diagnostic: Some(diag),
                    },
                    None => pattern_ok(out_cursor, pattern_with_children(AstOrPattern(), "", patterns, merge(first.span, end_span), join_pattern_text(patterns, "|"))),
                }
            } else {
                pattern_ok(first.cursor, first_pattern)
            },
            None => pattern_error(first.cursor, first.span, "E1048", "expected match pattern"),
        }
    }
}

fn parse_pattern_atom(cursor: ParserCursor) -> ParsePattern {
    let active = skip_trivia(cursor);
    let token = current_token(active);
    match token.kind {
        IntegerLiteral => pattern_ok(advance(active), simple_pattern(AstIntPattern(), token.lexeme, token.span, token.lexeme)),
        StringLiteral => pattern_ok(advance(active), simple_pattern(AstStringPattern(), token.lexeme, token.span, token.lexeme)),
        CharLiteral => pattern_ok(advance(active), simple_pattern(AstCharPattern(), token.lexeme, token.span, token.lexeme)),
        Keyword => if token.lexeme == "true" || token.lexeme == "false" {
            pattern_ok(advance(active), simple_pattern(AstBoolPattern(), token.lexeme, token.span, token.lexeme))
        } else {
            pattern_error(active, token.span, "E1048", "expected match pattern")
        },
        Delimiter => if token.lexeme == "_" {
            pattern_ok(advance(active), simple_pattern(AstWildcardPattern(), "", token.span, "_"))
        } else if token.lexeme == "(" {
            parse_tuple_or_parenthesized_pattern(active)
        } else {
            pattern_error(active, token.span, "E1048", "expected match pattern")
        },
        Identifier => parse_named_pattern(active),
        _ => pattern_error(active, token.span, "E1048", "expected match pattern"),
    }
}

fn parse_tuple_or_parenthesized_pattern(cursor: ParserCursor) -> ParsePattern {
    let open = expect_delimiter(cursor, "(", "E1351", "expected pattern tuple opener");
    if has_diagnostic(open) {
        pattern_error(open.cursor, open.token.span, "E1351", "expected pattern tuple opener")
    } else if at_delimiter(open.cursor, ")") {
        let close = expect_delimiter(open.cursor, ")", "E1046", "expected ')' after unit pattern");
        if has_diagnostic(close) {
            pattern_error(close.cursor, close.token.span, "E1046", "expected ')' after unit pattern")
        } else {
            pattern_ok(close.cursor, simple_pattern(AstUnitPattern(), "", merge(open.token.span, close.token.span), "()"))
        }
    } else {
        let first = parse_pattern(open.cursor);
        if has_pattern_diagnostic(first) {
            first
        } else {
            match first.pattern {
                Some(first_pattern) => if at_delimiter(first.cursor, ",") {
                    let mut out_cursor = first.cursor;
                    let mut patterns: Vec[AstPattern] = vec.new_vec();
                    let mut end_span = first_pattern.span;
                    let mut diagnostic: Option[Diagnostic] = None();
                    let mut done = false;
                    patterns = vec.push(patterns, first_pattern);
                    while !done {
                        let comma = expect_delimiter(out_cursor, ",", "E1352", "expected tuple pattern separator");
                        out_cursor = comma.cursor;
                        if at_delimiter(out_cursor, ")") {
                            done = true;
                        } else {
                            let item = parse_pattern(out_cursor);
                            if has_pattern_diagnostic(item) {
                                diagnostic = item.diagnostic;
                                out_cursor = item.cursor;
                                end_span = item.span;
                                done = true;
                            } else {
                                match item.pattern {
                                    Some(pattern) => if true {
                                        end_span = pattern.span;
                                        patterns = vec.push(patterns, pattern);
                                        out_cursor = item.cursor;
                                        ()
                                    } else {
                                        ()
                                    },
                                    None => if true {
                                        diagnostic = Some(error(diagnostic_code("E1048"), item.span, "expected tuple pattern"));
                                        done = true;
                                        ()
                                    } else {
                                        ()
                                    },
                                };
                                if !done && !at_delimiter(out_cursor, ",") {
                                    done = true;
                                } else {
                                    ()
                                }
                            }
                        }
                    };
                    match diagnostic {
                        Some(diag) => ParsePattern {
                            cursor: out_cursor,
                            pattern: None(),
                            span: merge(open.token.span, end_span),
                            diagnostic: Some(diag),
                        },
                        None => if true {
                            let close = expect_delimiter(out_cursor, ")", "E1046", "expected ')' after tuple pattern");
                            if has_diagnostic(close) {
                                pattern_error(close.cursor, close.token.span, "E1046", "expected ')' after tuple pattern")
                            } else {
                                pattern_ok(close.cursor, pattern_with_children(AstTuplePattern(), "", patterns, merge(open.token.span, close.token.span), wrap_text("(", join_pattern_text(patterns, ","), ")")))
                            }
                        } else {
                            pattern_error(out_cursor, end_span, "E1048", "expected tuple pattern")
                        },
                    }
                } else {
                    let close = expect_delimiter(first.cursor, ")", "E1046", "expected ')' after parenthesized pattern");
                    if has_diagnostic(close) {
                        pattern_error(close.cursor, close.token.span, "E1046", "expected ')' after parenthesized pattern")
                    } else {
                        pattern_ok(close.cursor, simple_pattern(first_pattern.kind, first_pattern.name, merge(open.token.span, close.token.span), first_pattern.text))
                    }
                },
                None => pattern_error(first.cursor, first.span, "E1048", "expected match pattern"),
            }
        }
    }
}

fn parse_named_pattern(cursor: ParserCursor) -> ParsePattern {
    let name = expect_identifier(cursor, "E1048", "expected match pattern");
    if has_diagnostic(name) {
        pattern_error(name.cursor, name.token.span, "E1048", "expected match pattern")
    } else if at_delimiter(name.cursor, "(") {
        let open = expect_delimiter(name.cursor, "(", "E1353", "expected variant pattern opener");
        let mut out_cursor = open.cursor;
        let mut args: Vec[AstPattern] = vec.new_vec();
        let mut end_span = open.token.span;
        let mut diagnostic: Option[Diagnostic] = None();
        let mut done = false;
        while !done && !at_delimiter(out_cursor, ")") {
            let arg = parse_pattern(out_cursor);
            if has_pattern_diagnostic(arg) {
                diagnostic = arg.diagnostic;
                out_cursor = arg.cursor;
                end_span = arg.span;
                done = true;
            } else {
                match arg.pattern {
                    Some(pattern) => if true {
                        end_span = pattern.span;
                        args = vec.push(args, pattern);
                        out_cursor = arg.cursor;
                        if at_delimiter(out_cursor, ",") {
                            let comma = expect_delimiter(out_cursor, ",", "E1354", "expected variant pattern separator");
                            out_cursor = comma.cursor;
                        } else {
                            done = true;
                        };
                        ()
                    } else {
                        ()
                    },
                    None => if true {
                        diagnostic = Some(error(diagnostic_code("E1048"), arg.span, "expected variant pattern argument"));
                        done = true;
                        ()
                    } else {
                        ()
                    },
                }
            }
        };
        match diagnostic {
            Some(diag) => ParsePattern {
                cursor: out_cursor,
                pattern: None(),
                span: merge(name.token.span, end_span),
                diagnostic: Some(diag),
            },
            None => if true {
                let close = expect_delimiter(out_cursor, ")", "E1047", "expected ')' after variant pattern");
                if has_diagnostic(close) {
                    pattern_error(close.cursor, close.token.span, "E1047", "expected ')' after variant pattern")
                } else {
                    pattern_ok(close.cursor, pattern_with_children(AstVariantPattern(), name.token.lexeme, args, merge(name.token.span, close.token.span), wrap_text(name.token.lexeme, wrap_text("(", join_pattern_text(args, ","), ")"), "")))
                }
            } else {
                pattern_error(out_cursor, end_span, "E1048", "expected variant pattern")
            },
        }
    } else if at_delimiter(name.cursor, "{") {
        parse_struct_pattern(name.cursor, name.token)
    } else {
        pattern_ok(name.cursor, simple_pattern(AstVarPattern(), name.token.lexeme, name.token.span, name.token.lexeme))
    }
}

fn parse_struct_pattern(cursor: ParserCursor, name_token: Token) -> ParsePattern {
    let open = expect_delimiter(cursor, "{", "E1355", "expected struct pattern opener");
    if has_diagnostic(open) {
        pattern_error(open.cursor, open.token.span, "E1355", "expected struct pattern opener")
    } else {
        let mut out_cursor = open.cursor;
        let mut fields: Vec[AstPattern] = vec.new_vec();
        let mut text_parts: Vec[String] = vec.new_vec();
        let mut end_span = open.token.span;
        let mut diagnostic: Option[Diagnostic] = None();
        let mut done = false;
        text_parts = vec.push(text_parts, name_token.lexeme);
        text_parts = vec.push(text_parts, "{");
        while !done && !at_delimiter(out_cursor, "}") {
            if at_delimiter(out_cursor, "..") {
                let rest = expect_delimiter(out_cursor, "..", "E1356", "expected struct pattern rest");
                text_parts = vec.push(text_parts, "..");
                out_cursor = rest.cursor;
                end_span = rest.token.span;
                done = true;
            } else {
                if vec.vec_len(fields) > 0 {
                    text_parts = vec.push(text_parts, ",");
                } else {
                    ()
                };
                let field = expect_identifier(out_cursor, "E1049", "expected struct pattern field");
                if has_diagnostic(field) {
                    diagnostic = field.diagnostic;
                    out_cursor = field.cursor;
                    end_span = field.token.span;
                    done = true;
                } else {
                    let pat = if at_delimiter(field.cursor, ":") {
                        let colon = expect_delimiter(field.cursor, ":", "E1357", "expected ':' in struct pattern field");
                        parse_pattern(colon.cursor)
                    } else {
                        pattern_ok(field.cursor, simple_pattern(AstVarPattern(), field.token.lexeme, field.token.span, field.token.lexeme))
                    };
                    if has_pattern_diagnostic(pat) {
                        diagnostic = pat.diagnostic;
                        out_cursor = pat.cursor;
                        end_span = pat.span;
                        done = true;
                    } else {
                        match pat.pattern {
                            Some(pattern) => if true {
                                text_parts = vec.push(text_parts, field.token.lexeme);
                                if field.token.lexeme != pattern.text {
                                    text_parts = vec.push(text_parts, ":");
                                    text_parts = vec.push(text_parts, pattern.text);
                                } else {
                                    ()
                                };
                                end_span = pattern.span;
                                fields = vec.push(fields, pattern);
                                out_cursor = pat.cursor;
                                if at_delimiter(out_cursor, ",") {
                                    let comma = expect_delimiter(out_cursor, ",", "E1358", "expected struct pattern separator");
                                    out_cursor = comma.cursor;
                                } else {
                                    done = true;
                                };
                                ()
                            } else {
                                ()
                            },
                            None => if true {
                                diagnostic = Some(error(diagnostic_code("E1048"), pat.span, "expected struct field pattern"));
                                done = true;
                                ()
                            } else {
                                ()
                            },
                        }
                    }
                }
            }
        };
        match diagnostic {
            Some(diag) => ParsePattern {
                cursor: out_cursor,
                pattern: None(),
                span: merge(name_token.span, end_span),
                diagnostic: Some(diag),
            },
            None => if true {
                let close = expect_delimiter(out_cursor, "}", "E1047", "expected '}' after struct pattern");
                if has_diagnostic(close) {
                    pattern_error(close.cursor, close.token.span, "E1047", "expected '}' after struct pattern")
                } else {
                    text_parts = vec.push(text_parts, "}");
                    pattern_ok(close.cursor, pattern_with_children(AstStructPattern(), name_token.lexeme, fields, merge(name_token.span, close.token.span), string.join(text_parts, "")))
                }
            } else {
                pattern_error(out_cursor, end_span, "E1048", "expected struct pattern")
            },
        }
    }
}

fn statement_ok(cursor: ParserCursor, statement: AstStatement) -> ParseStatement {
    ParseStatement {
        cursor: cursor,
        statement: Some(statement),
        diagnostic: None(),
    }
}

fn statement_error(cursor: ParserCursor, span: SourceSpan, code: String, message: String) -> ParseStatement {
    ParseStatement {
        cursor: cursor,
        statement: None(),
        diagnostic: Some(error(diagnostic_code(code), span, message)),
    }
}

fn is_assignment_operator_token(token: Token) -> Bool {
    is_operator(token, "=") || is_operator(token, "&=") || is_operator(token, "|=") || is_operator(token, "^=") || is_operator(token, "<<=") || is_operator(token, ">>=") || is_operator(token, ">>>=")
}

fn is_assignment_statement_start(cursor: ParserCursor) -> Bool {
    let active = skip_trivia(cursor);
    let first = current_token(active);
    if is_identifier_token(first) {
        is_assignment_operator_token(current_token(skip_trivia(advance(active))))
    } else {
        false
    }
}

pub fn parse_block(cursor: ParserCursor) -> ParseBlock {
    let open = expect_delimiter(cursor, "{", "E1029", "expected '{' to start block");
    if has_diagnostic(open) {
        ParseBlock {
            cursor: open.cursor,
            block: None(),
            diagnostic: open.diagnostic,
        }
    } else {
        let mut out_cursor = open.cursor;
        let mut statements: Vec[AstStatement] = vec.new_vec();
        let mut tail_expr: Option[AstExpr] = None();
        let mut text_parts: Vec[String] = vec.new_vec();
        let mut diagnostic: Option[Diagnostic] = None();
        let mut done = false;
        text_parts = vec.push(text_parts, "{");
        while !done && !at_delimiter(out_cursor, "}") && !is_at_end(out_cursor) {
            if at_keyword(out_cursor, "let") {
                let stmt = parse_let_statement(out_cursor);
                if has_statement_diagnostic(stmt) {
                    diagnostic = stmt.diagnostic;
                    out_cursor = stmt.cursor;
                    done = true;
                } else {
                    match stmt.statement {
                        Some(statement) => if true {
                            text_parts = vec.push(text_parts, statement.text);
                            statements = vec.push(statements, statement);
                            out_cursor = stmt.cursor;
                            ()
                        } else {
                            ()
                        },
                        None => if true {
                            diagnostic = Some(error(diagnostic_code("E1360"), current_token(skip_trivia(stmt.cursor)).span, "expected let statement"));
                            done = true;
                            ()
                        } else {
                            ()
                        },
                    }
                }
            } else if at_keyword(out_cursor, "return") {
                let stmt = parse_return_statement(out_cursor);
                if has_statement_diagnostic(stmt) {
                    diagnostic = stmt.diagnostic;
                    out_cursor = stmt.cursor;
                    done = true;
                } else {
                    match stmt.statement {
                        Some(statement) => if true {
                            text_parts = vec.push(text_parts, statement.text);
                            statements = vec.push(statements, statement);
                            out_cursor = stmt.cursor;
                            ()
                        } else {
                            ()
                        },
                        None => if true {
                            diagnostic = Some(error(diagnostic_code("E1361"), current_token(skip_trivia(stmt.cursor)).span, "expected return statement"));
                            done = true;
                            ()
                        } else {
                            ()
                        },
                    }
                }
            } else if is_assignment_statement_start(out_cursor) {
                let stmt = parse_assignment_statement(out_cursor);
                if has_statement_diagnostic(stmt) {
                    diagnostic = stmt.diagnostic;
                    out_cursor = stmt.cursor;
                    done = true;
                } else {
                    match stmt.statement {
                        Some(statement) => if true {
                            text_parts = vec.push(text_parts, statement.text);
                            statements = vec.push(statements, statement);
                            out_cursor = stmt.cursor;
                            ()
                        } else {
                            ()
                        },
                        None => if true {
                            diagnostic = Some(error(diagnostic_code("E1362"), current_token(skip_trivia(stmt.cursor)).span, "expected assignment statement"));
                            done = true;
                            ()
                        } else {
                            ()
                        },
                    }
                }
            } else {
                let expr = parse_expr(out_cursor);
                if has_expr_diagnostic(expr) {
                    diagnostic = expr.diagnostic;
                    out_cursor = expr.cursor;
                    done = true;
                } else {
                    match expr.expr {
                        Some(value) => if at_delimiter(expr.cursor, ";") {
                            let semi = expect_delimiter(expr.cursor, ";", "E1363", "expected expression statement semicolon");
                            let text = wrap_text(value.text, ";", "");
                            let statement = ast_statement(AstExprStatement(), "", "", false, None(), None(), Some(value), merge(value.span, semi.token.span), text);
                            text_parts = vec.push(text_parts, statement.text);
                            statements = vec.push(statements, statement);
                            out_cursor = semi.cursor;
                        } else {
                            text_parts = vec.push(text_parts, value.text);
                            tail_expr = Some(value);
                            out_cursor = expr.cursor;
                            done = true;
                        },
                        None => if true {
                            diagnostic = Some(error(diagnostic_code("E1300"), expr.span, "expected expression"));
                            done = true;
                            ()
                        } else {
                            ()
                        },
                    }
                }
            }
        };
        match diagnostic {
            Some(diag) => ParseBlock {
                cursor: out_cursor,
                block: None(),
                diagnostic: Some(diag),
            },
            None => if true {
                let close = expect_delimiter(out_cursor, "}", "E1030", "expected '}' to close block");
                if has_diagnostic(close) {
                    ParseBlock {
                        cursor: close.cursor,
                        block: None(),
                        diagnostic: close.diagnostic,
                    }
                } else {
                    text_parts = vec.push(text_parts, "}");
                    ParseBlock {
                        cursor: close.cursor,
                        block: Some(ast_block(statements, tail_expr, merge(open.token.span, close.token.span), string.join(text_parts, ""))),
                        diagnostic: None(),
                    }
                }
            } else {
                ParseBlock {
                    cursor: out_cursor,
                    block: None(),
                    diagnostic: Some(error(diagnostic_code("E1030"), open.token.span, "expected block")),
                }
            },
        }
    }
}

fn parse_let_statement(cursor: ParserCursor) -> ParseStatement {
    let keyword = expect_keyword(cursor, "let", "E1364", "expected let statement");
    if has_diagnostic(keyword) {
        statement_error(keyword.cursor, keyword.token.span, "E1364", "expected let statement")
    } else {
        let mutable = at_keyword(keyword.cursor, "mut");
        let after_mut = if mutable { advance(skip_trivia(keyword.cursor)) } else { keyword.cursor };
        let pattern = parse_pattern(after_mut);
        if has_pattern_diagnostic(pattern) {
            ParseStatement {
                cursor: pattern.cursor,
                statement: None(),
                diagnostic: pattern.diagnostic,
            }
        } else {
            match pattern.pattern {
                Some(pat) => if true {
                    let type_result = if at_delimiter(pattern.cursor, ":") {
                        let colon = expect_delimiter(pattern.cursor, ":", "E1365", "expected let type separator");
                        parse_type_ref(colon.cursor, false)
                    } else {
                        ParseTypeRef {
                            cursor: pattern.cursor,
                            type_ref: None(),
                            span: empty_span(pattern.cursor.source, current_token(skip_trivia(pattern.cursor)).span.start),
                            diagnostic: None(),
                        }
                    };
                    if has_type_ref_diagnostic(type_result) {
                        ParseStatement {
                            cursor: type_result.cursor,
                            statement: None(),
                            diagnostic: type_result.diagnostic,
                        }
                    } else {
                        let eq = expect_operator(type_result.cursor, "=", "E1032", "expected '=' in let binding");
                        if has_diagnostic(eq) {
                            statement_error(eq.cursor, eq.token.span, "E1032", "expected '=' in let binding")
                        } else {
                            let expr = parse_expr(eq.cursor);
                            if has_expr_diagnostic(expr) {
                                ParseStatement {
                                    cursor: expr.cursor,
                                    statement: None(),
                                    diagnostic: expr.diagnostic,
                                }
                            } else {
                                match expr.expr {
                                    Some(value) => if true {
                                        let semi = expect_delimiter(expr.cursor, ";", "E1033", "expected ';' after let binding");
                                        if has_diagnostic(semi) {
                                            statement_error(semi.cursor, semi.token.span, "E1033", "expected ';' after let binding")
                                        } else {
                                            let type_text_value = match type_result.type_ref {
                                                Some(type_ref) => wrap_text(":", type_text(type_ref), ""),
                                                None => "",
                                            };
                                            let mut parts: Vec[String] = vec.new_vec();
                                            parts = vec.push(parts, "let ");
                                            if mutable {
                                                parts = vec.push(parts, "mut ");
                                            } else {
                                                ()
                                            };
                                            parts = vec.push(parts, pat.text);
                                            parts = vec.push(parts, type_text_value);
                                            parts = vec.push(parts, "=");
                                            parts = vec.push(parts, value.text);
                                            parts = vec.push(parts, ";");
                                            statement_ok(semi.cursor, ast_statement(AstLetStatement(), pat.text, "", mutable, type_result.type_ref, Some(pat), Some(value), merge(keyword.token.span, semi.token.span), string.join(parts, "")))
                                        }
                                    } else {
                                        statement_error(expr.cursor, expr.span, "E1366", "expected let initializer")
                                    },
                                    None => statement_error(expr.cursor, expr.span, "E1366", "expected let initializer"),
                                }
                            }
                        }
                    }
                } else {
                    statement_error(pattern.cursor, pattern.span, "E1367", "expected let pattern")
                },
                None => statement_error(pattern.cursor, pattern.span, "E1367", "expected let pattern"),
            }
        }
    }
}

fn parse_assignment_statement(cursor: ParserCursor) -> ParseStatement {
    let target = expect_identifier(cursor, "E1060", "expected assignment target");
    if has_diagnostic(target) {
        statement_error(target.cursor, target.token.span, "E1060", "expected assignment target")
    } else {
        let op_token = current_token(skip_trivia(target.cursor));
        if !is_assignment_operator_token(op_token) {
            statement_error(target.cursor, op_token.span, "E1061", "expected assignment operator")
        } else {
            let value = parse_expr(advance(skip_trivia(target.cursor)));
            if has_expr_diagnostic(value) {
                ParseStatement {
                    cursor: value.cursor,
                    statement: None(),
                    diagnostic: value.diagnostic,
                }
            } else {
                match value.expr {
                    Some(expr) => if true {
                        let semi = expect_delimiter(value.cursor, ";", "E1062", "expected ';' after assignment");
                        if has_diagnostic(semi) {
                            statement_error(semi.cursor, semi.token.span, "E1062", "expected ';' after assignment")
                        } else {
                            let text = wrap_text(target.token.lexeme, op_token.lexeme, wrap_text(expr.text, ";", ""));
                            statement_ok(semi.cursor, ast_statement(AstAssignStatement(), "", target.token.lexeme, false, None(), None(), Some(expr), merge(target.token.span, semi.token.span), text))
                        }
                    } else {
                        statement_error(value.cursor, value.span, "E1368", "expected assignment value")
                    },
                    None => statement_error(value.cursor, value.span, "E1368", "expected assignment value"),
                }
            }
        }
    }
}

fn parse_return_statement(cursor: ParserCursor) -> ParseStatement {
    let keyword = expect_keyword(cursor, "return", "E1369", "expected return statement");
    if has_diagnostic(keyword) {
        statement_error(keyword.cursor, keyword.token.span, "E1369", "expected return statement")
    } else if at_delimiter(keyword.cursor, ";") {
        let semi = expect_delimiter(keyword.cursor, ";", "E1034", "expected ';' after return");
        statement_ok(semi.cursor, ast_statement(AstReturnStatement(), "", "", false, None(), None(), None(), merge(keyword.token.span, semi.token.span), "return;"))
    } else {
        let value = parse_expr(keyword.cursor);
        if has_expr_diagnostic(value) {
            ParseStatement {
                cursor: value.cursor,
                statement: None(),
                diagnostic: value.diagnostic,
            }
        } else {
            match value.expr {
                Some(expr) => if true {
                    let semi = expect_delimiter(value.cursor, ";", "E1034", "expected ';' after return");
                    if has_diagnostic(semi) {
                        statement_error(semi.cursor, semi.token.span, "E1034", "expected ';' after return")
                    } else {
                        statement_ok(semi.cursor, ast_statement(AstReturnStatement(), "", "", false, None(), None(), Some(expr), merge(keyword.token.span, semi.token.span), wrap_text("return ", expr.text, ";")))
                    }
                } else {
                    statement_error(value.cursor, value.span, "E1370", "expected return expression")
                },
                None => statement_error(value.cursor, value.span, "E1370", "expected return expression"),
            }
        }
    }
}

fn struct_field_result(
    cursor: ParserCursor,
    attrs: Vec[AstAttribute],
    name_token: Token,
    visibility: AstVisibility,
    type_ref: AstType,
    default_expr: Option[AstExpr],
    default_text: String,
    field_start: SourceSpan,
    field_end: SourceSpan,
) -> ParseStructField {
    ParseStructField {
        cursor: cursor,
        field: Some(ast_field_with_attrs(attrs, ast_name(name_token.lexeme, name_token.span), visibility, type_ref, default_expr, default_text, merge(field_start, field_end))),
        diagnostic: None(),
    }
}

pub fn parse_struct_field(cursor: ParserCursor) -> ParseStructField {
    let start_token = current_token(skip_trivia(cursor));
    let attrs_result = parse_attribute_list(cursor);
    if has_attribute_list_diagnostic(attrs_result) {
        ParseStructField {
            cursor: attrs_result.cursor,
            field: None(),
            diagnostic: attrs_result.diagnostic,
        }
    } else {
    let visibility_result = parse_visibility(attrs_result.cursor);
    if has_visibility_diagnostic(visibility_result) {
        ParseStructField {
            cursor: visibility_result.cursor,
            field: None(),
            diagnostic: visibility_result.diagnostic,
        }
    } else {
        let name_result = expect_identifier(visibility_result.cursor, "E1121", "expected struct field name");
        if has_diagnostic(name_result) {
            ParseStructField {
                cursor: name_result.cursor,
                field: None(),
                diagnostic: name_result.diagnostic,
            }
        } else {
            let colon_result = expect_delimiter(name_result.cursor, ":", "E1122", "expected ':' after struct field name");
            if has_diagnostic(colon_result) {
                ParseStructField {
                    cursor: colon_result.cursor,
                    field: None(),
                    diagnostic: colon_result.diagnostic,
                }
            } else {
                let type_result = parse_type_ref(colon_result.cursor, true);
                if has_type_ref_diagnostic(type_result) {
                    ParseStructField {
                        cursor: type_result.cursor,
                        field: None(),
                        diagnostic: type_result.diagnostic,
                    }
                } else {
                    let mut out_cursor = type_result.cursor;
                    let mut default_expr: Option[AstExpr] = None();
                    let mut default_text = "";
                    let mut field_end = type_result.span;
                    let mut default_diagnostic: Option[Diagnostic] = None();
                    if at_operator(out_cursor, "=") {
                        let eq_result = expect_operator(out_cursor, "=", "E1123", "expected struct field default assignment");
                        let default_result = parse_expr(eq_result.cursor);
                        out_cursor = default_result.cursor;
                        field_end = default_result.span;
                        default_diagnostic = default_result.diagnostic;
                        match default_result.expr {
                            Some(expr) => if true {
                                default_text = expr.text;
                                default_expr = Some(expr);
                                ()
                            } else {
                                ()
                            },
                            None => (),
                        };
                    } else {
                        ()
                    };

                    match default_diagnostic {
                        Some(diag) => ParseStructField {
                            cursor: out_cursor,
                            field: None(),
                            diagnostic: Some(diag),
                        },
	                        None => match visibility_result.visibility {
	                            Some(visibility) => match type_result.type_ref {
	                                Some(type_ref) => struct_field_result(out_cursor, attrs_result.attrs, name_result.token, visibility, type_ref, default_expr, default_text, start_token.span, field_end),
	                                None => ParseStructField {
                                    cursor: type_result.cursor,
                                    field: None(),
                                    diagnostic: Some(error(diagnostic_code("E1125"), type_result.span, "missing struct field type")),
                                },
                            },
                            None => ParseStructField {
                                cursor: visibility_result.cursor,
                                field: None(),
                                diagnostic: Some(error(diagnostic_code("E1126"), visibility_result.span, "missing struct field visibility")),
                            },
                        },
                    }
                }
            }
        }
    }
    }
}

pub fn parse_struct_field_list(cursor: ParserCursor) -> ParseStructFieldList {
    let open_result = expect_delimiter(cursor, "{", "E1130", "expected struct field list opener");
    if has_diagnostic(open_result) {
        ParseStructFieldList {
            cursor: open_result.cursor,
            fields: vec.new_vec(),
            span: open_result.token.span,
            diagnostic: open_result.diagnostic,
        }
    } else {
        let mut out_cursor = open_result.cursor;
        let mut fields: Vec[AstField] = vec.new_vec();
        let mut end_span = open_result.token.span;
        let mut diagnostic: Option[Diagnostic] = None();
        let mut done = false;
        if at_delimiter(out_cursor, "}") {
            let close_result = expect_delimiter(out_cursor, "}", "E1131", "expected struct field list closer");
            out_cursor = close_result.cursor;
            end_span = close_result.token.span;
            diagnostic = close_result.diagnostic;
            done = true;
        } else {
            ()
        };

        while !done {
            let field_result = parse_struct_field(out_cursor);
            if has_struct_field_diagnostic(field_result) {
                out_cursor = field_result.cursor;
                diagnostic = field_result.diagnostic;
                done = true;
            } else {
                let field_count_before = vec.vec_len(fields);
                fields = match field_result.field {
                    Some(field) => vec.push(fields, field),
                    None => fields,
                };
                out_cursor = field_result.cursor;
                if vec.vec_len(fields) == field_count_before {
                    diagnostic = Some(error(diagnostic_code("E1132"), current_token(skip_trivia(field_result.cursor)).span, "missing struct field"));
                    done = true;
                } else if at_delimiter(out_cursor, ",") {
                    let comma_result = expect_delimiter(out_cursor, ",", "E1133", "expected struct field separator");
                    out_cursor = comma_result.cursor;
                    end_span = comma_result.token.span;
                    if at_delimiter(out_cursor, "}") {
                        let close_result = expect_delimiter(out_cursor, "}", "E1131", "expected struct field list closer");
                        out_cursor = close_result.cursor;
                        end_span = close_result.token.span;
                        diagnostic = close_result.diagnostic;
                        done = true;
                    } else {
                        ()
                    };
                } else {
                    let close_result = expect_delimiter(out_cursor, "}", "E1131", "expected struct field list closer");
                    out_cursor = close_result.cursor;
                    end_span = close_result.token.span;
                    diagnostic = close_result.diagnostic;
                    done = true;
                };
            };
        };

        ParseStructFieldList {
            cursor: out_cursor,
            fields: fields,
            span: merge(open_result.token.span, end_span),
            diagnostic: diagnostic,
        }
    }
}

fn struct_decl_result(
    cursor: ParserCursor,
    header: AstItemHeader,
    generic_params: AstGenericParamList,
    fields: Vec[AstField],
    field_span: SourceSpan,
    invariant_expr: Option[AstExpr],
    invariant_text: String,
    invariant_span: SourceSpan,
) -> ParseStructDecl {
    let mut item_span = merge(header.span, field_span);
    if invariant_span.start != invariant_span.end {
        item_span = merge(item_span, invariant_span);
    } else {
        ()
    };
    ParseStructDecl {
        cursor: cursor,
        struct_item: Some(struct_decl(header.name, header.visibility, generic_params, fields, invariant_expr, invariant_text, item_span)),
        diagnostic: None(),
    }
}

pub fn parse_struct_declaration(cursor: ParserCursor) -> ParseStructDecl {
    let header_result = parse_item_header(cursor);
    if has_item_header_diagnostic(header_result) {
        ParseStructDecl {
            cursor: header_result.cursor,
            struct_item: None(),
            diagnostic: header_result.diagnostic,
        }
    } else {
        match header_result.header {
            Some(header) => if is_struct_item_kind(header.kind) {
                let generic_result = parse_optional_generic_params(header_result.cursor);
                if has_generic_params_diagnostic(generic_result) {
                    ParseStructDecl {
                        cursor: generic_result.cursor,
                        struct_item: None(),
                        diagnostic: generic_result.diagnostic,
                    }
                } else {
                    let fields_result = parse_struct_field_list(generic_result.cursor);
                    if has_struct_field_list_diagnostic(fields_result) {
                        ParseStructDecl {
                            cursor: fields_result.cursor,
                            struct_item: None(),
                            diagnostic: fields_result.diagnostic,
                        }
	                    } else {
	                        if at_keyword(fields_result.cursor, "invariant") {
	                            let invariant_keyword = expect_keyword(fields_result.cursor, "invariant", "E1140", "expected struct invariant keyword");
	                            let invariant_result = parse_expr(invariant_keyword.cursor);
	                            if has_expr_diagnostic(invariant_result) {
	                                ParseStructDecl {
	                                    cursor: invariant_result.cursor,
	                                    struct_item: None(),
	                                    diagnostic: invariant_result.diagnostic,
	                                }
	                            } else {
                                    match invariant_result.expr {
                                        Some(invariant_expr) => struct_decl_result(
                                            invariant_result.cursor,
                                            header,
                                            generic_result.params,
                                            fields_result.fields,
                                            fields_result.span,
                                            Some(invariant_expr),
                                            invariant_expr.text,
                                            merge(invariant_keyword.token.span, invariant_result.span),
                                        ),
                                        None => ParseStructDecl {
                                            cursor: invariant_result.cursor,
                                            struct_item: None(),
                                            diagnostic: Some(error(diagnostic_code("E1141"), invariant_result.span, "expected struct invariant expression")),
                                        },
                                    }
	                            }
	                        } else {
	                            struct_decl_result(
	                                fields_result.cursor,
	                                header,
	                                generic_result.params,
	                                fields_result.fields,
	                                fields_result.span,
	                                None(),
	                                "",
	                                empty_span(fields_result.cursor.source, current_token(skip_trivia(fields_result.cursor)).span.start),
	                            )
                        }
                    }
                }
            } else {
                ParseStructDecl {
                    cursor: header_result.cursor,
                    struct_item: None(),
                    diagnostic: Some(error(diagnostic_code("E1142"), header.span, "expected struct item")),
                }
            },
            None => ParseStructDecl {
                cursor: header_result.cursor,
                struct_item: None(),
                diagnostic: Some(error(diagnostic_code("E1143"), current_token(skip_trivia(header_result.cursor)).span, "missing struct header")),
            },
        }
    }
}

fn enum_variant_result(
    cursor: ParserCursor,
    attrs: Vec[AstAttribute],
    name_token: Token,
    payload_type: Option[AstType],
    variant_start: SourceSpan,
    variant_end: SourceSpan,
) -> ParseEnumVariant {
    ParseEnumVariant {
        cursor: cursor,
        variant: Some(enum_variant_with_attrs(attrs, ast_name(name_token.lexeme, name_token.span), payload_type, merge(variant_start, variant_end))),
        diagnostic: None(),
    }
}

pub fn parse_enum_variant(cursor: ParserCursor) -> ParseEnumVariant {
    let start_token = current_token(skip_trivia(cursor));
    let attrs_result = parse_attribute_list(cursor);
    if has_attribute_list_diagnostic(attrs_result) {
        ParseEnumVariant {
            cursor: attrs_result.cursor,
            variant: None(),
            diagnostic: attrs_result.diagnostic,
        }
    } else {
    let name_result = expect_identifier(attrs_result.cursor, "E1150", "expected enum variant name");
    if has_diagnostic(name_result) {
        ParseEnumVariant {
            cursor: name_result.cursor,
            variant: None(),
            diagnostic: name_result.diagnostic,
        }
    } else {
        if at_delimiter(name_result.cursor, "(") {
            let open_result = expect_delimiter(name_result.cursor, "(", "E1151", "expected enum variant payload opener");
            let payload_result = parse_type_ref(open_result.cursor, false);
            if has_type_ref_diagnostic(payload_result) {
                ParseEnumVariant {
                    cursor: payload_result.cursor,
                    variant: None(),
                    diagnostic: payload_result.diagnostic,
                }
            } else {
                let close_result = expect_delimiter(payload_result.cursor, ")", "E1152", "expected ')' after enum variant payload type");
                if has_diagnostic(close_result) {
                    ParseEnumVariant {
                        cursor: close_result.cursor,
                        variant: None(),
                        diagnostic: close_result.diagnostic,
                    }
                } else {
                    match payload_result.type_ref {
                        Some(payload_type) => enum_variant_result(close_result.cursor, attrs_result.attrs, name_result.token, Some(payload_type), start_token.span, close_result.token.span),
                        None => ParseEnumVariant {
                            cursor: payload_result.cursor,
                            variant: None(),
                            diagnostic: Some(error(diagnostic_code("E1153"), payload_result.span, "missing enum variant payload type")),
                        },
                    }
                }
            }
        } else {
            enum_variant_result(name_result.cursor, attrs_result.attrs, name_result.token, None(), start_token.span, name_result.token.span)
        }
    }
    }
}

pub fn parse_enum_variant_list(cursor: ParserCursor) -> ParseEnumVariantList {
    let open_result = expect_delimiter(cursor, "{", "E1160", "expected enum variant list opener");
    if has_diagnostic(open_result) {
        ParseEnumVariantList {
            cursor: open_result.cursor,
            variants: vec.new_vec(),
            span: open_result.token.span,
            diagnostic: open_result.diagnostic,
        }
    } else {
        let mut out_cursor = open_result.cursor;
        let mut variants: Vec[AstEnumVariant] = vec.new_vec();
        let mut end_span = open_result.token.span;
        let mut diagnostic: Option[Diagnostic] = None();
        let mut done = false;
        if at_delimiter(out_cursor, "}") {
            let close_result = expect_delimiter(out_cursor, "}", "E1161", "expected enum variant list closer");
            out_cursor = close_result.cursor;
            end_span = close_result.token.span;
            diagnostic = close_result.diagnostic;
            done = true;
        } else {
            ()
        };

        while !done {
            let variant_result = parse_enum_variant(out_cursor);
            if has_enum_variant_diagnostic(variant_result) {
                out_cursor = variant_result.cursor;
                diagnostic = variant_result.diagnostic;
                done = true;
            } else {
                let variant_count_before = vec.vec_len(variants);
                variants = match variant_result.variant {
                    Some(variant) => vec.push(variants, variant),
                    None => variants,
                };
                out_cursor = variant_result.cursor;
                if vec.vec_len(variants) == variant_count_before {
                    diagnostic = Some(error(diagnostic_code("E1162"), current_token(skip_trivia(variant_result.cursor)).span, "missing enum variant"));
                    done = true;
                } else if at_delimiter(out_cursor, ",") {
                    let comma_result = expect_delimiter(out_cursor, ",", "E1163", "expected enum variant separator");
                    out_cursor = comma_result.cursor;
                    end_span = comma_result.token.span;
                    if at_delimiter(out_cursor, "}") {
                        let close_result = expect_delimiter(out_cursor, "}", "E1161", "expected enum variant list closer");
                        out_cursor = close_result.cursor;
                        end_span = close_result.token.span;
                        diagnostic = close_result.diagnostic;
                        done = true;
                    } else {
                        ()
                    };
                } else {
                    let close_result = expect_delimiter(out_cursor, "}", "E1161", "expected enum variant list closer");
                    out_cursor = close_result.cursor;
                    end_span = close_result.token.span;
                    diagnostic = close_result.diagnostic;
                    done = true;
                };
            };
        };

        ParseEnumVariantList {
            cursor: out_cursor,
            variants: variants,
            span: merge(open_result.token.span, end_span),
            diagnostic: diagnostic,
        }
    }
}

fn enum_decl_result(
    cursor: ParserCursor,
    header: AstItemHeader,
    generic_params: AstGenericParamList,
    variants: Vec[AstEnumVariant],
    variant_span: SourceSpan,
) -> ParseEnumDecl {
    ParseEnumDecl {
        cursor: cursor,
        enum_item: Some(enum_decl(header.name, header.visibility, generic_params, variants, merge(header.span, variant_span))),
        diagnostic: None(),
    }
}

pub fn parse_enum_declaration(cursor: ParserCursor) -> ParseEnumDecl {
    let header_result = parse_item_header(cursor);
    if has_item_header_diagnostic(header_result) {
        ParseEnumDecl {
            cursor: header_result.cursor,
            enum_item: None(),
            diagnostic: header_result.diagnostic,
        }
    } else {
        match header_result.header {
            Some(header) => if is_enum_item_kind(header.kind) {
                let generic_result = parse_optional_generic_params(header_result.cursor);
                if has_generic_params_diagnostic(generic_result) {
                    ParseEnumDecl {
                        cursor: generic_result.cursor,
                        enum_item: None(),
                        diagnostic: generic_result.diagnostic,
                    }
                } else {
                    let variants_result = parse_enum_variant_list(generic_result.cursor);
                    if has_enum_variant_list_diagnostic(variants_result) {
                        ParseEnumDecl {
                            cursor: variants_result.cursor,
                            enum_item: None(),
                            diagnostic: variants_result.diagnostic,
                        }
                    } else {
                        enum_decl_result(variants_result.cursor, header, generic_result.params, variants_result.variants, variants_result.span)
                    }
                }
            } else {
                ParseEnumDecl {
                    cursor: header_result.cursor,
                    enum_item: None(),
                    diagnostic: Some(error(diagnostic_code("E1170"), header.span, "expected enum item")),
                }
            },
            None => ParseEnumDecl {
                cursor: header_result.cursor,
                enum_item: None(),
                diagnostic: Some(error(diagnostic_code("E1171"), current_token(skip_trivia(header_result.cursor)).span, "missing enum header")),
            },
        }
    }
}

fn type_alias_decl_result(
    cursor: ParserCursor,
    header: AstItemHeader,
    generic_params: AstGenericParamList,
    target_type: AstType,
    end_span: SourceSpan,
) -> ParseTypeAliasDecl {
    ParseTypeAliasDecl {
        cursor: cursor,
        alias_item: Some(type_alias_decl(header.name, generic_params, target_type, merge(header.span, end_span))),
        diagnostic: None(),
    }
}

pub fn parse_type_alias_declaration(cursor: ParserCursor) -> ParseTypeAliasDecl {
    let header_result = parse_item_header(cursor);
    if has_item_header_diagnostic(header_result) {
        ParseTypeAliasDecl {
            cursor: header_result.cursor,
            alias_item: None(),
            diagnostic: header_result.diagnostic,
        }
    } else {
        match header_result.header {
            Some(header) => if is_type_alias_item_kind(header.kind) {
                if !is_private_visibility_kind(header.visibility) {
                    ParseTypeAliasDecl {
                        cursor: header_result.cursor,
                        alias_item: None(),
                        diagnostic: Some(error(diagnostic_code("E1180"), header.span, "visibility modifiers are not supported on type aliases")),
                    }
                } else {
                    let generic_result = parse_optional_generic_params(header_result.cursor);
                    if has_generic_params_diagnostic(generic_result) {
                        ParseTypeAliasDecl {
                            cursor: generic_result.cursor,
                            alias_item: None(),
                            diagnostic: generic_result.diagnostic,
                        }
                    } else {
                        let eq_result = expect_operator(generic_result.cursor, "=", "E1181", "expected '=' in type alias declaration");
                        if has_diagnostic(eq_result) {
                            ParseTypeAliasDecl {
                                cursor: eq_result.cursor,
                                alias_item: None(),
                                diagnostic: eq_result.diagnostic,
                            }
                        } else {
                            let target_result = parse_type_ref(eq_result.cursor, false);
                            if has_type_ref_diagnostic(target_result) {
                                ParseTypeAliasDecl {
                                    cursor: target_result.cursor,
                                    alias_item: None(),
                                    diagnostic: target_result.diagnostic,
                                }
                            } else {
                                let semi_result = expect_delimiter(target_result.cursor, ";", "E1182", "expected semicolon after type alias declaration");
                                if has_diagnostic(semi_result) {
                                    ParseTypeAliasDecl {
                                        cursor: semi_result.cursor,
                                        alias_item: None(),
                                        diagnostic: semi_result.diagnostic,
                                    }
                                } else {
                                    match target_result.type_ref {
                                        Some(target_type) => type_alias_decl_result(semi_result.cursor, header, generic_result.params, target_type, semi_result.token.span),
                                        None => ParseTypeAliasDecl {
                                            cursor: target_result.cursor,
                                            alias_item: None(),
                                            diagnostic: Some(error(diagnostic_code("E1183"), target_result.span, "missing type alias target type")),
                                        },
                                    }
                                }
                            }
                        }
                    }
                }
            } else {
                ParseTypeAliasDecl {
                    cursor: header_result.cursor,
                    alias_item: None(),
                    diagnostic: Some(error(diagnostic_code("E1184"), header.span, "expected type alias item")),
                }
            },
            None => ParseTypeAliasDecl {
                cursor: header_result.cursor,
                alias_item: None(),
                diagnostic: Some(error(diagnostic_code("E1185"), current_token(skip_trivia(header_result.cursor)).span, "missing type alias header")),
            },
        }
    }
}

fn const_decl_result(
    cursor: ParserCursor,
    header: AstItemHeader,
    type_ref: AstType,
    initializer_expr: AstExpr,
    initializer_text: String,
    end_span: SourceSpan,
) -> ParseConstDecl {
    ParseConstDecl {
        cursor: cursor,
        const_item: Some(const_decl(header.name, type_ref, Some(initializer_expr), initializer_text, merge(header.span, end_span))),
        diagnostic: None(),
    }
}

pub fn parse_const_declaration(cursor: ParserCursor) -> ParseConstDecl {
    let header_result = parse_item_header(cursor);
    if has_item_header_diagnostic(header_result) {
        ParseConstDecl {
            cursor: header_result.cursor,
            const_item: None(),
            diagnostic: header_result.diagnostic,
        }
    } else {
        match header_result.header {
            Some(header) => if is_const_item_kind(header.kind) {
                if !is_private_visibility_kind(header.visibility) {
                    ParseConstDecl {
                        cursor: header_result.cursor,
                        const_item: None(),
                        diagnostic: Some(error(diagnostic_code("E1190"), header.span, "visibility modifiers are not supported on const items")),
                    }
                } else {
                    let colon_result = expect_delimiter(header_result.cursor, ":", "E1191", "expected ':' after const name");
                    if has_diagnostic(colon_result) {
                        ParseConstDecl {
                            cursor: colon_result.cursor,
                            const_item: None(),
                            diagnostic: colon_result.diagnostic,
                        }
                    } else {
                        let type_result = parse_type_ref(colon_result.cursor, false);
                        if has_type_ref_diagnostic(type_result) {
                            ParseConstDecl {
                                cursor: type_result.cursor,
                                const_item: None(),
                                diagnostic: type_result.diagnostic,
                            }
                        } else {
                            let eq_result = expect_operator(type_result.cursor, "=", "E1192", "expected '=' in const declaration");
                            if has_diagnostic(eq_result) {
                                ParseConstDecl {
                                    cursor: eq_result.cursor,
                                    const_item: None(),
                                    diagnostic: eq_result.diagnostic,
                                }
                            } else {
	                                let initializer_result = parse_expr(eq_result.cursor);
	                                if has_expr_diagnostic(initializer_result) {
	                                    ParseConstDecl {
	                                        cursor: initializer_result.cursor,
	                                        const_item: None(),
	                                        diagnostic: initializer_result.diagnostic,
	                                    }
	                                } else {
	                                    let semi_result = expect_delimiter(initializer_result.cursor, ";", "E1194", "expected semicolon after const declaration");
                                    if has_diagnostic(semi_result) {
                                        ParseConstDecl {
                                            cursor: semi_result.cursor,
                                            const_item: None(),
                                            diagnostic: semi_result.diagnostic,
                                        }
	                                    } else {
                                            match initializer_result.expr {
                                                Some(initializer_expr) => match type_result.type_ref {
                                                    Some(type_ref) => const_decl_result(semi_result.cursor, header, type_ref, initializer_expr, initializer_expr.text, semi_result.token.span),
                                                    None => ParseConstDecl {
                                                        cursor: type_result.cursor,
                                                        const_item: None(),
                                                        diagnostic: Some(error(diagnostic_code("E1195"), type_result.span, "missing const type")),
                                                    },
                                                },
                                                None => ParseConstDecl {
                                                    cursor: initializer_result.cursor,
                                                    const_item: None(),
                                                    diagnostic: Some(error(diagnostic_code("E1193"), initializer_result.span, "expected const initializer expression")),
                                                },
                                            }
	                                    }
	                                }
                            }
                        }
                    }
                }
            } else {
                ParseConstDecl {
                    cursor: header_result.cursor,
                    const_item: None(),
                    diagnostic: Some(error(diagnostic_code("E1196"), header.span, "expected const item")),
                }
            },
            None => ParseConstDecl {
                cursor: header_result.cursor,
                const_item: None(),
                diagnostic: Some(error(diagnostic_code("E1197"), current_token(skip_trivia(header_result.cursor)).span, "missing const header")),
            },
        }
    }
}

pub fn parse_function_declaration(cursor: ParserCursor) -> ParseFunctionDecl {
    let signature_result = parse_function_signature(cursor);
    if has_function_signature_diagnostic(signature_result) {
        ParseFunctionDecl {
            cursor: signature_result.cursor,
            function_item: None(),
            diagnostic: signature_result.diagnostic,
        }
    } else {
        match signature_result.signature {
            Some(signature) => if true {
                let mut out_cursor = signature_result.cursor;
                let mut requires_expr: Option[AstExpr] = None();
                let mut ensures_expr: Option[AstExpr] = None();
                let mut diagnostic: Option[Diagnostic] = None();
                let mut contract_span = signature.span;
                if at_keyword(out_cursor, "requires") {
                    let keyword = expect_keyword(out_cursor, "requires", "E1371", "expected requires clause");
                    let expr = parse_expr(keyword.cursor);
                    if has_expr_diagnostic(expr) {
                        diagnostic = expr.diagnostic;
                        out_cursor = expr.cursor;
                        contract_span = expr.span;
                    } else {
                        match expr.expr {
                            Some(value) => if true {
                                contract_span = value.span;
                                requires_expr = Some(value);
                                out_cursor = expr.cursor;
                                ()
                            } else {
                                ()
                            },
                            None => if true {
                                diagnostic = Some(error(diagnostic_code("E1372"), expr.span, "expected requires expression"));
                                out_cursor = expr.cursor;
                                contract_span = expr.span;
                                ()
                            } else {
                                ()
                            },
                        }
                    }
                } else {
                    ()
                };
                if !has_optional_diagnostic(diagnostic) && at_keyword(out_cursor, "ensures") {
                    let keyword = expect_keyword(out_cursor, "ensures", "E1373", "expected ensures clause");
                    let expr = parse_expr(keyword.cursor);
                    if has_expr_diagnostic(expr) {
                        diagnostic = expr.diagnostic;
                        out_cursor = expr.cursor;
                        contract_span = expr.span;
                    } else {
                        match expr.expr {
                            Some(value) => if true {
                                contract_span = value.span;
                                ensures_expr = Some(value);
                                out_cursor = expr.cursor;
                                ()
                            } else {
                                ()
                            },
                            None => if true {
                                diagnostic = Some(error(diagnostic_code("E1374"), expr.span, "expected ensures expression"));
                                out_cursor = expr.cursor;
                                contract_span = expr.span;
                                ()
                            } else {
                                ()
                            },
                        }
                    }
                } else {
                    ()
                };
                match diagnostic {
                    Some(diag) => ParseFunctionDecl {
                        cursor: out_cursor,
                        function_item: None(),
                        diagnostic: Some(diag),
                    },
                    None => if true {
                        let body = parse_block(out_cursor);
                        if has_block_diagnostic(body) {
                            ParseFunctionDecl {
                                cursor: body.cursor,
                                function_item: None(),
                                diagnostic: body.diagnostic,
                            }
                        } else {
                            match body.block {
                                Some(block) => if type_text(signature.return_type) != "()" && !block_has_required_tail(block) {
                                    ParseFunctionDecl {
                                        cursor: body.cursor,
                                        function_item: None(),
                                        diagnostic: Some(error(diagnostic_code("E1377"), block.span, "expected tail expression or return statement in non-unit function body")),
                                    }
                                } else {
                                    ParseFunctionDecl {
                                        cursor: body.cursor,
                                        function_item: Some(function_decl(signature, requires_expr, ensures_expr, block, merge(signature.span, block.span))),
                                        diagnostic: None(),
                                    }
                                },
                                None => ParseFunctionDecl {
                                    cursor: body.cursor,
                                    function_item: None(),
                                    diagnostic: Some(error(diagnostic_code("E1375"), contract_span, "expected function body")),
                                },
                            }
                        }
                    } else {
                        ParseFunctionDecl {
                            cursor: out_cursor,
                            function_item: None(),
                            diagnostic: Some(error(diagnostic_code("E1375"), contract_span, "expected function body")),
                        }
                    },
                }
            } else {
                ParseFunctionDecl {
                    cursor: signature_result.cursor,
                    function_item: None(),
                    diagnostic: Some(error(diagnostic_code("E1376"), current_token(skip_trivia(signature_result.cursor)).span, "missing function signature")),
                }
            },
            None => ParseFunctionDecl {
                cursor: signature_result.cursor,
                function_item: None(),
                diagnostic: Some(error(diagnostic_code("E1376"), current_token(skip_trivia(signature_result.cursor)).span, "missing function signature")),
            },
        }
    }
}

pub fn parse_trait_method_signature(cursor: ParserCursor) -> ParseTraitMethodSignature {
    let attrs_result = parse_attribute_list(cursor);
    if has_attribute_list_diagnostic(attrs_result) {
        ParseTraitMethodSignature {
            cursor: attrs_result.cursor,
            signature: None(),
            diagnostic: attrs_result.diagnostic,
        }
    } else {
    let signature_result = parse_function_signature(attrs_result.cursor);
    if has_function_signature_diagnostic(signature_result) {
        ParseTraitMethodSignature {
            cursor: signature_result.cursor,
            signature: None(),
            diagnostic: signature_result.diagnostic,
        }
    } else {
        let semi_result = expect_delimiter(signature_result.cursor, ";", "E1200", "expected semicolon after trait method signature");
        if has_diagnostic(semi_result) {
            ParseTraitMethodSignature {
                cursor: semi_result.cursor,
                signature: None(),
                diagnostic: semi_result.diagnostic,
            }
        } else {
            ParseTraitMethodSignature {
                cursor: semi_result.cursor,
                signature: match signature_result.signature {
                    Some(signature) => Some(function_signature_with_new_attrs(signature, attrs_result.attrs)),
                    None => None(),
                },
                diagnostic: None(),
            }
        }
    }
    }
}

pub fn parse_trait_method_list(cursor: ParserCursor) -> ParseTraitMethodList {
    let open_result = expect_delimiter(cursor, "{", "E1210", "expected trait method list opener");
    if has_diagnostic(open_result) {
        ParseTraitMethodList {
            cursor: open_result.cursor,
            methods: vec.new_vec(),
            span: open_result.token.span,
            diagnostic: open_result.diagnostic,
        }
    } else {
        let mut out_cursor = open_result.cursor;
        let mut methods: Vec[AstFunctionSignature] = vec.new_vec();
        let mut end_span = open_result.token.span;
        let mut diagnostic: Option[Diagnostic] = None();
        let mut done = false;
        if at_delimiter(out_cursor, "}") {
            let close_result = expect_delimiter(out_cursor, "}", "E1211", "expected trait method list closer");
            out_cursor = close_result.cursor;
            end_span = close_result.token.span;
            diagnostic = close_result.diagnostic;
            done = true;
        } else {
            ()
        };

        while !done {
            let method_result = parse_trait_method_signature(out_cursor);
            if has_trait_method_signature_diagnostic(method_result) {
                out_cursor = method_result.cursor;
                diagnostic = method_result.diagnostic;
                done = true;
            } else {
                let method_count_before = vec.vec_len(methods);
                methods = match method_result.signature {
                    Some(signature) => vec.push(methods, signature),
                    None => methods,
                };
                out_cursor = method_result.cursor;
                if vec.vec_len(methods) == method_count_before {
                    diagnostic = Some(error(diagnostic_code("E1212"), current_token(skip_trivia(method_result.cursor)).span, "missing trait method signature"));
                    done = true;
                } else if at_delimiter(out_cursor, "}") {
                    let close_result = expect_delimiter(out_cursor, "}", "E1211", "expected trait method list closer");
                    out_cursor = close_result.cursor;
                    end_span = close_result.token.span;
                    diagnostic = close_result.diagnostic;
                    done = true;
                } else {
                    ()
                };
            };
        };

        ParseTraitMethodList {
            cursor: out_cursor,
            methods: methods,
            span: merge(open_result.token.span, end_span),
            diagnostic: diagnostic,
        }
    }
}

fn trait_decl_result(
    cursor: ParserCursor,
    header: AstItemHeader,
    generic_params: AstGenericParamList,
    methods: Vec[AstFunctionSignature],
    end_span: SourceSpan,
) -> ParseTraitDecl {
    ParseTraitDecl {
        cursor: cursor,
        trait_item: Some(trait_decl(header.name, header.visibility, generic_params, methods, merge(header.span, end_span))),
        diagnostic: None(),
    }
}

pub fn parse_trait_declaration(cursor: ParserCursor) -> ParseTraitDecl {
    let header_result = parse_item_header(cursor);
    if has_item_header_diagnostic(header_result) {
        ParseTraitDecl {
            cursor: header_result.cursor,
            trait_item: None(),
            diagnostic: header_result.diagnostic,
        }
    } else {
        match header_result.header {
            Some(header) => if is_trait_item_kind(header.kind) {
                let generic_result = parse_optional_generic_params(header_result.cursor);
                if has_generic_params_diagnostic(generic_result) {
                    ParseTraitDecl {
                        cursor: generic_result.cursor,
                        trait_item: None(),
                        diagnostic: generic_result.diagnostic,
                    }
                } else {
                    if at_delimiter(generic_result.cursor, ";") {
                        let semi_result = expect_delimiter(generic_result.cursor, ";", "E1220", "expected semicolon after trait declaration");
                        if has_diagnostic(semi_result) {
                            ParseTraitDecl {
                                cursor: semi_result.cursor,
                                trait_item: None(),
                                diagnostic: semi_result.diagnostic,
                            }
                        } else {
                            trait_decl_result(semi_result.cursor, header, generic_result.params, vec.new_vec(), semi_result.token.span)
                        }
                    } else {
                        let methods_result = parse_trait_method_list(generic_result.cursor);
                        if has_trait_method_list_diagnostic(methods_result) {
                            ParseTraitDecl {
                                cursor: methods_result.cursor,
                                trait_item: None(),
                                diagnostic: methods_result.diagnostic,
                            }
                        } else {
                            trait_decl_result(methods_result.cursor, header, generic_result.params, methods_result.methods, methods_result.span)
                        }
                    }
                }
            } else {
                ParseTraitDecl {
                    cursor: header_result.cursor,
                    trait_item: None(),
                    diagnostic: Some(error(diagnostic_code("E1221"), header.span, "expected trait item")),
                }
            },
            None => ParseTraitDecl {
                cursor: header_result.cursor,
                trait_item: None(),
                diagnostic: Some(error(diagnostic_code("E1222"), current_token(skip_trivia(header_result.cursor)).span, "missing trait header")),
            },
        }
    }
}

pub fn parse_impl_method(cursor: ParserCursor) -> ParseImplMethod {
    let attrs_result = parse_attribute_list(cursor);
    if has_attribute_list_diagnostic(attrs_result) {
        ParseImplMethod {
            cursor: attrs_result.cursor,
            method: None(),
            diagnostic: attrs_result.diagnostic,
        }
    } else {
    let signature_result = parse_function_signature(attrs_result.cursor);
    if has_function_signature_diagnostic(signature_result) {
        ParseImplMethod {
            cursor: signature_result.cursor,
            method: None(),
            diagnostic: signature_result.diagnostic,
        }
    } else {
        match signature_result.signature {
            Some(signature) => if true {
                let attributed_signature = function_signature_with_new_attrs(signature, attrs_result.attrs);
                let body_result = parse_block(signature_result.cursor);
                if has_block_diagnostic(body_result) {
                    ParseImplMethod {
                        cursor: body_result.cursor,
                        method: None(),
                        diagnostic: body_result.diagnostic,
                    }
                } else {
                    match body_result.block {
                        Some(block) => if type_text(attributed_signature.return_type) != "()" && !block_has_required_tail(block) {
                            ParseImplMethod {
                                cursor: body_result.cursor,
                                method: None(),
                                diagnostic: Some(error(diagnostic_code("E1377"), block.span, "expected tail expression or return statement in non-unit method body")),
                            }
                        } else {
                            ParseImplMethod {
                                cursor: body_result.cursor,
                                method: Some(impl_method(attributed_signature, block, merge(attributed_signature.span, block.span))),
                                diagnostic: None(),
                            }
                        },
                        None => ParseImplMethod {
                            cursor: body_result.cursor,
                            method: None(),
                            diagnostic: Some(error(diagnostic_code("E1240"), current_token(skip_trivia(body_result.cursor)).span, "missing impl method body")),
                        },
                    }
                }
            } else {
                ParseImplMethod {
                    cursor: signature_result.cursor,
                    method: None(),
                    diagnostic: Some(error(diagnostic_code("E1241"), current_token(skip_trivia(signature_result.cursor)).span, "missing impl method signature")),
                }
            },
            None => ParseImplMethod {
                cursor: signature_result.cursor,
                method: None(),
                diagnostic: Some(error(diagnostic_code("E1241"), current_token(skip_trivia(signature_result.cursor)).span, "missing impl method signature")),
            },
        }
    }
    }
}

pub fn parse_impl_method_list(cursor: ParserCursor) -> ParseImplMethodList {
    let open_result = expect_delimiter(cursor, "{", "E1232", "expected impl block opener");
    if has_diagnostic(open_result) {
        ParseImplMethodList {
            cursor: open_result.cursor,
            methods: vec.new_vec(),
            span: open_result.token.span,
            text: "",
            diagnostic: open_result.diagnostic,
        }
    } else {
        let mut out_cursor = open_result.cursor;
        let mut methods: Vec[AstImplMethod] = vec.new_vec();
        let mut text_parts: Vec[String] = vec.new_vec();
        let mut end_span = open_result.token.span;
        let mut diagnostic: Option[Diagnostic] = None();
        let mut done = false;
        if at_delimiter(out_cursor, "}") {
            let close_result = expect_delimiter(out_cursor, "}", "E1234", "expected impl block closer");
            out_cursor = close_result.cursor;
            end_span = close_result.token.span;
            diagnostic = close_result.diagnostic;
            done = true;
        } else {
            ()
        };

        while !done {
            if is_at_end(out_cursor) {
                diagnostic = Some(error(diagnostic_code("E1234"), current_token(skip_trivia(out_cursor)).span, "expected impl block closer"));
                done = true;
            } else {
                let method_result = parse_impl_method(out_cursor);
                if has_impl_method_diagnostic(method_result) {
                    out_cursor = method_result.cursor;
                    diagnostic = method_result.diagnostic;
                    done = true;
                } else {
                    let method_count_before = vec.vec_len(methods);
                    methods = match method_result.method {
                        Some(method) => if true {
                            text_parts = vec.push(text_parts, impl_method_text(method));
                            end_span = method.span;
                            vec.push(methods, method)
                        } else {
                            methods
                        },
                        None => methods,
                    };
                    out_cursor = method_result.cursor;
                    if vec.vec_len(methods) == method_count_before {
                        diagnostic = Some(error(diagnostic_code("E1241"), current_token(skip_trivia(method_result.cursor)).span, "missing impl method signature"));
                        done = true;
                    } else if at_delimiter(out_cursor, "}") {
                        let close_result = expect_delimiter(out_cursor, "}", "E1234", "expected impl block closer");
                        out_cursor = close_result.cursor;
                        end_span = close_result.token.span;
                        diagnostic = close_result.diagnostic;
                        done = true;
                    } else if is_at_end(out_cursor) {
                        diagnostic = Some(error(diagnostic_code("E1234"), current_token(skip_trivia(out_cursor)).span, "expected impl block closer"));
                        done = true;
                    } else {
                        ()
                    };
                }
            }
        };

        ParseImplMethodList {
            cursor: out_cursor,
            methods: methods,
            span: merge(open_result.token.span, end_span),
            text: string.join(text_parts, ""),
            diagnostic: diagnostic,
        }
    }
}

fn impl_decl_result(
    cursor: ParserCursor,
    visibility: AstVisibility,
    generic_params: AstGenericParamList,
    start_span: SourceSpan,
    head_type: AstType,
    methods: Vec[AstImplMethod],
    body_text: String,
    has_block: Bool,
    end_span: SourceSpan,
) -> ParseImplDecl {
    ParseImplDecl {
        cursor: cursor,
        impl_item: Some(impl_decl(visibility, generic_params, head_type, methods, body_text, has_block, merge(start_span, end_span))),
        diagnostic: None(),
    }
}

pub fn parse_impl_declaration(cursor: ParserCursor) -> ParseImplDecl {
    let visibility_result = parse_visibility(cursor);
    if has_visibility_diagnostic(visibility_result) {
        ParseImplDecl {
            cursor: visibility_result.cursor,
            impl_item: None(),
            diagnostic: visibility_result.diagnostic,
        }
    } else {
        let impl_keyword = expect_keyword(visibility_result.cursor, "impl", "E1230", "expected impl declaration");
        if has_diagnostic(impl_keyword) {
            ParseImplDecl {
                cursor: impl_keyword.cursor,
                impl_item: None(),
                diagnostic: impl_keyword.diagnostic,
            }
        } else {
            let generic_result = parse_optional_generic_params(impl_keyword.cursor);
            if has_generic_params_diagnostic(generic_result) {
                ParseImplDecl {
                    cursor: generic_result.cursor,
                    impl_item: None(),
                    diagnostic: generic_result.diagnostic,
                }
            } else {
                let head_result = parse_type_ref(generic_result.cursor, false);
                if has_type_ref_diagnostic(head_result) {
                    ParseImplDecl {
                        cursor: head_result.cursor,
                        impl_item: None(),
                        diagnostic: head_result.diagnostic,
                    }
                } else {
                    match visibility_result.visibility {
                        Some(visibility) => match head_result.type_ref {
                            Some(head_type) => if at_delimiter(head_result.cursor, ";") {
                                let semi_result = expect_delimiter(head_result.cursor, ";", "E1231", "expected semicolon after impl declaration");
                                if has_diagnostic(semi_result) {
                                    ParseImplDecl {
                                        cursor: semi_result.cursor,
                                        impl_item: None(),
                                        diagnostic: semi_result.diagnostic,
                                    }
                                } else {
                                    impl_decl_result(semi_result.cursor, visibility, generic_result.params, merge(visibility_result.span, impl_keyword.token.span), head_type, vec.new_vec(), "", false, semi_result.token.span)
                                }
                            } else if at_delimiter(head_result.cursor, "{") {
                                let methods_result = parse_impl_method_list(head_result.cursor);
                                if has_impl_method_list_diagnostic(methods_result) {
                                    ParseImplDecl {
                                        cursor: methods_result.cursor,
                                        impl_item: None(),
                                        diagnostic: methods_result.diagnostic,
                                    }
                                } else {
                                    impl_decl_result(methods_result.cursor, visibility, generic_result.params, merge(visibility_result.span, impl_keyword.token.span), head_type, methods_result.methods, methods_result.text, true, methods_result.span)
                                }
                            } else {
                                ParseImplDecl {
                                    cursor: head_result.cursor,
                                    impl_item: None(),
                                    diagnostic: Some(error(diagnostic_code("E1235"), current_token(skip_trivia(head_result.cursor)).span, "expected semicolon or block after impl head")),
                                }
                            },
                            None => ParseImplDecl {
                                cursor: head_result.cursor,
                                impl_item: None(),
                                diagnostic: Some(error(diagnostic_code("E1236"), head_result.span, "missing impl head type")),
                            },
                        },
                        None => ParseImplDecl {
                            cursor: visibility_result.cursor,
                            impl_item: None(),
                            diagnostic: Some(error(diagnostic_code("E1237"), visibility_result.span, "missing impl visibility")),
                        },
                    }
                }
            }
        }
    }
}

fn parse_attribute_value_error(cursor: ParserCursor, token: Token, code: String, message: String) -> ParseAttributeValue {
    ParseAttributeValue {
        cursor: cursor,
        value: "",
        kind: AstAttributeIdentValue(),
        span: token.span,
        text: "",
        diagnostic: Some(error(diagnostic_code(code), token.span, message)),
    }
}

fn parse_attribute_value_ok(cursor: ParserCursor, token: Token, kind: AstAttributeValueKind, value: String, text: String) -> ParseAttributeValue {
    ParseAttributeValue {
        cursor: cursor,
        value: value,
        kind: kind,
        span: token.span,
        text: text,
        diagnostic: None(),
    }
}

pub fn parse_attribute_value(cursor: ParserCursor) -> ParseAttributeValue {
    let active = skip_trivia(cursor);
    let token = current_token(active);
    match token.kind {
        StringLiteral => parse_attribute_value_ok(advance(active), token, AstAttributeStringValue(), token.lexeme, token.lexeme),
        IntegerLiteral => parse_attribute_value_ok(advance(active), token, AstAttributeIntValue(), token.lexeme, token.lexeme),
        Identifier => parse_attribute_value_ok(advance(active), token, AstAttributeIdentValue(), token.lexeme, token.lexeme),
        Keyword => if token.lexeme == "true" || token.lexeme == "false" {
            parse_attribute_value_ok(advance(active), token, AstAttributeBoolValue(), token.lexeme, token.lexeme)
        } else {
            parse_attribute_value_error(active, token, "E1095", "expected attribute argument value")
        },
        Operator => if token.lexeme == "-" {
            let minus = expect_operator(active, "-", "E1095", "expected attribute argument value");
            let number = current_token(skip_trivia(minus.cursor));
            match number.kind {
                IntegerLiteral => parse_attribute_value_ok(advance(skip_trivia(minus.cursor)), token, AstAttributeIntValue(), wrap_text("-", number.lexeme, ""), wrap_text("-", number.lexeme, "")),
                _ => parse_attribute_value_error(minus.cursor, number, "E1095", "expected integer literal after '-' in attribute argument"),
            }
        } else {
            parse_attribute_value_error(active, token, "E1095", "expected attribute argument value")
        },
        _ => parse_attribute_value_error(active, token, "E1095", "expected attribute argument value"),
    }
}

fn recover_to_attribute_delimiter(cursor: ParserCursor) -> ParserCursor {
    let mut out = cursor;
    let mut done = false;
    while !done && !is_at_end(out) {
        if at_delimiter(out, ",") || at_delimiter(out, ")") || at_delimiter(out, "]") {
            done = true;
        } else {
            let next = advance(skip_trivia(out));
            if next.index == out.index {
                done = true;
            } else {
                out = next;
            };
        };
    };
    out
}

fn recover_to_attribute_end(cursor: ParserCursor) -> ParserCursor {
    let mut out = cursor;
    let mut done = false;
    while !done && !is_at_end(out) {
        if at_delimiter(out, "]") {
            out = advance(skip_trivia(out));
            done = true;
        } else {
            let next = advance(skip_trivia(out));
            if next.index == out.index {
                done = true;
            } else {
                out = next;
            };
        };
    };
    out
}

fn parse_attribute_arg_result(cursor: ParserCursor, name: String, value: ParseAttributeValue, named: Bool, start_span: SourceSpan) -> ParseAttributeArg {
    if has_attribute_value_diagnostic(value) {
        ParseAttributeArg {
            cursor: recover_to_attribute_delimiter(value.cursor),
            arg: None(),
            diagnostic: value.diagnostic,
        }
    } else {
        ParseAttributeArg {
            cursor: value.cursor,
            arg: Some(ast_attribute_arg(name, value.value, value.kind, named, merge(start_span, value.span), if named { wrap_text(name, "=", value.text) } else { value.text })),
            diagnostic: None(),
        }
    }
}

pub fn parse_attribute_arg(cursor: ParserCursor) -> ParseAttributeArg {
    let active = skip_trivia(cursor);
    let token = current_token(active);
    let after_token = advance(active);
    if at_identifier(active) && at_operator(after_token, "=") {
        let name_result = expect_identifier(active, "E1095", "expected attribute argument name");
        if has_diagnostic(name_result) {
            ParseAttributeArg {
                cursor: recover_to_attribute_delimiter(name_result.cursor),
                arg: None(),
                diagnostic: name_result.diagnostic,
            }
        } else {
            let eq_result = expect_operator(name_result.cursor, "=", "E1095", "expected '=' after attribute argument name");
            if has_diagnostic(eq_result) {
                ParseAttributeArg {
                    cursor: recover_to_attribute_delimiter(eq_result.cursor),
                    arg: None(),
                    diagnostic: eq_result.diagnostic,
                }
            } else {
                parse_attribute_arg_result(eq_result.cursor, name_result.token.lexeme, parse_attribute_value(eq_result.cursor), true, name_result.token.span)
            }
        }
    } else {
        parse_attribute_arg_result(active, "", parse_attribute_value(active), false, token.span)
    }
}

fn attribute_args_text(args: Vec[AstAttributeArg]) -> String {
    let mut parts: Vec[String] = vec.new_vec();
    let mut index = 0;
    while index < vec.vec_len(args) {
        match vec.get(args, index) {
            Some(arg) => if true {
                parts = vec.push(parts, arg.text);
                ()
            } else {
                ()
            },
            None => (),
        };
        index = index + 1;
    };
    string.join(parts, ",")
}

pub fn parse_attribute(cursor: ParserCursor) -> ParseAttribute {
    let hash = expect_delimiter(cursor, "#", "E1094", "expected attribute marker");
    if has_diagnostic(hash) {
        ParseAttribute {
            cursor: hash.cursor,
            attr: None(),
            diagnostic: hash.diagnostic,
        }
    } else {
        let open = expect_delimiter(hash.cursor, "[", "E1094", "expected '[' after attribute marker");
        if has_diagnostic(open) {
            ParseAttribute {
                cursor: open.cursor,
                attr: None(),
                diagnostic: open.diagnostic,
            }
        } else {
            let name = expect_identifier(open.cursor, "E1094", "expected attribute name after '#['");
            if has_diagnostic(name) {
                ParseAttribute {
                    cursor: recover_to_attribute_end(name.cursor),
                    attr: None(),
                    diagnostic: name.diagnostic,
                }
            } else {
                let mut out_cursor = name.cursor;
                let mut args: Vec[AstAttributeArg] = vec.new_vec();
                let mut diagnostic: Option[Diagnostic] = None();
                let mut done = false;
                if at_delimiter(out_cursor, "(") {
                    let open_args = expect_delimiter(out_cursor, "(", "E1095", "expected attribute argument list opener");
                    out_cursor = open_args.cursor;
                    if at_delimiter(out_cursor, ")") {
                        let close_args = expect_delimiter(out_cursor, ")", "E1095", "expected ')' after attribute arguments");
                        out_cursor = close_args.cursor;
                        diagnostic = close_args.diagnostic;
                    } else {
                        while !done {
                            let arg_result = parse_attribute_arg(out_cursor);
                            if has_attribute_arg_diagnostic(arg_result) {
                                diagnostic = arg_result.diagnostic;
                                out_cursor = arg_result.cursor;
                                done = true;
                            } else {
                                args = match arg_result.arg {
                                    Some(arg) => vec.push(args, arg),
                                    None => args,
                                };
                                out_cursor = arg_result.cursor;
                                if at_delimiter(out_cursor, ",") {
                                    let comma = expect_delimiter(out_cursor, ",", "E1095", "expected attribute argument separator");
                                    out_cursor = comma.cursor;
                                } else {
                                    done = true;
                                };
                            };
                        };
                        if !has_optional_diagnostic(diagnostic) {
                            let close_args = expect_delimiter(out_cursor, ")", "E1095", "expected ')' after attribute arguments");
                            out_cursor = close_args.cursor;
                            diagnostic = close_args.diagnostic;
                        } else {
                            out_cursor = recover_to_attribute_end(out_cursor);
                        };
                    };
                } else {
                    ()
                };

                match diagnostic {
                    Some(diag) => ParseAttribute {
                        cursor: out_cursor,
                        attr: None(),
                        diagnostic: Some(diag),
                    },
                    None => if true {
                        let close = expect_delimiter(out_cursor, "]", "E1094", "expected ']' after attribute");
                        if has_diagnostic(close) {
                            ParseAttribute {
                                cursor: recover_to_attribute_end(close.cursor),
                                attr: None(),
                                diagnostic: close.diagnostic,
                            }
                        } else {
                            let arg_text = attribute_args_text(args);
                            let text = if arg_text == "" {
                                wrap_text("#[", name.token.lexeme, "]")
                            } else {
                                wrap_text("#[", name.token.lexeme, wrap_text("(", arg_text, ")]"))
                            };
                            ParseAttribute {
                                cursor: close.cursor,
                                attr: Some(ast_attribute(name.token.lexeme, args, merge(hash.token.span, close.token.span), text)),
                                diagnostic: None(),
                            }
                        }
                    } else {
                        ParseAttribute {
                            cursor: out_cursor,
                            attr: None(),
                            diagnostic: Some(error(diagnostic_code("E1094"), name.token.span, "expected attribute")),
                        }
                    },
                }
            }
        }
    }
}

fn at_attribute_start(cursor: ParserCursor) -> Bool {
    let active = skip_trivia(cursor);
    at_delimiter(active, "#") && at_delimiter(advance(active), "[")
}

pub fn parse_attribute_list(cursor: ParserCursor) -> ParseAttributeList {
    let mut out_cursor = cursor;
    let mut attrs: Vec[AstAttribute] = vec.new_vec();
    let mut diagnostic: Option[Diagnostic] = None();
    let mut done = false;
    while !done && at_attribute_start(out_cursor) {
        let attr_result = parse_attribute(out_cursor);
        if has_attribute_diagnostic(attr_result) {
            diagnostic = attr_result.diagnostic;
            out_cursor = attr_result.cursor;
            done = true;
        } else {
            attrs = match attr_result.attr {
                Some(attr) => vec.push(attrs, attr),
                None => attrs,
            };
            out_cursor = attr_result.cursor;
        };
    };
    ParseAttributeList {
        cursor: out_cursor,
        attrs: attrs,
        diagnostic: diagnostic,
    }
}

fn attribute_value_is_string(value: AstAttributeArg) -> Bool {
    match value.kind {
        AstAttributeStringValue => true,
        AstAttributeIntValue => false,
        AstAttributeBoolValue => false,
        AstAttributeIdentValue => false,
    }
}

fn attribute_value_is_int(value: AstAttributeArg) -> Bool {
    match value.kind {
        AstAttributeIntValue => true,
        AstAttributeStringValue => false,
        AstAttributeBoolValue => false,
        AstAttributeIdentValue => false,
    }
}

fn is_known_framework_attribute(name: String) -> Bool {
    name == "get"
        || name == "post"
        || name == "put"
        || name == "patch"
        || name == "delete"
        || name == "filter"
        || name == "body"
        || name == "header"
        || name == "path"
        || name == "query"
        || name == "validate"
}

fn is_singleton_framework_attribute(name: String) -> Bool {
    is_known_framework_attribute(name)
}

fn attribute_target_label(target: String) -> String {
    if target == "function" {
        "a function"
    } else if target == "struct" {
        "a struct"
    } else if target == "field" {
        "a struct field"
    } else if target == "enum" {
        "an enum"
    } else if target == "variant" {
        "an enum variant"
    } else if target == "trait" {
        "a trait"
    } else if target == "impl" {
        "an impl block"
    } else if target == "param" {
        "a parameter"
    } else if target == "type_alias" {
        "a type alias"
    } else if target == "const" {
        "a const item"
    } else {
        "a declaration"
    }
}

fn framework_attribute_allowed_on(name: String, target: String) -> Bool {
    if name == "get" || name == "post" || name == "put" || name == "patch" || name == "delete" {
        target == "function"
    } else if name == "filter" {
        target == "struct"
    } else if name == "body" || name == "header" || name == "path" || name == "query" {
        target == "param"
    } else if name == "validate" {
        target == "field" || target == "param"
    } else {
        true
    }
}

fn attribute_has_one_positional_string(attr: AstAttribute) -> Bool {
    if vec.vec_len(attr.args) != 1 {
        false
    } else {
        match vec.get(attr.args, 0) {
            Some(arg) => !arg.named && attribute_value_is_string(arg),
            None => false,
        }
    }
}

fn attribute_has_named_int(attr: AstAttribute, expected_name: String) -> Bool {
    if vec.vec_len(attr.args) != 1 {
        false
    } else {
        match vec.get(attr.args, 0) {
            Some(arg) => arg.named && arg.name == expected_name && attribute_value_is_int(arg),
            None => false,
        }
    }
}

fn framework_attribute_shape_valid(attr: AstAttribute) -> Bool {
    if attr.name == "get" || attr.name == "post" || attr.name == "put" || attr.name == "patch" || attr.name == "delete" {
        attribute_has_one_positional_string(attr)
    } else if attr.name == "filter" {
        attribute_has_named_int(attr, "order")
    } else if attr.name == "body" {
        vec.vec_len(attr.args) == 0
    } else if attr.name == "header" || attr.name == "path" || attr.name == "query" {
        attribute_has_one_positional_string(attr)
    } else if attr.name == "validate" {
        vec.vec_len(attr.args) > 0
    } else {
        true
    }
}

fn push_diagnostic_if_room(diagnostics: Vec[Diagnostic], max_errors: Int, diagnostic: Diagnostic) -> Vec[Diagnostic] {
    if vec.vec_len(diagnostics) < max_errors {
        vec.push(diagnostics, diagnostic)
    } else {
        diagnostics
    }
}

fn validate_program_attributes(attrs: Vec[AstAttribute], target: String, diagnostics: Vec[Diagnostic], max_errors: Int) -> Vec[Diagnostic] {
    let mut out = diagnostics;
    let mut index = 0;
    while index < vec.vec_len(attrs) && vec.vec_len(out) < max_errors {
        match vec.get(attrs, index) {
            Some(attr) => if is_known_framework_attribute(attr.name) {
                if !framework_attribute_allowed_on(attr.name, target) {
                    let mut parts: Vec[String] = vec.new_vec();
                    parts = vec.push(parts, "framework attribute '#[");
                    parts = vec.push(parts, attr.name);
                    parts = vec.push(parts, "]' is not supported on ");
                    parts = vec.push(parts, attribute_target_label(target));
                    out = push_diagnostic_if_room(out, max_errors, error(diagnostic_code("E1096"), attr.span, string.join(parts, "")));
                } else {
                    ()
                };
                if vec.vec_len(out) < max_errors && !framework_attribute_shape_valid(attr) {
                    let mut shape_parts: Vec[String] = vec.new_vec();
                    shape_parts = vec.push(shape_parts, "invalid argument shape for framework attribute '#[");
                    shape_parts = vec.push(shape_parts, attr.name);
                    shape_parts = vec.push(shape_parts, "]'");
                    out = push_diagnostic_if_room(out, max_errors, error(diagnostic_code("E1097"), attr.span, string.join(shape_parts, "")));
                } else {
                    ()
                };
                if vec.vec_len(out) < max_errors && is_singleton_framework_attribute(attr.name) {
                    let mut earlier_index = 0;
                    let mut duplicate = false;
                    while !duplicate && earlier_index < index {
                        match vec.get(attrs, earlier_index) {
                            Some(earlier) => if earlier.name == attr.name {
                                duplicate = true;
                            } else {
                                ()
                            },
                            None => (),
                        };
                        earlier_index = earlier_index + 1;
                    };
                    if duplicate {
                        let mut dup_parts: Vec[String] = vec.new_vec();
                        dup_parts = vec.push(dup_parts, "duplicate framework attribute '#[");
                        dup_parts = vec.push(dup_parts, attr.name);
                        dup_parts = vec.push(dup_parts, "]'");
                        out = push_diagnostic_if_room(out, max_errors, error(diagnostic_code("E1096"), attr.span, string.join(dup_parts, "")));
                    } else {
                        ()
                    };
                } else {
                    ()
                };
                ()
            } else {
                ()
            },
            None => (),
        };
        index = index + 1;
    };
    out
}

fn validate_param_attributes(params: Vec[AstParam], diagnostics: Vec[Diagnostic], max_errors: Int) -> Vec[Diagnostic] {
    let mut out = diagnostics;
    let mut index = 0;
    while index < vec.vec_len(params) && vec.vec_len(out) < max_errors {
        match vec.get(params, index) {
            Some(param) => if true {
                out = validate_program_attributes(param.attrs, "param", out, max_errors);
                ()
            } else {
                ()
            },
            None => (),
        };
        index = index + 1;
    };
    out
}

fn validate_signature_attributes(signature: AstFunctionSignature, diagnostics: Vec[Diagnostic], max_errors: Int) -> Vec[Diagnostic] {
    let out = validate_program_attributes(signature.attrs, "function", diagnostics, max_errors);
    validate_param_attributes(signature.params, out, max_errors)
}

fn validate_field_attributes(fields: Vec[AstField], diagnostics: Vec[Diagnostic], max_errors: Int) -> Vec[Diagnostic] {
    let mut out = diagnostics;
    let mut index = 0;
    while index < vec.vec_len(fields) && vec.vec_len(out) < max_errors {
        match vec.get(fields, index) {
            Some(field) => if true {
                out = validate_program_attributes(field.attrs, "field", out, max_errors);
                ()
            } else {
                ()
            },
            None => (),
        };
        index = index + 1;
    };
    out
}

fn validate_variant_attributes(variants: Vec[AstEnumVariant], diagnostics: Vec[Diagnostic], max_errors: Int) -> Vec[Diagnostic] {
    let mut out = diagnostics;
    let mut index = 0;
    while index < vec.vec_len(variants) && vec.vec_len(out) < max_errors {
        match vec.get(variants, index) {
            Some(variant) => if true {
                out = validate_program_attributes(variant.attrs, "variant", out, max_errors);
                ()
            } else {
                ()
            },
            None => (),
        };
        index = index + 1;
    };
    out
}

fn validate_trait_method_attributes(methods: Vec[AstFunctionSignature], diagnostics: Vec[Diagnostic], max_errors: Int) -> Vec[Diagnostic] {
    let mut out = diagnostics;
    let mut index = 0;
    while index < vec.vec_len(methods) && vec.vec_len(out) < max_errors {
        match vec.get(methods, index) {
            Some(method) => if true {
                out = validate_signature_attributes(method, out, max_errors);
                ()
            } else {
                ()
            },
            None => (),
        };
        index = index + 1;
    };
    out
}

fn validate_impl_method_attributes(methods: Vec[AstImplMethod], diagnostics: Vec[Diagnostic], max_errors: Int) -> Vec[Diagnostic] {
    let mut out = diagnostics;
    let mut index = 0;
    while index < vec.vec_len(methods) && vec.vec_len(out) < max_errors {
        match vec.get(methods, index) {
            Some(method) => if true {
                out = validate_signature_attributes(method.signature, out, max_errors);
                ()
            } else {
                ()
            },
            None => (),
        };
        index = index + 1;
    };
    out
}

fn validate_program_item_nested_attributes(item: AstProgramItem, diagnostics: Vec[Diagnostic], max_errors: Int) -> Vec[Diagnostic] {
    let mut out = diagnostics;
    match item.function_item {
        Some(function_item) => if true {
            out = validate_signature_attributes(function_item.signature, out, max_errors);
            ()
        } else {
            ()
        },
        None => (),
    };
    match item.function_signature {
        Some(signature) => if true {
            out = validate_signature_attributes(signature, out, max_errors);
            ()
        } else {
            ()
        },
        None => (),
    };
    match item.struct_item {
        Some(struct_item) => if true {
            out = validate_field_attributes(struct_item.fields, out, max_errors);
            ()
        } else {
            ()
        },
        None => (),
    };
    match item.enum_item {
        Some(enum_item) => if true {
            out = validate_variant_attributes(enum_item.variants, out, max_errors);
            ()
        } else {
            ()
        },
        None => (),
    };
    match item.trait_item {
        Some(trait_item) => if true {
            out = validate_trait_method_attributes(trait_item.methods, out, max_errors);
            ()
        } else {
            ()
        },
        None => (),
    };
    match item.impl_item {
        Some(impl_item) => if true {
            out = validate_impl_method_attributes(impl_item.methods, out, max_errors);
            ()
        } else {
            ()
        },
        None => (),
    };
    out
}

fn program_item_kind_label(kind: AstItemKind) -> String {
    match kind {
        FunctionItem => "function",
        StructItem => "struct",
        EnumItem => "enum",
        TraitItem => "trait",
        ImplItem => "impl",
        TypeAliasItem => "type_alias",
        ConstItem => "const",
    }
}

fn program_item_target(kind: AstItemKind) -> String {
    program_item_kind_label(kind)
}

fn program_item_modifier_names(cursor: ParserCursor) -> String {
    let visibility = parse_visibility(cursor);
    let mut out_cursor = visibility.cursor;
    let mut parts: Vec[String] = vec.new_vec();
    let mut done = false;
    while !done {
        if at_keyword(out_cursor, "async") {
            parts = vec.push(parts, "async");
            out_cursor = advance(skip_trivia(out_cursor));
        } else if at_keyword(out_cursor, "intrinsic") {
            parts = vec.push(parts, "intrinsic");
            out_cursor = advance(skip_trivia(out_cursor));
        } else if at_keyword(out_cursor, "unsafe") {
            parts = vec.push(parts, "unsafe");
            out_cursor = advance(skip_trivia(out_cursor));
        } else if at_keyword(out_cursor, "extern") {
            parts = vec.push(parts, "extern");
            out_cursor = skip_optional_extern_abi(advance(skip_trivia(out_cursor)));
        } else {
            done = true;
        };
    };
    string.join(parts, ",")
}

fn starts_with_signature_only_function(cursor: ParserCursor) -> Bool {
    let visibility = parse_visibility(cursor);
    let active = skip_trivia(visibility.cursor);
    at_keyword(active, "extern") || at_keyword(active, "intrinsic")
}

fn program_item_from_function_decl(cursor: ParserCursor, attrs: Vec[AstAttribute], visibility: AstVisibility, modifiers: String, result: ParseFunctionDecl) -> ParseProgramItem {
    if has_function_decl_diagnostic(result) {
        ParseProgramItem {
            cursor: result.cursor,
            item: None(),
            diagnostic: result.diagnostic,
        }
    } else {
        match result.function_item {
            Some(function_item) => ParseProgramItem {
                cursor: result.cursor,
                item: Some(ast_program_item(FunctionItem(), function_item.signature.name, visibility, attrs, Some(function_item), None(), None(), None(), None(), None(), None(), None(), false, modifiers, function_item.span)),
                diagnostic: None(),
            },
            None => ParseProgramItem {
                cursor: result.cursor,
                item: None(),
                diagnostic: Some(error(diagnostic_code("E1382"), current_token(skip_trivia(cursor)).span, "missing function item")),
            },
        }
    }
}

fn parse_signature_only_program_function(cursor: ParserCursor, attrs: Vec[AstAttribute], visibility: AstVisibility, modifiers: String) -> ParseProgramItem {
    let signature = parse_function_signature(cursor);
    if has_function_signature_diagnostic(signature) {
        ParseProgramItem {
            cursor: signature.cursor,
            item: None(),
            diagnostic: signature.diagnostic,
        }
    } else {
        let semi = expect_delimiter(signature.cursor, ";", "E1093", "expected semicolon after signature-only function declaration");
        if has_diagnostic(semi) {
            ParseProgramItem {
                cursor: semi.cursor,
                item: None(),
                diagnostic: semi.diagnostic,
            }
        } else {
            match signature.signature {
                Some(sig) => ParseProgramItem {
                    cursor: semi.cursor,
                    item: Some(ast_program_item(FunctionItem(), sig.name, visibility, attrs, None(), Some(sig), None(), None(), None(), None(), None(), None(), true, modifiers, merge(sig.span, semi.token.span))),
                    diagnostic: None(),
                },
                None => ParseProgramItem {
                    cursor: signature.cursor,
                    item: None(),
                    diagnostic: Some(error(diagnostic_code("E1382"), current_token(skip_trivia(cursor)).span, "missing function signature")),
                },
            }
        }
    }
}

fn program_item_from_struct(attrs: Vec[AstAttribute], result: ParseStructDecl) -> ParseProgramItem {
