pub fn parse_program_item(cursor: ParserCursor, attrs: Vec[AstAttribute]) -> ParseProgramItem {
    let header = parse_item_header(cursor);
    if has_item_header_diagnostic(header) {
        ParseProgramItem {
            cursor: header.cursor,
            item: None(),
            diagnostic: header.diagnostic,
        }
    } else {
        match header.header {
            Some(item_header_value) => if is_function_item_kind(item_header_value.kind) {
                let modifiers = program_item_modifier_names(cursor);
                if starts_with_signature_only_function(cursor) {
                    parse_signature_only_program_function(cursor, attrs, item_header_value.visibility, modifiers)
                } else {
                    program_item_from_function_decl(cursor, attrs, item_header_value.visibility, modifiers, parse_function_declaration(cursor))
                }
            } else if is_struct_item_kind(item_header_value.kind) {
                program_item_from_struct(attrs, parse_struct_declaration(cursor))
            } else if is_enum_item_kind(item_header_value.kind) {
                program_item_from_enum(attrs, parse_enum_declaration(cursor))
            } else if is_type_alias_item_kind(item_header_value.kind) {
                program_item_from_type_alias(attrs, parse_type_alias_declaration(cursor))
            } else if is_const_item_kind(item_header_value.kind) {
                program_item_from_const(attrs, parse_const_declaration(cursor))
            } else if is_trait_item_kind(item_header_value.kind) {
                program_item_from_trait(attrs, parse_trait_declaration(cursor))
            } else if is_impl_item_kind(item_header_value.kind) {
                program_item_from_impl(attrs, parse_impl_declaration(cursor))
            } else {
                ParseProgramItem {
                    cursor: header.cursor,
                    item: None(),
                    diagnostic: Some(error(diagnostic_code("E1389"), item_header_value.span, "unsupported program item")),
                }
            },
            None => ParseProgramItem {
                cursor: header.cursor,
                item: None(),
                diagnostic: Some(error(diagnostic_code("E1389"), current_token(skip_trivia(header.cursor)).span, "missing program item")),
            },
        }
    }
}

fn recover_program_item(cursor: ParserCursor, force_advance: Bool) -> ParserCursor {
    let mut out = if force_advance { advance(skip_trivia(cursor)) } else { cursor };
    let mut done = false;
    while !done && !is_at_end(out) {
        if at_attribute_start(out)
            || at_keyword(out, "module")
            || at_keyword(out, "import")
            || at_keyword(out, "async")
            || at_keyword(out, "fn")
            || at_keyword(out, "type")
            || at_keyword(out, "const")
            || at_keyword(out, "extern")
            || at_keyword(out, "intrinsic")
            || at_keyword(out, "unsafe")
            || at_keyword(out, "struct")
            || at_keyword(out, "enum")
            || at_keyword(out, "trait")
            || at_keyword(out, "impl") {
            done = true;
        } else if at_delimiter(out, ";") {
            out = advance(skip_trivia(out));
            done = true;
        } else {
            let next = advance(skip_trivia(out));
            if next.index == out.index {
                done = true;
            } else {
                out = next;
            };
        };
    };
    out
}

fn push_item_source_entry(entries: Vec[AstSourceMapEntry], item: AstProgramItem) -> Vec[AstSourceMapEntry] {
    vec.push(entries, ast_source_map_entry(program_item_kind_label(item.kind), item.name.value, item.span))
}

fn parse_program_span(start: SourceSpan, cursor: ParserCursor) -> SourceSpan {
    let end_token = current_token(skip_trivia(cursor));
    merge(start, end_token.span)
}

pub fn parse_program(cursor: ParserCursor, max_errors: Int) -> ParseProgram
requires max_errors > 0 {
    let start_cursor = skip_trivia(cursor);
    let start_token = current_token(start_cursor);
    let mut out_cursor = start_cursor;
    let mut module_item: Option[AstModuleDecl] = None();
    let mut imports: Vec[AstImportDecl] = vec.new_vec();
    let mut items: Vec[AstProgramItem] = vec.new_vec();
    let mut source_map: Vec[AstSourceMapEntry] = vec.new_vec();
    let mut diagnostics: Vec[Diagnostic] = vec.new_vec();
    let mut seen_items = false;

    if at_keyword(out_cursor, "module") {
        let module_result = parse_module_declaration(out_cursor);
        if has_module_decl_diagnostic(module_result) {
            diagnostics = push_diagnostic_if_room(diagnostics, max_errors, match module_result.diagnostic { Some(diag) => diag, None => error(diagnostic_code("E1390"), current_token(skip_trivia(out_cursor)).span, "invalid module declaration") });
            out_cursor = recover_program_item(module_result.cursor, module_result.cursor.index == out_cursor.index);
        } else {
            match module_result.module_item {
                Some(value) => if true {
                    source_map = vec.push(source_map, ast_source_map_entry("module", value.path.text, value.span));
                    module_item = Some(value);
                    ()
                } else {
                    ()
                },
                None => (),
            };
            out_cursor = module_result.cursor;
        };
    } else {
        ()
    };

    while vec.vec_len(diagnostics) < max_errors && at_keyword(out_cursor, "import") {
        let import_result = parse_import_declaration(out_cursor);
        if has_import_decl_diagnostic(import_result) {
            diagnostics = push_diagnostic_if_room(diagnostics, max_errors, match import_result.diagnostic { Some(diag) => diag, None => error(diagnostic_code("E1391"), current_token(skip_trivia(out_cursor)).span, "invalid import declaration") });
            out_cursor = recover_program_item(import_result.cursor, import_result.cursor.index == out_cursor.index);
        } else {
            match import_result.import_item {
                Some(value) => if true {
                    source_map = vec.push(source_map, ast_source_map_entry("import", value.path.text, value.span));
                    imports = vec.push(imports, value);
                    ()
                } else {
                    ()
                },
                None => (),
            };
            out_cursor = import_result.cursor;
        };
    };

    while vec.vec_len(diagnostics) < max_errors && !is_at_end(out_cursor) {
        if at_keyword(out_cursor, "module") {
            let token = current_token(skip_trivia(out_cursor));
            diagnostics = push_diagnostic_if_room(diagnostics, max_errors, error(diagnostic_code("E1392"), token.span, "module declaration must appear before imports and items"));
            out_cursor = recover_program_item(out_cursor, true);
        } else if at_keyword(out_cursor, "import") {
            let token = current_token(skip_trivia(out_cursor));
            diagnostics = push_diagnostic_if_room(diagnostics, max_errors, error(diagnostic_code("E1393"), token.span, "import declaration must appear before items"));
            let import_result = parse_import_declaration(out_cursor);
            out_cursor = recover_program_item(import_result.cursor, import_result.cursor.index == out_cursor.index);
        } else {
            let attrs_result = parse_attribute_list(out_cursor);
            out_cursor = attrs_result.cursor;
            if has_attribute_list_diagnostic(attrs_result) {
                diagnostics = push_diagnostic_if_room(diagnostics, max_errors, match attrs_result.diagnostic { Some(diag) => diag, None => error(diagnostic_code("E1094"), current_token(skip_trivia(out_cursor)).span, "invalid attribute") });
            } else {
                ()
            };
            let item_start = out_cursor;
            let item_result = parse_program_item(out_cursor, attrs_result.attrs);
            if has_program_item_diagnostic(item_result) {
                diagnostics = push_diagnostic_if_room(diagnostics, max_errors, match item_result.diagnostic { Some(diag) => diag, None => error(diagnostic_code("E1389"), current_token(skip_trivia(item_start)).span, "invalid program item") });
                out_cursor = recover_program_item(item_result.cursor, item_result.cursor.index == item_start.index);
            } else {
                match item_result.item {
                    Some(item) => if true {
                        diagnostics = validate_program_attributes(item.attrs, program_item_target(item.kind), diagnostics, max_errors);
                        diagnostics = validate_program_item_nested_attributes(item, diagnostics, max_errors);
                        source_map = push_item_source_entry(source_map, item);
                        items = vec.push(items, item);
                        seen_items = true;
                        ()
                    } else {
                        ()
                    },
                    None => (),
                };
                out_cursor = item_result.cursor;
            };
        };
    };

    let program_span = parse_program_span(start_token.span, out_cursor);
    ParseProgram {
        cursor: out_cursor,
        program: Some(ast_program(out_cursor.source, module_item, imports, items, source_map, program_span)),
        diagnostics: diagnostics,
    }
}

pub fn parse_source_program(source: SourceId, text: String, max_errors: Int) -> ParseProgram
requires max_errors > 0 {
    parse_program(parser_cursor_from_source(source, text), max_errors)
}

pub fn remaining_token_count(cursor: ParserCursor) -> Int {
    let token_count = vec.vec_len(cursor.tokens);
    if cursor.index >= token_count {
        0
    } else {
        token_count - cursor.index
    }
}
