    parts = push_json_field(parts, "value", json_quote(value.value), false);
    parts = push_json_field(parts, "kind", ast_attribute_value_kind_json(value.kind), false);
    parts = push_json_field(parts, "named", json_bool(value.named), false);
    parts = push_json_field(parts, "span", json_span(value.span), false);
    parts = push_json_field(parts, "text", json_quote(value.text), false);
    parts = vec.push(parts, "}");
    string.join(parts, "")
}

