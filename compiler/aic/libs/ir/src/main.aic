}

pub struct IrImplDef {
    pub symbol: IrSymbolId,
    pub head_type: IrTypeId,
    pub head_text: String,
    pub visibility: AstVisibility,
    pub attrs: Vec[AstAttribute],
    pub generics: Vec[IrGenericParam],
    pub methods: Vec[IrFunctionDef],
