module compiler.ir;

import compiler.source;
import compiler.diagnostics;
import compiler.ast;
import compiler.typecheck;
import std.option;
import std.string;
import std.vec;

pub struct IrNodeId {
    pub value: Int,
} invariant value >= 0

pub struct IrSymbolId {
    pub value: Int,
} invariant value >= 0

pub struct IrTypeId {
    pub value: Int,
} invariant value >= 0

pub enum IrSymbolKind {
    IrFunctionSymbol,
    IrStructSymbol,
    IrEnumSymbol,
    IrTraitSymbol,
    IrImplSymbol,
    IrVariantSymbol,
    IrFieldSymbol,
    IrParameterSymbol,
    IrLocalSymbol,
    IrConstSymbol,
    IrTypeAliasSymbol,
    IrModuleSymbol,
}

pub enum IrTypeKind {
    IrUnitType,
    IrBoolType,
    IrIntType,
    IrUIntType,
    IrFloatType,
    IrStringType,
    IrCharType,
    IrNamedType(String),
    IrTupleType(String),
    IrFunctionType(String),
    IrDynTraitType(String),
    IrUnknownType,
}

pub enum IrExprKind {
    IrIntExpr,
    IrFloatExpr,
    IrBoolExpr,
    IrStringExpr,
    IrCharExpr,
    IrTemplateExpr,
    IrUnitExpr,
    IrNameExpr,
    IrCallExpr,
    IrClosureExpr,
    IrIfExpr,
    IrWhileExpr,
    IrForExpr,
    IrLoopExpr,
    IrBreakExpr,
    IrContinueExpr,
    IrMatchExpr,
    IrBinaryExpr,
    IrUnaryExpr,
    IrBorrowExpr,
    IrAwaitExpr,
    IrTryExpr,
    IrStructLiteralExpr,
    IrTupleExpr,
    IrFieldAccessExpr,
    IrBlockExpr,
    IrUnsafeBlockExpr,
}

pub enum IrPatternKind {
    IrWildcardPattern,
    IrVarPattern,
    IrIntPattern,
    IrBoolPattern,
    IrCharPattern,
    IrStringPattern,
    IrUnitPattern,
    IrOrPattern,
    IrVariantPattern,
    IrTuplePattern,
    IrStructPattern,
}

pub enum IrStatementKind {
    IrLetStatement,
    IrAssignStatement,
    IrExprStatement,
    IrReturnStatement,
    IrAssertStatement,
}

pub enum IrItemKind {
    IrFunctionItem,
    IrStructItem,
    IrEnumItem,
    IrTraitItem,
    IrImplItem,
    IrTypeAliasItem,
    IrConstItem,
}

pub enum IrGenericInstantiationKind {
    IrFunctionInstantiation,
    IrStructInstantiation,
    IrEnumInstantiation,
    IrUnknownInstantiation,
}

pub struct IrSymbol {
    pub id: IrSymbolId,
    pub name: String,
    pub kind: IrSymbolKind,
    pub span: SourceSpan,
}

pub struct IrTypeDef {
    pub id: IrTypeId,
    pub name: String,
    pub kind: IrTypeKind,
    pub span: SourceSpan,
}

pub struct IrFunction {
    pub symbol: IrSymbolId,
    pub name: String,
    pub return_type: IrTypeId,
    pub span: SourceSpan,
}

pub struct IrGenericParam {
    pub name: String,
    pub bounds: Vec[String],
    pub span: SourceSpan,
}

pub struct IrParam {
    pub symbol: IrSymbolId,
    pub name: String,
    pub attrs: Vec[AstAttribute],
    pub type_id: IrTypeId,
    pub span: SourceSpan,
}

pub struct IrClosureParam {
    pub name: String,
    pub type_id: Option[IrTypeId],
    pub span: SourceSpan,
}

pub struct IrField {
    pub symbol: IrSymbolId,
    pub name: String,
    pub visibility: AstVisibility,
    pub attrs: Vec[AstAttribute],
