fn ir_function_json(value: IrFunctionDef) -> String {
    let mut parts: Vec[String] = vec.new_vec();
    parts = vec.push(parts, "{");
    parts = push_json_field(parts, "symbol", ir_symbol_id_json(value.symbol), true);
    parts = push_json_field(parts, "name", json_quote(value.name), false);
    parts = push_json_field(parts, "visibility", ast_visibility_json(value.visibility), false);
    parts = push_json_field(parts, "attrs", ast_attributes_json(value.attrs), false);
    parts = push_json_field(parts, "is_async", json_bool(value.is_async), false);
    parts = push_json_field(parts, "is_unsafe", json_bool(value.is_unsafe), false);
    parts = push_json_field(parts, "is_extern", json_bool(value.is_extern), false);
    parts = push_json_field(parts, "extern_abi", if value.extern_abi == "" { "null" } else { json_quote(value.extern_abi) }, false);
    parts = push_json_field(parts, "is_intrinsic", json_bool(value.is_intrinsic), false);
    parts = push_json_field(parts, "intrinsic_abi", if value.intrinsic_abi == "" { "null" } else { json_quote(value.intrinsic_abi) }, false);
    parts = push_json_field(parts, "generics", ir_generic_params_json(value.generics), false);
    parts = push_json_field(parts, "params", ir_params_json(value.params), false);
    parts = push_json_field(parts, "ret_type", ir_type_id_json(value.return_type), false);
    parts = push_json_field(parts, "effects", json_string_array(value.effect_names), false);
    parts = push_json_field(parts, "capabilities", json_string_array(value.capability_names), false);
    parts = push_json_field(parts, "requires", optional_expr_json(value.requires_expr), false);
    parts = push_json_field(parts, "ensures", optional_expr_json(value.ensures_expr), false);
    parts = push_json_field(parts, "body", ir_block_json(value.body), false);
    parts = push_json_field(parts, "runtime_visible", json_bool(value.runtime_visible), false);
    parts = push_json_field(parts, "span", json_span(value.span), false);
    parts = vec.push(parts, "}");
    string.join(parts, "")
}

