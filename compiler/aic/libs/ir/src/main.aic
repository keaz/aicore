                parts = vec.push(parts, json_module_path(value));
                ()
            } else {
                ()
            },
            None => (),
        };
        index = index + 1;
    };
    parts = vec.push(parts, "]");
    string.join(parts, "")
}

fn json_span(value: SourceSpan) -> String {
    let mut parts: Vec[String] = vec.new_vec();
    parts = vec.push(parts, "{");
    parts = push_json_field(parts, "start", json_int(value.start), true);
    parts = push_json_field(parts, "end", json_int(value.end), false);
    parts = vec.push(parts, "}");
    string.join(parts, "")
}

fn json_source_span(value: SourceSpan) -> String {
    let mut parts: Vec[String] = vec.new_vec();
    parts = vec.push(parts, "{");
    parts = push_json_field(parts, "source", json_int(value.source.value), true);
    parts = push_json_field(parts, "start", json_int(value.start), false);
    parts = push_json_field(parts, "end", json_int(value.end), false);
    parts = vec.push(parts, "}");
    string.join(parts, "")
}

fn ast_visibility_json(value: AstVisibility) -> String {
