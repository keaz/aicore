fn ir_item_json(value: IrItem) -> String {
    let mut parts: Vec[String] = vec.new_vec();
    parts = vec.push(parts, "{");
    match value {
        IrFunctionItemValue(item) => if true {
            parts = push_json_field(parts, "Function", ir_function_json(item), true);
            ()
        } else {
            ()
        },
        IrStructItemValue(item) => if true {
            parts = push_json_field(parts, "Struct", ir_struct_json(item), true);
            ()
        } else {
            ()
        },
        IrEnumItemValue(item) => if true {
            parts = push_json_field(parts, "Enum", ir_enum_json(item), true);
            ()
        } else {
            ()
        },
        IrTraitItemValue(item) => if true {
            parts = push_json_field(parts, "Trait", ir_trait_json(item), true);
            ()
        } else {
            ()
        },
        IrImplItemValue(item) => if true {
            parts = push_json_field(parts, "Impl", ir_impl_json(item), true);
            ()
        } else {
            ()
        },
        IrTypeAliasItemValue(item) => if true {
            parts = push_json_field(parts, "TypeAlias", ir_type_alias_json(item), true);
            ()
        } else {
            ()
        },
        IrConstItemValue(item) => if true {
            parts = push_json_field(parts, "Const", ir_const_json(item), true);
            ()
        } else {
            ()
        },
    };
    parts = vec.push(parts, "}");
    string.join(parts, "")
}

