    parts = push_json_field(parts, "id", json_int(value.id), true);
    parts = push_json_field(parts, "kind", json_quote(ir_generic_instantiation_kind_name(value.kind)), false);
    parts = push_json_field(parts, "name", json_quote(value.name), false);
    parts = push_json_field(parts, "symbol", optional_symbol_id_json(value.symbol), false);
    parts = push_json_field(parts, "type_args", json_string_array(value.type_args), false);
    parts = push_json_field(parts, "mangled", json_quote(value.mangled), false);
    parts = push_json_field(parts, "span", json_span(value.span), false);
    parts = vec.push(parts, "}");
    string.join(parts, "")
}

fn ir_generic_instantiations_json(values: Vec[IrGenericInstantiation]) -> String {
    let mut parts: Vec[String] = vec.new_vec();
    parts = vec.push(parts, "[");
    let mut index = 0;
    while index < vec.vec_len(values) {
        match vec.get(values, index) {
            Some(value) => if true {
                if index > 0 {
                    parts = vec.push(parts, ",");
                } else {
                    ()
                };
                parts = vec.push(parts, ir_generic_instantiation_json(value));
                ()
            } else {
                ()
            },
            None => (),
        };
        index = index + 1;
    };
    parts = vec.push(parts, "]");
    string.join(parts, "")
}

fn ir_source_map_entry_json(value: IrSourceMapEntry) -> String {
    let mut parts: Vec[String] = vec.new_vec();
    parts = vec.push(parts, "{");
    parts = push_json_field(parts, "kind", json_quote(value.kind), true);
    parts = push_json_field(parts, "name", json_quote(value.name), false);
    parts = push_json_field(parts, "node", ir_node_id_json(value.node), false);
    parts = push_json_field(parts, "span", json_source_span(value.span), false);
    parts = vec.push(parts, "}");
    string.join(parts, "")
}

fn ir_source_map_json(values: Vec[IrSourceMapEntry]) -> String {
    let mut parts: Vec[String] = vec.new_vec();
    parts = vec.push(parts, "[");
    let mut index = 0;
    while index < vec.vec_len(values) {
        match vec.get(values, index) {
            Some(value) => if true {
                if index > 0 {
                    parts = vec.push(parts, ",");
                } else {
                    ()
                };
                parts = vec.push(parts, ir_source_map_entry_json(value));
                ()
            } else {
                ()
            },
            None => (),
        };
        index = index + 1;
    };
    parts = vec.push(parts, "]");
    string.join(parts, "")
}

fn diagnostic_severity_json(value: Severity) -> String {
    match value {
        Error => json_quote("error"),
        Warning => json_quote("warning"),
        Note => json_quote("note"),
    }
}

fn diagnostic_help_json(value: DiagnosticHelp) -> String {
    match value {
        NoHelp => "null",
        Help(text) => json_quote(text),
    }
}

fn diagnostic_json(value: Diagnostic) -> String {
    let mut parts: Vec[String] = vec.new_vec();
    parts = vec.push(parts, "{");
    parts = push_json_field(parts, "code", json_quote(value.code.value), true);
    parts = push_json_field(parts, "severity", diagnostic_severity_json(value.severity), false);
    parts = push_json_field(parts, "span", json_source_span(value.span), false);
    parts = push_json_field(parts, "message", json_quote(value.message), false);
    parts = push_json_field(parts, "help", diagnostic_help_json(value.help), false);
    parts = vec.push(parts, "}");
    string.join(parts, "")
}

fn diagnostics_json(values: Vec[Diagnostic]) -> String {
    let mut parts: Vec[String] = vec.new_vec();
    parts = vec.push(parts, "[");
    let mut index = 0;
    while index < vec.vec_len(values) {
        match vec.get(values, index) {
            Some(value) => if true {
                if index > 0 {
                    parts = vec.push(parts, ",");
                } else {
                    ()
                };
                parts = vec.push(parts, diagnostic_json(value));
                ()
            } else {
                ()
            },
            None => (),
        };
        index = index + 1;
    };
    parts = vec.push(parts, "]");
    string.join(parts, "")
}

pub fn ir_program_to_json(value: IrProgram) -> String {
    let mut parts: Vec[String] = vec.new_vec();
    parts = vec.push(parts, "{");
    parts = push_json_field(parts, "schema_version", json_int(value.schema_version), true);
    parts = push_json_field(parts, "format", json_quote("aicore-selfhost-ir-v1"), false);
    parts = push_json_field(parts, "module", json_module_path(value.module_path), false);
    parts = push_json_field(parts, "module_path", json_quote(value.module_path), false);
    parts = push_json_field(parts, "imports", json_imports(value.imports), false);
    parts = push_json_field(parts, "items", ir_items_json(value.items), false);
    parts = push_json_field(parts, "symbols", ir_symbols_json(value.symbols), false);
    parts = push_json_field(parts, "types", ir_types_json(value.types), false);
    parts = push_json_field(parts, "generic_instantiations", ir_generic_instantiations_json(value.generic_instantiations), false);
    parts = push_json_field(parts, "source_map", ir_source_map_json(value.source_map), false);
    parts = push_json_field(parts, "span", json_span(value.span), false);
    parts = vec.push(parts, "}");
    string.join(parts, "")
}

pub fn ir_lowering_result_to_json(value: IrLoweringResult) -> String {
    let mut parts: Vec[String] = vec.new_vec();
    parts = vec.push(parts, "{");
    parts = push_json_field(parts, "format", json_quote("aicore-selfhost-ir-lowering-v1"), true);
    parts = push_json_field(parts, "schema_version", json_int(current_ir_schema_version()), false);
    parts = push_json_field(parts, "diagnostics", diagnostics_json(value.diagnostics), false);
    parts = push_json_field(parts, "program", match value.program { Some(program_value) => ir_program_to_json(program_value), None => "null" }, false);
    parts = vec.push(parts, "}");
    string.join(parts, "")
}

pub fn ir_program_to_debug_text(value: IrProgram) -> String {
    let mut parts: Vec[String] = vec.new_vec();
    parts = vec.push(parts, "IR schema ");
    parts = vec.push(parts, string.int_to_string(value.schema_version));
    parts = vec.push(parts, "\nmodule ");
    parts = vec.push(parts, if value.module_path == "" { "<none>" } else { value.module_path });
    parts = vec.push(parts, "\nitems ");
    parts = vec.push(parts, string.int_to_string(vec.vec_len(value.items)));
    parts = vec.push(parts, "\nsymbols ");
    parts = vec.push(parts, string.int_to_string(vec.vec_len(value.symbols)));
    parts = vec.push(parts, "\ntypes ");
    parts = vec.push(parts, string.int_to_string(vec.vec_len(value.types)));
    parts = vec.push(parts, "\ninstantiations ");
    parts = vec.push(parts, string.int_to_string(vec.vec_len(value.generic_instantiations)));
    parts = vec.push(parts, "\nruntime_functions ");
    parts = vec.push(parts, string.int_to_string(ir_runtime_function_count(value)));
    parts = vec.push(parts, "\ndigest ");
    parts = vec.push(parts, ir_program_digest(value));
    string.join(parts, "")
}

fn serialization_error(code: String, span_value: SourceSpan, message: String, help: String) -> Diagnostic {
    with_help(error(diagnostic_code(code), span_value, message), help)
}

fn has_source_map_for_node(values: Vec[IrSourceMapEntry], node_value: IrNodeId) -> Bool {
    let mut index = 0;
    let mut found = false;
    while !found && index < vec.vec_len(values) {
        match vec.get(values, index) {
            Some(entry) => if entry.node.value == node_value.value {
                found = true;
            } else {
                ()
            },
            None => (),
        };
        index = index + 1;
    };
    found
}

fn item_source_map_kind(value: IrItem) -> String {
    match value {
        IrFunctionItemValue(_) => "function",
        IrStructItemValue(_) => "struct",
        IrEnumItemValue(_) => "enum",
        IrTraitItemValue(_) => "trait",
        IrImplItemValue(_) => "impl",
        IrTypeAliasItemValue(_) => "type_alias",
        IrConstItemValue(_) => "const",
    }
}

fn item_source_map_name(value: IrItem) -> String {
    match value {
        IrFunctionItemValue(item) => item.name,
        IrStructItemValue(item) => item.name,
        IrEnumItemValue(item) => item.name,
        IrTraitItemValue(item) => item.name,
        IrImplItemValue(item) => item.head_text,
        IrTypeAliasItemValue(item) => item.name,
        IrConstItemValue(item) => item.name,
    }
}

fn has_source_map_for_item(values: Vec[IrSourceMapEntry], item: IrItem) -> Bool {
    let kind = item_source_map_kind(item);
    let name = item_source_map_name(item);
    let mut index = 0;
    let mut found = false;
    while !found && index < vec.vec_len(values) {
        match vec.get(values, index) {
            Some(entry) => if entry.kind == kind && entry.name == name {
                found = true;
            } else {
                ()
            },
            None => (),
        };
        index = index + 1;
    };
    found
}

fn append_serialization_diagnostic(values: Vec[Diagnostic], code: String, span_value: SourceSpan, message: String, help: String) -> Vec[Diagnostic] {
    vec.push(values, serialization_error(code, span_value, message, help))
}

pub fn validate_ir_serialization_contract(value: IrProgram) -> Vec[Diagnostic] {
    let mut out: Vec[Diagnostic] = vec.new_vec();
    if value.schema_version != current_ir_schema_version() {
        out = append_serialization_diagnostic(out, "E5010", value.span, "IR serialization requires schema_version 1", "migrate older IR JSON before serializing or reject future schema versions explicitly");
    } else {
        ()
    };
    if vec.vec_len(value.items) > 0 && vec.vec_len(value.source_map) == 0 {
        out = append_serialization_diagnostic(out, "E5011", value.span, "IR serialization requires source-map metadata for item-bearing programs", "preserve lowering source_map entries so parity reports can locate generated nodes");
    } else {
        ()
    };
    let mut symbol_index = 0;
    let mut previous_symbol = 0;
    while symbol_index < vec.vec_len(value.symbols) {
        match vec.get(value.symbols, symbol_index) {
            Some(symbol_value) => if true {
                if symbol_value.id.value <= previous_symbol {
                    out = append_serialization_diagnostic(out, "E5012", symbol_value.span, "IR symbols must be serialized in strictly increasing id order", "emit symbols in deterministic lowering allocation order");
                } else {
                    ()
                };
                if symbol_value.name == "" {
                    out = append_serialization_diagnostic(out, "E5013", symbol_value.span, "IR symbol serialization requires a non-empty name", "retain symbol names during lowering");
                } else {
                    ()
                };
                previous_symbol = symbol_value.id.value;
                ()
            } else {
                ()
            },
            None => (),
        };
        symbol_index = symbol_index + 1;
    };
    let mut type_index = 0;
    let mut previous_type = 0;
    while type_index < vec.vec_len(value.types) {
        match vec.get(value.types, type_index) {
            Some(type_value) => if true {
                if type_value.id.value <= previous_type {
                    out = append_serialization_diagnostic(out, "E5012", type_value.span, "IR types must be serialized in strictly increasing id order", "emit types in deterministic interning order");
                } else {
                    ()
                };
                if type_value.name == "" {
                    out = append_serialization_diagnostic(out, "E5013", type_value.span, "IR type serialization requires a non-empty repr", "retain canonical type repr metadata during lowering");
                } else {
                    ()
                };
                previous_type = type_value.id.value;
                ()
            } else {
                ()
            },
            None => (),
        };
        type_index = type_index + 1;
    };
    let mut source_index = 0;
    let mut previous_node = 0;
    while source_index < vec.vec_len(value.source_map) {
        match vec.get(value.source_map, source_index) {
            Some(entry) => if true {
                if entry.node.value <= previous_node {
                    out = append_serialization_diagnostic(out, "E5012", entry.span, "IR source-map entries must be serialized in strictly increasing node order", "emit source-map entries in deterministic lowering order");
                } else {
                    ()
                };
                if entry.kind == "" || entry.name == "" {
                    out = append_serialization_diagnostic(out, "E5013", entry.span, "IR source-map serialization requires kind and name metadata", "preserve source-map kind/name fields during lowering");
                } else {
                    ()
                };
                previous_node = entry.node.value;
                ()
            } else {
                ()
            },
            None => (),
        };
        source_index = source_index + 1;
    };
    let mut item_index = 0;
    while item_index < vec.vec_len(value.items) {
        match vec.get(value.items, item_index) {
            Some(item_value) => if !has_source_map_for_item(value.source_map, item_value) {
                out = append_serialization_diagnostic(out, "E5011", value.span, "IR item is missing source-map metadata", "append a source-map entry for each lowered item symbol");
            } else {
                ()
            },
            None => (),
        };
        item_index = item_index + 1;
    };
    out
}

pub fn ir_serialization_has_diagnostic_code(values: Vec[Diagnostic], code: String) -> Bool {
    let mut index = 0;
    let mut found = false;
    while !found && index < vec.vec_len(values) {
        match vec.get(values, index) {
            Some(value) => if value.code.value == code {
                found = true;
            } else {
                ()
            },
            None => (),
        };
        index = index + 1;
    };
    found
}

pub fn ir_serialization_diagnostic_count(values: Vec[Diagnostic]) -> Int {
    vec.vec_len(values)
}

pub fn serialize_ir_program(value: IrProgram) -> IrSerializationReport {
    let diags = validate_ir_serialization_contract(value);
    IrSerializationReport {
        format: "aicore-selfhost-ir-serialization-v1",
        schema_version: current_ir_schema_version(),
        digest: ir_program_digest(value),
        json: ir_program_to_json(value),
        debug_text: ir_program_to_debug_text(value),
        diagnostics: diags,
    }
}

pub fn ir_serialization_report_to_json(value: IrSerializationReport) -> String {
    let mut parts: Vec[String] = vec.new_vec();
    parts = vec.push(parts, "{");
    parts = push_json_field(parts, "format", json_quote(value.format), true);
    parts = push_json_field(parts, "schema_version", json_int(value.schema_version), false);
    parts = push_json_field(parts, "digest", json_quote(value.digest), false);
    parts = push_json_field(parts, "ok", json_bool(vec.vec_len(value.diagnostics) == 0), false);
    parts = push_json_field(parts, "json", json_quote(value.json), false);
    parts = push_json_field(parts, "debug_text", json_quote(value.debug_text), false);
    parts = push_json_field(parts, "diagnostics", diagnostics_json(value.diagnostics), false);
    parts = vec.push(parts, "}");
    string.join(parts, "")
}

pub fn ir_program_to_parity_artifact_json(value: IrProgram, case_name: String, source_path: String) -> String {
    let report = serialize_ir_program(value);
    let mut parts: Vec[String] = vec.new_vec();
    parts = vec.push(parts, "{");
    parts = push_json_field(parts, "format", json_quote("aicore-selfhost-ir-artifact-v1"), true);
    parts = push_json_field(parts, "case", json_quote(case_name), false);
    parts = push_json_field(parts, "path", json_quote(source_path), false);
    parts = push_json_field(parts, "schema_version", json_int(report.schema_version), false);
    parts = push_json_field(parts, "digest", json_quote(report.digest), false);
    parts = push_json_field(parts, "ok", json_bool(vec.vec_len(report.diagnostics) == 0), false);
    parts = push_json_field(parts, "diagnostics", diagnostics_json(report.diagnostics), false);
    parts = push_json_field(parts, "ir", report.json, false);
    parts = vec.push(parts, "}");
    string.join(parts, "")
}
