/// The `std.concurrent` module provides standard-library `concurrent` APIs.
///
/// ## Example
/// ```aic
/// import std.concurrent;
/// ```
module std.concurrent;

import std.bytes;
import std.json;
import std.option;
import std.result;
import std.vec;

/// `ConcurrencyError` is a `enum` in `std.concurrent`.
///
/// ## Example
/// ```aic
/// // Use `ConcurrencyError` through `std.concurrent` APIs.
/// ```
enum ConcurrencyError {
    /// `NotFound` enum variant.
    NotFound,
    /// `Timeout` enum variant.
    Timeout,
    /// `Cancelled` enum variant.
    Cancelled,
    /// `InvalidInput` enum variant.
    InvalidInput,
    /// `Panic` enum variant.
    Panic,
    /// `Closed` enum variant.
    Closed,
    /// `Io` enum variant.
    Io,
}

/// `ChannelError` is a `enum` in `std.concurrent`.
///
/// ## Example
/// ```aic
/// // Use `ChannelError` through `std.concurrent` APIs.
/// ```
enum ChannelError {
    /// `Closed` enum variant.
    Closed,
    /// `Full` enum variant.
    Full,
    /// `Empty` enum variant.
    Empty,
    /// `Timeout` enum variant.
    Timeout,
}

