/// `unlock_guard` in `std.concurrent`.
///
/// ## Example
/// ```aic
/// // Import `std.concurrent` and call `unlock_guard` with module-specific arguments.
/// ```
///
/// ## Effects
/// See the function signature for required effects and capabilities.
///
/// ## Errors
/// Returns module-defined error variants when the operation fails.
fn unlock_guard[T](g: MutexGuard[T]) -> () effects { concurrency } {
    let payload_id = match json_encode_payload(g.value) {
        Ok(payload) => match aic_conc_payload_store_intrinsic(payload) {
            Ok(id) => id,
            Err(_) => 0,
        },
        Err(_) => 0,
    };
    if g.guard_kind == 2 {
        let _unlock = aic_conc_rwlock_write_unlock_intrinsic(
            IntRwLock { handle: g.handle },
            payload_id,
        );
    } else {
        let _unlock = aic_conc_mutex_unlock_intrinsic(
            IntMutex { handle: g.handle },
            payload_id,
        );
    }
}

