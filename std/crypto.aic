/// The `std.crypto` module provides standard-library `crypto` APIs.
///
/// ## Example
/// ```aic
/// import std.crypto;
/// ```
module std.crypto;

import std.bytes;
import std.result;

/// `CryptoError` is a `enum` in `std.crypto`.
///
/// ## Example
/// ```aic
/// // Use `CryptoError` through `std.crypto` APIs.
/// ```
enum CryptoError {
    /// `InvalidInput` enum variant.
    InvalidInput,
    /// `UnsupportedAlgorithm` enum variant.
    UnsupportedAlgorithm,
    /// `Internal` enum variant.
    Internal,
}

