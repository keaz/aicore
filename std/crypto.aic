    }
}

/// `pbkdf2_sha256` in `std.crypto`.
///
/// ## Example
/// ```aic
/// // Import `std.crypto` and call `pbkdf2_sha256` with module-specific arguments.
/// ```
///
/// ## Effects
/// See the function signature for required effects and capabilities.
///
/// ## Errors
/// Returns module-defined error variants when the operation fails.
fn pbkdf2_sha256(password: String, salt: Bytes, iterations: Int, key_length: Int) -> Result[Bytes, CryptoError] {
    let raw = aic_crypto_pbkdf2_sha256_intrinsic(password, salt.data, iterations, key_length);
    match raw {
        Ok(data) => Ok(Bytes { data: data }),
        Err(err) => Err(err),
    }
}

