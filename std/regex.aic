/// The `std.regex` module provides standard-library `regex` APIs.
///
/// ## Example
/// ```aic
/// import std.regex;
/// ```
module std.regex;

import std.option;
import std.result;
import std.string;
import std.vec;

/// `RegexError` is a `enum` in `std.regex`.
///
/// ## Example
/// ```aic
/// // Use `RegexError` through `std.regex` APIs.
/// ```
enum RegexError {
    /// `InvalidPattern` enum variant.
    InvalidPattern,
    /// `InvalidInput` enum variant.
    InvalidInput,
    /// `NoMatch` enum variant.
    NoMatch,
    /// `UnsupportedFeature` enum variant.
    UnsupportedFeature,
    /// `TooComplex` enum variant.
    TooComplex,
    /// `Internal` enum variant.
    Internal,
}

/// `Regex` is a `struct` in `std.regex`.
///
/// ## Example
/// ```aic
/// // Use `Regex` through `std.regex` APIs.
/// ```
struct Regex {
    pattern: String,
    flags: Int,
}

/// `RegexMatch` is a `struct` in `std.regex`.
///
/// ## Example
/// ```aic
/// // Use `RegexMatch` through `std.regex` APIs.
/// ```
struct RegexMatch {
    full: String,
    groups: Vec[String],
    start: Int,
    end: Int,
}

/// `aic_regex_compile_intrinsic` in `std.regex`.
///
/// ## Example
/// ```aic
/// // Import `std.regex` and call `aic_regex_compile_intrinsic` with module-specific arguments.
/// ```
///
/// ## Effects
/// See the function signature for required effects and capabilities.
///
/// ## Errors
/// Returns module-defined error variants when the operation fails.
fn aic_regex_compile_intrinsic(pattern: String, flags: Int) -> Result[Regex, RegexError] {
    let out: Result[Regex, RegexError] = Ok(Regex {
        pattern: pattern,
        flags: flags,
    });
    out
}

