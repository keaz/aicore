fn aic_regex_captures_intrinsic(regex: Regex, text: String) -> Result[Option[RegexMatch], RegexError] {
    let out: Result[Option[RegexMatch], RegexError] = Ok(None());
    out
}

/// No regex flags.
fn no_flags() -> Int {
    0
}

/// Case-insensitive matching (ASCII semantics from the runtime regex engine).
fn flag_case_insensitive() -> Int {
    1
}

/// Multi-line mode: ^ and $ match line boundaries.
fn flag_multiline() -> Int {
    2
}

/// Dot matches newline. Unsupported together with multi-line mode in this runtime.
fn flag_dot_matches_newline() -> Int {
    4
}

/// `compile` in `std.regex`.
///
/// ## Example
/// ```aic
/// // Import `std.regex` and call `compile` with module-specific arguments.
/// ```
///
/// ## Effects
/// See the function signature for required effects and capabilities.
///
/// ## Errors
/// Returns module-defined error variants when the operation fails.
fn compile(pattern: String) -> Result[Regex, RegexError] {
    compile_with_flags(pattern, no_flags())
}

/// `compile_with_flags` in `std.regex`.
