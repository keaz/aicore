/// ```aic
/// // Import `std.fs` and call `mkdir` with module-specific arguments.
/// ```
///
/// ## Effects
/// See the function signature for required effects and capabilities.
///
/// ## Errors
/// Returns module-defined error variants when the operation fails.
fn mkdir(path: String) -> Result[Bool, FsError] effects { fs } {
    aic_fs_mkdir_intrinsic(path)
}

