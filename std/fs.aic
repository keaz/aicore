/// `fs_async_poll_bool_task` in `std.fs`.
///
/// Polls a task-backed async filesystem bool operation without blocking and
/// unwraps the nested `Result` shape into the public fs error contract.
fn fs_async_poll_bool_task(
    task: Task[Result[Bool, FsError]],
) -> Result[Option[Bool], FsError] effects { concurrency } {
    match concurrent.poll_value_task(task) {
        Ok(state) => match state {
            Some(result) => match result {
                Ok(value) => Ok(Some(value)),
                Err(err) => Err(err),
            },
            None => Ok(None()),
        },
        Err(err) => Err(fs_map_concurrency_error(err)),
    }
}

