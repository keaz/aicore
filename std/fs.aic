/// Task-backed filesystem helpers run blocking fs operations on the concurrent task runtime.
/// Public submit/wait APIs and `await Result[AsyncFs*Op, FsError]` build on these handles.

/// `spawn_read_text` in `std.fs`.
fn spawn_read_text(
    path: String,
) -> Result[Task[Result[String, FsError]], ConcurrencyError] effects { fs, concurrency } {
    concurrent.aic_conc_spawn_fn_named_intrinsic("fs.read_text", || -> Result[String, FsError] {
        read_text(path)
    })
}

/// `spawn_write_text` in `std.fs`.
fn spawn_write_text(
    path: String,
    content: String,
) -> Result[Task[Result[Bool, FsError]], ConcurrencyError] effects { fs, concurrency } {
