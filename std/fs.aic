/// `fs_timeout_error` in `std.fs`.
///
/// Builds the canonical timeout error used by async filesystem wait helpers.
fn fs_timeout_error() -> FsError {
    Timeout()
}

/// `fs_cancelled_error` in `std.fs`.
///
/// Builds the canonical cancelled error used by async filesystem submit and
/// cancellation helpers.
fn fs_cancelled_error() -> FsError {
    Cancelled()
}

/// `fs_map_concurrency_error` in `std.fs`.
///
/// Maps task-runtime concurrency failures into the public `FsError` contract
/// used by async filesystem APIs.
fn fs_map_concurrency_error(err: ConcurrencyError) -> FsError {
    match err {
        Timeout => fs_timeout_error(),
        Cancelled => fs_cancelled_error(),
        InvalidInput => InvalidInput(),
        NotFound => InvalidInput(),
        Panic => Io(),
        Closed => Io(),
        Io => Io(),
    }
}

/// `fs_async_bool_task` in `std.fs`.
///
/// Reinterprets a typed async filesystem bool handle as the underlying task
/// handle used by the concurrent runtime.
fn fs_async_bool_task(op: AsyncFsBoolOp) -> Task[Result[Bool, FsError]] {
    Task { handle: op.handle }
}

