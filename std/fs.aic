/// On Windows, creating symbolic links may require elevated privileges and can return
/// PermissionDenied/Io when the OS denies the operation.
fn create_symlink(target_path: String, link_path: String) -> Result[Bool, FsError] effects { fs } {
    aic_fs_create_symlink_intrinsic(target_path, link_path)
}

/// On Windows, read_symlink is currently unsupported and returns Io.
fn read_symlink(path: String) -> Result[String, FsError] effects { fs } {
    aic_fs_read_symlink_intrinsic(path)
}

