/// `fs_async_wait_bool_task` in `std.fs`.
///
/// Waits for completion of a task-backed async filesystem bool operation until
/// success, failure, or timeout.
fn fs_async_wait_bool_task(
    task: Task[Result[Bool, FsError]],
    timeout_ms: Int,
) -> Result[Bool, FsError] effects { concurrency, time } {
    if timeout_ms < 0 {
        Err(InvalidInput())
    } else {
        let deadline_ms = deadline_after_ms(timeout_ms);
        let task_handle = task.handle;
        let mut done = false;
        let mut value: Option[Bool] = None();
        let mut failure: Option[FsError] = None();

        while !done {
            match fs_async_poll_bool_task(Task { handle: task_handle }) {
                Ok(state) => match state {
                    Some(found) => if true {
                        done = true;
                        value = Some(found);
                    } else {
                        ()
                    },
                    None => if remaining_ms(deadline_ms) <= 0 {
                        done = true;
                        failure = Some(fs_timeout_error());
                    } else {
                        sleep_ms(1);
                    },
                },
                Err(err) => if true {
                    done = true;
                    failure = Some(err);
                } else {
                    ()
                },
            };
        };

        match failure {
            Some(err) => Err(err),
            None => match value {
                Some(found) => Ok(found),
                None => Err(fs_timeout_error()),
            },
        }
    }
}

