/// `async_wait_many_bool` in `std.fs`.
fn async_wait_many_bool(
    ops: Vec[AsyncFsBoolOp],
    timeout_ms: Int,
) -> Result[FsAsyncBoolSelection, FsError] effects { concurrency, time } {
    if timeout_ms < 0 || ops.len == 0 {
        Err(InvalidInput())
    } else {
        let deadline_ms = deadline_after_ms(timeout_ms);
        let mut done = false;
        let mut selected = FsAsyncBoolSelection { index: 0, value: false };
        let mut failed = false;
        let mut failure: FsError = fs_timeout_error();

        while !done && !failed {
            let mut i = 0;
            while i < ops.len && !done && !failed {
                match aic_vec_get_intrinsic(ops, i) {
                    Some(op) => match async_poll_bool(AsyncFsBoolOp { handle: op.handle }) {
                        Ok(state) => match state {
                            Some(value) => if true {
                                done = true;
                                selected = FsAsyncBoolSelection { index: i, value: value };
                            } else {
                                ()
                            },
                            None => (),
                        },
                        Err(err) => if true {
                            failed = true;
                            failure = err;
                        } else {
                            ()
                        },
                    },
                    None => (),
                };
                i = i + 1;
            };

            if !done && !failed {
                if remaining_ms(deadline_ms) <= 0 {
                    failed = true;
                    failure = fs_timeout_error();
                } else {
                    sleep_ms(1);
                };
            } else {
                ()
            };
        };

        if done {
            Ok(selected)
        } else {
            Err(failure)
        }
    }
}

