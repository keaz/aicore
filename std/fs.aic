/// The `std.fs` module provides standard-library `fs` APIs.
///
/// ## Example
/// ```aic
/// import std.fs;
/// ```
module std.fs;

import std.bytes;
import std.option;
import std.result;
import std.vec;

/// `FsError` is a `enum` in `std.fs`.
///
/// ## Example
/// ```aic
/// // Use `FsError` through `std.fs` APIs.
/// ```
enum FsError {
    /// `NotFound` enum variant.
    NotFound,
    /// `PermissionDenied` enum variant.
    PermissionDenied,
    /// `AlreadyExists` enum variant.
    AlreadyExists,
    /// `InvalidInput` enum variant.
    InvalidInput,
    /// `Io` enum variant.
    Io,
}

/// `FsMetadata` is a `struct` in `std.fs`.
///
/// ## Example
/// ```aic
/// // Use `FsMetadata` through `std.fs` APIs.
/// ```
struct FsMetadata {
    is_file: Bool,
    is_dir: Bool,
    size: Int,
}

/// `FileHandle` is a `struct` in `std.fs`.
///
/// ## Example
/// ```aic
/// // Use `FileHandle` through `std.fs` APIs.
/// ```
struct FileHandle {
    handle: Int,
}

// Internal compiler/runtime intrinsics lowered by the LLVM backend.
// Public APIs below delegate to these entrypoints.
