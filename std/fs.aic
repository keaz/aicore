/// The `std.fs` module provides standard-library `fs` APIs.
///
/// ## Example
/// ```aic
/// import std.fs;
/// ```
module std.fs;

import std.bytes;
import std.concurrent;
import std.option;
import std.result;
import std.time;
import std.vec;

/// `FsError` is a `enum` in `std.fs`.
///
/// ## Example
/// ```aic
/// // Use `FsError` through `std.fs` APIs.
/// ```
///
/// `Timeout` and `Cancelled` are used by async filesystem submit/wait/control APIs.
/// Synchronous filesystem operations continue to return the stable filesystem variants
/// (`NotFound`, `PermissionDenied`, `AlreadyExists`, `InvalidInput`, `Io`).
enum FsError {
    /// `NotFound` enum variant.
    NotFound,
    /// `PermissionDenied` enum variant.
    PermissionDenied,
    /// `AlreadyExists` enum variant.
    AlreadyExists,
    /// `InvalidInput` enum variant.
    InvalidInput,
    /// `Timeout` enum variant.
    Timeout,
    /// `Cancelled` enum variant.
    Cancelled,
    /// `Io` enum variant.
    Io,
}

/// `FsMetadata` is a `struct` in `std.fs`.
///
/// ## Example
/// ```aic
/// // Use `FsMetadata` through `std.fs` APIs.
/// ```
struct FsMetadata {
    is_file: Bool,
    is_dir: Bool,
    size: Int,
}

/// `FileHandle` is a `struct` in `std.fs`.
///
/// ## Example
/// ```aic
/// // Use `FileHandle` through `std.fs` APIs.
/// ```
struct FileHandle {
    handle: Int,
}

/// `AsyncFsBoolOp` is a `struct` in `std.fs`.
struct AsyncFsBoolOp {
    handle: Int,
}

/// `AsyncFsTextOp` is a `struct` in `std.fs`.
struct AsyncFsTextOp {
    handle: Int,
}

/// `AsyncFsBytesOp` is a `struct` in `std.fs`.
struct AsyncFsBytesOp {
    handle: Int,
}

/// `FsAsyncRuntimePressure` is a `struct` in `std.fs`.
struct FsAsyncRuntimePressure {
    active_ops: Int,
    queue_depth: Int,
    op_limit: Int,
    queue_limit: Int,
}

/// `FsAsyncBoolSelection` is a `struct` in `std.fs`.
struct FsAsyncBoolSelection {
    index: Int,
    value: Bool,
}

/// `FsAsyncTextSelection` is a `struct` in `std.fs`.
struct FsAsyncTextSelection {
    index: Int,
    text: String,
}

/// `FsAsyncBytesSelection` is a `struct` in `std.fs`.
struct FsAsyncBytesSelection {
    index: Int,
    payload: Bytes,
}

