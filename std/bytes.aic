/// Returns module-defined error variants when the operation fails.
fn aic_bytes_len_intrinsic(data: String) -> Int {
    aic_string_len_intrinsic(data)
}

/// `aic_bytes_concat_intrinsic` in `std.bytes`.
///
/// ## Example
/// ```aic
/// // Import `std.bytes` and call `aic_bytes_concat_intrinsic` with module-specific arguments.
/// ```
///
/// ## Effects
/// See the function signature for required effects and capabilities.
///
/// ## Errors
/// Returns module-defined error variants when the operation fails.
fn aic_bytes_concat_intrinsic(left: String, right: String) -> String {
    let pieces = append(vec_of(left), vec_of(right));
    aic_string_format_intrinsic("{0}{1}", pieces)
}

