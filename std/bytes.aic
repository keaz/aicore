/// `compare_bytes` in `std.bytes`.
///
/// ## Example
/// ```aic
/// // Import `std.bytes` and call `compare_bytes` with module-specific arguments.
/// ```
///
/// ## Effects
/// See the function signature for required effects and capabilities.
///
/// ## Errors
/// Returns module-defined error variants when the operation fails.
fn compare_bytes(a: Bytes, b: Bytes) -> Int {
    let len_a = byte_len(a);
    let len_b = byte_len(b);
    let mut i = 0;
    let mut cmp = 0;
    let mut done = false;
    while i < len_a && i < len_b && !done {
        let av = match byte_at(a, i) {
            Ok(v) => v,
            Err(_) => 0,
        };
        let bv = match byte_at(b, i) {
            Ok(v) => v,
            Err(_) => 0,
        };
        if av < bv {
            cmp = -1;
            done = true;
        } else {
            if av > bv {
                cmp = 1;
                done = true;
            } else {
                ();
            }
        };
        i = i + 1;
    };
    if done {
        cmp
    } else {
        if len_a < len_b {
            -1
        } else {
            if len_a > len_b {
                1
            } else {
                0
            }
        }
    }
}

/// `from_byte_values` in `std.bytes`.
///
/// ## Example
/// ```aic
/// // Import `std.bytes` and call `from_byte_values` with module-specific arguments.
/// ```
///
/// ## Effects
/// See the function signature for required effects and capabilities.
///
/// ## Errors
/// Returns module-defined error variants when the operation fails.
fn from_byte_values(values: Vec[Int]) -> Result[Bytes, BytesError] {
    let mut i = 0;
    let mut valid = true;
    while i < values.len {
        let v = match aic_vec_get_intrinsic(values, i) {
            Some(byte) => byte,
            None => -1,
        };
        if (v < 0 || v > 255) && valid {
            valid = false;
        } else {
            ();
        };
        i = i + 1;
    };
    if valid {
        let out: Result[Bytes, BytesError] = Ok(Bytes {
            data: aic_bytes_from_byte_values_intrinsic(values),
        });
        out
    } else {
        let out: Result[Bytes, BytesError] = Err(InvalidInput());
        out
    }
}

/// `to_byte_values` in `std.bytes`.
///
/// ## Example
/// ```aic
/// // Import `std.bytes` and call `to_byte_values` with module-specific arguments.
/// ```
///
/// ## Effects
/// See the function signature for required effects and capabilities.
///
/// ## Errors
/// Returns module-defined error variants when the operation fails.
fn to_byte_values(data: Bytes) -> Vec[Int] {
    let mut out: Vec[Int] = aic_vec_new_intrinsic();
    let len = byte_len(data);
    let mut i = 0;
    while i < len {
        let value = match byte_at(data, i) {
            Ok(v) => v,
            Err(_) => 0,
        };
        out = aic_vec_push_intrinsic(out, value);
        i = i + 1;
    };
    out
}
