/// `is_empty` in `std.bytes`.
///
/// ## Example
/// ```aic
/// // Import `std.bytes` and call `is_empty` with module-specific arguments.
/// ```
///
/// ## Effects
/// See the function signature for required effects and capabilities.
///
/// ## Errors
/// Returns module-defined error variants when the operation fails.
fn is_empty(data: Bytes) -> Bool {
    byte_len(data) == 0
}

/// `concat` in `std.bytes`.
///
/// ## Example
/// ```aic
/// // Import `std.bytes` and call `concat` with module-specific arguments.
/// ```
///
/// ## Effects
/// See the function signature for required effects and capabilities.
///
/// ## Errors
/// Returns module-defined error variants when the operation fails.
fn concat(left: Bytes, right: Bytes) -> Bytes {
    let mut values = to_byte_values(left);
    let right_values = to_byte_values(right);
    let mut i = 0;
    while i < right_values.len {
        let value = match aic_vec_get_intrinsic(right_values, i) {
            Some(v) => v,
            None => 0,
        };
        values = aic_vec_push_intrinsic(values, value);
        i = i + 1;
    };
    match from_byte_values(values) {
        Ok(data) => data,
        Err(_) => empty(),
    }
}

/// `to_string` in `std.bytes`.
///
/// ## Example
/// ```aic
/// // Import `std.bytes` and call `to_string` with module-specific arguments.
/// ```
///
/// ## Effects
/// See the function signature for required effects and capabilities.
///
/// ## Errors
/// Returns module-defined error variants when the operation fails.
fn to_string(data: Bytes) -> Result[String, BytesError] {
    if aic_bytes_is_valid_utf8_intrinsic(data.data) {
        let out: Result[String, BytesError] = Ok(data.data);
        out
    } else {
        let out: Result[String, BytesError] = Err(InvalidUtf8());
        out
    }
}

