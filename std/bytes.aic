/// The `std.bytes` module provides standard-library `bytes` APIs.
///
/// ## Example
/// ```aic
/// import std.bytes;
/// ```
module std.bytes;

import std.result;
import std.string;
import std.vec;

/// `BytesError` is a `enum` in `std.bytes`.
///
/// ## Example
/// ```aic
/// // Use `BytesError` through `std.bytes` APIs.
/// ```
enum BytesError {
    /// `InvalidUtf8` enum variant.
    InvalidUtf8,
    /// `InvalidInput` enum variant.
    InvalidInput,
    /// `Io` enum variant.
    Io,
}

/// `Bytes` is a `struct` in `std.bytes`.
///
/// ## Example
/// ```aic
/// // Use `Bytes` through `std.bytes` APIs.
/// ```
struct Bytes {
    data: String,
}

