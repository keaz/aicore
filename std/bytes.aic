/// `byte_at` in `std.bytes`.
///
/// ## Example
/// ```aic
/// // Import `std.bytes` and call `byte_at` with module-specific arguments.
/// ```
///
/// ## Effects
/// See the function signature for required effects and capabilities.
///
/// ## Errors
/// Returns module-defined error variants when the operation fails.
fn byte_at(data: Bytes, index: Int) -> Result[Int, BytesError] {
    let len = byte_len(data);
    if index < 0 || index >= len {
        let out: Result[Int, BytesError] = Err(InvalidInput());
        out
    } else {
        let out: Result[Int, BytesError] = Ok(aic_bytes_byte_at_intrinsic(data.data, index));
        out
    }
}

/// `byte_slice` in `std.bytes`.
///
/// ## Example
/// ```aic
/// // Import `std.bytes` and call `byte_slice` with module-specific arguments.
/// ```
///
/// ## Effects
/// See the function signature for required effects and capabilities.
///
/// ## Errors
/// Returns module-defined error variants when the operation fails.
fn byte_slice(data: Bytes, start: Int, end: Int) -> Result[Bytes, BytesError] {
    let len = byte_len(data);
    if start < 0 || end < 0 || start > end || end > len {
        let out: Result[Bytes, BytesError] = Err(InvalidInput());
        out
    } else {
        let out: Result[Bytes, BytesError] = Ok(Bytes {
            data: aic_string_substring_intrinsic(data.data, start, end),
        });
        out
    }
}

/// `find_byte` in `std.bytes`.
///
/// ## Example
/// ```aic
/// // Import `std.bytes` and call `find_byte` with module-specific arguments.
/// ```
///
/// ## Effects
/// See the function signature for required effects and capabilities.
///
/// ## Errors
/// Returns module-defined error variants when the operation fails.
fn find_byte(data: Bytes, value: Int) -> Option[Int] {
    if value < 0 || value > 255 {
        let out: Option[Int] = None();
        out
    } else {
        let len = byte_len(data);
        let mut i = 0;
        let mut found = -1;
        while i < len {
            let b = match byte_at(data, i) {
                Ok(v) => v,
                Err(_) => -1,
            };
            if b == value && found < 0 {
                found = i;
            } else {
                ();
            };
            i = i + 1;
        };
        if found >= 0 {
            let out: Option[Int] = Some(found);
            out
        } else {
            let out: Option[Int] = None();
            out
        }
    }
}

