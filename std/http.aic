/// The `std.http` module provides standard-library `http` APIs.
///
/// ## Example
/// ```aic
/// import std.http;
/// ```
module std.http;

import std.result;
import std.vec;

/// `HttpError` is a `enum` in `std.http`.
///
/// ## Example
/// ```aic
/// // Use `HttpError` through `std.http` APIs.
/// ```
enum HttpError {
    /// `InvalidMethod` enum variant.
    InvalidMethod,
    /// `InvalidStatus` enum variant.
    InvalidStatus,
    /// `InvalidHeaderName` enum variant.
    InvalidHeaderName,
    /// `InvalidHeaderValue` enum variant.
    InvalidHeaderValue,
    /// `InvalidTarget` enum variant.
    InvalidTarget,
    /// `InvalidInput` enum variant.
    InvalidInput,
    /// `Internal` enum variant.
    Internal,
}

/// `HttpMethod` is a `enum` in `std.http`.
///
/// ## Example
/// ```aic
/// // Use `HttpMethod` through `std.http` APIs.
/// ```
enum HttpMethod {
    /// `Get` enum variant.
    Get,
    /// `Head` enum variant.
    Head,
    /// `Post` enum variant.
    Post,
    /// `Put` enum variant.
    Put,
    /// `Patch` enum variant.
    Patch,
    /// `Delete` enum variant.
    Delete,
    /// `Options` enum variant.
    Options,
}

/// `HttpHeader` is a `struct` in `std.http`.
///
/// ## Example
/// ```aic
/// // Use `HttpHeader` through `std.http` APIs.
/// ```
struct HttpHeader {
    name: String,
    value: String,
}

/// `HttpRequest` is a `struct` in `std.http`.
///
/// ## Example
/// ```aic
/// // Use `HttpRequest` through `std.http` APIs.
/// ```
struct HttpRequest {
    method: HttpMethod,
    target: String,
    headers: Vec[HttpHeader],
    body: String,
}

/// `HttpResponse` is a `struct` in `std.http`.
///
/// ## Example
/// ```aic
/// // Use `HttpResponse` through `std.http` APIs.
/// ```
struct HttpResponse {
    status: Int,
    reason: String,
    headers: Vec[HttpHeader],
    body: String,
}

/// `HttpResponseView` is a bounded public response model.
struct HttpResponseView {
    status: UInt16,
    reason: String,
    headers: Vec[HttpHeader],
    body: String,
}

/// `aic_http_parse_method_intrinsic` in `std.http`.
///
/// ## Example
/// ```aic
/// // Import `std.http` and call `aic_http_parse_method_intrinsic` with module-specific arguments.
/// ```
///
/// ## Effects
/// See the function signature for required effects and capabilities.
///
/// ## Errors
/// Returns module-defined error variants when the operation fails.
fn aic_http_parse_method_intrinsic(text: String) -> Result[HttpMethod, HttpError] {
    let out: Result[HttpMethod, HttpError] = Err(InvalidMethod());
    out
}

