/// `http_server_positive_chunk_bytes` normalizes nonpositive chunk sizes to `1`.
fn http_server_positive_chunk_bytes(chunk_bytes: Int) -> Int {
    if chunk_bytes <= 0 {
        1
    } else {
        chunk_bytes
    }
}

/// `http_server_request_body_reader_from_request` materializes a deterministic body reader from a buffered request.
fn http_server_request_body_reader_from_request(request: Request, chunk_bytes: Int) -> RequestBodyReader {
    let body = bytes.from_string(request.body);
    let head = http_server_request_head_from_request(request, body, false);
    RequestBodyReader {
        head: head,
        body: body,
        cursor: 0,
        chunk_bytes: http_server_positive_chunk_bytes(chunk_bytes),
    }
}

/// `http_server_request_head_from_request` derives streaming-safe request metadata from a buffered request payload.
fn http_server_request_head_from_request(
    request: Request,
    body: Bytes,
    chunked: Bool,
) -> RequestHead {
    RequestHead {
        method: request.method,
        path: request.path,
        query: request.query,
        headers: request.headers,
        content_length: bytes.byte_len(body),
        chunked: chunked,
    }
}

/// `http_server_streaming_response_wire_text` renders the HTTP status line and headers for fixed-length streaming responses.
fn http_server_streaming_response_wire_text(
    status: UInt16,
    headers: Map[String, String],
    content_length: Int,
) -> String {
    let status_text = http_server_status_reason_text(status);
    let status_line = string.format(
        "HTTP/1.1 {0} {1}\r\n",
        vec.append(vec.vec_of(string.int_to_string(http_server_status_to_int(status))), vec.vec_of(status_text)),
    );
    let header_lines = http_server_header_lines(headers);
    let content_line = string.format(
        "content-length: {0}\r\n\r\n",
        vec.vec_of(string.int_to_string(content_length)),
    );
    string.join(
        vec.append(
            vec.append(vec.vec_of(status_line), vec.vec_of(header_lines)),
            vec.vec_of(content_line),
        ),
        "",
    )
}

/// `http_server_header_lines` formats deterministic CRLF-delimited header lines from a response header map.
fn http_server_header_lines(headers: Map[String, String]) -> String {
    let entries = map.entries(headers);
    let mut lines: Vec[String] = vec.new_vec();
    let mut index = 0;
    while index < entries.len {
        let entry = match vec.get(entries, index) {
            Some(value) => value,
            None => MapEntry {
                key: "",
                value: "",
            },
        };
        let line = string.format(
            "{0}: {1}\r\n",
            vec.append(vec.vec_of(entry.key), vec.vec_of(entry.value)),
        );
        lines = vec.push(lines, line);
        index = index + 1;
    };
    string.join(lines, "")
}

/// `http_server_status_reason_text` maps bounded status codes to their HTTP reason phrases.
fn http_server_status_reason_text(status: UInt16) -> String {
    if status == 100u16 {
        "Continue"
    } else if status == 101u16 {
        "Switching Protocols"
    } else if status == 200u16 {
        "OK"
    } else if status == 201u16 {
        "Created"
    } else if status == 202u16 {
        "Accepted"
    } else if status == 204u16 {
        "No Content"
    } else if status == 301u16 {
        "Moved Permanently"
    } else if status == 302u16 {
        "Found"
    } else if status == 304u16 {
        "Not Modified"
    } else if status == 400u16 {
        "Bad Request"
    } else if status == 401u16 {
        "Unauthorized"
    } else if status == 403u16 {
        "Forbidden"
    } else if status == 404u16 {
        "Not Found"
    } else if status == 408u16 {
        "Request Timeout"
    } else if status == 409u16 {
        "Conflict"
    } else if status == 413u16 {
        "Payload Too Large"
    } else if status == 415u16 {
        "Unsupported Media Type"
    } else if status == 500u16 {
        "Internal Server Error"
    } else if status == 502u16 {
        "Bad Gateway"
    } else if status == 503u16 {
        "Service Unavailable"
    } else {
        ""
    }
}

/// `http_server_send_bytes` sends raw response bytes and maps transport errors into `ServerError`.
fn http_server_send_bytes(
    conn: Int,
    payload: Bytes,
    timeout_ms: Int,
) -> Result[Int, ServerError] effects { net } {
    match net.tcp_send_timeout(conn, payload, timeout_ms) {
        Ok(written) => Ok(written),
        Err(err) => Err(http_server_net_error_to_server_error(err)),
    }
}

/// `http_server_net_error_to_server_error` normalizes lower-level network failures into server-facing error variants.
fn http_server_net_error_to_server_error(err: NetError) -> ServerError {
    match err {
        Timeout => Timeout(),
        ConnectionClosed => ConnectionClosed(),
        InvalidInput => InvalidRequest(),
        Cancelled => Internal(),
        PermissionDenied => Net(),
        Refused => Net(),
        AddressInUse => Net(),
        Io => Net(),
        NotFound => Net(),
    }
}

/// `http_server_status_from_int` validates and converts runtime `Int` status to bounded `UInt16`.
fn http_server_status_from_int(status: Int) -> Result[UInt16, ServerError] {
    if status < 0 || status > 65535 {
        Err(Internal())
    } else {
        let mut remaining = status;
        let mut out: UInt16 = 0;
        let mut bit: UInt16 = 1;
        while remaining > 0 {
            if (remaining % 2) == 1 {
                out = out + bit;
            } else {
                ()
            };
            remaining = remaining / 2;
            if remaining > 0 {
                bit = bit + bit;
            } else {
                ()
            };
        };
        Ok(out)
    }
}

/// `http_server_response_from_raw` converts runtime response payloads into bounded public models.
fn http_server_response_from_raw(raw: Response) -> Result[ResponseView, ServerError] {
    match http_server_status_from_int(raw.status) {
        Ok(bounded_status) => Ok(ResponseView {
            status: bounded_status,
            headers: raw.headers,
            body: raw.body,
        }),
        Err(err) => Err(err),
    }
}

/// `http_server_response_to_raw` converts bounded public models into runtime boundary payloads.
fn http_server_response_to_raw(response: ResponseView) -> Response {
    Response {
        status: http_server_status_to_int(response.status),
        headers: response.headers,
        body: response.body,
    }
}

/// `http_server_zero_u16` in `std.http_server`.
fn http_server_zero_u16() -> UInt16 {
    0u16
}

/// `http_server_one_u16` in `std.http_server`.
fn http_server_one_u16() -> UInt16 {
    1u16
}

/// `http_server_status_to_int` converts bounded HTTP status values to runtime `Int`.
fn http_server_status_to_int(status: UInt16) -> Int {
    let mut out = 0;
    let mut remaining = status;
    let zero = http_server_zero_u16();
    let one = http_server_one_u16();
    while remaining > zero {
        remaining = remaining - one;
        out = out + 1;
    };
    out
}

/// `async_serve_connection` serves one async request/response exchange and always closes the accepted connection.
fn async_serve_connection(
    conn: Int,
    max_bytes: Int,
    timeout_ms: Int,
    handler: Fn(Request) -> ResponseView,
) -> Result[Int, ServerError] effects { net } {
    let served = match async_read_request(conn, max_bytes, timeout_ms) {
        Ok(request) => async_write_response(conn, handler(request)),
        Err(err) => Err(err),
    };
    let closed = close(conn);
    match served {
        Ok(written) => match closed {
            Ok(_) => Ok(written),
            Err(err) => Err(err),
        },
        Err(err) => match closed {
            Ok(_) => Err(err),
            Err(_) => Err(err),
        },
    }
}
