/// The `std.http_server` module provides standard-library `http server` APIs.
///
/// ## Example
/// ```aic
/// import std.http_server;
/// ```
module std.http_server;

import std.bytes;
import std.map;
import std.net;
import std.option;
import std.result;
import std.string;
import std.vec;

/// `ServerError` is a `enum` in `std.http_server`.
///
/// ## Example
/// ```aic
/// // Use `ServerError` through `std.http_server` APIs.
/// ```
enum ServerError {
    /// `InvalidRequest` enum variant.
    InvalidRequest,
    /// `InvalidMethod` enum variant.
    InvalidMethod,
    /// `InvalidHeader` enum variant.
    InvalidHeader,
    /// `InvalidTarget` enum variant.
    InvalidTarget,
    /// `Timeout` enum variant.
    Timeout,
    /// `ConnectionClosed` enum variant.
    ConnectionClosed,
    /// `BodyTooLarge` enum variant.
    BodyTooLarge,
    /// `Net` enum variant.
    Net,
    /// `Internal` enum variant.
    Internal,
}

/// `Request` is a `struct` in `std.http_server`.
///
/// ## Example
/// ```aic
/// // Use `Request` through `std.http_server` APIs.
/// ```
struct Request {
    method: String,
    path: String,
    query: Map[String, String],
    headers: Map[String, String],
    body: String,
}

/// `Response` is a `struct` in `std.http_server`.
///
/// ## Example
/// ```aic
/// // Use `Response` through `std.http_server` APIs.
/// ```
struct Response {
    status: Int,
    headers: Map[String, String],
    body: String,
}

/// `ResponseView` is a bounded public response model.
struct ResponseView {
    status: UInt16,
    headers: Map[String, String],
    body: String,
}

/// `RequestHead` exposes request metadata for body-stream processing.
struct RequestHead {
    method: String,
    path: String,
    query: Map[String, String],
    headers: Map[String, String],
    content_length: Int,
    chunked: Bool,
}

/// `RequestBodyReader` tracks deterministic chunked reads over request body bytes.
struct RequestBodyReader {
    head: RequestHead,
    body: Bytes,
    cursor: Int,
    chunk_bytes: Int,
}

/// `RequestBodyStep` represents one deterministic read step.
struct RequestBodyStep {
    reader: RequestBodyReader,
    chunk: Option[Bytes],
}

/// `ResponseBodyWriter` tracks deterministic fixed-length streaming response writes.
struct ResponseBodyWriter {
    conn: Int,
    timeout_ms: Int,
    expected_bytes: Int,
    sent_bytes: Int,
}

