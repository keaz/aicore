/// The `std.http_server` module provides standard-library `http server` APIs.
///
/// ## Example
/// ```aic
/// import std.http_server;
/// ```
module std.http_server;

import std.map;
import std.result;

/// `ServerError` is a `enum` in `std.http_server`.
///
/// ## Example
/// ```aic
/// // Use `ServerError` through `std.http_server` APIs.
/// ```
enum ServerError {
    /// `InvalidRequest` enum variant.
    InvalidRequest,
    /// `InvalidMethod` enum variant.
    InvalidMethod,
    /// `InvalidHeader` enum variant.
    InvalidHeader,
    /// `InvalidTarget` enum variant.
    InvalidTarget,
    /// `Timeout` enum variant.
    Timeout,
    /// `ConnectionClosed` enum variant.
    ConnectionClosed,
    /// `BodyTooLarge` enum variant.
    BodyTooLarge,
    /// `Net` enum variant.
    Net,
    /// `Internal` enum variant.
    Internal,
}

/// `Request` is a `struct` in `std.http_server`.
///
/// ## Example
/// ```aic
/// // Use `Request` through `std.http_server` APIs.
/// ```
struct Request {
    method: String,
    path: String,
    query: Map[String, String],
    headers: Map[String, String],
    body: String,
}

/// `Response` is a `struct` in `std.http_server`.
///
/// ## Example
/// ```aic
/// // Use `Response` through `std.http_server` APIs.
/// ```
struct Response {
    status: Int,
    headers: Map[String, String],
    body: String,
}

/// `ResponseView` is a bounded public response model.
struct ResponseView {
    status: UInt16,
    headers: Map[String, String],
    body: String,
}

/// `aic_http_server_listen_intrinsic` in `std.http_server`.
///
/// ## Example
/// ```aic
/// // Import `std.http_server` and call `aic_http_server_listen_intrinsic` with module-specific arguments.
/// ```
///
/// ## Effects
/// See the function signature for required effects and capabilities.
///
/// ## Errors
/// Returns module-defined error variants when the operation fails.
fn aic_http_server_listen_intrinsic(addr: String) -> Result[Int, ServerError] effects { net } {
    let _addr = addr;
    let out: Result[Int, ServerError] = Err(Net());
    out
}

