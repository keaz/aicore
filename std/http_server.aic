fn request_stream_done(reader: RequestBodyReader) -> Bool {
    reader.cursor >= bytes.byte_len(reader.body)
}

/// `request_stream_read_next` in `std.http_server`.
///
/// ## Example
/// ```aic
/// // Import `std.http_server` and call `request_stream_read_next` with module-specific arguments.
/// ```
///
/// ## Effects
/// See the function signature for required effects and capabilities.
///
/// ## Errors
/// Returns module-defined error variants when the operation fails.
fn request_stream_read_next(reader: RequestBodyReader) -> Result[RequestBodyStep, ServerError] {
    let chunk_bytes = http_server_positive_chunk_bytes(reader.chunk_bytes);
    let body_len = bytes.byte_len(reader.body);
    if reader.cursor >= body_len {
        Ok(RequestBodyStep {
            reader: reader,
            chunk: None(),
        })
    } else {
        let remaining = body_len - reader.cursor;
        let next_end = if remaining < chunk_bytes {
            body_len
        } else {
            reader.cursor + chunk_bytes
        };
        match bytes.byte_slice(reader.body, reader.cursor, next_end) {
            Ok(chunk) => Ok(RequestBodyStep {
                reader: RequestBodyReader {
                    head: reader.head,
                    body: reader.body,
                    cursor: next_end,
                    chunk_bytes: chunk_bytes,
                },
                chunk: Some(chunk),
            }),
            Err(_) => Err(Internal()),
        }
    }
}

/// `begin_streaming_response` in `std.http_server`.
///
/// ## Example
/// ```aic
/// // Import `std.http_server` and call `begin_streaming_response` with module-specific arguments.
/// ```
///
/// ## Effects
/// See the function signature for required effects and capabilities.
///
/// ## Errors
/// Returns module-defined error variants when the operation fails.
fn begin_streaming_response(
    conn: Int,
    status: UInt16,
    headers: Map[String, String],
    content_length: Int,
    timeout_ms: Int,
) -> Result[ResponseBodyWriter, ServerError] effects { net } {
    if content_length < 0 {
        Err(InvalidHeader())
    } else {
        let wire = http_server_streaming_response_wire_text(status, headers, content_length);
        match http_server_send_bytes(conn, bytes.from_string(wire), timeout_ms) {
            Ok(_) => Ok(ResponseBodyWriter {
                conn: conn,
                timeout_ms: timeout_ms,
                expected_bytes: content_length,
                sent_bytes: 0,
            }),
            Err(err) => Err(err),
        }
    }
}

/// `write_streaming_response_chunk` in `std.http_server`.
///
/// ## Example
/// ```aic
/// // Import `std.http_server` and call `write_streaming_response_chunk` with module-specific arguments.
/// ```
///
/// ## Effects
/// See the function signature for required effects and capabilities.
///
/// ## Errors
/// Returns module-defined error variants when the operation fails.
fn write_streaming_response_chunk(
    writer: ResponseBodyWriter,
    chunk: Bytes,
) -> Result[ResponseBodyWriter, ServerError] effects { net } {
    let chunk_len = bytes.byte_len(chunk);
    let remaining = writer.expected_bytes - writer.sent_bytes;
    if chunk_len > remaining {
        Err(BodyTooLarge())
    } else {
        match http_server_send_bytes(writer.conn, chunk, writer.timeout_ms) {
            Ok(written) => if written != chunk_len {
                Err(Internal())
            } else {
                Ok(ResponseBodyWriter {
                    conn: writer.conn,
                    timeout_ms: writer.timeout_ms,
                    expected_bytes: writer.expected_bytes,
                    sent_bytes: writer.sent_bytes + written,
                })
            },
            Err(err) => Err(err),
        }
    }
}

/// `finish_streaming_response` in `std.http_server`.
///
/// ## Example
/// ```aic
/// // Import `std.http_server` and call `finish_streaming_response` with module-specific arguments.
/// ```
///
/// ## Effects
/// See the function signature for required effects and capabilities.
///
/// ## Errors
/// Returns module-defined error variants when the operation fails.
fn finish_streaming_response(writer: ResponseBodyWriter) -> Result[Int, ServerError] effects { net } {
    if writer.sent_bytes != writer.expected_bytes {
        Err(InvalidRequest())
    } else {
        Ok(writer.sent_bytes)
    }
}

