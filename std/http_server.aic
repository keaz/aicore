/// `http_server_status_from_int` validates and converts runtime `Int` status to bounded `UInt16`.
fn http_server_status_from_int(status: Int) -> Result[UInt16, ServerError] {
    if status < 0 || status > 65535 {
        Err(Internal())
    } else {
        let mut remaining = status;
        let mut out: UInt16 = 0;
        let mut bit: UInt16 = 1;
        while remaining > 0 {
            if (remaining % 2) == 1 {
                out = out + bit;
            } else {
                ()
            };
            remaining = remaining / 2;
            if remaining > 0 {
                bit = bit + bit;
            } else {
                ()
            };
        };
        Ok(out)
    }
}

/// `http_server_response_from_raw` converts runtime response payloads into bounded public models.
fn http_server_response_from_raw(raw: Response) -> Result[ResponseView, ServerError] {
    match http_server_status_from_int(raw.status) {
        Ok(bounded_status) => Ok(ResponseView {
            status: bounded_status,
            headers: raw.headers,
            body: raw.body,
        }),
        Err(err) => Err(err),
    }
}

/// `http_server_response_to_raw` converts bounded public models into runtime boundary payloads.
fn http_server_response_to_raw(response: ResponseView) -> Response {
    Response {
        status: http_server_status_to_int(response.status),
        headers: response.headers,
        body: response.body,
    }
}

/// `http_server_zero_u16` in `std.http_server`.
fn http_server_zero_u16() -> UInt16 {
    0u16
}

/// `http_server_one_u16` in `std.http_server`.
fn http_server_one_u16() -> UInt16 {
    1u16
}

/// `http_server_status_to_int` converts bounded HTTP status values to runtime `Int`.
fn http_server_status_to_int(status: UInt16) -> Int {
    let mut out = 0;
    let mut remaining = status;
    let zero = http_server_zero_u16();
    let one = http_server_one_u16();
    while remaining > zero {
        remaining = remaining - one;
        out = out + 1;
    };
    out
}
