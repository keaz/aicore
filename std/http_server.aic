/// `text_response` in `std.http_server`.
///
/// ## Example
/// ```aic
/// // Import `std.http_server` and call `text_response` with module-specific arguments.
/// ```
///
/// ## Effects
/// See the function signature for required effects and capabilities.
///
/// ## Errors
/// Returns module-defined error variants when the operation fails.
fn text_response(status: UInt16, body: String) -> ResponseView {
    let raw = aic_http_server_text_response_intrinsic(http_server_status_to_int(status), body);
    let bounded_status = match http_server_status_from_int(raw.status) {
        Ok(value) => value,
        Err(_) => status,
    };
    ResponseView {
        status: bounded_status,
        headers: raw.headers,
        body: raw.body,
    }
}

