/// `from_fs_error` in `std.io`.
///
/// ## Example
/// ```aic
/// // Import `std.io` and call `from_fs_error` with module-specific arguments.
/// ```
///
/// ## Effects
/// See the function signature for required effects and capabilities.
///
/// ## Errors
/// Returns module-defined error variants when the operation fails.
fn from_fs_error(err: FsError) -> IoError {
    match err {
        NotFound => io_end_of_input(),
        InvalidInput => io_invalid_input(),
        _ => io_other(),
    }
}

/// `from_net_error` in `std.io`.
///
/// ## Example
/// ```aic
/// // Import `std.io` and call `from_net_error` with module-specific arguments.
/// ```
///
/// ## Effects
/// See the function signature for required effects and capabilities.
///
/// ## Errors
/// Returns module-defined error variants when the operation fails.
fn from_net_error(err: NetError) -> IoError {
    match err {
        Timeout => io_end_of_input(),
        ConnectionClosed => io_end_of_input(),
        Cancelled => io_other(),
        InvalidInput => io_invalid_input(),
        _ => io_other(),
    }
}

