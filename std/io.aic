/// `IoError` is a `enum` in `std.io`.
///
/// ## Example
/// ```aic
/// // Use `IoError` through `std.io` APIs.
/// ```
enum IoError {
    /// `EndOfInput` enum variant.
    EndOfInput,
    /// `InvalidInput` enum variant.
    InvalidInput,
    /// `Io` enum variant.
    Io,
}

/// `IoErrorContext` is a `struct` in `std.io`.
///
/// ## Example
/// ```aic
/// // Use `IoErrorContext` through `std.io` APIs.
/// ```
struct IoErrorContext {
    error: IoError,
    context: String,
    chain: String,
}

/// `TcpReader` is a `struct` in `std.io`.
///
/// ## Example
/// ```aic
/// // Use `TcpReader` through `std.io` APIs.
/// ```
struct TcpReader {
    handle: Int,
    max_bytes: Int,
    timeout_ms: Int,
}

/// `Reader` is a `enum` in `std.io`.
///
/// ## Example
/// ```aic
/// // Use `Reader` through `std.io` APIs.
/// ```
enum Reader {
    /// `ReadStdin` enum variant.
    ReadStdin,
    /// `ReadFile` enum variant.
    ReadFile(FileHandle),
    /// `ReadTcp` enum variant.
    ReadTcp(TcpReader),
}

/// `Writer` is a `enum` in `std.io`.
///
/// ## Example
/// ```aic
/// // Use `Writer` through `std.io` APIs.
/// ```
enum Writer {
    /// `WriteStdout` enum variant.
    WriteStdout,
    /// `WriteStderr` enum variant.
    WriteStderr,
    /// `WriteFile` enum variant.
    WriteFile(FileHandle),
    /// `WriteTcp` enum variant.
    WriteTcp(Int),
}

/// `MockReader` is a `struct` in `std.io`.
///
/// ## Example
/// ```aic
/// // Use `MockReader` through `std.io` APIs.
