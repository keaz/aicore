/// `tls_version` in `std.tls`.
///
/// ## Example
/// ```aic
/// // Import `std.tls` and call `tls_version` with module-specific arguments.
/// ```
///
/// ## Effects
/// See the function signature for required effects and capabilities.
///
/// ## Errors
/// Returns module-defined error variants when the operation fails.
fn tls_version(stream: TlsStream) -> Result[TlsVersion, TlsError] effects { net } {
    let raw = aic_tls_version_intrinsic(stream.handle);
    match raw {
        Ok(value) => if value == 13 {
            Ok(Tls13())
        } else {
            if value == 12 {
                Ok(Tls12())
            } else {
                Err(ProtocolError())
            }
        },
        Err(err) => Err(err),
    }
}

/// `tls_subject_cn_value` in `std.tls`.
///
/// ## Example
/// ```aic
/// // Import `std.tls` and call `tls_subject_cn_value` with module-specific arguments.
/// ```
///
/// ## Effects
/// See the function signature for required effects and capabilities.
///
/// ## Errors
/// Returns module-defined error variants when the operation fails.
fn tls_subject_cn_value(text: String, start: Int) -> Result[String, TlsError] {
    let offset = start + 3;
    let tail = aic_string_substring_intrinsic(text, offset, aic_string_len_intrinsic(text));
    let cn = match aic_string_index_of_intrinsic(tail, "/") {
        Some(idx) => aic_string_substring_intrinsic(tail, 0, idx),
        None => tail,
    };
    if aic_string_len_intrinsic(cn) > 0 {
        Ok(cn)
    } else {
        Err(ProtocolError())
    }
}

/// `tls_peer_cn` in `std.tls`.
///
/// ## Example
/// ```aic
/// // Import `std.tls` and call `tls_peer_cn` with module-specific arguments.
/// ```
///
/// ## Effects
/// See the function signature for required effects and capabilities.
///
/// ## Errors
/// Returns module-defined error variants when the operation fails.
fn tls_peer_cn(stream: TlsStream) -> Result[String, TlsError] effects { net } {
    let subject = tls_peer_subject(stream);
    match subject {
        Err(err) => Err(err),
        Ok(text) => match aic_string_index_of_intrinsic(text, "CN=") {
            None => Err(ProtocolError()),
            Some(start) => tls_subject_cn_value(text, start),
        },
    }
}
