/// `tls_frame_len_be` in `std.tls`.
///
/// ## Example
/// ```aic
/// // Import `std.tls` and call `tls_frame_len_be` with module-specific arguments.
/// ```
///
/// ## Effects
/// See the function signature for required effects and capabilities.
///
/// ## Errors
/// Returns module-defined error variants when the operation fails.
fn tls_frame_len_be(header: Bytes) -> Result[Int, TlsError] {
    if byte_len(header) != 4 {
        Err(ProtocolError())
    } else {
        let b0 = match byte_at(header, 0) {
            Ok(value) => value,
            Err(_) => -1,
        };
        let b1 = match byte_at(header, 1) {
            Ok(value) => value,
            Err(_) => -1,
        };
        let b2 = match byte_at(header, 2) {
            Ok(value) => value,
            Err(_) => -1,
        };
        let b3 = match byte_at(header, 3) {
            Ok(value) => value,
            Err(_) => -1,
        };
        if b0 < 0 || b1 < 0 || b2 < 0 || b3 < 0 {
            Err(ProtocolError())
        } else {
            Ok((b0 * 16777216) + (b1 * 65536) + (b2 * 256) + b3)
        }
    }
}

/// `tls_recv_framed_payload` in `std.tls`.
///
/// ## Example
/// ```aic
/// // Import `std.tls` and call `tls_recv_framed_payload` with module-specific arguments.
/// ```
///
/// ## Effects
/// See the function signature for required effects and capabilities.
///
/// ## Errors
/// Returns module-defined error variants when the operation fails.
fn tls_recv_framed_payload(stream: TlsStream, frame_header: Bytes, max_frame_bytes: Int, deadline_ms: Int) -> Result[Bytes, TlsError] effects { net, time } {
    let frame_len = tls_frame_len_be(frame_header);
    match frame_len {
        Err(err) => Err(err),
        Ok(payload_len) => if payload_len < 0 || payload_len > max_frame_bytes {
            Err(ProtocolError())
        } else {
            tls_recv_exact_deadline(stream, payload_len, deadline_ms)
        },
    }
}

