/// The `std.tls` module provides standard-library `tls` APIs.
///
/// ## Example
/// ```aic
/// import std.tls;
/// ```
module std.tls;

import std.bytes;
import std.option;
import std.result;
import std.string;

/// `TlsError` is a `enum` in `std.tls`.
///
/// ## Example
/// ```aic
/// // Use `TlsError` through `std.tls` APIs.
/// ```
enum TlsError {
    /// `HandshakeFailed` enum variant.
    HandshakeFailed,
    /// `CertificateInvalid` enum variant.
    CertificateInvalid,
    /// `CertificateExpired` enum variant.
    CertificateExpired,
    /// `HostnameMismatch` enum variant.
    HostnameMismatch,
    /// `ProtocolError` enum variant.
    ProtocolError,
    /// `ConnectionClosed` enum variant.
    ConnectionClosed,
    /// `Io` enum variant.
    Io,
}

/// `TlsVersion` is a `enum` in `std.tls`.
///
/// ## Example
/// ```aic
/// // Use `TlsVersion` through `std.tls` APIs.
/// ```
enum TlsVersion {
    /// `Tls12` enum variant.
    Tls12,
    /// `Tls13` enum variant.
    Tls13,
}

/// `TlsConfig` is a `struct` in `std.tls`.
///
/// ## Example
/// ```aic
/// // Use `TlsConfig` through `std.tls` APIs.
/// ```
struct TlsConfig {
    verify_server: Bool,
    ca_cert_path: Option[String],
    client_cert_path: Option[String],
    client_key_path: Option[String],
    server_name: Option[String],
}

/// `TlsStream` is a `struct` in `std.tls`.
///
/// ## Example
/// ```aic
/// // Use `TlsStream` through `std.tls` APIs.
/// ```
struct TlsStream {
    handle: Int,
}

