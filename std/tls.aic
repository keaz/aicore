fn tls_zero_u8() -> UInt8 {
    0
}

fn tls_one_u8() -> UInt8 {
    1
}

fn tls_u8_to_int(value: UInt8) -> Int {
    let mut out = 0;
    let mut current: UInt8 = tls_zero_u8();
    let one = tls_one_u8();
    while current != value {
        current = current + one;
        out = out + 1;
    };
    out
}

fn tls_frame_byte_to_int(header: Bytes, index: Int) -> Result[Int, TlsError] {
    match byte_at(header, index) {
        Ok(value) => Ok(tls_u8_to_int(value)),
        Err(_) => Err(ProtocolError()),
    }
}

/// `tls_frame_len_be` in `std.tls`.
///
/// ## Example
/// ```aic
/// // Import `std.tls` and call `tls_frame_len_be` with module-specific arguments.
/// ```
///
/// ## Effects
/// See the function signature for required effects and capabilities.
///
/// ## Errors
/// Returns module-defined error variants when the operation fails.
fn tls_frame_len_be(header: Bytes) -> Result[Int, TlsError] {
    if byte_len(header) != 4 {
        Err(ProtocolError())
    } else {
        match tls_frame_byte_to_int(header, 0) {
            Err(err) => Err(err),
            Ok(b0) => match tls_frame_byte_to_int(header, 1) {
                Err(err) => Err(err),
                Ok(b1) => match tls_frame_byte_to_int(header, 2) {
                    Err(err) => Err(err),
                    Ok(b2) => match tls_frame_byte_to_int(header, 3) {
                        Err(err) => Err(err),
                        Ok(b3) => Ok((b0 * 16777216) + (b1 * 65536) + (b2 * 256) + b3),
                    },
                },
            },
        }
    }
}

/// `tls_recv_framed_payload` in `std.tls`.
///
/// ## Example
/// ```aic
/// // Import `std.tls` and call `tls_recv_framed_payload` with module-specific arguments.
/// ```
///
/// ## Effects
/// See the function signature for required effects and capabilities.
///
/// ## Errors
/// Returns module-defined error variants when the operation fails.
fn tls_recv_framed_payload(stream: TlsStream, frame_header: Bytes, max_frame_bytes: Int, deadline_ms: Int) -> Result[Bytes, TlsError] effects { net, time } {
    let frame_len = tls_frame_len_be(frame_header);
    match frame_len {
        Err(err) => Err(err),
        Ok(payload_len) => if payload_len < 0 || payload_len > max_frame_bytes {
            Err(ProtocolError())
        } else {
            tls_recv_exact_deadline(stream, payload_len, deadline_ms)
        },
    }
}

