}

/// `TlsAsyncStringSelection` is a `struct` in `std.tls`.
///
/// ## Example
/// ```aic
/// // Use `TlsAsyncStringSelection` through `std.tls` APIs.
/// ```
struct TlsAsyncStringSelection {
    index: Int,
    payload: Bytes,
}

