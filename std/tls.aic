        Tcp(tcp) => byte_stream_map_net(tcp_stream_recv_exact(tcp, expected_bytes, timeout_ms)),
        Tls(tls) => byte_stream_map_tls(tls_recv_exact(tls, expected_bytes, timeout_ms)),
    }
}

