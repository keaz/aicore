fn tls_recv_framed_deadline(stream: TlsStream, max_frame_bytes: Int, deadline_ms: Int) -> Result[Bytes, TlsError] effects { net, time } {
    if max_frame_bytes < 0 {
        Err(ProtocolError())
    } else {
        let header = tls_recv_exact_deadline(stream, 4, deadline_ms);
        match header {
            Err(err) => Err(err),
            Ok(frame_header) => tls_recv_framed_payload(stream, frame_header, max_frame_bytes, deadline_ms),
        }
    }
}

