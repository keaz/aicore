/// Internal conversion helper for deterministic UInt32 zero value.
fn buffer_zero_u32() -> UInt32 {
    0u32
}

/// Internal conversion helper for deterministic UInt32 one value.
fn buffer_one_u32() -> UInt32 {
    1u32
}

/// Internal conversion helper for deterministic Int domain upper-bound.
fn buffer_u32_int_max() -> UInt32 {
    2147483647u32
}

/// Converts Int to UInt32 and returns InvalidInput on out-of-range values.
fn buffer_int_to_u32(value: Int) -> Result[UInt32, BufferError] {
    if value < 0 {
        Err(InvalidInput())
    } else if value > 4294967295 {
        Err(InvalidInput())
    } else {
        let mut out: UInt32 = buffer_zero_u32();
        let mut remaining = value;
        let one_u32 = buffer_one_u32();
        while remaining > 0 {
            out = out + one_u32;
            remaining = remaining - 1;
        };
        Ok(out)
    }
}

/// Converts UInt32 to Int and returns InvalidInput on out-of-range values.
fn buffer_u32_to_int(value: UInt32) -> Result[Int, BufferError] {
    if value > buffer_u32_int_max() {
        Err(InvalidInput())
    } else {
        let mut out = 0;
        let mut remaining = value;
        let one_u32 = buffer_one_u32();
        while remaining > buffer_zero_u32() {
            out = out + 1;
            remaining = remaining - one_u32;
        };
        Ok(out)
    }
}

/// `new_buffer` in `std.buffer`.
///
/// ## Example
/// ```aic
/// // Import `std.buffer` and call `new_buffer` with module-specific arguments.
/// ```
///
/// ## Effects
/// See the function signature for required effects and capabilities.
///
/// ## Errors
/// Returns module-defined error variants when the operation fails.
fn new_buffer(capacity: Int) -> ByteBuffer {
    aic_buffer_new_intrinsic(capacity)
}

/// `new_buffer_u32` in `std.buffer`.
fn new_buffer_u32(capacity: BufferCapacityU32) -> Result[ByteBuffer, BufferError] {
    match buffer_u32_to_int(capacity) {
        Ok(capacity_int) => Ok(new_buffer(capacity_int)),
        Err(err) => Err(err),
    }
}

/// `new_growable_buffer` in `std.buffer`.
///
/// ## Example
/// ```aic
/// // Import `std.buffer` and call `new_growable_buffer` with module-specific arguments.
/// ```
///
/// ## Effects
/// See the function signature for required effects and capabilities.
///
/// ## Errors
/// Returns module-defined error variants when the operation fails.
fn new_growable_buffer(initial_capacity: Int, max_capacity: Int) -> Result[ByteBuffer, BufferError] {
    aic_buffer_new_growable_intrinsic(initial_capacity, max_capacity)
}

/// `new_growable_buffer_u32` in `std.buffer`.
fn new_growable_buffer_u32(
    initial_capacity: BufferCapacityU32,
    max_capacity: BufferCapacityU32,
) -> Result[ByteBuffer, BufferError] {
    match buffer_u32_to_int(initial_capacity) {
        Err(err) => Err(err),
        Ok(initial_capacity_int) => match buffer_u32_to_int(max_capacity) {
            Err(err) => Err(err),
            Ok(max_capacity_int) => new_growable_buffer(initial_capacity_int, max_capacity_int),
        },
    }
}

