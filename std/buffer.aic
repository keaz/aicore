/// `buf_peek_u8` in `std.buffer`.
///
/// ## Example
/// ```aic
/// // Import `std.buffer` and call `buf_peek_u8` with module-specific arguments.
/// ```
///
/// ## Effects
/// See the function signature for required effects and capabilities.
///
/// ## Errors
/// Returns module-defined error variants when the operation fails.
fn buf_peek_u8(buf: ByteBuffer, position: Int) -> Result[UInt8, BufferError] {
    let current = buf_position(buf);
    let seek = buf_seek(buf, position);
    let out: Result[UInt8, BufferError] = match seek {
        Err(err) => Err(err),
        Ok(_) => buf_read_u8(buf),
    };
    let _restore = buf_seek(buf, current);
    out
}

/// `buf_size` in `std.buffer`.
///
/// ## Example
/// ```aic
/// // Import `std.buffer` and call `buf_size` with module-specific arguments.
/// ```
///
/// ## Effects
/// See the function signature for required effects and capabilities.
///
/// ## Errors
/// Returns module-defined error variants when the operation fails.
fn buf_size(buf: ByteBuffer) -> Int {
    buf_position(buf) + buf_remaining(buf)
}

/// `buf_size_u32` in `std.buffer`.
fn buf_size_u32(buf: ByteBuffer) -> Result[BufferCountU32, BufferError] {
    buffer_int_to_u32(buf_size(buf))
}

/// `buf_slice` in `std.buffer`.
///
/// ## Example
/// ```aic
/// // Import `std.buffer` and call `buf_slice` with module-specific arguments.
/// ```
///
/// ## Effects
/// See the function signature for required effects and capabilities.
///
/// ## Errors
/// Returns module-defined error variants when the operation fails.
fn buf_slice(buf: ByteBuffer, start: Int, length: Int) -> Result[ByteBuffer, BufferError] {
    if start < 0 || length < 0 {
        Err(InvalidInput())
    } else {
        let end = start + length;
        if end < start {
            Err(InvalidInput())
        } else {
            let total = buf_size(buf);
            if start > total || end > total {
                Err(InvalidInput())
            } else {
                let raw = buffer_to_bytes(buf);
                let sliced = byte_slice(raw, start, end);
                match sliced {
                    Ok(data) => Ok(buffer_from_bytes(data)),
                    Err(_) => Err(InvalidInput()),
                }
            }
        }
    }
}

/// `buf_slice_u32` in `std.buffer`.
fn buf_slice_u32(
    buf: ByteBuffer,
    start: BufferOffsetU32,
    length: BufferCountU32,
) -> Result[ByteBuffer, BufferError] {
    match buffer_u32_to_int(start) {
        Err(err) => Err(err),
        Ok(start_int) => match buffer_u32_to_int(length) {
            Err(err) => Err(err),
            Ok(length_int) => buf_slice(buf, start_int, length_int),
        },
    }
}
