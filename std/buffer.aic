fn buf_seek_u32(buf: ByteBuffer, position: BufferOffsetU32) -> Result[(), BufferError] {
    match buffer_u32_to_int(position) {
        Ok(position_int) => buf_seek(buf, position_int),
        Err(_) => buf_seek(buf, -1),
