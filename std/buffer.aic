/// The `std.buffer` module provides standard-library `buffer` APIs.
///
/// ## Example
/// ```aic
/// import std.buffer;
/// ```
module std.buffer;

import std.bytes;
import std.result;

/// Explicit non-negative capacity domain for buffer APIs.
type BufferCapacityU32 = UInt32;
/// Explicit non-negative offset domain for buffer APIs.
type BufferOffsetU32 = UInt32;
/// Explicit non-negative count domain for buffer APIs.
type BufferCountU32 = UInt32;

/// `BufferError` is a `enum` in `std.buffer`.
///
/// ## Example
/// ```aic
/// // Use `BufferError` through `std.buffer` APIs.
/// ```
enum BufferError {
    /// `Underflow` enum variant.
    Underflow,
    /// `Overflow` enum variant.
    Overflow,
    /// `InvalidUtf8` enum variant.
    InvalidUtf8,
    /// `InvalidInput` enum variant.
    InvalidInput,
}

/// `ByteBuffer` is a `struct` in `std.buffer`.
///
/// ## Example
