/// The `std.net` module provides standard-library `net` APIs.
///
/// ## Example
/// ```aic
/// import std.net;
/// ```
module std.net;

import std.bytes;
import std.result;

/// `NetError` is a `enum` in `std.net`.
///
/// ## Example
/// ```aic
/// // Use `NetError` through `std.net` APIs.
/// ```
enum NetError {
    /// `NotFound` enum variant.
    NotFound,
    /// `PermissionDenied` enum variant.
    PermissionDenied,
    /// `Refused` enum variant.
    Refused,
    /// `Timeout` enum variant.
    Timeout,
    /// `AddressInUse` enum variant.
    AddressInUse,
    /// `InvalidInput` enum variant.
    InvalidInput,
    /// `Io` enum variant.
    Io,
}

/// `UdpPacket` is a `struct` in `std.net`.
///
/// ## Example
/// ```aic
/// // Use `UdpPacket` through `std.net` APIs.
/// ```
struct UdpPacket {
    from: String,
    payload: Bytes,
}

