                            None => (),
                        },
                        Err(err) => if true {
                            failed = true;
                            failure = err;
                        } else {
                            ()
                        },
                    },
                    None => (),
                };
                i = i + 1;
            };

            if !done && !failed {
                if remaining_ms(deadline_ms) <= 0 {
                    failed = true;
                    failure = net_timeout_error();
                } else {
                    sleep_ms(1);
                };
            } else {
                ()
            };
        };

        if done {
            Ok(selected)
        } else {
            Err(failure)
        }
    }
}

