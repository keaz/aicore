/// `net_zero_u8` in `std.net`.
fn net_zero_u8() -> UInt8 {
    0
}

/// `net_one_u8` in `std.net`.
fn net_one_u8() -> UInt8 {
    1
}

/// `net_zero_u32` in `std.net`.
fn net_zero_u32() -> UInt32 {
    0u32
}

/// `net_one_u32` in `std.net`.
fn net_one_u32() -> UInt32 {
    1u32
}

/// `net_u8_to_u32` in `std.net`.
fn net_u8_to_u32(value: UInt8) -> UInt32 {
    let mut out: UInt32 = net_zero_u32();
    let mut current: UInt8 = net_zero_u8();
    let one_u8 = net_one_u8();
    let one_u32 = net_one_u32();
    while current != value {
        current = current + one_u8;
        out = out + one_u32;
    };
    out
}

/// `net_int_to_u32` in `std.net`.
fn net_int_to_u32(value: Int) -> Result[UInt32, NetError] {
    if value < 0 {
        Err(InvalidInput())
    } else if value > 4294967295 {
        Err(InvalidInput())
    } else {
        let mut out: UInt32 = net_zero_u32();
        let mut remaining = value;
        let one_u32 = net_one_u32();
        while remaining > 0 {
            out = out + one_u32;
            remaining = remaining - 1;
        };
        Ok(out)
    }
}

/// `net_u32_int_max` in `std.net`.
fn net_u32_int_max() -> UInt32 {
    2147483647u32
}

/// `net_u32_to_int` in `std.net`.
fn net_u32_to_int(value: UInt32) -> Result[Int, NetError] {
    if value > net_u32_int_max() {
        Err(InvalidInput())
    } else {
        let mut out = 0;
        let mut remaining = value;
        let one_u32 = net_one_u32();
        while remaining > net_zero_u32() {
            out = out + 1;
            remaining = remaining - one_u32;
        };
        Ok(out)
    }
}

/// `net_u8_to_int` in `std.net`.
fn net_u8_to_int(value: UInt8) -> Int {
    let mut out = 0;
    let mut current: UInt8 = net_zero_u8();
    let one = net_one_u8();
    while current != value {
        current = current + one;
        out = out + 1;
    };
    out
}

/// `tcp_stream_frame_byte_to_int` in `std.net`.
fn tcp_stream_frame_byte_to_int(header: Bytes, index: Int) -> Result[Int, NetError] {
    match byte_at(header, index) {
        Ok(value) => Ok(net_u8_to_int(value)),
        Err(_) => Err(InvalidInput()),
    }
}

/// `tcp_stream_frame_byte_to_u32` in `std.net`.
fn tcp_stream_frame_byte_to_u32(header: Bytes, index: Int) -> Result[UInt32, NetError] {
    match byte_at(header, index) {
        Ok(value) => Ok(net_u8_to_u32(value)),
        Err(_) => Err(InvalidInput()),
    }
}

/// `tcp_stream_frame_len_be_u32` in `std.net`.
fn tcp_stream_frame_len_be_u32(header: Bytes) -> Result[FrameLengthU32, NetError] {
    if byte_len(header) != 4 {
        Err(InvalidInput())
    } else {
        match tcp_stream_frame_byte_to_u32(header, 0) {
            Err(err) => Err(err),
            Ok(b0) => match tcp_stream_frame_byte_to_u32(header, 1) {
                Err(err) => Err(err),
                Ok(b1) => match tcp_stream_frame_byte_to_u32(header, 2) {
                    Err(err) => Err(err),
                    Ok(b2) => match tcp_stream_frame_byte_to_u32(header, 3) {
                        Err(err) => Err(err),
                        Ok(b3) => Ok((b0 * 16777216u32) + (b1 * 65536u32) + (b2 * 256u32) + b3),
                    },
                },
            },
        }
    }
}

