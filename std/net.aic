/// Returns module-defined error variants when the operation fails.
fn async_poll_int(op: AsyncIntOp) -> Result[Option[Int], NetError] effects { net, concurrency } {
    let waited = async_wait_int(AsyncIntOp { handle: op.handle }, 0);
    match waited {
        Ok(value) => Ok(Some(value)),
        Err(err) => match err {
            Timeout => Ok(None()),
            _ => Err(err),
        },
    }
}

