/// `async_wait_many_int` in `std.net`.
///
/// ## Example
/// ```aic
/// // Import `std.net` and call `async_wait_many_int` with module-specific arguments.
/// ```
///
/// ## Effects
/// See the function signature for required effects and capabilities.
///
/// ## Errors
/// Returns module-defined error variants when the operation fails.
fn async_wait_many_int(
    ops: Vec[AsyncIntOp],
    timeout_ms: Int,
) -> Result[AsyncIntSelection, NetError] effects { net, concurrency, time } {
    if timeout_ms < 0 || ops.len == 0 {
        Err(InvalidInput())
    } else {
        let deadline_ms = deadline_after_ms(timeout_ms);
        let mut done = false;
        let mut selected = AsyncIntSelection { index: 0, value: 0 };
        let mut failed = false;
        let mut failure: NetError = net_timeout_error();

        while !done && !failed {
            let mut i = 0;
            while i < ops.len && !done && !failed {
                match aic_vec_get_intrinsic(ops, i) {
                    Some(op) => match async_poll_int(AsyncIntOp { handle: op.handle }) {
                        Ok(state) => match state {
                            Some(value) => if true {
                                done = true;
                                selected = AsyncIntSelection { index: i, value: value };
                            } else {
                                ()
                            },
                            None => (),
                        },
                        Err(err) => if true {
                            failed = true;
                            failure = err;
                        } else {
                            ()
                        },
                    },
                    None => (),
                };
                i = i + 1;
            };

            if !done && !failed {
                if remaining_ms(deadline_ms) <= 0 {
                    failed = true;
                    failure = net_timeout_error();
                } else {
                    sleep_ms(1);
                };
            } else {
                ()
            };
        };

        if done {
            Ok(selected)
        } else {
            Err(failure)
        }
    }
}

