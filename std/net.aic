module std.net;

import std.bytes;
import std.result;

enum NetError {
    NotFound,
    PermissionDenied,
    Refused,
    Timeout,
    AddressInUse,
    InvalidInput,
    Io,
}

struct UdpPacket {
    from: String,
    payload: Bytes,
}

struct AsyncIntOp {
    handle: Int,
}

struct AsyncStringOp {
    handle: Int,
}

intrinsic fn aic_net_tcp_listen_intrinsic(addr: String) -> Result[Int, NetError] effects { net };
intrinsic fn aic_net_tcp_local_addr_intrinsic(handle: Int) -> Result[String, NetError] effects { net };
intrinsic fn aic_net_tcp_accept_intrinsic(listener: Int, timeout_ms: Int) -> Result[Int, NetError] effects { net };
intrinsic fn aic_net_tcp_connect_intrinsic(addr: String, timeout_ms: Int) -> Result[Int, NetError] effects { net };
intrinsic fn aic_net_tcp_send_intrinsic(handle: Int, payload: String) -> Result[Int, NetError] effects { net };
intrinsic fn aic_net_tcp_recv_intrinsic(handle: Int, max_bytes: Int, timeout_ms: Int) -> Result[String, NetError] effects { net };
intrinsic fn aic_net_tcp_close_intrinsic(handle: Int) -> Result[Bool, NetError] effects { net };
intrinsic fn aic_net_udp_bind_intrinsic(addr: String) -> Result[Int, NetError] effects { net };
intrinsic fn aic_net_udp_local_addr_intrinsic(handle: Int) -> Result[String, NetError] effects { net };
intrinsic fn aic_net_udp_send_to_intrinsic(handle: Int, addr: String, payload: String) -> Result[Int, NetError] effects { net };
intrinsic fn aic_net_udp_recv_from_intrinsic(handle: Int, max_bytes: Int, timeout_ms: Int) -> Result[UdpPacket, NetError] effects { net };
intrinsic fn aic_net_udp_close_intrinsic(handle: Int) -> Result[Bool, NetError] effects { net };
intrinsic fn aic_net_dns_lookup_intrinsic(host: String) -> Result[String, NetError] effects { net };
intrinsic fn aic_net_dns_reverse_intrinsic(addr: String) -> Result[String, NetError] effects { net };
intrinsic fn aic_net_async_accept_submit_intrinsic(listener: Int, timeout_ms: Int) -> Result[AsyncIntOp, NetError] effects { net, concurrency };
intrinsic fn aic_net_async_send_submit_intrinsic(handle: Int, payload: String) -> Result[AsyncIntOp, NetError] effects { net, concurrency };
intrinsic fn aic_net_async_recv_submit_intrinsic(handle: Int, max_bytes: Int, timeout_ms: Int) -> Result[AsyncStringOp, NetError] effects { net, concurrency };
intrinsic fn aic_net_async_wait_int_intrinsic(op: AsyncIntOp, timeout_ms: Int) -> Result[Int, NetError] effects { net, concurrency };
intrinsic fn aic_net_async_wait_string_intrinsic(op: AsyncStringOp, timeout_ms: Int) -> Result[String, NetError] effects { net, concurrency };
intrinsic fn aic_net_async_shutdown_intrinsic() -> Result[Bool, NetError] effects { net, concurrency };

fn tcp_listen(addr: String) -> Result[Int, NetError] effects { net } {
    aic_net_tcp_listen_intrinsic(addr)
}

fn tcp_local_addr(handle: Int) -> Result[String, NetError] effects { net } {
    aic_net_tcp_local_addr_intrinsic(handle)
}

fn tcp_accept(listener: Int, timeout_ms: Int) -> Result[Int, NetError] effects { net } {
    aic_net_tcp_accept_intrinsic(listener, timeout_ms)
}

fn tcp_connect(addr: String, timeout_ms: Int) -> Result[Int, NetError] effects { net } {
    aic_net_tcp_connect_intrinsic(addr, timeout_ms)
}

fn tcp_send(handle: Int, payload: Bytes) -> Result[Int, NetError] effects { net } {
    aic_net_tcp_send_intrinsic(handle, payload.data)
}

fn tcp_recv(handle: Int, max_bytes: Int, timeout_ms: Int) -> Result[Bytes, NetError] effects { net } {
    let raw = aic_net_tcp_recv_intrinsic(handle, max_bytes, timeout_ms);
    match raw {
        Ok(data) => Ok(Bytes { data: data }),
        Err(err) => Err(err),
    }
}

fn tcp_close(handle: Int) -> Result[Bool, NetError] effects { net } {
    aic_net_tcp_close_intrinsic(handle)
}

fn udp_bind(addr: String) -> Result[Int, NetError] effects { net } {
    aic_net_udp_bind_intrinsic(addr)
}

fn udp_local_addr(handle: Int) -> Result[String, NetError] effects { net } {
    aic_net_udp_local_addr_intrinsic(handle)
}

fn udp_send_to(handle: Int, addr: String, payload: Bytes) -> Result[Int, NetError] effects { net } {
    aic_net_udp_send_to_intrinsic(handle, addr, payload.data)
}

fn udp_recv_from(handle: Int, max_bytes: Int, timeout_ms: Int) -> Result[UdpPacket, NetError] effects { net } {
    aic_net_udp_recv_from_intrinsic(handle, max_bytes, timeout_ms)
}

fn udp_close(handle: Int) -> Result[Bool, NetError] effects { net } {
    aic_net_udp_close_intrinsic(handle)
}

fn dns_lookup(host: String) -> Result[String, NetError] effects { net } {
    aic_net_dns_lookup_intrinsic(host)
}

fn dns_reverse(addr: String) -> Result[String, NetError] effects { net } {
    aic_net_dns_reverse_intrinsic(addr)
}

fn async_accept_submit(listener: Int, timeout_ms: Int) -> Result[AsyncIntOp, NetError] effects { net, concurrency } {
    aic_net_async_accept_submit_intrinsic(listener, timeout_ms)
}

fn async_tcp_send_submit(handle: Int, payload: Bytes) -> Result[AsyncIntOp, NetError] effects { net, concurrency } {
    aic_net_async_send_submit_intrinsic(handle, payload.data)
}

fn async_tcp_recv_submit(handle: Int, max_bytes: Int, timeout_ms: Int) -> Result[AsyncStringOp, NetError] effects { net, concurrency } {
    aic_net_async_recv_submit_intrinsic(handle, max_bytes, timeout_ms)
}

fn async_wait_int(op: AsyncIntOp, timeout_ms: Int) -> Result[Int, NetError] effects { net, concurrency } {
    aic_net_async_wait_int_intrinsic(op, timeout_ms)
}

fn async_wait_string(op: AsyncStringOp, timeout_ms: Int) -> Result[Bytes, NetError] effects { net, concurrency } {
    let raw = aic_net_async_wait_string_intrinsic(op, timeout_ms);
    match raw {
        Ok(data) => Ok(Bytes { data: data }),
        Err(err) => Err(err),
    }
}

fn async_shutdown() -> Result[Bool, NetError] effects { net, concurrency } {
    aic_net_async_shutdown_intrinsic()
}

fn async_accept(listener: Int, timeout_ms: Int) -> Result[Int, NetError] effects { net, concurrency } {
    let submitted = async_accept_submit(listener, timeout_ms);
    match submitted {
        Ok(op) => async_wait_int(op, timeout_ms),
        Err(err) => Err(err),
    }
}

fn async_tcp_send(handle: Int, payload: Bytes, timeout_ms: Int) -> Result[Int, NetError] effects { net, concurrency } {
    let submitted = async_tcp_send_submit(handle, payload);
    match submitted {
        Ok(op) => async_wait_int(op, timeout_ms),
        Err(err) => Err(err),
    }
}

fn async_tcp_recv(handle: Int, max_bytes: Int, timeout_ms: Int) -> Result[Bytes, NetError] effects { net, concurrency } {
    let submitted = async_tcp_recv_submit(handle, max_bytes, timeout_ms);
    match submitted {
        Ok(op) => async_wait_string(op, timeout_ms),
        Err(err) => Err(err),
    }
}
