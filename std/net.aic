/// `tcp_stream_recv_exact_deadline` in `std.net`.
///
/// ## Example
/// ```aic
/// // Import `std.net` and call `tcp_stream_recv_exact_deadline` with module-specific arguments.
/// ```
///
/// ## Effects
/// See the function signature for required effects and capabilities.
///
/// ## Errors
/// Returns module-defined error variants when the operation fails.
fn tcp_stream_recv_exact_deadline(stream: TcpStream, expected_bytes: Int, deadline_ms: Int) -> Result[Bytes, NetError] effects { net, time } {
    if expected_bytes < 0 {
        Err(InvalidInput())
    } else {
        let mut remaining = expected_bytes;
        let mut out = empty();
        let mut failed = false;
        let mut failure: NetError = net_io_error();
        while remaining > 0 && !failed {
            let timeout_ms = remaining_ms(deadline_ms);
            if timeout_ms <= 0 {
                failed = true;
                failure = net_timeout_error();
            } else {
                let next = tcp_stream_recv(stream, remaining, timeout_ms);
                let next_failed = match next {
                    Err(_) => true,
                    Ok(_) => false,
                };
                if next_failed {
                    failed = true;
                    failure = match next {
                        Err(err) => err,
                        Ok(_) => net_io_error(),
                    };
                } else {
                    let chunk = match next {
                        Ok(value) => value,
                        Err(_) => empty(),
                    };
                    let read_count = byte_len(chunk);
                    if read_count <= 0 {
                        failed = true;
                        failure = net_io_error();
                    } else {
                        out = concat(out, chunk);
                        remaining = remaining - read_count;
                    }
                };
            }
        };
        if failed {
            Err(failure)
        } else {
            Ok(out)
        }
    }
}

