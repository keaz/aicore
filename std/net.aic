/// The `std.net` module provides standard-library `net` APIs.
///
/// ## Example
/// ```aic
/// import std.net;
/// ```
module std.net;

import std.bytes;
import std.result;
import std.time;

type ByteCountU32 = UInt32;
type FrameLengthU32 = UInt32;
type QueueDepthU32 = UInt32;
type RuntimeLimitU32 = UInt32;

/// `NetError` is a `enum` in `std.net`.
///
/// ## Example
/// ```aic
/// // Use `NetError` through `std.net` APIs.
/// ```
enum NetError {
    /// `NotFound` enum variant.
    NotFound,
    /// `PermissionDenied` enum variant.
    PermissionDenied,
    /// `Refused` enum variant.
    Refused,
    /// `Timeout` enum variant.
    Timeout,
    /// `AddressInUse` enum variant.
    AddressInUse,
    /// `InvalidInput` enum variant.
    InvalidInput,
    /// `Io` enum variant.
    Io,
    /// `ConnectionClosed` enum variant.
    ConnectionClosed,
    /// `Cancelled` enum variant.
    Cancelled,
}

/// `UdpPacket` is a `struct` in `std.net`.
///
/// ## Example
/// ```aic
/// // Use `UdpPacket` through `std.net` APIs.
/// ```
struct UdpPacket {
    from: String,
    payload: Bytes,
}

/// `TcpStream` is a `struct` in `std.net`.
///
/// ## Example
/// ```aic
/// // Use `TcpStream` through `std.net` APIs.
/// ```
struct TcpStream {
    handle: Int,
}

