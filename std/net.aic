/// `async_accept` in `std.net`.
///
/// ## Example
/// ```aic
/// // Import `std.net` and call `async_accept` with module-specific arguments.
/// ```
///
/// ## Effects
/// See the function signature for required effects and capabilities.
///
/// ## Errors
/// Returns module-defined error variants when the operation fails.
fn async_accept(listener: Int, timeout_ms: Int) -> Result[Int, NetError] effects { net, concurrency } {
    let submitted = async_accept_submit(listener, timeout_ms);
    match submitted {
        Ok(op) => async_wait_int(op, timeout_ms),
        Err(err) => Err(err),
    }
}

