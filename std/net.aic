/// `AsyncRuntimePressure` is a `struct` in `std.net`.
///
/// ## Example
/// ```aic
/// // Use `AsyncRuntimePressure` through `std.net` APIs.
/// ```
struct AsyncRuntimePressure {
    active_ops: Int,
    queue_depth: Int,
    op_limit: Int,
    queue_limit: Int,
}

/// `AsyncRuntimePressureU32` is a `struct` in `std.net`.
struct AsyncRuntimePressureU32 {
    active_ops: QueueDepthU32,
    queue_depth: QueueDepthU32,
    op_limit: RuntimeLimitU32,
    queue_limit: RuntimeLimitU32,
}

