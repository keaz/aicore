fn tcp_stream_frame_len_be(header: Bytes) -> Result[Int, NetError] {
    match tcp_stream_frame_len_be_u32(header) {
        Ok(value) => net_u32_to_int(value),
        Err(err) => Err(err),
    }
}

/// `tcp_stream_recv_framed_payload_u32` in `std.net`.
fn tcp_stream_recv_framed_payload_u32(
    stream: TcpStream,
    frame_header: Bytes,
    max_frame_bytes: FrameLengthU32,
    deadline_ms: Int,
) -> Result[Bytes, NetError] effects { net, time } {
    let frame_len = tcp_stream_frame_len_be_u32(frame_header);
    match frame_len {
        Err(err) => Err(err),
        Ok(payload_len) => if payload_len > max_frame_bytes {
            Err(InvalidInput())
        } else {
            tcp_stream_recv_exact_deadline_u32(stream, payload_len, deadline_ms)
        },
    }
}

