/// ## Errors
/// Returns module-defined error variants when the operation fails.
fn all[T](v: Vec[T], predicate: Fn(T) -> Bool) -> Bool {
    let mut out = true;
    let mut i = 0;
    while i < v.len && out {
        out = match aic_vec_get_intrinsic(v, i) {
            Some(value) => predicate(value),
            None => out,
        };
        i = i + 1;
    };
    out
}

/// `count` in `std.vec`.
///
/// ## Example
/// ```aic
/// // Import `std.vec` and call `count` with module-specific arguments.
/// ```
///
/// ## Effects
/// See the function signature for required effects and capabilities.
///
/// ## Errors
/// Returns module-defined error variants when the operation fails.
fn count[T](v: Vec[T], predicate: Fn(T) -> Bool) -> Int {
    let mut total = 0;
    let mut i = 0;
    while i < v.len {
        total = match aic_vec_get_intrinsic(v, i) {
            Some(value) => if predicate(value) { total + 1 } else { total },
            None => total,
        };
        i = i + 1;
    };
    total
}

/// `zip` in `std.vec`.
///
/// ## Example
/// ```aic
/// // Import `std.vec` and call `zip` with module-specific arguments.
/// ```
///
/// ## Effects
/// See the function signature for required effects and capabilities.
///
/// ## Errors
/// Returns module-defined error variants when the operation fails.
fn zip[T, U](left: Vec[T], right: Vec[U]) -> Vec[ZipPair[T, U]] {
    let mut out: Vec[ZipPair[T, U]] = new_vec();
    let limit = if left.len < right.len { left.len } else { right.len };
    let mut i = 0;
    while i < limit {
        out = match aic_vec_get_intrinsic(left, i) {
            Some(left_value) => match aic_vec_get_intrinsic(right, i) {
                Some(right_value) => aic_vec_push_intrinsic(out, ZipPair {
                    left: left_value,
                    right: right_value,
                }),
                None => out,
            },
            None => out,
        };
        i = i + 1;
    };
    out
}

/// `enumerate` in `std.vec`.
///
/// ## Example
/// ```aic
/// // Import `std.vec` and call `enumerate` with module-specific arguments.
/// ```
///
/// ## Effects
/// See the function signature for required effects and capabilities.
///
/// ## Errors
/// Returns module-defined error variants when the operation fails.
fn enumerate[T](v: Vec[T]) -> Vec[IndexedValue[T]] {
    let mut out: Vec[IndexedValue[T]] = new_vec();
    let mut i = 0;
    while i < v.len {
        out = match aic_vec_get_intrinsic(v, i) {
            Some(value) => aic_vec_push_intrinsic(out, IndexedValue {
                index: i,
                value: value,
            }),
            None => out,
        };
        i = i + 1;
    };
    out
}
