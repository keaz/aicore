/// ## Effects
/// See the function signature for required effects and capabilities.
///
/// ## Errors
/// Returns module-defined error variants when the operation fails.
fn filter_vec[T](v: Vec[T], predicate: Fn(T) -> Bool) -> Vec[T] {
    let mut out: Vec[T] = new_vec();
    let mut i = 0;
    while i < v.len {
        out = match aic_vec_get_intrinsic(v, i) {
            Some(value) => if predicate(value) { aic_vec_push_intrinsic(out, value) } else { out },
            None => out,
        };
        i = i + 1;
    };
    out
}

/// `fold_vec` in `std.vec`.
///
/// ## Example
