/// Build a vector containing start <= value < end.
fn range(start: Int, end: Int) -> Vec[Int] {
    let mut out: Vec[Int] = new_vec();
    let mut current = start;
    while current < end {
        out = aic_vec_push_intrinsic(out, current);
        current = current + 1;
    };
    out
}

/// `map_vec` in `std.vec`.
///
/// ## Example
/// ```aic
/// // Import `std.vec` and call `map_vec` with module-specific arguments.
/// ```
///
/// ## Effects
/// See the function signature for required effects and capabilities.
///
/// ## Errors
/// Returns module-defined error variants when the operation fails.
fn map_vec[T, U](v: Vec[T], mapper: Fn(T) -> U) -> Vec[U] {
    let mut out: Vec[U] = new_vec();
    let mut i = 0;
    while i < v.len {
        out = match aic_vec_get_intrinsic(v, i) {
            Some(value) => aic_vec_push_intrinsic(out, mapper(value)),
            None => out,
        };
        i = i + 1;
    };
    out
}

