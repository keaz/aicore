/// The `std.iterator` module provides standard-library iterator APIs.
///
/// ## Example
/// ```aic
/// import std.iterator;
/// import std.vec;
///
/// fn demo() -> Int {
///     let mut v: Vec[Int] = vec.new_vec();
///     v = vec.push(v, 1);
///     v = vec.push(v, 2);
///     let out = v.iter().map(|x| x * 10).collect();
///     if out.len == 2 { 1 } else { 0 }
/// }
/// ```
module std.iterator;

import std.deque;
import std.map;
import std.option;
import std.set;
import std.vec;

/// `IterStep` is a `struct` in `std.iterator`.
///
/// ## Example
/// ```aic
/// // Use `IterStep` through `std.iterator` APIs.
/// ```
struct IterStep[T, S] {
    item: Option[T],
    iter: S,
}

/// `LazyIter` is a `struct` in `std.iterator`.
///
/// ## Example
/// ```aic
/// // Use `LazyIter` through `std.iterator` APIs.
/// ```
struct LazyIter[T, S] {
    state: S,
    next_fn: Fn(S) -> IterStep[T, S],
}

