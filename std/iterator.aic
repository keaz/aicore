        let mut current = self;
        let mut done = false;
        while !done {
            let step = lazy_next(current);
            current = step.iter;
            out = match step.item {
                Some(value) => aic_vec_push_intrinsic(out, value),
                None => if true {
                    done = true;
                    out
                } else {
                    out
                },
            };
        };
