/// `from_state` in `std.iterator`.
///
/// ## Example
/// ```aic
/// // Import `std.iterator` and call `from_state` with module-specific arguments.
/// ```
///
/// ## Effects
/// See the function signature for required effects and capabilities.
///
/// ## Errors
/// Returns module-defined error variants when the operation fails.
fn from_state[T, S](state: S, next_fn: Fn(S) -> IterStep[T, S]) -> LazyIter[T, S] {
    LazyIter {
        state: state,
        next_fn: next_fn,
    }
}

/// `vec_next` in `std.iterator`.
///
/// ## Example
/// ```aic
/// // Import `std.iterator` and call `vec_next` with module-specific arguments.
/// ```
///
/// ## Effects
/// See the function signature for required effects and capabilities.
///
/// ## Errors
/// Returns module-defined error variants when the operation fails.
fn vec_next[T](values: Vec[T]) -> IterStep[T, Vec[T]] {
    match aic_vec_get_intrinsic(values, 0) {
        Some(value) => IterStep {
            item: Some(value),
            iter: aic_vec_remove_at_intrinsic(values, 0),
        },
        None => IterStep {
            item: None(),
            iter: values,
        },
    }
}

/// `map_next` in `std.iterator`.
///
/// ## Example
/// ```aic
/// // Import `std.iterator` and call `map_next` with module-specific arguments.
/// ```
///
/// ## Effects
/// See the function signature for required effects and capabilities.
///
/// ## Errors
/// Returns module-defined error variants when the operation fails.
fn map_next[K, V](values: Map[K, V]) -> IterStep[MapEntry[K, V], Map[K, V]] {
    let entries = aic_map_entries_intrinsic(values);
    match aic_vec_get_intrinsic(entries, 0) {
        Some(entry) => IterStep {
            item: Some(entry),
            iter: aic_map_remove_intrinsic(values, entry.key),
        },
        None => IterStep {
            item: None(),
            iter: values,
        },
    }
}

/// `set_next` in `std.iterator`.
///
/// ## Example
/// ```aic
/// // Import `std.iterator` and call `set_next` with module-specific arguments.
/// ```
///
/// ## Effects
/// See the function signature for required effects and capabilities.
///
/// ## Errors
/// Returns module-defined error variants when the operation fails.
fn set_next[T](values: Set[T]) -> IterStep[T, Set[T]] {
    let items = aic_map_keys_intrinsic(values.items);
    match aic_vec_get_intrinsic(items, 0) {
        Some(value) => IterStep {
            item: Some(value),
            iter: Set {
                items: aic_map_remove_intrinsic(values.items, value),
            },
        },
        None => IterStep {
            item: None(),
            iter: values,
        },
    }
}

/// `deque_next` in `std.iterator`.
///
/// ## Example
/// ```aic
/// // Import `std.iterator` and call `deque_next` with module-specific arguments.
/// ```
///
/// ## Effects
/// See the function signature for required effects and capabilities.
///
/// ## Errors
/// Returns module-defined error variants when the operation fails.
fn deque_next[T](values: Deque[T]) -> IterStep[T, Deque[T]] {
    let (item, next_values) = pop_front(values);
    IterStep {
        item: item,
        iter: next_values,
    }
}

/// `lazy_next` in `std.iterator`.
///
/// ## Example
/// ```aic
/// // Import `std.iterator` and call `lazy_next` with module-specific arguments.
/// ```
///
/// ## Effects
/// See the function signature for required effects and capabilities.
///
/// ## Errors
/// Returns module-defined error variants when the operation fails.
fn lazy_next[T, S](iter: LazyIter[T, S]) -> IterStep[T, LazyIter[T, S]] {
    let step_fn = iter.next_fn;
    let step = step_fn(iter.state);
    IterStep {
        item: step.item,
        iter: LazyIter {
            state: step.iter,
            next_fn: step_fn,
        },
    }
}

/// `map_state_next` in `std.iterator`.
///
/// ## Example
/// ```aic
/// // Import `std.iterator` and call `map_state_next` with module-specific arguments.
/// ```
///
/// ## Effects
/// See the function signature for required effects and capabilities.
///
/// ## Errors
/// Returns module-defined error variants when the operation fails.
fn map_state_next[T, U, S](state: MapState[T, U, S]) -> IterStep[U, MapState[T, U, S]] {
    let step = lazy_next(state.base);
    let mapper = state.mapper;
    match step.item {
        Some(value) => IterStep {
            item: Some(mapper(value)),
            iter: MapState {
                base: step.iter,
                mapper: mapper,
            },
        },
        None => IterStep {
            item: None(),
            iter: MapState {
                base: step.iter,
                mapper: mapper,
            },
        },
    }
}

/// `filter_state_next` in `std.iterator`.
///
/// ## Example
/// ```aic
/// // Import `std.iterator` and call `filter_state_next` with module-specific arguments.
/// ```
///
/// ## Effects
/// See the function signature for required effects and capabilities.
///
/// ## Errors
/// Returns module-defined error variants when the operation fails.
fn filter_state_next[T, S](state: FilterState[T, S]) -> IterStep[T, FilterState[T, S]] {
    let predicate = state.predicate;
    let mut current = state.base;
    let mut found: Option[T] = None();
    let mut done = false;
    while !done {
        let step = lazy_next(current);
        current = step.iter;
        match step.item {
            Some(value) => if predicate(value) {
                found = Some(value);
                done = true;
            } else {
                ()
            },
            None => if true {
                done = true;
            } else {
                ()
            },
        };
    };
    IterStep {
        item: found,
        iter: FilterState {
            base: current,
            predicate: predicate,
        },
    }
}

/// `take_state_next` in `std.iterator`.
///
/// ## Example
/// ```aic
/// // Import `std.iterator` and call `take_state_next` with module-specific arguments.
/// ```
///
/// ## Effects
/// See the function signature for required effects and capabilities.
///
/// ## Errors
/// Returns module-defined error variants when the operation fails.
fn take_state_next[T, S](state: TakeState[T, S]) -> IterStep[T, TakeState[T, S]] {
    if state.remaining <= 0 {
        IterStep {
            item: None(),
            iter: TakeState {
                base: state.base,
                remaining: 0,
            },
        }
    } else {
        let step = lazy_next(state.base);
        match step.item {
            Some(value) => IterStep {
                item: Some(value),
                iter: TakeState {
                    base: step.iter,
                    remaining: state.remaining - 1,
                },
            },
            None => IterStep {
                item: None(),
                iter: TakeState {
                    base: step.iter,
                    remaining: 0,
                },
            },
        }
    }
}

/// `skip_state_next` in `std.iterator`.
///
/// ## Example
/// ```aic
/// // Import `std.iterator` and call `skip_state_next` with module-specific arguments.
/// ```
///
/// ## Effects
/// See the function signature for required effects and capabilities.
///
/// ## Errors
/// Returns module-defined error variants when the operation fails.
fn skip_state_next[T, S](state: SkipState[T, S]) -> IterStep[T, SkipState[T, S]] {
    let mut current = state.base;
    let mut remaining = state.remaining;
    while remaining > 0 {
        let step = lazy_next(current);
        current = step.iter;
        remaining = remaining - 1;
    };
    let next_step = lazy_next(current);
    IterStep {
        item: next_step.item,
        iter: SkipState {
            base: next_step.iter,
            remaining: 0,
        },
    }
}

/// `enumerate_state_next` in `std.iterator`.
///
/// ## Example
/// ```aic
/// // Import `std.iterator` and call `enumerate_state_next` with module-specific arguments.
/// ```
///
/// ## Effects
/// See the function signature for required effects and capabilities.
///
/// ## Errors
/// Returns module-defined error variants when the operation fails.
fn enumerate_state_next[T, S](state: EnumerateState[T, S]) -> IterStep[EnumeratedValue[T], EnumerateState[T, S]] {
    let step = lazy_next(state.base);
    match step.item {
        Some(value) => IterStep {
            item: Some(EnumeratedValue {
                index: state.index,
                value: value,
            }),
            iter: EnumerateState {
                base: step.iter,
                index: state.index + 1,
            },
        },
        None => IterStep {
            item: None(),
            iter: EnumerateState {
                base: step.iter,
                index: state.index,
            },
        },
    }
}

/// `zip_state_next` in `std.iterator`.
///
/// ## Example
/// ```aic
/// // Import `std.iterator` and call `zip_state_next` with module-specific arguments.
/// ```
///
/// ## Effects
/// See the function signature for required effects and capabilities.
///
/// ## Errors
/// Returns module-defined error variants when the operation fails.
fn zip_state_next[T, U, LS, RS](state: ZipState[T, U, LS, RS]) -> IterStep[ZipPair[T, U], ZipState[T, U, LS, RS]] {
    let left_step = lazy_next(state.left);
    let right_step = lazy_next(state.right);
    match left_step.item {
        Some(left_value) => match right_step.item {
            Some(right_value) => IterStep {
                item: Some(ZipPair {
                    left: left_value,
                    right: right_value,
                }),
                iter: ZipState {
                    left: left_step.iter,
                    right: right_step.iter,
                },
            },
            None => IterStep {
                item: None(),
                iter: ZipState {
                    left: left_step.iter,
                    right: right_step.iter,
                },
            },
        },
        None => IterStep {
            item: None(),
            iter: ZipState {
                left: left_step.iter,
                right: right_step.iter,
            },
        },
    }
}

/// `chain_state_next` in `std.iterator`.
///
/// ## Example
/// ```aic
/// // Import `std.iterator` and call `chain_state_next` with module-specific arguments.
/// ```
///
/// ## Effects
/// See the function signature for required effects and capabilities.
///
/// ## Errors
/// Returns module-defined error variants when the operation fails.
fn chain_state_next[T, LS, RS](state: ChainState[T, LS, RS]) -> IterStep[T, ChainState[T, LS, RS]] {
    if state.in_left {
        let left_step = lazy_next(state.left);
        match left_step.item {
            Some(value) => IterStep {
                item: Some(value),
                iter: ChainState {
                    left: left_step.iter,
                    right: state.right,
                    in_left: true,
                },
            },
            None => if true {
                let right_step = lazy_next(state.right);
                IterStep {
                    item: right_step.item,
                    iter: ChainState {
                        left: left_step.iter,
                        right: right_step.iter,
                        in_left: false,
                    },
                }
            } else {
                IterStep {
                    item: None(),
                    iter: state,
                }
            },
        }
    } else {
        let right_step = lazy_next(state.right);
        IterStep {
            item: right_step.item,
            iter: ChainState {
                left: state.left,
                right: right_step.iter,
                in_left: false,
            },
        }
    }
}

