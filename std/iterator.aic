/// `Iterator` is a `trait` in `std.iterator`.
///
/// ## Example
/// ```aic
/// // Use `Iterator` through `std.iterator` APIs.
/// ```
trait Iterator[State, Item] {
    /// `next` in `std.iterator`.
    ///
    /// ## Example
    /// ```aic
    /// // Import `std.iterator` and call `next` with module-specific arguments.
    /// ```
    ///
    /// ## Effects
    /// See the function signature for required effects and capabilities.
    ///
    /// ## Errors
    /// Returns module-defined error variants when the operation fails.
    fn next[A, B](self: State) -> IterStep[Item, State];
}

