/// ## Effects
/// See the function signature for required effects and capabilities.
///
/// ## Errors
/// Returns module-defined error variants when the operation fails.
fn wait(handle: ProcHandle) -> Result[ProcExitStatus, ProcError] effects { proc } {
    let raw = aic_proc_wait_intrinsic(proc_handle_to_int(handle));
    match raw {
        Ok(value) => proc_exit_status_from_int(value),
        Err(err) => Err(err),
    }
}

