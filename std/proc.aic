/// The `std.proc` module provides standard-library `proc` APIs.
///
/// ## Example
/// ```aic
/// import std.proc;
/// ```
module std.proc;

import std.result;
import std.vec;

/// `ProcError` is a `enum` in `std.proc`.
///
/// ## Example
/// ```aic
/// // Use `ProcError` through `std.proc` APIs.
/// ```
enum ProcError {
    /// `NotFound` enum variant.
    NotFound,
    /// `PermissionDenied` enum variant.
    PermissionDenied,
    /// `InvalidInput` enum variant.
    InvalidInput,
    /// `Io` enum variant.
    Io,
    /// `UnknownProcess` enum variant.
    UnknownProcess,
}

/// `ProcOutput` is a `struct` in `std.proc`.
///
/// ## Example
/// ```aic
/// // Use `ProcOutput` through `std.proc` APIs.
/// ```
struct ProcOutput {
    status: Int,
    stdout: String,
    stderr: String,
}

/// `ProcHandle` is the bounded public process handle type.
type ProcHandle = UInt32;

/// `ProcExitStatus` is the bounded public process exit-code type.
type ProcExitStatus = Int32;

/// `ProcResult` is the bounded public process output model.
struct ProcResult {
    status: ProcExitStatus,
    stdout: String,
    stderr: String,
}

/// `RunOptions` is a `struct` in `std.proc`.
///
/// ## Example
/// ```aic
/// // Use `RunOptions` through `std.proc` APIs.
/// ```
struct RunOptions {
    stdin: String,
    cwd: String,
    env: Vec[String],
    timeout_ms: Int,
}

/// `aic_proc_spawn_intrinsic` in `std.proc`.
///
/// ## Example
/// ```aic
/// // Import `std.proc` and call `aic_proc_spawn_intrinsic` with module-specific arguments.
/// ```
///
/// ## Effects
/// See the function signature for required effects and capabilities.
///
/// ## Errors
/// Returns module-defined error variants when the operation fails.
intrinsic fn aic_proc_spawn_intrinsic(command: String) -> Result[Int, ProcError] effects { proc, env };
