/// `spawn` in `std.proc`.
///
/// ## Example
/// ```aic
/// // Import `std.proc` and call `spawn` with module-specific arguments.
/// ```
///
/// ## Effects
/// See the function signature for required effects and capabilities.
///
/// ## Errors
/// Returns module-defined error variants when the operation fails.
fn spawn(command: String) -> Result[ProcHandle, ProcError] effects { proc, env } {
    let raw = aic_proc_spawn_intrinsic(command);
    match raw {
        Ok(value) => proc_handle_from_int(value),
        Err(err) => Err(err),
    }
}

/// `wait` in `std.proc`.
///
/// ## Example
/// ```aic
/// // Import `std.proc` and call `wait` with module-specific arguments.
/// ```
