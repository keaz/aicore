/// The `std.string` module provides standard-library `string` APIs.
///
/// ## Example
/// ```aic
/// import std.string;
/// ```
module std.string;

import std.option;
import std.result;
import std.vec;

/// `Bytes` is a `struct` in `std.string`.
///
/// ## Example
/// ```aic
/// // Use `Bytes` through `std.string` APIs.
/// ```
struct Bytes {
    data: String,
}

/// `EncodingError` is a `enum` in `std.string`.
///
/// ## Example
/// ```aic
/// // Use `EncodingError` through `std.string` APIs.
/// ```
enum EncodingError {
    /// `InvalidSequence` enum variant.
    InvalidSequence,
    /// `UnsupportedEncoding` enum variant.
    UnsupportedEncoding,
    /// `BufferTooSmall` enum variant.
    BufferTooSmall,
}

/// `aic_string_len_intrinsic` in `std.string`.
///
/// ## Example
/// ```aic
/// // Import `std.string` and call `aic_string_len_intrinsic` with module-specific arguments.
/// ```
///
/// ## Effects
/// See the function signature for required effects and capabilities.
///
/// ## Errors
/// Returns module-defined error variants when the operation fails.
fn aic_string_len_intrinsic(s: String) -> Int {
    0
}

/// Return string length in bytes.
fn len(s: String) -> Int {
    aic_string_len_intrinsic(s)
}

/// Return true when the string is empty.
fn is_empty(s: String) -> Bool {
    aic_string_len_intrinsic(s) == 0
}

