/// Returns module-defined error variants when the operation fails.
fn string_to_bytes(s: String) -> Bytes {
    Bytes { data: s }
}

/// `bytes_to_string` in `std.string`.
///
/// ## Example
/// ```aic
/// // Import `std.string` and call `bytes_to_string` with module-specific arguments.
/// ```
///
/// ## Effects
/// See the function signature for required effects and capabilities.
///
/// ## Errors
/// Returns module-defined error variants when the operation fails.
fn bytes_to_string(data: Bytes) -> Result[String, EncodingError] {
    if aic_string_is_valid_utf8_intrinsic(data.data) {
        let out: Result[String, EncodingError] = Ok(data.data);
        out
    } else {
        let out: Result[String, EncodingError] = Err(InvalidSequence());
        out
    }
}

