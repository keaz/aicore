/// The `std.router` module provides standard-library `router` APIs.
///
/// ## Example
/// ```aic
/// import std.router;
/// ```
module std.router;

import std.map;
import std.result;

/// `RouterError` is a `enum` in `std.router`.
///
/// ## Example
/// ```aic
/// // Use `RouterError` through `std.router` APIs.
/// ```
enum RouterError {
    /// `InvalidPattern` enum variant.
    InvalidPattern,
    /// `InvalidMethod` enum variant.
    InvalidMethod,
    /// `Capacity` enum variant.
    Capacity,
    /// `Internal` enum variant.
    Internal,
}

/// `Router` is a `struct` in `std.router`.
///
/// ## Example
/// ```aic
/// // Use `Router` through `std.router` APIs.
/// ```
struct Router {
    handle: Int,
}

/// `RouteMatch` is a `struct` in `std.router`.
///
/// ## Example
/// ```aic
/// // Use `RouteMatch` through `std.router` APIs.
/// ```
struct RouteMatch {
    route_id: Int,
    params: Map[String, String],
}

/// `aic_router_new_intrinsic` in `std.router`.
///
/// ## Example
