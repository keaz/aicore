fn aic_router_add_intrinsic(router: Router, method: String, pattern: String, route_id: Int) -> Result[Router, RouterError] {
    let _router = router;
    let _method = method;
    let _pattern = pattern;
    let _route_id = route_id;
    let out: Result[Router, RouterError] = Err(Capacity());
    out
}

