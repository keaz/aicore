{
  "Function with effects": {
    "prefix": "fn",
    "body": [
      "fn ${1:name}(${2:params}) -> ${3:ReturnType} effects { ${4:io} } {",
      "\t$0",
      "}"
    ],
    "description": "Function declaration with effects block"
  },
  "Async function": {
    "prefix": "afn",
    "body": [
      "async fn ${1:name}(${2:params}) -> ${3:ReturnType} effects { ${4:io} } {",
      "\t$0",
      "}"
    ],
    "description": "Async function declaration"
  },
  "Struct definition": {
    "prefix": "struct",
    "body": [
      "struct ${1:Name} {",
      "\t${2:field}: ${3:Type},",
      "}"
    ],
    "description": "Struct definition"
  },
  "Enum definition": {
    "prefix": "enum",
    "body": [
      "enum ${1:Name} {",
      "\t${2:Variant},",
      "}"
    ],
    "description": "Enum definition"
  },
  "Trait definition": {
    "prefix": "trait",
    "body": [
      "trait ${1:Name}[${2:T}] {",
      "\tfn ${3:method}(self: ${2:T}) -> ${4:ReturnType};",
      "}"
    ],
    "description": "Trait declaration"
  },
  "Impl block": {
    "prefix": "impl",
    "body": [
      "impl ${1:Trait}[${2:Type}] {",
      "\t$0",
      "}"
    ],
    "description": "Impl block"
  },
  "Match expression": {
    "prefix": "match",
    "body": [
      "match ${1:expr} {",
      "\t${2:Pattern} => ${3:result},",
      "\t_ => ${4:default},",
      "}"
    ],
    "description": "Match expression skeleton"
  },
  "Option match": {
    "prefix": "iflet",
    "body": [
      "match ${1:expr} {",
      "\tSome(${2:value}) => $0,",
      "\tNone => ${3:default},",
      "}"
    ],
    "description": "If-let style Option match"
  },
  "Test function": {
    "prefix": "test",
    "body": [
      "#[test]",
      "fn test_${1:name}() -> () {",
      "\tassert_eq(${2:actual}, ${3:expected});",
      "}"
    ],
    "description": "Unit test skeleton"
  },
  "Route handler": {
    "prefix": "route",
    "body": [
      "#[${1|get,post,put,patch,delete|}(\"${2:/path}\")]",
      "async fn ${3:handler}(${4:params}) -> ${5:Int} effects { ${6:io} } {",
      "\t$0",
      "}"
    ],
    "description": "Annotated web route handler"
  },
  "Request body parameter": {
    "prefix": "body",
    "body": [
      "#[body] ${1:payload}: ${2:Type}"
    ],
    "description": "Request body parameter attribute"
  },
  "Request extractor parameter": {
    "prefix": "extract",
    "body": [
      "#[${1|path,query,header|}(\"${2:name}\")] ${3:name}: ${4:String}"
    ],
    "description": "Path, query, or header extractor parameter attribute"
  },
  "Validation attribute": {
    "prefix": "validate",
    "body": [
      "#[validate(${1|required,min_length = 1,max_length = 255,min = 0,max = 100|})]"
    ],
    "description": "Validation attribute for DTO fields or parameters"
  },
  "Module template": {
    "prefix": "mod",
    "body": [
      "module ${1:name};",
      "",
      "import std.${2:io};"
    ],
    "description": "Module declaration and import"
  },
  "Requires contract": {
    "prefix": "req",
    "body": [
      "requires ${1:condition}"
    ],
    "description": "Function precondition contract"
  },
  "Ensures contract": {
    "prefix": "ens",
    "body": [
      "ensures ${1:condition}"
    ],
    "description": "Function postcondition contract"
  },
  "Effects declaration": {
    "prefix": "eff",
    "body": [
      "effects { ${1:io} }"
    ],
    "description": "Effects declaration"
  }
}
