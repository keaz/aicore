{
  "name": "aic-language-tools",
  "displayName": "AICore Language Tools",
  "description": "VS Code integration for AICore via aic lsp",
  "version": "0.1.1",
  "publisher": "keaz",
  "license": "MIT",
  "icon": "assets/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/keaz/aicore.git"
  },
  "bugs": {
    "url": "https://github.com/keaz/aicore/issues"
  },
  "homepage": "https://github.com/keaz/aicore/tree/main/tools/vscode-aic",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "keywords": [
    "aicore",
    "ai",
    "programming-language",
    "lsp"
  ],
  "galleryBanner": {
    "color": "#0A2342",
    "theme": "dark"
  },
  "activationEvents": [
    "onLanguage:aic",
    "onCommand:aic.showLanguageServerOutput",
    "onCommand:aic.restartLanguageServer",
    "onCommand:aic.debug.createLaunchJson",
    "onDebugInitialConfigurations",
    "onDebugResolve:aic"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "aic",
        "aliases": [
          "AICore",
          "aic"
        ],
        "extensions": [
          ".aic"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "aic",
        "scopeName": "source.aic",
        "path": "./syntaxes/aic.tmLanguage.json"
      }
    ],
    "semanticTokenModifiers": [
      {
        "id": "effectful",
        "description": "Marks effectful functions and calls in AICore"
      }
    ],
    "semanticTokenScopes": [
      {
        "language": "aic",
        "scopes": {
          "variable.mutable": [
            "variable.other.mutable.aic"
          ],
          "variable.readonly": [
            "variable.other.constant.aic"
          ],
          "function.effectful": [
            "entity.name.function.effectful.aic"
          ],
          "function.deprecated": [
            "entity.name.function.deprecated.aic"
          ],
          "typeParameter": [
            "entity.name.type.parameter.aic"
          ],
          "enumMember": [
            "variable.other.enummember.aic"
          ],
          "property": [
            "variable.other.property.aic"
          ]
        }
      }
    ],
    "snippets": [
      {
        "language": "aic",
        "path": "./snippets/aic.json"
      }
    ],
    "commands": [
      {
        "command": "aic.showLanguageServerOutput",
        "title": "AICore: Show Language Server Output"
      },
      {
        "command": "aic.restartLanguageServer",
        "title": "AICore: Restart Language Server"
      },
      {
        "command": "aic.debug.createLaunchJson",
        "title": "AICore: Create launch.json"
      }
    ],
    "debuggers": [
      {
        "type": "aic",
        "label": "AICore",
        "languages": [
          "aic"
        ],
        "configurationAttributes": {
          "launch": {
            "required": [
              "program"
            ],
            "properties": {
              "program": {
                "type": "string",
                "description": "Path to an AICore source (.aic) or already-built debug executable."
              },
              "args": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "default": [],
                "description": "Arguments passed to the debug target."
              },
              "cwd": {
                "type": "string",
                "default": "${workspaceFolder}",
                "description": "Working directory for the debug session."
              },
              "stopOnEntry": {
                "type": "boolean",
                "default": false,
                "description": "Stop immediately at program entry."
              },
              "breakOnContractViolation": {
                "type": "boolean",
                "default": false,
                "description": "Insert an initial breakpoint at AICore runtime panic handler."
              }
            }
          }
        },
        "initialConfigurations": [
          {
            "type": "aic",
            "request": "launch",
            "name": "Debug AICore",
            "program": "${workspaceFolder}/src/main.aic",
            "args": [],
            "cwd": "${workspaceFolder}",
            "stopOnEntry": false,
            "breakOnContractViolation": false
          }
        ]
      }
    ],
    "configuration": {
      "title": "AICore",
      "properties": {
        "aic.server.path": {
          "type": "string",
          "default": "aic",
          "description": "Path to AICore executable"
        },
        "aic.server.args": {
          "type": "array",
          "default": [
            "lsp"
          ],
          "description": "Arguments passed to AICore language server executable",
          "items": {
            "type": "string"
          }
        },
        "aic.trace.server": {
          "type": "string",
          "enum": [
            "off",
            "messages",
            "verbose"
          ],
          "default": "off",
          "description": "Trace level for AICore language server"
        },
        "aic.debug.adapterPath": {
          "type": "string",
          "default": "",
          "description": "Optional path to a DAP backend binary (lldb-dap/lldb-vscode) used by `aic debug dap`."
        },
        "aic.errorLens.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Show inline diagnostic messages at end of line"
        },
        "aic.errorLens.showOnlyFirstPerLine": {
          "type": "boolean",
          "default": true,
          "description": "Show only the first diagnostic message per line in inline error lens"
        },
        "aic.inlayHints.typeAnnotations": {
          "type": "boolean",
          "default": true,
          "description": "Show inlay type hints for inferred let bindings"
        },
        "aic.inlayHints.effectAnnotations": {
          "type": "boolean",
          "default": true,
          "description": "Show inlay effect hints at effectful call sites"
        },
        "aic.inlayHints.contractAnnotations": {
          "type": "boolean",
          "default": false,
          "description": "Show inlay hints for static contract diagnostics"
        }
      }
    },
    "configurationDefaults": {
      "[aic]": {
        "editor.quickSuggestions": {
          "other": true,
          "comments": false,
          "strings": true
        },
        "editor.suggestOnTriggerCharacters": true,
        "editor.semanticHighlighting.enabled": true,
        "editor.inlayHints.enabled": "on"
      }
    }
  },
  "scripts": {
    "build": "tsc -p .",
    "watch": "tsc -w -p .",
    "test": "npm run build && node ./dist/test/runTest.js"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "@vscode/test-electron": "^2.5.2",
    "mocha": "^10.8.2",
    "typescript": "^5.4.0"
  }
}
