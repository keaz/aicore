module examples.ops.sandbox_profiles.net_blocked_demo;

import std.net;

fn main() -> Int effects { net } {
    let result = net.dns_lookup("localhost");
    match result {
        Ok(_) => 1,
        Err(err) => match err {
            PermissionDenied() => 0,
            _ => 2,
        },
    }
}
