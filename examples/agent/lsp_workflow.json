{
  "protocol": "lsp-3.17",
  "workspace": "examples/agent/lsp_workspace",
  "flows": [
    {
      "name": "completion",
      "request": {
        "jsonrpc": "2.0",
        "id": 6,
        "method": "textDocument/completion",
        "params": {
          "textDocument": {
            "uri": "file:///workspace/examples/agent/lsp_workspace/src/main.aic"
          },
          "position": {
            "line": 6,
            "character": 4
          }
        }
      },
      "response": {
        "jsonrpc": "2.0",
        "id": 6,
        "result": [
          {
            "label": "double_plus",
            "kind": 3,
            "detail": "fn double_plus(x: Int) -> Int"
          }
        ]
      }
    },
    {
      "name": "goto-definition",
      "request": {
        "jsonrpc": "2.0",
        "id": 7,
        "method": "textDocument/definition",
        "params": {
          "textDocument": {
            "uri": "file:///workspace/examples/agent/lsp_workspace/src/main.aic"
          },
          "position": {
            "line": 6,
            "character": 10
          }
        }
      },
      "response": {
        "jsonrpc": "2.0",
        "id": 7,
        "result": [
          {
            "uri": "file:///workspace/examples/agent/lsp_workspace/src/ops.aic",
            "range": {
              "start": {
                "line": 2,
                "character": 3
              },
              "end": {
                "line": 2,
                "character": 14
              }
            }
          }
        ]
      }
    },
    {
      "name": "rename",
      "request": {
        "jsonrpc": "2.0",
        "id": 8,
        "method": "textDocument/rename",
        "params": {
          "textDocument": {
            "uri": "file:///workspace/examples/agent/lsp_workspace/src/main.aic"
          },
          "position": {
            "line": 6,
            "character": 10
          },
          "newName": "twice_plus"
        }
      },
      "response": {
        "jsonrpc": "2.0",
        "id": 8,
        "result": {
          "changes": {
            "file:///workspace/examples/agent/lsp_workspace/src/main.aic": [],
            "file:///workspace/examples/agent/lsp_workspace/src/ops.aic": []
          }
        }
      }
    },
    {
      "name": "code-action",
      "request": {
        "jsonrpc": "2.0",
        "id": 9,
        "method": "textDocument/codeAction",
        "params": {
          "textDocument": {
            "uri": "file:///workspace/examples/agent/fixable_imports.aic"
          },
          "range": {
            "start": {
              "line": 2,
              "character": 2
            },
            "end": {
              "line": 2,
              "character": 12
            }
          },
          "context": {
            "diagnostics": []
          }
        }
      },
      "response": {
        "jsonrpc": "2.0",
        "id": 9,
        "result": [
          {
            "title": "aic: insert ';' after let binding",
            "kind": "quickfix"
          }
        ]
      }
    },
    {
      "name": "semantic-tokens",
      "request": {
        "jsonrpc": "2.0",
        "id": 10,
        "method": "textDocument/semanticTokens/full",
        "params": {
          "textDocument": {
            "uri": "file:///workspace/examples/agent/lsp_workspace/src/main.aic"
          }
        }
      },
      "response": {
        "jsonrpc": "2.0",
        "id": 10,
        "result": {
          "data": [
            0,
            0,
            2,
            5,
            0
          ]
        }
      }
    }
  ],
  "error_cases": [
    {
      "name": "unknown-method",
      "request": {
        "jsonrpc": "2.0",
        "id": 99,
        "method": "textDocument/unsupportedMethod",
        "params": {}
      },
      "response": {
        "jsonrpc": "2.0",
        "id": 99,
        "error": {
          "code": -32601,
          "message": "method not found: textDocument/unsupportedMethod"
        }
      }
    }
  ]
}
