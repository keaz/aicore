    let rx: Receiver[String] = Receiver { handle: 2 };
    let _sent = send(tx, "hello");
    let _recv = recv_timeout(rx, 5);
    let _close_tx = close_sender(tx);
    let _close_rx = close_receiver(rx);
    0
}
