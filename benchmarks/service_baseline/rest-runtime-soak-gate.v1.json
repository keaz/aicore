{
  "schema_version": 1,
  "warmup_runs": 1,
  "measure_runs": 3,
  "regression_tolerance_pct": 45.0,
  "env": {
    "CARGO_TERM_COLOR": "never"
  },
  "preflight": [
    [
      "cargo",
      "test",
      "--locked",
      "--test",
      "e8_perf_tests",
      "--no-run"
    ],
    [
      "cargo",
      "test",
      "--locked",
      "--test",
      "execution_tests",
      "--no-run"
    ]
  ],
  "scenarios": [
    {
      "id": "parse_pipeline_benchmark",
      "description": "Parse/typecheck/codegen benchmark gate on fixed service dataset",
      "command": [
        "cargo",
        "test",
        "--locked",
        "--test",
        "e8_perf_tests",
        "perf_budget_gate_passes_for_reference_dataset",
        "--",
        "--exact",
        "--nocapture"
      ],
      "thresholds": {
        "linux": {
          "baseline_ms": 170.0,
          "max_ms": 900.0
        },
        "macos": {
          "baseline_ms": 200.0,
          "max_ms": 900.0
        },
        "windows": {
          "baseline_ms": 260.0,
          "max_ms": 1200.0
        }
      }
    },
    {
      "id": "router_match_path_order",
      "description": "REST router match path/param ordering runtime path",
      "command": [
        "cargo",
        "test",
        "--locked",
        "--test",
        "execution_tests",
        "exec_router_matches_paths_params_and_order",
        "--",
        "--exact",
        "--nocapture",
        "--test-threads=1"
      ],
      "thresholds": {
        "linux": {
          "baseline_ms": 1900.0,
          "max_ms": 4500.0
        },
        "macos": {
          "baseline_ms": 2200.0,
          "max_ms": 5000.0
        },
        "windows": {
          "baseline_ms": 2600.0,
          "max_ms": 6200.0
        }
      }
    },
    {
      "id": "json_runtime_hardening",
      "description": "JSON parse limits/format diagnostics deterministic runtime path",
      "command": [
        "cargo",
        "test",
        "--locked",
        "--test",
        "execution_tests",
        "exec_json_runtime_hardening_limits_and_format_failures_are_deterministic",
        "--",
        "--exact",
        "--nocapture",
        "--test-threads=1"
      ],
      "thresholds": {
        "linux": {
          "baseline_ms": 2100.0,
          "max_ms": 4800.0
        },
        "macos": {
          "baseline_ms": 2300.0,
          "max_ms": 5600.0
        },
        "windows": {
          "baseline_ms": 3000.0,
          "max_ms": 7000.0
        }
      }
    },
    {
      "id": "async_net_lifecycle_sustained_churn",
      "description": "Async net submit/wait/cancel sustained churn soak path",
      "command": [
        "cargo",
        "test",
        "--locked",
        "--test",
        "execution_tests",
        "exec_runtime_net_async_lifecycle_sustained_churn_is_leak_free",
        "--",
        "--exact",
        "--nocapture",
        "--test-threads=1"
      ],
      "thresholds": {
        "linux": {
          "baseline_ms": 2300.0,
          "max_ms": 5600.0
        },
        "macos": {
          "baseline_ms": 2300.0,
          "max_ms": 6000.0
        },
        "windows": {
          "baseline_ms": 3200.0,
          "max_ms": 7800.0
        }
      }
    },
    {
      "id": "async_net_multi_worker_service_load",
      "description": "Shared-queue multi-worker async net service-load path",
      "command": [
        "cargo",
        "test",
        "--locked",
        "--test",
        "execution_tests",
        "exec_runtime_net_async_multi_worker_service_load_is_stable",
        "--",
        "--exact",
        "--nocapture",
        "--test-threads=1"
      ],
      "thresholds": {
        "linux": {
          "baseline_ms": 2400.0,
          "max_ms": 6200.0
        },
        "macos": {
          "baseline_ms": 2700.0,
          "max_ms": 7000.0
        },
        "windows": {
          "baseline_ms": 3600.0,
          "max_ms": 8600.0
        }
      }
    }
  ]
}
