{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://keaz.github.io/aicore/schemas/telemetry.schema.json",
  "title": "AICore Telemetry Event",
  "type": "object",
  "required": [
    "schema_version",
    "event_index",
    "timestamp_ms",
    "trace_id",
    "command",
    "kind",
    "attrs"
  ],
  "properties": {
    "schema_version": { "type": "string", "const": "1.0" },
    "event_index": { "type": "integer", "minimum": 1 },
    "timestamp_ms": { "type": "integer", "minimum": 0 },
    "trace_id": { "type": "string", "minLength": 1 },
    "command": { "type": "string", "minLength": 1 },
    "kind": { "type": "string", "enum": ["phase", "metric"] },
    "phase": { "type": ["string", "null"] },
    "status": { "type": ["string", "null"], "enum": ["ok", "error", null] },
    "duration_ms": { "type": ["number", "null"], "minimum": 0 },
    "metric_name": { "type": ["string", "null"] },
    "metric_value": { "type": ["number", "null"] },
    "attrs": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}
