{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://aicore.dev/schemas/agent/build-response-1.0.schema.json",
  "title": "AIC Agent Build Response v1.0",
  "type": "object",
  "additionalProperties": false,
  "required": ["protocol_version", "phase", "input", "artifact", "output", "ok", "diagnostics"],
  "properties": {
    "protocol_version": { "const": "1.0" },
    "phase": { "const": "build" },
    "input": { "type": "string" },
    "artifact": { "type": "string", "enum": ["exe", "obj", "lib"] },
    "output": { "type": "string" },
    "ok": { "type": "boolean" },
    "diagnostics": {
      "type": "array",
      "items": { "$ref": "#/$defs/diagnostic" }
    }
  },
  "$defs": {
    "diagnostic": {
      "type": "object",
      "additionalProperties": false,
      "required": ["code", "severity", "message", "spans", "help", "suggested_fixes"],
      "properties": {
        "code": { "type": "string" },
        "severity": { "type": "string", "enum": ["error", "warning", "note"] },
        "message": { "type": "string" },
        "spans": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["file", "start", "end", "label"],
            "properties": {
              "file": { "type": "string" },
              "start": { "type": "integer", "minimum": 0 },
              "end": { "type": "integer", "minimum": 0 },
              "label": { "type": ["string", "null"] }
            }
          }
        },
        "help": {
          "type": "array",
          "items": { "type": "string" }
        },
        "suggested_fixes": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["message", "replacement", "start", "end"],
            "properties": {
              "message": { "type": "string" },
              "replacement": { "type": ["string", "null"] },
              "start": { "type": ["integer", "null"], "minimum": 0 },
              "end": { "type": ["integer", "null"], "minimum": 0 }
            }
          }
        }
      }
    }
  }
}
