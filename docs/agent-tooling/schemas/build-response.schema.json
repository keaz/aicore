{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://aicore.dev/schemas/agent/build-response-1.0.schema.json",
  "title": "AIC Agent Build Response v1.0",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "protocol_version",
    "phase",
    "input",
    "artifact",
    "output",
    "ok",
    "cache_hit",
    "frontend_cache_hit",
    "fingerprint",
    "has_errors",
    "diagnostics",
    "output_sha256",
    "duration_ms"
  ],
  "properties": {
    "protocol_version": {
      "const": "1.0"
    },
    "phase": {
      "const": "build"
    },
    "input": {
      "type": "string"
    },
    "artifact": {
      "type": "string",
      "enum": [
        "exe",
        "obj",
        "lib"
      ]
    },
    "output": {
      "type": "string"
    },
    "ok": {
      "type": "boolean"
    },
    "cache_hit": {
      "type": "boolean"
    },
    "frontend_cache_hit": {
      "type": "boolean"
    },
    "fingerprint": {
      "type": "string"
    },
    "has_errors": {
      "type": "boolean"
    },
    "diagnostics": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/diagnostic"
      }
    },
    "output_sha256": {
      "type": [
        "string",
        "null"
      ]
    },
    "duration_ms": {
      "type": "integer",
      "minimum": 0
    }
  },
  "$defs": {
    "diagnostic": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "code",
        "severity",
        "message",
        "spans",
        "help",
        "suggested_fixes"
      ],
      "properties": {
        "code": {
          "type": "string"
        },
        "severity": {
          "type": "string",
          "enum": [
            "error",
            "warning",
            "note"
          ]
        },
        "message": {
          "type": "string"
        },
        "spans": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "file",
              "start",
              "end",
              "label"
            ],
            "properties": {
              "file": {
                "type": "string"
              },
              "start": {
                "type": "integer",
                "minimum": 0
              },
              "end": {
                "type": "integer",
                "minimum": 0
              },
              "label": {
                "type": [
                  "string",
                  "null"
                ]
              }
            }
          }
        },
        "help": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "suggested_fixes": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "message",
              "replacement",
              "start",
              "end"
            ],
            "properties": {
              "message": {
                "type": "string"
              },
              "replacement": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "start": {
                "type": [
                  "integer",
                  "null"
                ],
                "minimum": 0
              },
              "end": {
                "type": [
                  "integer",
                  "null"
                ],
                "minimum": 0
              }
            }
          }
        },
        "reasoning": {
          "$ref": "#/$defs/diagnostic_reasoning"
        }
      }
    },
    "diagnostic_reasoning": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version",
        "strategy",
        "summary",
        "confidence",
        "evidence",
        "hypotheses",
        "next_actions",
        "spec_refs"
      ],
      "properties": {
        "schema_version": {
          "const": "1.0"
        },
        "strategy": {
          "type": "string"
        },
        "summary": {
          "type": "string"
        },
        "confidence": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100
        },
        "evidence": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "hypotheses": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/diagnostic_hypothesis"
          }
        },
        "next_actions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "spec_refs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "diagnostic_hypothesis": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "title",
        "detail",
        "confidence"
      ],
      "properties": {
        "kind": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "detail": {
          "type": "string"
        },
        "confidence": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100
        }
      }
    }
  }
}
