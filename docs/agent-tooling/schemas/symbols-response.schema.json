{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://aicore.dev/schemas/agent/symbols-response-1.0.schema.json",
  "title": "AIC Symbols Response v1.0",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "command",
    "ok",
    "project_root",
    "symbol_count",
    "symbols",
    "files_scanned",
    "files_indexed",
    "files_skipped",
    "skipped_files"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0"
    },
    "command": {
      "const": "symbols"
    },
    "ok": {
      "type": "boolean"
    },
    "project_root": {
      "type": "string"
    },
    "symbol_count": {
      "type": "integer",
      "minimum": 0
    },
    "symbols": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/symbol_record"
      }
    },
    "files_scanned": {
      "type": "integer",
      "minimum": 0
    },
    "files_indexed": {
      "type": "integer",
      "minimum": 0
    },
    "files_skipped": {
      "type": "integer",
      "minimum": 0
    },
    "skipped_files": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/symbol_index_warning"
      }
    },
    "error": {
      "$ref": "#/$defs/query_error"
    }
  },
  "$defs": {
    "symbol_index_warning": {
      "type": "object",
      "additionalProperties": false,
      "required": ["file", "error_count", "code_count", "codes", "summary"],
      "properties": {
        "file": {
          "type": "string"
        },
        "error_count": {
          "type": "integer",
          "minimum": 0
        },
        "code_count": {
          "type": "integer",
          "minimum": 0
        },
        "codes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "summary": {
          "type": "string"
        }
      }
    },
    "query_error": {
      "type": "object",
      "additionalProperties": false,
      "required": ["code", "message", "details"],
      "properties": {
        "code": {
          "type": "string"
        },
        "message": {
          "type": "string"
        },
        "details": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "symbol_kind": {
      "type": "string",
      "enum": [
        "function",
        "struct",
        "enum",
        "variant",
        "trait",
        "impl",
        "module"
      ]
    },
    "location": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "file",
        "line",
        "column",
        "span_start",
        "span_end"
      ],
      "properties": {
        "file": {
          "type": "string"
        },
        "line": {
          "type": "integer",
          "minimum": 1
        },
        "column": {
          "type": "integer",
          "minimum": 1
        },
        "span_start": {
          "type": "integer",
          "minimum": 0
        },
        "span_end": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "symbol_contracts": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "requires": {
          "type": "string"
        },
        "ensures": {
          "type": "string"
        },
        "invariant": {
          "type": "string"
        }
      }
    },
    "symbol_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "kind",
        "signature",
        "module",
        "location",
        "effects",
        "contracts"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "kind": {
          "$ref": "#/$defs/symbol_kind"
        },
        "signature": {
          "type": "string"
        },
        "module": {
          "type": [
            "string",
            "null"
          ]
        },
        "location": {
          "$ref": "#/$defs/location"
        },
        "effects": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "contracts": {
          "$ref": "#/$defs/symbol_contracts"
        },
        "capabilities": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "generics": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "container": {
          "type": "string"
        }
      }
    }
  }
}
