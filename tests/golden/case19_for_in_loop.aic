    total = total + i;
};
    if true {
    let mut aic_for_iter_1 = aic_for_into_iter(range(0, n));
    loop {
    let aic_for_step_1 = aic_for_next_iter(aic_for_iter_1);
    match aic_for_step_1.item {
    Some(j) => if true {
    aic_for_iter_1 = aic_for_step_1.iter;
    if j == 1 {
    continue;
} else {
    ()
};
    total = total + j;
} else {
    ()
},
    None => break,
};
}
} else {
    ()
};
    if true {
    let mut aic_for_iter_2 = aic_for_into_iter(values);
