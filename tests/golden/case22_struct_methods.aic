struct User {
    age: Int,
}

impl User {
    fn new(age: Int) -> User {
        User {age: age}
    }
    fn age_plus(self: User) -> Int {
        self.age + 12
    }
    fn is_adult(self: User) -> Bool {
        self.age >= 18
    }
}

fn main() -> Int {
    let user = User::new(30);
    if user.is_adult() {
    user.age_plus()
} else {
    0
}
}
